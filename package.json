{
  "main": "electron.js",
  "name": "cash-sales",
  "version": "1.0.7",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run copy-static",
    "obfuscate": "node obfuscate.js",
    "copy-static": "xcopy /E /I /Y .next\\static .next\\standalone\\.next\\static && xcopy /E /I /Y public .next\\standalone\\public",
    "start": "next start",
    "electron": "node node_modules/electron/cli.js .",
    "dist": "npm run build && npm run obfuscate && electron-builder"
  },
  "build": {
    "appId": "com.cashsales",
    "productName": "Cash Sales",
    "artifactName": "Cash-Sales-Setup-${version}.${ext}",
    "directories": {
      "app": "build-temp"
    },
    "files": [
      "electron.js",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "build-temp/.next/standalone",
        "to": "app.asar.unpacked/.next/standalone"
      }
    ],
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "aladin7453",
        "repo": "Cash-Sales"
      }
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-google-maps/api": "^2.20.8",
    "@react-pdf/renderer": "^3.4.5",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cmdk": "^0.2.1",
    "currency.js": "^2.0.4",
    "date-fns": "^3.6.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "idb": "^8.0.3",
    "jquery": "^4.0.0",
    "jsencrypt": "^3.5.4",
    "leaflet": "^1.9.4",
    "moment": "^2.30.1",
    "next": "^14.2.35",
    "next-pwa": "^5.6.0",
    "puppeteer": "^24.43.1",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-accessible-treeview": "^2.11.2",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.3.1",
    "react-colorful": "^5.7.0",
    "react-datetime-picker": "^6.0.1",
    "react-day-picker": "^8.10.2",
    "react-dom": "^18.3.1",
    "react-flatpickr": "^3.10.13",
    "react-hook-form": "^7.80.0",
    "react-leaflet": "^4.2.1",
    "react-pdf": "^9.2.1",
    "react-quill": "^2.0.0",
    "react-signature-canvas": "^1.0.7",
    "react-tabs": "^6.1.1",
    "swr": "^2.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-signature-canvas": "^1.0.7",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "fs-extra": "^11.3.6",
    "javascript-obfuscator": "^5.4.3",
    "lucide-react": "^0.302.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-icons": "^4.12.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  }
}
