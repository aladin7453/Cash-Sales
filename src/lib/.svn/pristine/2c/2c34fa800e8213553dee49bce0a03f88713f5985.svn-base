export const TOOLTIP_DELAY_DURATION = 300;

export const DATE_FORMAT = "YYYY-MM-DD"; // moment format

/**
 * Date format string for date-fns library.
 * This format can be used to format Date objects into a readable string.
 *
 * @example
 * // Returns "2023-01-01 00:00"
 * const formattedDate = format(new Date(), DATE_TIME_FORMAT);
 */
export const DATE_TIME_FORMAT = "yyyy-MM-dd HH:mm";

export const ORIGIN = `http://192.168.1.101/1ofis/application/backend`;

export const downloadFilePath = `https://1ofis.infollective.com/application/backend/../assets/uploads/template`;

export const DIRECTORY =
  window.location.origin.includes("localhost") || window.location.origin.includes("192.168.1.101")
    ? `${window.location.origin}`
    : `${window.location.origin}/view`;

export const DEFAULT_DATA_TABLE_PAGE_SIZE = 20;
export const DEFAULT_DATA_TABLE_PAGE_SIZE_NEW = 100000000;

/** Overrides TanStack Table's default column sizing */
export const DATA_TABLE_DEFAULT_COLUMN_SIZING = {
  size: 100, // starting column size
  minSize: 100, // enforced during column resizing
  maxSize: 1000, // enforced during column resizing
} as const;

export const getAuthHeaders = () => {
  let username: string = "";
  let authToken: string = "";

  if (typeof window !== "undefined") {
    username = JSON.parse(localStorage.getItem("username") || '""');
    authToken = JSON.parse(localStorage.getItem("authToken") || '""');
  }

  const headers = new Headers();
  headers.set("Authorization", "Basic " + btoa(`${username}:${authToken}`));
  return headers;
};

export const getCurrentAccount = (): string | null => {
  const currentAccount = JSON.parse(localStorage.getItem("currentAccount") || "null");
  return currentAccount && currentAccount.UUID ? currentAccount.UUID : null;
};

export const getCurrentAcc = (): string | null => {
  const currentAccount = JSON.parse(localStorage.getItem("currentAccount") || "null");
  return currentAccount && currentAccount.account ? currentAccount.account : null;
};

export const getCurrentCompanyUUID = () => {
  const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");
  return currentCompany && currentCompany.UUID ? currentCompany.UUID : null;
};

export const getCurrentCompany = () => {
  const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");
  return currentCompany && currentCompany.company ? currentCompany.company : null;
};

export const getCurrentUserID = () => {
  const currentUserID = JSON.parse(localStorage.getItem("userID") || "null");
  return currentUserID ? currentUserID : null;
};

export const getCurrentUserFullName = () => {
  const currentUserFullName = JSON.parse(localStorage.getItem("userFullName") || "null");
  return currentUserFullName ? currentUserFullName : null;
};

export const checkAccessToken = async (username: string, authToken: string) => {
  const headers = new Headers();
  headers.set("Authorization", "Basic " + btoa(`${username}:${authToken}`));

  try {
    const response = await fetch(`${ORIGIN}/site/api/site/check-access-token`, {
      method: "POST",
      headers,
    });

    if (!response.ok) {
      localStorage.removeItem("username");
      localStorage.removeItem("userID");
      localStorage.removeItem("authToken");
      localStorage.removeItem("currentAccount");
      localStorage.removeItem("currentCompany");
      localStorage.removeItem("currentLocation");
      //HardCode
      localStorage.removeItem("salesInvoiceLayout");
      throw new Error("Token is invalid or expired");
    }

    return true;
  } catch (error) {
    console.error("Error checking access token: ", error);
    return false;
  }
};

export const getDefaultCurrencyCode = async () => {
  let username: string = "";
  let authToken: string = "";

  if (typeof window !== "undefined") {
    username = JSON.parse(localStorage.getItem("username") || '""');
    authToken = JSON.parse(localStorage.getItem("authToken") || '""');
  }
  const formData = new FormData();
  const currency = "currency";
  const headers = new Headers();
  headers.set("Authorization", "Basic " + btoa(`${username}:${authToken}`));
  formData.append("table[]", currency);

  try {
    const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
      method: "POST",
      headers,
      body: formData,
    });

    if (!response.ok) {
      throw new Error("Failed to fetch currency data");
    }

    const currencyData = await response.json();

    const defaultCurrency = currencyData.rows.find((item) => item.currencyCode === "MYR");

    return defaultCurrency;
  } catch (error) {
    console.error("Error fetching default currency:", error);
  }
};

export const getGeneralPublic = async () => {
  let username: string = "";
  let authToken: string = "";

  if (typeof window !== "undefined") {
    username = JSON.parse(localStorage.getItem("username") || '""');
    authToken = JSON.parse(localStorage.getItem("authToken") || '""');
  }
  const headers = new Headers();
  headers.set("Authorization", "Basic " + btoa(`${username}:${authToken}`));
  try {
    const response = await fetch(`${ORIGIN}/universal/get-general-public`, {
      method: "GET",
      headers,
    });

    if (!response.ok) {
      throw new Error("Failed to fetch currency data");
    }

    const data = await response.json();

    return data;
  } catch (error) {
    console.error("Error fetching default currency:", error);
  }
};

export const removeAuthData = async () => {
  localStorage.removeItem("username");
  localStorage.removeItem("userID");
  localStorage.removeItem("authToken");
  localStorage.removeItem("currentAccount");
  localStorage.removeItem("currentCompany");
  localStorage.removeItem("currentLocation");
  //HardCode
  localStorage.removeItem("salesInvoiceLayout");
};

export function removeKeys(obj, keysToRemove) {
  const result = { ...obj };
  for (const key of keysToRemove) {
    delete result[key];
  }
  return result;
}

export const stripHtml = (html: string | null | undefined) => {
  if (!html) return "";
  let text = html.replace(/<br\s*\/?>/gi, "\n");
  text = text.replace(/<p[^>]*>/gi, "").replace(/<\/p>/gi, "\n");
  text = text.replace(/<[^>]+>/g, "");
  text = text.replace(/&nbsp;/g, " ").replace(/&amp;/g, "&");
  return text;
};

export const autoWordSize = (text: string) => {
  // include spaces in the count
  const totalChars = text.length;
  return totalChars * 8 + 70; // 8px per char + 100px padding
};
