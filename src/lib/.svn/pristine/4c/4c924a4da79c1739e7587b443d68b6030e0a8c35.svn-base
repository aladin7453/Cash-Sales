/**
 * This function checks if the current account is the system owner.
 *
 * @param accountUUID - The UUID of the current account.
 * @returns `true` if the account is the system owner, `false` otherwise.
 */
export function isSystemOwner(accountUUID: string): boolean {
  if (accountUUID === "----ISSB") {
    return true;
  }
  return false;
}
