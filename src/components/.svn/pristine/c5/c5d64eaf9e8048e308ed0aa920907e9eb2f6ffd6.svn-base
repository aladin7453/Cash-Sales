"use client";

import type { Table } from "@tanstack/react-table";
import { HiOutlineFilter } from "react-icons/hi";
import TableHeadColumnTextFilter from "@/components/data-table/TableHeadColumnTextFilter";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "../ui/dropdown-menu";

interface MobileActionGroupEndProps<T> {
  table: Table<T>;
  config: {
    searchColumn: string; // e.g., "docNo"
    searchPlaceholder: string; // e.g., "Search Doc No."
    sortColumn: string; // e.g., "docNo"
  };
  children?: React.ReactNode; // For additional mobile actions if needed
}

export default function MobileActionGroupEnd<T extends Record<string, any>>({
  table,
  config,
  children,
}: MobileActionGroupEndProps<T>) {
  return (
    <div className="block md:hidden flex items-center gap-2 w-full">
      <div className="flex-1 min-w-0 sm:min-w-48 [&_input]:!h-9 [&_input]:rounded-full [&_input]:!bg-white [&_input]:border-none [&_input]:text-xs [&_input]:px-4 [&_input]:py-1 [&_input]:shadow-md [&_input]:transition-all [&_input]:duration-300 [&input]:ease-in-out [&_input]:outline-none">
        <TableHeadColumnTextFilter
          column={table.getColumn(config.searchColumn)}
          table={table}
          placeholder={config.searchPlaceholder}
        />
      </div>

      <DropdownMenu modal={false}>
        <DropdownMenuTrigger className="shrink-0 flex items-center justify-center size-9 rounded-full bg-white text-erp-blue-14 shadow-md transition-all duration-300 ease-in-out border-2 border-transparent data-[state=open]:border-blue-300">
          <HiOutlineFilter className="size-4.5 text-[#1E1E1E]" />
        </DropdownMenuTrigger>
        <DropdownMenuContent className="[&_[role='menuitem']]:text-[clamp(11px,1.2vw,14px)] min-w-[150px]">
          <DropdownMenuLabel>Sort by</DropdownMenuLabel>
          <DropdownMenuSeparator />
          <DropdownMenuItem
            onClick={() => {
              table.getColumn(config.sortColumn)?.toggleSorting(false); // Asc
            }}
          >
            Ascending
          </DropdownMenuItem>
          <DropdownMenuItem
            onClick={() => {
              table.getColumn(config.sortColumn)?.toggleSorting(true); // Desc
            }}
          >
            Descending
          </DropdownMenuItem>
        </DropdownMenuContent>
      </DropdownMenu>
    </div>
  );
}