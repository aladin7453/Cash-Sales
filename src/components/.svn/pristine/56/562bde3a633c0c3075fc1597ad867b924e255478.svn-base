"use client";

import React, { useEffect, useState } from "react";
import {
  Dialog,
  DialogClose,
  DialogContent,
  DialogFooter,
  DialogTitle,
} from "@/components/ui/dialog";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardTitle,
} from "@/components/ui/card";
function ReleaseNotePopover() {
  const [openNoteDialog, setOpenNoteDialog] = useState(false);
  const [showAllReleases, setShowAllReleases] = useState(false);
  const [release, setRelease] = useState([]);
  // Show only the latest 2 releases initially
  const visibleReleases = showAllReleases ? release : release.slice(0, 2);
  const isDev = process.env.NODE_ENV === "development";

  useEffect(() => {
    fetch(isDev ? "/release.json" : "/view/release.json")
      .then((res) => res.json())
      .then((data) => setRelease(data.releases))
      .catch(() => setRelease([]));
  }, []);

  function ReleaseItem({ release }) {
    return (
      <div className="mb-4 border-b pb-2">
        <p>
          <strong>Version:</strong> {release.version}
        </p>

        {/* Features Section */}
        <h3 className="mt-2 text-lg font-bold text-sm">New Features</h3>
        {release.changes.length > 0 ? (
          <ul className="list-disc pl-5 text-sm">
            {release.changes.map((change, i) => (
              <li key={i}>{change.details}</li>
            ))}
          </ul>
        ) : (
          <p>No new features in this release.</p>
        )}

        {/* Bug Fixes Section */}
        <h3 className="mt-2 text-lg font-bold text-sm">Bug Fixes</h3>
        {release.bugFix.length > 0 ? (
          <ul className="list-disc pl-5 text-sm">
            {release.bugFix.map((fix, i) => (
              <li key={i}>{fix.details}</li>
            ))}
          </ul>
        ) : (
          <p>No bug fixes in this release.</p>
        )}
      </div>
    );
  }

  return (
    <>
      <button
        onClick={() => setOpenNoteDialog(true)}
        style={{ color: "#9B9797" }}
      >
        Release Note
      </button>
      <Dialog open={openNoteDialog} onOpenChange={setOpenNoteDialog}>
        <DialogContent className="max-w-l bg-white p-6 rounded-md">
          <DialogClose asChild>
            <button
              className="absolute right-3 top-1.5 rounded-full p-1 hover:bg-gray-100"
              aria-label="Close"
            >
              <div className="h-4 w-4">X</div>
            </button>
          </DialogClose>
          <Card
            className="w-full flex flex-col text-sm"
            style={{ height: "45vh", marginTop: "10px", overflow: "hidden" }}
          >
            <CardTitle className="p-2">Release Notes</CardTitle>
            <CardDescription></CardDescription>

            {/* Scrollable content area */}
            <CardContent
              className="flex-1 overflow-y-auto px-4"
              style={{ maxHeight: "calc(45vh - 60px)" }}
            >
              {visibleReleases.map((release, index) => (
                <ReleaseItem key={index} release={release} />
              ))}
            </CardContent>

            {/* Read More / Show Less Button */}
            {release.length > 2 && (
              <CardFooter className="flex justify-center">
                <button
                  className="text-blue-500 mt-2"
                  onClick={() => setShowAllReleases(!showAllReleases)}
                >
                  {showAllReleases ? "Show Less" : "Read More"}
                </button>
              </CardFooter>
            )}
          </Card>
        </DialogContent>
      </Dialog>
    </>
  );
}

export default ReleaseNotePopover;
