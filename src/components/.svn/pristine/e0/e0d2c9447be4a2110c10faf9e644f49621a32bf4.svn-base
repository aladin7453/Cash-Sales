const PreviewQuotationTemplate = ({
  previewData,
  itemsData,
  currentCompanyData,
  descriptionPreferences = { description: true, secondDescription: true, moreDescription: true },
  showMultipleUOM = false
}) => {
  if (!previewData) {
    return (
      <View style={styles.page}>
        <Text>Loading...</Text>
      </View>
    );
  }

  const pages = Array.isArray(previewData) ? previewData : [previewData];//Check for multiple data passed in for preview

  const itemArray = Array.isArray(itemsData) ? itemsData : [];

  let image64 = currentCompanyData.logoLink && currentCompanyData.logoLink[0]?.base64;

  return (
    <Document title={previewData.docNo || ''}>
      {pages.map((previewDoc, index) => {// map it in case there are multiple documents data passed in for preview

        const itemArray = Array.isArray(previewData) ? previewDoc.itemsData : itemsData ? itemsData : [];// get the item array for each document
      
        return (
          <Page size="A4" style={styles.page}>
            <View style={styles.header}>
              <Text>
                <Text style={styles.boldText}>{currentCompanyData.company || ""}</Text>
                {currentCompanyData.BRN ? ` (${currentCompanyData.BRN})` : ""}
              </Text>
              <Text style={styles.headerText}>
                {currentCompanyData.address || ""}
              </Text>
              <Text style={styles.headerText}>
                {currentCompanyData.phoneNo ? `Phone No.: ${currentCompanyData.phoneNo || ""}` : ""}  {currentCompanyData.email ? `Email: ${currentCompanyData.email || ""}` : ""}
              </Text>
              {/* <Text style={styles.headerText}>
                {currentCompanyData.email ? `Email: ${currentCompanyData.email || ""}` : ""}
              </Text> */}
            </View>

            <View style={styles.logoContainer}>
              <Image
                src={{ uri: image64, method: "GET", headers: { "Cache-Control": "no-cache" }, body: "" }}
                style={styles.logoImage}
              />
            </View>

            <View>
              <View style={styles.firstSeparator} />
            </View>

            <View style={styles.contentContainer}>
              <View style={styles.mainContainer}>
                <View style={styles.leftColumn}>
                  <View style={styles.section}>
                    <Text style={styles.boldText}>Co. Name : {previewDoc.customerName || ""}</Text>
                    <View style={styles.sectionRow}>
                      <Text style={styles.boldText}>Address    : </Text>
                      <Text style={[styles.boldText, { marginLeft: 5 }]}>{previewDoc.address || previewDoc.customerAddress || ""}</Text>
                    </View>
                  </View>

                  <View style={styles.section}>
                    <Text style={styles.boldText}>PIC      : {previewDoc.attentionName}</Text>
                    <Text style={styles.sectionText}>Tel       : {previewDoc.phoneNo}</Text>
                    <Text style={styles.sectionText}>Email : {previewDoc.email}</Text>
                  </View>
                </View>

                <View style={styles.rightColumn}>
                  <View style={styles.section}>
                    <Text>QUOTATION NO. : {previewDoc.docNo || ""}</Text>
                    <Text
                      render={({ pageNumber, totalPages }) => `Page No.                 : ${pageNumber} of ${totalPages}`}
                    />
                    <Text>Date                          : {previewDoc.docDateFormat || ""}</Text>
                  </View>
                </View>
              </View>

              <View style={styles.section}>
                <Text>
                  <Text style={styles.boldText}>
                    Dear
                  </Text> {previewDoc.attentionName}
                </Text>
                <Text style={styles.sectionTitle}>RE:
                  <Text style={styles.sectionTitleRE}>
                    {previewDoc.description}
                  </Text>
                </Text>
                <Text style={styles.sectionText}>Thank you for you inquiry. We are pleased to submit our quote as follows:</Text>
              </View>

              <View style={styles.table}>
                <View style={[styles.tableRow, styles.tableHeader]}>
                  <View style={[styles.tableCell, { flex: 1 }]}>
                    <Text>Item</Text>
                  </View>
                  <View style={[styles.tableCell, { flex: 1, textAlign: 'left' }]}>
                    <Text>[✓]</Text>
                  </View>
                  <View style={[styles.tableCell, { flex: showMultipleUOM ? 8 : 10 }, styles.tableCellLeftAlign]}>
                    <Text>Description</Text>
                  </View>
                  {showMultipleUOM ? (
                    <>
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>QTY/UOM [1]</Text>
                      </View>
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>QTY/UOM [2]</Text>
                      </View>
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>QTY/UOM [3]</Text>
                      </View>
                    </>
                  ) : (
                    <>
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>QTY</Text>
                      </View>
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>UOM</Text>
                      </View>
                    </>
                  )}
                  <View style={[styles.tableCell, { flex: 2 }]}>
                    <Text>Unit Price</Text>
                  </View>
                  <View style={[styles.tableCell, { flex: 2 }]}>
                    <Text>Amount</Text>
                  </View>
                </View>
                {itemArray.map((item, index) => (
                  <>
                    <View style={[styles.tableRow, styles.lastRow]} key={index}>
                      <View style={[styles.tableCell, { flex: 1 }]}>
                        <Text>{index + 1}</Text>
                      </View>
                      <View style={[styles.tableCell, styles.boldText, { flex: 1, textAlign: 'left' }]}>
                        <Text>[   ]</Text>
                      </View>
                      <View style={[styles.tableCell, { flex: showMultipleUOM ? 8 : 10 }, styles.tableCellLeftAlign]}>
                        <Text>{item.itemName || ""}</Text>
                        {descriptionPreferences.description && item.description && (
                          <Text>{stripHtml(item.description)}</Text>
                        )}
                        {descriptionPreferences.secondDescription && item["2ndDescription"] && (
                          <Text>{stripHtml(item["2ndDescription"])}</Text>
                        )}
                        {descriptionPreferences.moreDescription && item.moreDescription && (
                          <Text>{stripHtml(item.moreDescription)}</Text>
                        )}
                      </View>
                      {showMultipleUOM ? (
                        <>
                          <View style={[styles.tableCell, { flex: 2 }]}>
                            <Text>{(item.quantity && item.itemUOM) ? `${item.quantity || ""} ${item.itemUOM || ""}` : ""}</Text>
                            <View
                              style={[
                                styles.tableCellUnderline,
                                (!item.quantity || !item.itemUOM) && { marginTop: 10 },
                              ]}
                            />
                          </View>
                          <View style={[styles.tableCell, { flex: 2 }]}>
                            <Text>{(item.quantity2 && item.itemUOM2) ? `${item.quantity2 || ""} ${item.itemUOM2 || ""}` : ""}</Text>
                            <View
                              style={[
                                styles.tableCellUnderline,
                                (!item.quantity2 && !item.itemUOM2) && { marginTop: 10 },
                              ]}
                            />
                          </View>
                          <View style={[styles.tableCell, { flex: 2 }]}>
                            <Text>{(item.quantity3 && item.itemUOM3) ? `${item.quantity3 || ""} ${item.itemUOM3 || ""}` : ""}</Text>
                            <View
                              style={[
                                styles.tableCellUnderline,
                                (!item.quantity3 && !item.itemUOM3) && { marginTop: 10 },
                              ]}
                            />
                          </View>
                        </>
                      ) : (
                        <>
                          <View style={[styles.tableCell, { flex: 2 }]}>
                            {item.itemUOM && item.quantity ? <Text>{item.quantity}</Text> : null}
                            <View
                              style={[
                                styles.tableCellUnderline,
                                (!item.quantity || !item.itemUOM) && { marginTop: 10 },
                              ]}
                            />
                          </View>
                          <View style={[styles.tableCell, { flex: 2 }]}>
                            {item.itemUOM && item.quantity ? <Text>{item.itemUOM}</Text> : null}
                          </View>
                        </>
                      )}
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>{Number(item.price || 0).toFixed(2)}</Text>
                      </View>
                      <View style={[styles.tableCell, { flex: 2 }]}>
                        <Text>{Number(item.subtotalTax || 0).toFixed(2)}</Text>
                      </View>
                    </View>

                    {item.child && item.child.map((child, childIndex) => (
                      <View style={[styles.tableRow, styles.lastRow]} key={childIndex}>
                        <View style={[styles.tableCell, { flex: 1 }]}>
                          <Text></Text>
                        </View>
                        <View style={[styles.tableCell, { flex: 1 }]}>
                          <Text></Text>
                        </View>
                        <View style={[styles.tableCell, { flex: showMultipleUOM ? 8 : 10 }, styles.tableCellLeftAlign]}>
                          <Text>{child.itemName || ""}</Text>
                          {descriptionPreferences.description && child.description && (
                            <Text>{stripHtml(child.description)}</Text>
                          )}
                          {descriptionPreferences.secondDescription && child["2ndDescription"] && (
                            <Text>{stripHtml(child["2ndDescription"])}</Text>
                          )}
                          {descriptionPreferences.moreDescription && child.moreDescription && (
                            <Text>{stripHtml(child.moreDescription)}</Text>
                          )}
                        </View>
                        {showMultipleUOM ? (
                          <>
                            <View style={[styles.tableCell, { flex: 2 }]}>
                              <Text></Text>
                            </View>
                            <View style={[styles.tableCell, { flex: 2 }]}>
                              <Text></Text>
                            </View>
                            <View style={[styles.tableCell, { flex: 2 }]}>
                              <Text></Text>
                            </View>
                          </>
                        ) : (
                          <>
                            <View style={[styles.tableCell, { flex: 2 }]}>
                              <Text></Text>
                            </View>
                            <View style={[styles.tableCell, { flex: 2 }]}>
                              <Text></Text>
                            </View>
                          </>
                        )}
                        <View style={[styles.tableCell, { flex: 2 }]}>
                          <Text></Text>
                        </View>
                        <View style={[styles.tableCell, { flex: 2 }]}>
                          <Text></Text>
                        </View>
                      </View>
                    ))}
                  </>
                ))}
              </View>

              <View style={{ flex: 1 }} />

              <View style={styles.bottomSection} wrap={false}>
                <View>
                  <View style={styles.secondSeparator} />
                  <Text style={styles.sectionTotal}>
                    {showMultipleUOM
                      ? `Grand Total: ${Number(previewDoc.totalPayable || 0).toFixed(2)}`
                      : `Total: ${Number(previewDoc.totalPayable || 0).toFixed(2)}`}
                  </Text>
                  <View style={styles.thirdSeparator} />
                </View>

                <View style={styles.botContainer}>
                  <View style={[styles.leftBotColumn, { fontSize: 10, display: 'flex', flexDirection: 'column', height: '100%' }]}>
                    <View>
                      <View style={styles.remark}>
                        <Text>Remarks:</Text>
                        <Text>{stripHtml(previewDoc.note || "")}</Text>
                      </View>
                    </View>
                  </View>

                  <View style={[styles.rightBotColumn, { display: 'flex', flexDirection: 'column', height: '100%' }]}>
                    <View style={{ marginTop: 'auto' }}>
                      <View style={styles.customerSystemUserSection}>
                        <Text>We confirm the order by accepting the terms & conditions stated above.</Text>
                      </View>

                      <View>
                        <View style={styles.customerSignatureLine} />
                      </View>

                      <View style={styles.customerSignatureSection}>
                        <Text style={{ textAlign: "center" }}>Chop & Sign</Text>
                        <View>
                          <Text>Date:</Text>
                          <Text>Person in Charge:</Text>
                        </View>

                      </View>
                    </View>
                  </View>
                </View>
              </View>
            </View>
          </Page>
        )

      })}
    </Document>
  );
};


export default PreviewQuotationTemplate;

function stripHtml(html) {
  if (!html) return "";

  // Replace <br> and <br/> with newlines
  let text = html.replace(/<br\s*\/?>/gi, '\n');

  // Replace <p> with nothing, </p> with newline
  text = text.replace(/<p[^>]*>/gi, '').replace(/<\/p>/gi, '\n');

  // Preserve "<" and ">" with spaces inside, replace other HTML tags
  text = text.replace(/<\s*[^>]*\s*>/g, match => {
    return /\s/.test(match) ? match : '';
  });

  // Replace HTML entities
  text = text.replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&');

  // Replace bullet point characters with standard bullet
  text = text.replace(/⦁/g, '•');

  return text;
};