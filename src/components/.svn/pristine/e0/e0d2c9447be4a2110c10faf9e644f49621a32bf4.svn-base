  },
  customerSignatureLine: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 30,
    marginBottom: 5,
  },
  customerSignatureSection: {
    fontSize: 8,
    marginBottom: 20,
  },
  sectionTitle: {
    fontSize: 12,
    textAlign: "left",
    fontFamily: 'NotoSansSC-Bold',
  },
  sectionTitleRE: {
    fontSize: 12,
    textAlign: "left",
    fontFamily: 'NotoSansSC-Bold',
    textDecoration: "underline",
  },
  sectionTotal: {
    fontSize: 12,
    fontWeight: "bold",
    textAlign: "right",
    fontFamily: 'NotoSansSC-Bold',
  },
  sectionRow: {
    flexDirection: "row",
    justifyContent: "flex-start",
  },
  sectionText: {
    fontSize: 9,
    marginRight: 10,
  },
  table: {
    width: "100%",
    marginBottom: 10,
    borderStyle: "solid",
    borderColor: "#000000",
    borderTopWidth: 1,
    borderCollapse: "collapse",
  },
  tableRow: {
    flexDirection: "row",
    borderBottomWidth: 1,
    borderColor: "#000000",
  },
  tableCell: {
    padding: 2,
    fontSize: 7,
    textAlign: "center",
    flexShrink: 1,
    borderTopWidth: 0,
    borderBottomWidth: 0,
    borderColor: "#000000",
  },
  tableCellUnderline: {
    width: "80%",
    height: 1,
    backgroundColor: "#000000",
    alignSelf: "center",
  },
  tableCellLeftAlign: {
    textAlign: "left",
  },
  lastRow: {
    borderBottomWidth: 0,
  },
  tableHeader: {
    backgroundColor: "#ffffff",
    fontFamily: 'NotoSansSC-Bold',
  },
  firstSeparator: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 20,
    marginBottom: 10,
  },
  secondSeparator: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 5,
  },
  thirdSeparator: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginBottom: 5,
  },
  logoContainer: {
    width: "20%",
    position: "absolute",
    top: 30,
    right: 30,
    width: 100,
    height: 100,
    marginBottom: 10,
    overflow: "hidden",
    padding: 0,
  },
  logoImage: {
    width: 100,
    height: 100,
    objectFit: "contain",
  },
  pageNumber: {
    fontSize: 8,
  },
  remark: {
    marginTop: 5,
    marginRight: 10,
    fontSize: 8,
