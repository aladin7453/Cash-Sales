type UOMDropdownCellProps = {
  row: any;
  column: { id: string };
  UOMInputs: Record<string, string>;
  setUOMInputs: React.Dispatch<React.SetStateAction<Record<string, string>>>;
  UOM2Inputs: Record<string, string>;
  setUOM2Inputs: React.Dispatch<React.SetStateAction<Record<string, string>>>;
  UOM3Inputs: Record<string, string>;
  setUOM3Inputs: React.Dispatch<React.SetStateAction<Record<string, string>>>;
  setTempRowDetailsList: (updater: (prevList: any[]) => any[]) => void;
  isPaid?: boolean;
};

type NumberInputCellProps = {
  row: any;
  column: { id: string };
  allowDecimal: boolean;
  preferenceData?: any;
  setNumberInputs: React.Dispatch<React.SetStateAction<any>>;
  setTempRowDetailsList: (updater: (prevList: any[]) => any[]) => void;
  onPriceHistoryClick?: (itemId: string) => void;
  onSerialNumberClick?: (row: any) => void;
  userHasRuleData?: { userHasRule: Array<string> };
  allowNegative?: boolean;
  disableDiscountFields?: boolean;
  isPaid?: boolean;
  appliedVoucher?: boolean;
  moduleName?: string;
};

type TextInputCellProps = {
  row: any;
  column: { id: string };
  className?: string;
  setTextInputs: React.Dispatch<React.SetStateAction<any>>;
  setTempRowDetailsList: (updater: (prevList: any[]) => any[]) => void;
};

type DescriptionInputCellProps = {
  row: any;
  column: { id: string };
  className?: string;
  setTextInputs: React.Dispatch<React.SetStateAction<any>>;
  setMoreDescriptions: React.Dispatch<React.SetStateAction<any>>;
  setTempRowDetailsList: (updater: (prevList: any[]) => any[]) => void;
  moduleName?: String;
};

type DateInputCellProps = {
  row: any;
  column: { id: string };
  setTempRowDetailsList: (updater: (prevList: any[]) => any[]) => void;
};

type DropdownInputCellProps = {
  row: any;
  column: { id: string };
  dropdownDatas: Record<string, any[]>;
  setDropdownDatas: React.Dispatch<React.SetStateAction<Record<string, any[]>>>;
  dropdownInputDatas: Record<string, any>;
  setDropdownInputDatas: React.Dispatch<React.SetStateAction<Record<string, any>>>;
  showTables: Record<string, any>;
  setShowTables: React.Dispatch<React.SetStateAction<Record<string, any>>>;
  setTempRowDetailsList: (updater: (prevList: any[]) => any[]) => void;
  fetchDropdownData: (table: string) => Promise<void>;
  dropdownTableColumns: Record<string, any[]>;
  inputRef: React.RefObject<HTMLInputElement>;
  dropdownRef: React.RefObject<HTMLDivElement>;
  currentLocation?: { locationCode: string | null; UUID: string | null };
  setCurrentLocation?: React.Dispatch<
    React.SetStateAction<{ locationCode: string | null; UUID: string | null }>
  >;
  isPaid?: boolean;
  modifiedKnockOffDetails?: any[];
  setModifiedKnockOffDetails?: (data: any) => void;
};

export function UOMDropdownInputCell({
  row,
  column: { id },
  UOMInputs,
  setUOMInputs,
  UOM2Inputs,
  setUOM2Inputs,
  UOM3Inputs,
  setUOM3Inputs,
  setTempRowDetailsList,
  isPaid = false,
}: UOMDropdownCellProps) {
  // Determine which UOM we're dealing with based on column id
  const uomIndex = id === "itemUOM" ? 1 : id === "itemUOM2" ? 2 : 3;
  const uomField = uomIndex === 1 ? "UOM" : `UOM${uomIndex}`;
  const uomDropdownField = uomIndex === 1 ? "UOMDropdown" : `UOMDropdown${uomIndex}`;
  const inputStateField = uomIndex === 1 ? UOMInputs : uomIndex === 2 ? UOM2Inputs : UOM3Inputs;
  const setInputStateField =
    uomIndex === 1 ? setUOMInputs : uomIndex === 2 ? setUOM2Inputs : setUOM3Inputs;

  // Ensure we have an array before filtering
  const uomDropdownData = row.original[uomDropdownField];

  // Filter to only get indexed entries (0, 1, 2) and ignore string properties like "UOM": "Drop"
  let uomDataArray = [];

  if (uomDropdownData && typeof uomDropdownData === "object") {
    // Extract only numbered indices and convert to array
    uomDataArray = Object.keys(uomDropdownData)
      .filter((key) => /^\d+$/.test(key)) // Only numeric keys (0, 1, 2, etc.)
      .map((key) => uomDropdownData[key])
      .filter((item) => item && typeof item === "object" && item.UUID); // Ensure valid UOM objects
  }

  // Filter out options with null values for the relevant UOM field
  const uomOptions = uomDataArray.filter((uom) => uom[uomField] !== null);

  // Disable UOM2 and UOM3 for Stock items OR if dropdown is empty
  const isStockItem = row.original.type?.toLowerCase() === "stock";
  const isDisabled = uomOptions.length === 0 || (isStockItem && (uomIndex === 2 || uomIndex === 3));

  // Get the default UOM from UOM[1] to ensure all UOMs use the same default index
  const defaultUOM = row.original.UOM;
  const currentValue = inputStateField[row.id] ?? row.original[uomField] ?? defaultUOM;

  // Check if the current value exists in the filtered options
  const isValueValid = uomOptions.some((uom) => uom.UUID === currentValue);

  // For UOM2 and UOM3, if they don't have a value, use the same default as UOM[1]
  let displayValue = isValueValid ? currentValue : "";

  if (isDisabled) {
    displayValue = "";
  } else if (!isValueValid) {
    // If the current value is invalid, show the placeholder instead
    displayValue = "";
  }

  const onChange = (selectedUOMUUID) => {
    const selectedUOM = uomOptions.find((uom) => uom.UUID === selectedUOMUUID);

    if (selectedUOM) {
      row.original[uomField] = selectedUOMUUID;

      // Always update rate and price for any UOM selection
      row.original["itemRate"] = selectedUOM.rate;
      row.original["price"] = selectedUOM.refPrice;

      setInputStateField((prevInputs) => ({ ...prevInputs, [row.id]: selectedUOMUUID }));

      // Update UOM2 and UOM3 only if they have no value
      if (uomIndex === 1) {
        setUOM2Inputs((prevInputs) => ({
          ...prevInputs,
          [row.id]: row.original.UOM2 ? prevInputs[row.id] : selectedUOMUUID,
        }));
        setUOM3Inputs((prevInputs) => ({
          ...prevInputs,
          [row.id]: row.original.UOM3 ? prevInputs[row.id] : selectedUOMUUID,
        }));

        row.original.UOM2 = row.original.UOM2 || selectedUOMUUID;
        row.original.UOM3 = row.original.UOM3 || selectedUOMUUID;
      }

      setTempRowDetailsList((prevList) =>
        prevList.map((item, idx) => {
          if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
            const updatedItem = {
              ...item,
              [uomField]: selectedUOMUUID,
              // Always update rate and price for any UOM selection
              itemRate: selectedUOM.rate,
              price: selectedUOM.refPrice,
            };

            // Update UOM2 and UOM3 only if they have no value
            if (uomIndex === 1) {
              updatedItem.UOM2 = updatedItem.UOM2 || selectedUOMUUID;
              updatedItem.UOM3 = updatedItem.UOM3 || selectedUOMUUID;
            }

            return updatedItem;
          }
          return item;
        }),
      );
    }
  };

  return (
    <Select value={displayValue} onValueChange={onChange} disabled={isDisabled || isPaid}>
      <SelectTrigger className="h-7.5 w-full">
        <SelectValue
          placeholder={
            uomOptions.length === 0
              ? "No UOM available"
              : isStockItem && (uomIndex === 2 || uomIndex === 3)
                ? "N/A for Stock"
                : "Select UOM"
          }
        />
      </SelectTrigger>
      <SelectContent>
        {uomOptions.map((UOM) => (
          <SelectItem key={UOM.UUID} value={UOM.UUID}>
            {UOM[uomField]}
          </SelectItem>
        ))}
      </SelectContent>
    </Select>
  );
}

export function NumberInputCellComponent({
  row,
  column: { id },
  allowDecimal,
  preferenceData,
  setNumberInputs,
  setTempRowDetailsList,
  onPriceHistoryClick,
  onSerialNumberClick,
  userHasRuleData,
  allowNegative = false,
  disableDiscountFields = false,
  isPaid = false,
  appliedVoucher = false,
  moduleName,
}: NumberInputCellProps) {
  // Check if corresponding UOM dropdown is empty
  const getUOMDropdownField = (quantityId: string) => {
    if (quantityId === "quantity") return "UOMDropdown";
    if (quantityId === "quantity2") return "UOMDropdown2";
    if (quantityId === "quantity3") return "UOMDropdown3";
    return null;
  };

  const uomDropdownField = getUOMDropdownField(id);
  const uomOptions = uomDropdownField ? row.original[uomDropdownField] || [] : [];
  const isUOMDropdownEmpty = uomDropdownField && uomOptions.length === 0;

  // Disable quantity2 and quantity3 for Stock items OR if UOM dropdown is empty
  const isStockItem = row.original.type?.toLowerCase() === "stock";
  const isQuantityField = id === "quantity2" || id === "quantity3";

  // Check for discount field disabling
  const isDiscountField =
    id === "discountRate" ||
    id === "discountAmount" ||
    id === "discountRate2" ||
    id === "discountAmount2" ||
    id === "discountRate3" ||
    id === "discountAmount3";

  const shouldDisableDiscountFields = disableDiscountFields && isDiscountField;

  // Check if this is a Stock item and quantity field for serial number button
  const shouldShowSerialButton = isStockItem && id === "quantity" && onSerialNumberClick;

  const isDisabled =
    id === "feeRate" ||
    id === "feeAmount" ||
    (isStockItem && isQuantityField) ||
    isUOMDropdownEmpty ||
    shouldDisableDiscountFields ||
    isPaid ||
    appliedVoucher;

  // Clear value for disabled fields
  const displayValue =
    isDisabled &&
      (isUOMDropdownEmpty || (isStockItem && isQuantityField))
      ? ""
      : row.original[id] || "";

  // Get decimal places from preference data
  const decimal = preferenceData?.data?.decimal || 2;

  // Determine if negative values are allowed for price field
  const allowNegativePrice = id === "price" && allowNegative;

  // Calculate base amount for discount calculations
  const calculateBaseAmount = () => {
    const quantity1 = Number(row.original.quantity) || 0;
    const quantity2 = Number(row.original.quantity2) || 1;
    const quantity3 = Number(row.original.quantity3) || 1;
    const price = Number(row.original.price) || 0;
    return quantity1 * quantity2 * quantity3 * price;
  };

  // Calculate discount amount from rate
  const calculateDiscountAmountFromRate = (
    rate: number,
    baseAmount: number,
    discountLevel: number,
  ) => {
    let currentAmount = baseAmount;

    // Apply previous discount levels
    if (discountLevel >= 2) {
      const discountRate1 = Number(row.original.discountRate) || 0;
      currentAmount = currentAmount - (currentAmount * discountRate1) / 100;
    }
    if (discountLevel >= 3) {
      const discountRate2 = Number(row.original.discountRate2) || 0;
      currentAmount = currentAmount - (currentAmount * discountRate2) / 100;
    }

    return (currentAmount * rate) / 100;
  };

  // Calculate discount rate from amount
  const calculateDiscountRateFromAmount = (
    amount: number,
    baseAmount: number,
    discountLevel: number,
  ) => {
    let currentAmount = baseAmount;

    // Apply previous discount levels
    if (discountLevel >= 2) {
      const discountRate1 = Number(row.original.discountRate) || 0;
      currentAmount = currentAmount - (currentAmount * discountRate1) / 100;
    }
    if (discountLevel >= 3) {
      const discountRate2 = Number(row.original.discountRate2) || 0;
      currentAmount = currentAmount - (currentAmount * discountRate2) / 100;
    }

    return currentAmount > 0 ? (amount * 100) / currentAmount : 0;
  };

  // Handle discount rate blur events
  const handleDiscountRateBlur = (value: string, discountLevel: number) => {
    const rate = Number(value) || 0;
    const baseAmount = calculateBaseAmount();

    if (baseAmount > 0) {
      const discountAmount = calculateDiscountAmountFromRate(rate, baseAmount, discountLevel);
      const amountField = discountLevel === 1 ? "discountAmount" : `discountAmount${discountLevel}`;

      row.original[amountField] = discountAmount.toFixed(decimal);

      // Update state and tempRowDetailsList
      updateRowData(amountField, discountAmount.toFixed(decimal));
    }
  };

  // Handle discount amount blur events
  const handleDiscountAmountBlur = (value: string, discountLevel: number) => {
    const amount = Number(value) || 0;
    const baseAmount = calculateBaseAmount();

    if (baseAmount > 0) {
      const discountRate = calculateDiscountRateFromAmount(amount, baseAmount, discountLevel);
      const rateField = discountLevel === 1 ? "discountRate" : `discountRate${discountLevel}`;

      row.original[rateField] = discountRate.toFixed(decimal);

      // Update state and tempRowDetailsList
      updateRowData(rateField, discountRate.toFixed(decimal));
    }
  };

  // Helper function to update both state and tempRowDetailsList
  const updateRowData = (fieldId: string, value: string) => {
    setNumberInputs((numberInputs) => ({
      ...numberInputs,
      [fieldId]: { ...numberInputs[fieldId], [row.id]: value },
    }));

    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          return { ...item, [fieldId]: value };
        }
        return item;
      }),
    );
  };

  const handleValueChange = (value: string) => {
    // Don't allow changes to disabled fields
    if (isDisabled) return;

    // For quantity field changes, preserve original quantity if it hasn't been set
    if (id === "quantity" && !row.original.originalQuantity) {
      // Store the current quantity as original before making changes
      row.original.originalQuantity = row.original.quantity || value;
    }

    // Update the row's original data with the new value
    row.original[id] = value;

    // Multi-UOM calculation logic - multiply all quantities with price
    const baseAmount = calculateBaseAmount();

    // 3-tier discount calculation function
    const calculateTieredDiscounts = (baseAmount: number) => {
      const discountRate1 = Number(row.original.discountRate) || 0;
      const discountRate2 = Number(row.original.discountRate2) || 0;
      const discountRate3 = Number(row.original.discountRate3) || 0;

      let currentAmount = baseAmount;
      let discountAmount1 = 0;
      let discountAmount2 = 0;
      let discountAmount3 = 0;

      // First discount - preserve existing amount if it exists
      if (row.original.discountAmount && Number(row.original.discountAmount) > 0) {
        discountAmount1 = Number(row.original.discountAmount);
      } else if (discountRate1 > 0) {
        discountAmount1 = (currentAmount * discountRate1) / 100;
      }
      currentAmount = currentAmount - discountAmount1;

      // Second discount - preserve existing amount if it exists
      if (row.original.discountAmount2 && Number(row.original.discountAmount2) > 0) {
        discountAmount2 = Number(row.original.discountAmount2);
      } else if (discountRate2 > 0) {
        discountAmount2 = (currentAmount * discountRate2) / 100;
      }
      currentAmount = currentAmount - discountAmount2;

      // Third discount - preserve existing amount if it exists
      if (row.original.discountAmount3 && Number(row.original.discountAmount3) > 0) {
        discountAmount3 = Number(row.original.discountAmount3);
      } else if (discountRate3 > 0) {
        discountAmount3 = (currentAmount * discountRate3) / 100;
      }

      return {
        discountAmount1: discountAmount1.toFixed(decimal),
        discountAmount2: discountAmount2.toFixed(decimal),
        discountAmount3: discountAmount3.toFixed(decimal),
        finalAmount: currentAmount,
      };
    };

    // Update related fields based on ID - only for quantity/price changes
    if (id === "quantity" || id === "quantity2" || id === "quantity3" || id === "price") {
      // Only recalculate discount amounts if they don't already exist
      if (baseAmount > 0) {
        const discountResult = calculateTieredDiscounts(baseAmount);

        // Only update if the current discount amount is empty or zero
        if (!row.original.discountAmount || Number(row.original.discountAmount) === 0) {
          row.original.discountAmount = discountResult.discountAmount1;
        }
        if (!row.original.discountAmount2 || Number(row.original.discountAmount2) === 0) {
          row.original.discountAmount2 = discountResult.discountAmount2;
        }
        if (!row.original.discountAmount3 || Number(row.original.discountAmount3) === 0) {
          row.original.discountAmount3 = discountResult.discountAmount3;
        }
      }

      if (row.original.feeRate && baseAmount > 0) {
        row.original.feeAmount = ((baseAmount * Number(row.original.feeRate)) / 100)
          .toFixed(decimal)
          .toString();
      }
    } else if (id === "feeRate" && value) {
      if (baseAmount > 0) {
        row.original.feeAmount = ((baseAmount * Number(value)) / 100).toFixed(decimal).toString();
      }
    } else if (id === "feeAmount" && value) {
      if (baseAmount > 0) {
        row.original.feeRate = ((100 * Number(value)) / baseAmount).toFixed(decimal).toString();
      }
    }

    // Update the state with the new value
    setNumberInputs((numberInputs) => ({
      ...numberInputs,
      [id]: { ...numberInputs[id], [row.id]: value },
    }));

    // Update tempRowDetailsList
    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          const updatedItem = { ...item, [id]: value };

          // Preserve original quantity for quantity field changes
          if (id === "quantity" && !updatedItem.originalQuantity) {
            updatedItem.originalQuantity = item.quantity || value;
          }

          // Recalculate amounts for quantity and price changes
          if (id === "quantity" || id === "quantity2" || id === "quantity3" || id === "price") {
            const newQuantity1 = id === "quantity" ? Number(value) : Number(item.quantity) || 0;
            const newQuantity2 = id === "quantity2" ? Number(value) : Number(item.quantity2) || 1;
            const newQuantity3 = id === "quantity3" ? Number(value) : Number(item.quantity3) || 1;
            const newPrice = id === "price" ? Number(value) : Number(item.price) || 0;
            const newTotalAmount = newQuantity1 * newQuantity2 * newQuantity3 * newPrice;

            if (newTotalAmount > 0) {
              const discountResult = calculateTieredDiscounts(newTotalAmount);
              updatedItem.discountAmount = discountResult.discountAmount1;
              updatedItem.discountAmount2 = discountResult.discountAmount2;
              updatedItem.discountAmount3 = discountResult.discountAmount3;
            }

            if (item.feeRate) {
              updatedItem.feeAmount = ((newTotalAmount * Number(item.feeRate)) / 100)
                .toFixed(decimal)
                .toString();
            }
          } else if (id === "feeRate" && value) {
            const currentQuantity1 = Number(item.quantity) || 0;
            const currentQuantity2 = Number(item.quantity2) || 1;
            const currentQuantity3 = Number(item.quantity3) || 1;
            const currentPrice = Number(item.price) || 0;
            const currentTotalAmount =
              currentQuantity1 * currentQuantity2 * currentQuantity3 * currentPrice;

            if (currentTotalAmount > 0) {
              updatedItem.feeAmount = ((currentTotalAmount * Number(value)) / 100)
                .toFixed(decimal)
                .toString();
            }
          } else if (id === "feeAmount" && value) {
            const currentQuantity1 = Number(item.quantity) || 0;
            const currentQuantity2 = Number(item.quantity2) || 1;
            const currentQuantity3 = Number(item.quantity3) || 1;
            const currentPrice = Number(item.price) || 0;
            const currentTotalAmount =
              currentQuantity1 * currentQuantity2 * currentQuantity3 * currentPrice;

            if (currentTotalAmount > 0) {
              updatedItem.feeRate = ((100 * Number(value)) / currentTotalAmount)
                .toFixed(decimal)
                .toString();
            }
          }
          //Promotion discount logic
          if(value && id=="discountRate" && moduleName=="promotion-discount"){
            updatedItem.isDiscountAmountDisabled=true
          }else if(!value && id=="discountRate"  && moduleName=="promotion-discount"){
            updatedItem.isDiscountAmountDisabled=false
          }

          if(value && id=="discountAmount"  && moduleName=="promotion-discount"){
            updatedItem.isDiscountRateDisabled=true
          }else if(!value && id=="discountAmount"  && moduleName=="promotion-discount"){
            updatedItem.isDiscountRateDisabled=false
          }

          return updatedItem;
        }
        return item;
      }),
    );
  };

  // Create the onBlur callback for discount calculations
  const getOnBlurCallback = () => {
    if (id === "discountRate") return (value: string) => handleDiscountRateBlur(value, 1);
    if (id === "discountRate2") return (value: string) => handleDiscountRateBlur(value, 2);
    if (id === "discountRate3") return (value: string) => handleDiscountRateBlur(value, 3);
    if (id === "discountAmount") return (value: string) => handleDiscountAmountBlur(value, 1);
    if (id === "discountAmount2") return (value: string) => handleDiscountAmountBlur(value, 2);
    if (id === "discountAmount3") return (value: string) => handleDiscountAmountBlur(value, 3);
    return undefined;
  };

  //Promotion discount logic 
  if ((id=="discountRate" || id=="discountAmount") && (moduleName && moduleName == "promotion-discount")) {
    return (
      <div className="flex items-center gap-1">
        <NumberInputCell
          className="h-7.5 flex-1"
          onValueChange={handleValueChange}
          onBlurCallback={getOnBlurCallback()}
          value={displayValue}
          disabled={id=="discountAmount" && row.original.isDiscountAmountDisabled?true:id=="discountRate" && row.original.isDiscountRateDisabled?true:false }
          allowDecimal={allowDecimal}
          allowNegative={allowNegativePrice}
          decimalPlaces={decimal}
        />

      </div>
    );

  } else {
    return (
      <div className="flex items-center gap-1">
        <NumberInputCell
          className="h-7.5 flex-1"
          onValueChange={handleValueChange}
          onBlurCallback={getOnBlurCallback()}
          value={displayValue}
          disabled={isDisabled}
          allowDecimal={allowDecimal}
          allowNegative={allowNegativePrice}
          decimalPlaces={decimal}
          placeholder={
            isUOMDropdownEmpty
              ? "N/A"
              : isStockItem && isQuantityField
                ? "N/A"
                : undefined
          }
        />
        {shouldShowSerialButton && (
          <Button
            variant="ghost"
            size="sm"
            className="h-7 w-7 border border-erp-blue-14 p-0 text-erp-blue-14 hover:text-erp-blue-14"
            onClick={(e) => {
              e.stopPropagation();
              onSerialNumberClick(row);
            }}
          >
            <ChevronDown className="h-4 w-4" />
          </Button>
        )}
        {id === "price" && onPriceHistoryClick && (
          <Button
            variant="ghost"
            size="sm"
            className="h-7 w-7 p-0 text-erp-blue-14 hover:text-erp-blue-14"
            onClick={(e) => {
              e.stopPropagation();
              // Use the row's item field which contains the item UUID
              onPriceHistoryClick(row.original.item || "");
            }}
          >
            <SVGPriceHistory className="h-5.5 w-5.5" />
          </Button>
        )}
      </div>
    );
  }

}

export function TextInputCellComponent({
  row,
  column: { id },
  className = "h-7.5",
  setTextInputs,
  setTempRowDetailsList,
}: TextInputCellProps) {
  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const newValue = e.target.value;

    // Update the row's original data
    row.original[id] = newValue;

    // Update the local state for text inputs
    setTextInputs((prevTextInputs) => ({
      ...prevTextInputs,
      [id]: { ...prevTextInputs[id], [row.id]: newValue },
    }));

    // Update the tempRowDetailsList to reflect the change
    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          return { ...item, [id]: newValue };
        }
        return item;
      }),
    );
  };

  const textInputs = {}; // This should be passed from parent or accessed differently
  const currentValue = textInputs[id] ? textInputs[id][row.id] : row.original[id];

  return <Input className={className} value={currentValue || ""} onChange={handleChange} />;
}


export function SelectInputCellComponent({
  row,
  column: { id },
  className = "h-7.5",
  setTextInputs,
  setTempRowDetailsList,
  options = [],
  placeholder = "Select option",
  isDisabled = false,
}: TextInputCellProps & {
  options: { label: string; value: string }[];
  placeholder?: string;
  isDisabled?: boolean;
}) {
  const handleChange = (newValue: string) => {
    // Update row original
    row.original[id] = newValue;

    // If module changes → reset template
    if (id === "module") {
      row.original["template"] = "";

      // reset template in textInputs
      setTextInputs((prev) => ({
        ...prev,
        [id]: { ...prev[id], [row.id]: newValue },
        template: {
          ...prev.template,
          [row.id]: "",
        },
      }));
    } else {
      // normal update
      setTextInputs((prev) => ({
        ...prev,
        [id]: { ...prev[id], [row.id]: newValue },
      }));
    }

    // Update temp list
    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          const updatedItem = { ...item, [id]: newValue };

          // also reset template in temp list
          if (id === "module") {
            updatedItem["template"] = "";
          }

          return updatedItem;
        }
        return item;
      }),
    );
  };

  const textInputs = {}; // ⚠️ should come from parent
  const currentValue = textInputs[id]
    ? textInputs[id][row.id]
    : row.original[id];

  const displayValue = currentValue || "";

  return (
    <Select value={displayValue} onValueChange={handleChange} disabled={isDisabled}>
      <SelectTrigger className={`${className} w-full`}>
        <SelectValue placeholder={placeholder} />
      </SelectTrigger>

      <SelectContent>
        {options.length === 0 ? (
          <SelectItem value="__empty" disabled>
            No options available
          </SelectItem>
        ) : (
          options.map((opt) => (
            <SelectItem key={opt.value} value={opt.value}>
              {opt.label}
            </SelectItem>
          ))
        )}
      </SelectContent>
    </Select>
  );
}

export function DescriptionInputCellComponent({
  row,
  column: { id },
  className = "h-7.5 p-0",
  setTextInputs,
  setMoreDescriptions,
  setTempRowDetailsList,
  moduleName,
}: DescriptionInputCellProps) {
  const handleChange = (e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement>) => {
    const rawValue = e.target.value;
    // Sanitize input
    const newValue = stripHtml(rawValue);
    row.original[id] = newValue;

    // Update the appropriate state based on field type
    if (id === "moreDescription") {
      setMoreDescriptions((moreDescriptions) => ({
        ...moreDescriptions,
        [row.id]: newValue,
      }));
    } else {
      // For description and 2ndDescription
      setTextInputs((prevTextInputs) => ({
        ...prevTextInputs,
        [row.id]: {
          ...prevTextInputs[row.id],
          [id]: newValue,
        },
      }));
    }

    // Update the tempRowDetailsList to reflect the change
    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          return { ...item, [id]: newValue };
        }
        return item;
      }),
    );
  };

  // Get current value based on field type
  const textInputs = {}; // This should be passed from parent
  const moreDescriptions = {}; // This should be passed from parent
  const currentValue =
    id === "moreDescription"
      ? moreDescriptions[row.id] ?? row.original.moreDescription
      : textInputs[id]
        ? textInputs[id][row.id]
        : row.original[id];

  // Get placeholder text
  const placeholder =
    id === "2ndDescription"
      ? "Enter 2nd Description"
      : id === "moreDescription"
        ? "Enter More Description"
        : "Enter Description";

  return (
    <Popover>
      <PopoverTrigger asChild>
        {id === "moreDescription" ? (
          <button className="items-center text-erp-blue-14" onClick={(e) => e.stopPropagation()}>
            <FaPenClip className="size-3" />
          </button>
        ) : (
          <Input
            className={`${className} text-left`}
            value={currentValue || ""}
            onChange={handleChange}
            placeholder={placeholder}
            onClick={(e) => e.stopPropagation()}
          />
        )}
      </PopoverTrigger>
      <PopoverContent className="bg-erp-blue-3 p-2">
        <Textarea
          className="p-2 text-left"
          value={currentValue || ""}
          onChange={handleChange}
          placeholder={placeholder}
          onClick={(e) => e.stopPropagation()}
          fieldName={
            id == "2ndDescription" || id == "moreDescription" || id == "description"
              ? "description"
              : id
          }
          moduleName={moduleName}
          columnName={
            id == "2ndDescription" || id == "moreDescription" || id == "description"
              ? "Description"
              : id
          }
        />
      </PopoverContent>
    </Popover>
  );
}

export function DateInputCellComponent({
  row,
  column: { id },
  setTempRowDetailsList,
}: DateInputCellProps) {
  const [open, setOpen] = React.useState(false);

  const onChange = (newValue: string) => {
    row.original[id] = newValue;

    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          return { ...item, [id]: newValue };
        }
        return item;
      }),
    );
  };

  const onClear = () => {
    onChange("");
    setOpen(false);
  };

  return (
    <Popover open={open} onOpenChange={setOpen}>
      <PopoverTrigger asChild>
        <Button
          className={cn(
            "flex h-7.5 w-full justify-between",
            !row.original[id] && "text-muted-foreground",
          )}
          variant="outline"
          size="sm"
        >
          {row.original[id] ? moment.unix(row.original[id]).format(DATE_FORMAT) : "Pick a date"}
          <CalendarIcon className="h-4 w-4 text-gray-400" />
        </Button>
      </PopoverTrigger>

      <PopoverContent className="w-auto p-2" align="start">
        <Calendar
          mode="single"
          selected={row.original[id] ? new Date(Number(row.original[id]) * 1000) : undefined}
          onSelect={(date) => {
            const unixTimestamp = date ? Math.floor(date.getTime() / 1000).toString() : "";
            onChange(unixTimestamp);
            setOpen(false);
          }}
          initialFocus
        />
      </PopoverContent>
    </Popover>
  );
}

export function DropdownInputCellComponent({
  row,
  column: { id },
  dropdownDatas,
  setDropdownDatas,
  dropdownInputDatas,
  setDropdownInputDatas,
  showTables,
  setShowTables,
  setTempRowDetailsList,
  fetchDropdownData,
  dropdownTableColumns,
  inputRef,
  dropdownRef,
  currentLocation,
  setCurrentLocation,
  isPaid = false,
  modifiedKnockOffDetails = [],
  setModifiedKnockOffDetails,
}: DropdownInputCellProps) {
  // Initialize location code if not set
  if (id === "locationCode" && !row.original.locationCode && currentLocation?.locationCode) {
    row.original.locationCode = currentLocation.locationCode;
  }
  const [inputRect, setInputRect] = useState(null);
  const isDisabled = isPaid && id === "taxCode";
  const inputRefs = useRef({});
  const onClickRow = (e) => {
    if (isDisabled) return;

    if (id === "salesDocument") {
      // For salesDocument, store UUID in salesDocument and display docNo
      row.original[id] = e.UUID;
      row.original["salesCreditNoteDocNo"] = e.docNo;

      // Assign credit note net total to salesCreditNoteTotalPayable
      const creditNoteNetTotal = Number(e.netTotal) || 0;
      row.original["salesCreditNoteTotalPayable"] = creditNoteNetTotal.toFixed(2);

      // Calculate outstanding amount for this row
      const currentOutstanding = Number(row.original.outstandingAmount) || 0;

      // Calculate how much credit note amount will be used and remaining
      const usedAmount = Math.min(creditNoteNetTotal, currentOutstanding);
      const remainingCreditNote = creditNoteNetTotal - usedAmount;

      // Set the remaining credit note amount
      row.original["salesCreditNoteOutstanding"] = remainingCreditNote.toFixed(2);

      // Update the outstanding amount (reduce by the used amount)
      const newOutstanding = Math.max(0, currentOutstanding - usedAmount);
      row.original["outstandingAmount"] = newOutstanding.toFixed(2);
    } else {
      row.original[id] = e[id];
      row.original[id.slice(0, -4)] = e.UUID;
    }

    if (id === "taxCode") {
      row.original["tax"] = e.UUID;
      row.original["taxRate"] = isNaN(Number(e.taxRate)) ? 0 : e.taxRate;
      row.original["taxTypeCode"] = e.taxTypeCode;
    }
    if (id === "customerCodeCode") {
      // row.original["customerCodeCode"] = e.customerCode;
      row.original["customerCode"] = e.UUID;
      row.original["customerName"] = e.customerName;
      row.original["customerBRN"] = e.BRN;
      row.original["customerID"] = e.ID;
      row.original["customermembershipID"] = e.membershipID;
    }
    if (id === "supplierCodeCode") {
      row.original["supplierCode"] = e.UUID;
      row.original["supplierName"] = e.supplierName;
      row.original["supplierBRN"] = e.BRN;
      row.original["supplierID"] = e.ID;
      row.original["supplierMembershipID"] = e.membershipID;
    }
    if (id === "withholdingTaxCode") row.original["withholdingTaxRate"] = e.withholdingTaxRate;
    if (id === "locationCode" && setCurrentLocation) {
      setCurrentLocation({ locationCode: e[id], UUID: e.UUID });
      row.original.locationCode = e[id];
    }

    // Update dropdown input data to show the selected value
    if (id === "salesDocument") {
      setDropdownInputDatas((prevInputDatas) => ({
        ...prevInputDatas,
        [id]: {
          ...prevInputDatas[id],
          [row.id]: e.docNo,
        },
      }));
    }

    setShowTables((prevShowTables) => ({
      ...prevShowTables,
      [id]: {
        ...prevShowTables[id],
        [row.id]: false,
      },
    }));

    setTempRowDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          let updatedItem;

          if (id === "salesDocument") {
            // For salesDocument, store UUID in salesDocument and docNo in salesCreditNoteDocNo
            // Also calculate credit note amounts
            const creditNoteNetTotal = Number(e.netTotal) || 0;
            const currentOutstanding = Number(item.outstandingAmount) || 0;
            const usedAmount = Math.min(creditNoteNetTotal, currentOutstanding);
            const remainingCreditNote = creditNoteNetTotal - usedAmount;
            const newOutstanding = Math.max(0, currentOutstanding - usedAmount);

            updatedItem = {
              ...item,
              [id]: e.UUID,
              salesCreditNoteDocNo: e.docNo,
              salesCreditNoteTotalPayable: creditNoteNetTotal.toFixed(2),
              salesCreditNoteOutstanding: remainingCreditNote.toFixed(2),
              outstandingAmount: newOutstanding.toFixed(2),
            };
          } else {
            updatedItem = { ...item, [id]: e[id] };
            updatedItem[id.slice(0, -4)] = e.UUID;
          }

          // Update related fields
          if (id === "taxCode") {
            updatedItem["taxRate"] = isNaN(Number(e.taxRate)) ? 0 : e.taxRate; // Ensure taxRate is numeric
            updatedItem["taxTypeCode"] = e.taxTypeCode;
          }
          if (id === "customerCodeCode") {
            // row.original["customerCodeCode"] = e.customerCode;
            updatedItem["customerCode"] = e.UUID;
            updatedItem["customerName"] = e.customerName;
            updatedItem["customerBRN"] = e.BRN;
            updatedItem["customerID"] = e.ID;
            updatedItem["customermembershipID"] = e.membershipID;
          }

          if (id === "supplierCodeCode") {
            // row.original["supplierCodeCode"] = e.supplierCode;
            updatedItem["supplierCode"] = e.UUID;
            updatedItem["supplierName"] = e.supplierName;
            updatedItem["supplierBRN"] = e.BRN;
            updatedItem["supplierID"] = e.ID;
            updatedItem["supplierMembershipID"] = e.membershipID;
          }

          if (id === "withholdingTaxCode") updatedItem["withholdingTaxRate"] = e.withholdingTaxRate;
          if (id === "locationCode") updatedItem.locationCode = e[id];

          return updatedItem;
        }
        return item;
      }),
    );

    // Update modifiedKnockOffDetails for salesDocument changes
    if (id === "salesDocument" && setModifiedKnockOffDetails) {
      // Calculate the same values for modification tracking
      const creditNoteNetTotal = Number(e.netTotal) || 0;
      const currentOutstanding = Number(row.original.outstandingAmount) || 0;
      const usedAmount = Math.min(creditNoteNetTotal, currentOutstanding);
      const remainingCreditNote = creditNoteNetTotal - usedAmount;
      const newOutstanding = Math.max(0, currentOutstanding - usedAmount);

      const updatedRowData = {
        ...row.original,
        [id]: e.UUID,
        salesCreditNoteDocNo: e.docNo,
        salesCreditNoteTotalPayable: creditNoteNetTotal.toFixed(2),
        salesCreditNoteOutstanding: remainingCreditNote.toFixed(2),
        outstandingAmount: newOutstanding.toFixed(2),
      };

      const existingIndex = modifiedKnockOffDetails.findIndex(
        (item) => item.UUID === row.original.UUID,
      );

      if (existingIndex >= 0) {
        // Update existing modified row
        const updatedModified = [...modifiedKnockOffDetails];
        updatedModified[existingIndex] = updatedRowData;
        setModifiedKnockOffDetails(updatedModified);
      } else {
        // Add new modified row
        setModifiedKnockOffDetails([...modifiedKnockOffDetails, updatedRowData]);
      }
    }
  };

  useEffect(() => {
    const handleScroll = () => {
      if (!inputRefs.current[row.id]) return;

      const rect = inputRefs.current[row.id].getBoundingClientRect();
      setInputRect(rect);
    };

    window.addEventListener("scroll", handleScroll, true);
    window.addEventListener("resize", handleScroll);

    return () => {
      window.removeEventListener("scroll", handleScroll, true);
      window.removeEventListener("resize", handleScroll);
    };
  }, [row.id]);

  return (
    <div className="relative">
      <Input
        className="h-7.5 pr-8"
        value={
          id === "salesDocument"
            ? dropdownInputDatas[id]?.[row.id] || row.original["salesCreditNoteDocNo"] || ""
            : dropdownInputDatas[id]?.[row.id] || row.original[id] || ""
        }
        readOnly
        onClick={async () => {
          await fetchDropdownData(id);
          const el = inputRefs.current[row.id];
          if (el) {
            const rect = el.getBoundingClientRect();
            setInputRect(rect);
          }

          setShowTables((prev) => ({
            ...prev,
            [id]: {
              ...prev[id],
              [row.id]: true,
            },
          }));
        }}
        ref={(el) => (inputRefs.current[row.id] = el)}
        autoComplete="off"
        disabled={isDisabled}
      />

      <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
        <FaMagnifyingGlass className="text-gray-400" />
      </div>

      {showTables[id] && showTables[id][row.id] && inputRect && (
        <Portal>
          <div
            ref={dropdownRef}
            className="dropdown-table-class fixed z-50 rounded border border-gray-200 bg-white shadow-md"
            style={{
              top: inputRect.bottom,
              left: inputRect.left,
              minWidth: inputRect.width,
              maxWidth: "80vw",
            }}
          >
            <ScrollArea className="h-[50cqh] bg-erp-gray-3">
              <DropdownTable
                columns={dropdownTableColumns[id]}
                data={dropdownDatas[id] ?? []}
                onClickRow={onClickRow}
              />
              <ScrollBar orientation="vertical" />
            </ScrollArea>
          </div>
        </Portal>
      )}
    </div>
  );
}
