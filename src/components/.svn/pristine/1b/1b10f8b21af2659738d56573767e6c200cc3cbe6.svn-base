import {
  Document,
  Image,
  Page,
  StyleSheet,
  Text,
  View,
  Font,
} from "@react-pdf/renderer";
import moment from "moment";

// Avoid double registration in dev
let fontsRegistered = false;

if (!fontsRegistered) {
  const isDev = process.env.NODE_ENV === "development";

  Font.register({
    family: "NotoSansSC",
    src: isDev
      ? "/fonts/NotoSansSC-Regular.ttf"
      : "/view/fonts/NotoSansSC-Regular.ttf",
  });

  Font.register({
    family: "NotoSansSC-Black",
    src: isDev
      ? "/fonts/NotoSansSC-Black.ttf"
      : "/view/fonts/NotoSansSC-Black.ttf",
  });

  fontsRegistered = true;
}


const styles = StyleSheet.create({
  page: {
    flexDirection: "column",
    backgroundColor: "#FFFFFF",
    padding: 30,
    fontFamily: "NotoSansSC", // Set the default font for the entire document
  },
  logoContainer: {
    position: "absolute",
    top: 30,
    left: 30,
    width: 100,
    height: 100,
    marginBottom: 10,
    overflow: "hidden",
    padding: 0,
  },
  logoImage: {
    width: 100,
    height: 100,
  },
  header: {
    fontSize: 9,
    marginLeft: 120,
    marginBottom: 5,
    textAlign: "left",
  },
  headerRow: {
    flexDirection: "row",
  },
  headerText: {
    fontSize: 8,
    marginRight: 10,
    marginTop: 5,
  },
  sectionTitle: {
    fontSize: 16,
    fontWeight: "bold",
    textAlign: "right",
  },
  firstSeparator: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 70,
    marginBottom: 5,
  },
  table: {
    width: "100%",
    marginTop: 10,
    marginBottom: 10,
    borderStyle: "solid",
    borderColor: "#000000",
  },
  tableRow: {
    flexDirection: "row",
    borderBottomWidth: 1,
    borderColor: "#000000",
  },
  tableHeader: {
    backgroundColor: "#deebf7",
    borderTopWidth: 1,
    fontWeight: "bold",
  },
  tableCellNo: {
    padding: 5,
    fontSize: 7,
    flex: 1,
    textAlign: "center",
    borderRightWidth: 1,
    borderLeftWidth: 1,
    borderColor: "#000000",
  },
  tableCell: {
    padding: 5,
    fontSize: 7,
    flex: 4,
    textAlign: "center",
    borderRightWidth: 1,
    borderColor: "#000000",
  },
  summaryBox: {
    backgroundColor: "#deebf7",
    padding: 10,
    marginTop: 10,
    borderRadius: 2,
  },
  summaryText: {
    fontSize: 7,
  },
  summaryTextValue: {
    fontSize: 7,
    textAlign: "right",
  },
  summaryTitle: {
    fontSize: 8,
    fontWeight: "bold",
  },
  summaryField: {
    backgroundColor: "#FFFFFF",
    padding: 3,
    marginTop: 2,
    borderWidth: 1,
    borderRadius: 3,
    borderColor: "#CCCCCC",
    width: 100,
    height: 18,
  },
  footerLine: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 5,
  },
  footerContainer: {
    position: "absolute",
    bottom: 10,
    left: 30,
    right: 30,
  },
  footerText: {
    fontSize: 7,
  },
});

const AssetReport = ({
  type,
  data,
  assetReportData,
  generatedReport,
  assetReportColumns,
  totalCounts,
}: {
  type: string;
  data?: any;
  assetReportData?: any;
  generatedReport: any;
  assetReportColumns?: any[];
  totalCounts: any;
}) => {
  let image64 = data?.currentCompany?.logoLink[0]?.base64;

  // Format the date range
  const formatDateRange = () => {
    if (!assetReportData?.startDate || !assetReportData?.endDate) return "";

    const startDate = moment
      .unix(Number(assetReportData.startDate))
      .format("DD-MM-YYYY");
    const endDate = moment
      .unix(Number(assetReportData.endDate))
      .format("DD-MM-YYYY");

    return `${startDate} to ${endDate}`;
  };

  // Calculate totals if not provided
  const totalAssetValueCost = data?.rows?.reduce(
    (sum, row) => sum + (parseFloat(row.costTotal) || 0),
    0
  );
  const totalLeaseAmountCost = data?.rows?.reduce(
    (sum, row) => sum + (parseFloat(row.amount) || 0),
    0
  );

  const totalNoOfDocuments = data?.rows?.length;

  return (
    <Document>
      <Page size="A4" style={styles.page} wrap>
        {/* Logo */}
        <View style={styles.logoContainer}>
          {image64 ? (
            <Image
              src={{
                uri: image64,
                method: "GET",
                headers: { "Cache-Control": "no-cache" },
                body: "",
              }}
              style={styles.logoImage}
            />
          ) : null}
        </View>

        {/* Header */}
        <View style={styles.header}>
          <Text>
            {data?.currentCompany?.company ?? ""} (
            {data?.currentCompany?.BRN ?? ""})
          </Text>
          <Text style={styles.headerText}>
            {data?.currentCompany?.address ?? ""}
          </Text>
          <View style={styles.headerRow}>
            <Text style={styles.headerText}>
              Phone No.: {data?.currentCompany?.phoneNo ?? ""}
            </Text>
            <Text style={styles.headerText}>
              Email: {data?.currentCompany?.email ?? ""}
            </Text>
          </View>
        </View>

        {/* First Separator */}
        <View>
          <View style={styles.firstSeparator} />
        </View>

        {/* Section Title */}
        <View>
          <Text style={[styles.sectionTitle, { textAlign: "center" }]}>
            ASSET {type.toUpperCase()} REPORT
          </Text>
        </View>

        {/* Generated By and Date Range */}
        <View style={{ marginTop: 40 }}>
          <Text style={{ fontSize: 7, textAlign: "left" }}>
            Generated By: {data?.currentUser ?? ""}
          </Text>
          <Text style={{ fontSize: 7, textAlign: "left" }}>
            Date Range: {formatDateRange()}
          </Text>
        </View>

        {/* Dynamic Table */}
        <View style={styles.table} wrap>
          {/* Table Header */}
          <View fixed style={[styles.tableRow, styles.tableHeader]}>
            {assetReportColumns?.map((column, index) => (
              <Text
                key={index}
                style={
                  column.header === "No."
                    ? styles.tableCellNo
                    : styles.tableCell
                }
              >
                {column.header}
              </Text>
            ))}
          </View>
          {/* Table Rows */}
          {data?.rows?.map((item, rowIndex) => (
            <View style={styles.tableRow} wrap={false} key={item.UUID}>
              {assetReportColumns?.map((column, colIndex) => (
                <Text
                  key={colIndex}
                  style={
                    column.header === "No."
                      ? styles.tableCellNo
                      : styles.tableCell
                  }
                >
                  {column.header === "No."
                    ? rowIndex + 1
                    : item[column.accessorKey]}
                </Text>
              ))}
            </View>
          ))}
        </View>

        {/* Summary Box */}
        <View style={styles.summaryBox}>
          <Text style={styles.summaryTitle}>Summary: </Text>
          <View style={{ marginTop: 5 }}>
            {type === "Inventory" ? (
              <>
                <View style={{ flexDirection: "row", gap: 10 }}>
                  <View>
                    <Text style={styles.summaryText}>Total Assets:</Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {parseFloat(totalCounts.totalAssets) ?? 0}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Assigned Assets:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalAssignedAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Available Assets:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalAvailableAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Unavailable Assets:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalUnavailableAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Asset Value (Cost):
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalAssetValueCost}
                      </Text>
                    </View>
                  </View>
                </View>
              </>
            ) : type === "Assignment" ? (
              <>
                <View style={{ flexDirection: "row", gap: 10 }}>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Assets Assigned to Departments:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalAssetAssignToDepartments}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Assets Assigned to Employees:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalAssetAssignToEmployees}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Asset Value (Cost):
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalAssetValueCost}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total No. Of Documents:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalNoOfDocuments}
                      </Text>
                    </View>
                  </View>
                </View>
              </>
            ) : type === "Lease" ? (
              <>
                <View style={{ flexDirection: "row", gap: 10 }}>
                  <View>
                    <Text style={styles.summaryText}>Total Active Leases:</Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalActiveLeaseAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Overdue Leases:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalOverdueLeaseAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Asset Value (Cost):
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalLeaseAmountCost}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total No. Of Documents:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalNoOfDocuments}
                      </Text>
                    </View>
                  </View>
                </View>
              </>
            ) : type === "Borrow" ? (
              <>
                <View style={{ flexDirection: "row", gap: 10 }}>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Assets Borrowed-Company:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalAssetBorrowCompanyAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Assets Borrowed-Employees:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalAssetBorrowEmployeeAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>Total Active Borrow:</Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalActiveBorrowAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Overdue Borrow:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalOverdueBorrowAssets}
                      </Text>
                    </View>
                  </View>
                </View>

                <View style={{ flexDirection: "row", gap: 10 }}>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Borrowed Asset Value (Cost):
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalAssetValueCost}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total No. Of Documents:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalNoOfDocuments}
                      </Text>
                    </View>
                  </View>
                </View>
              </>
            ) : type === "Disposal" ? (
              <>
                <View style={{ flexDirection: "row", gap: 10 }}>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Disposed Assets:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalCounts.totalDisposedAssets}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Disposal Value:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalAssetValueCost}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total Disposed Reason:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text
                        style={[styles.summaryTextValue, { textAlign: "left" }]}
                      >
                        {`Obsolete: ${totalCounts?.totalObsoleteAssets ?? 0}`}
                      </Text>
                    </View>
                    <View style={styles.summaryField}>
                      <Text
                        style={[styles.summaryTextValue, { textAlign: "left" }]}
                      >
                        {`Damaged: ${totalCounts?.totalDamagedAssets ?? 0}`}
                      </Text>
                    </View>
                    <View style={styles.summaryField}>
                      <Text
                        style={[styles.summaryTextValue, { textAlign: "left" }]}
                      >
                        {`End of Useful Life: ${
                          totalCounts?.totalEndOfLifeAssets ?? 0
                        }`}
                      </Text>
                    </View>
                  </View>
                  <View>
                    <Text style={styles.summaryText}>
                      Total No. Of Documents:
                    </Text>
                    <View style={styles.summaryField}>
                      <Text style={styles.summaryTextValue}>
                        {totalNoOfDocuments}
                      </Text>
                    </View>
                  </View>
                </View>
              </>
            ) : (
              <>
                <Text style={styles.summaryText}>No Summary!</Text>
              </>
            )}
          </View>
        </View>

        {/* Footer */}
        <View fixed style={styles.footerContainer}>
          <View style={styles.footerLine} />
          <View
            style={{
              flexDirection: "row",
              justifyContent: "space-between",
              paddingTop: 5,
            }}
          >
            <Text style={styles.footerText}>
              Date Generated: {moment().format("DD-MM-YYYY")}
            </Text>
            <Text
              style={styles.footerText}
              render={({ pageNumber, totalPages }) =>
                `Page ${pageNumber} of ${totalPages}`
              }
            />
          </View>
        </View>
      </Page>
    </Document>
  );
};

export default AssetReport;
