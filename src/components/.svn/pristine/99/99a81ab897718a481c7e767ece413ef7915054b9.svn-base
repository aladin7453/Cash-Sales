import React, { useState } from "react";
import { FaTriangleExclamation } from "react-icons/fa6";
import type { Table } from "@tanstack/react-table";

import { buttonVariants } from "@/components/ui/button";
import { ToastAction } from "@/components/ui/toast";
import { useToast } from "@/components/ui/use-toast";
import { SVGDiscard } from "@/components/icons/svg-repo/SVGDiscard";
import CancelEInvoiceDialog from "@/components/ui/e-invoice/CancelEInvoiceDialog";

import { useSearchParams } from "next/navigation";

import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

import CancelCompletionDialog from "@/app/sales/sales-invoice/[slug]/CancelCompletation";

type Props<TData> = {
  table: Table<TData>;
  module: string;
  model: string;
  refreshTable: () => void;
  selectedRow?: any;
};

type CancelResponseItem = {
  ErrorMessage?: string[];
  SuccessMessage?: string[];
};

export default function CancelEInvoiceButton<TData>({
  table,
  module,
  model,
  refreshTable,
  selectedRow,
}: Props<TData>) {
  const { toast } = useToast();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const headers = getAuthHeaders();

  const [cancelDialogOpen, setCancelDialogOpen] = useState(false);
  const [cancelResponse, setCancelResponse] = useState<CancelResponseItem[]>([]);
  const [reasonDialogOpen, setReasonDialogOpen] = useState(false);

  const submitRows = async (reason: string) => {
    const form_data = new FormData();
    const selectedRows = table.getSelectedRowModel().rows;

    selectedRows.forEach((row) => {
      form_data.append("UUIDs[]", row.original["UUID"]);
      form_data.append("cancelReason[]", reason);
    });

    try {
      const response = await fetch(
        `${ORIGIN}/${module}/api/${model}/cancel-e-invoicing-2`,
        {
          method: "POST",
          headers,
          body: form_data,
        }
      );

      if (!response.ok) {
        throw new Error("Network response was not ok");
      }

      const data = await response.json();

      setCancelResponse(data);
      setCancelDialogOpen(true);
      refreshTable(); // optional: refresh after successful cancel
    } catch (error) {
      console.error(error);

      setCancelResponse([
        {
          ErrorMessage: ["An error occurred while cancelling the document. Please try again."],
        },
      ]);

      setCancelDialogOpen(true);
    }
  };

  const handleCancelConfirm = (reason: string) => {
    setReasonDialogOpen(false);
    submitRows(reason);
  };

  const selectedRows = table.getSelectedRowModel().rows;
  const isButtonDisabled = selectedRows.length === 0 || !selectedRows.every((row) => row.getValue("valid") === "0");
  const isDisabled = !selectedRow || selectedRow.original?.cancelRejectTimeLeft === "Expired" || selectedRow?.original?.eInvoiceStatus !== "Valid";

  return (
    <>
      <button
        className="group flex flex-col items-center gap-y-1 disabled:cursor-not-allowed"
        disabled={
          table.getSelectedRowModel().rows.length === 0 ||
          table.getSelectedRowModel().rows.every((row) => row.getValue("valid") === "0") ||
          isDisabled ||
          model !== "consolidated-invoice" && table.getSelectedRowModel().rows.some(
            (row) => row.getValue("invoiceType") == null
          ) ||
          model !== "consolidated-invoice" && table.getSelectedRowModel().rows.some(
            (row) => row.getValue("invoiceType") == "None"
          )
          || model !== "consolidated-invoice" && table.getSelectedRowModel().rows.some(
            (row) => row.getValue("invoiceType") == "Consolidate"
          )

        }
        title={
          selectedRow?.original?.eInvoiceStatus !== "Valid"
            ? "Only e-Invoices with 'Valid' status can be cancelled"
            : ""
        }
        onClick={() => setReasonDialogOpen(true)}
      >
        <SVGDiscard className="size-5.5 text-erp-blue-11 group-disabled:text-erp-gray-5" />
        <span className="text-[11px]/none font-medium group-disabled:text-erp-gray-5">
          Cancel E-Inv
        </span>
      </button>

      <CancelEInvoiceDialog
        open={reasonDialogOpen}
        onOpenChange={setReasonDialogOpen}
        onConfirm={handleCancelConfirm}
      />

      <CancelCompletionDialog
        open={cancelDialogOpen}
        setOpen={setCancelDialogOpen}
        response={cancelResponse}
      />
    </>
  );
}