import React from "react";
import { Document, Page, Text, View, StyleSheet, Image } from "@react-pdf/renderer";

const styles = StyleSheet.create({
  page: {
    flexDirection: 'column',
    backgroundColor: '#FFFFFF',
    padding: 30,
  },
  header: {
    fontSize: 12,
    marginBottom: 20,
    textAlign: 'center',
  },
  mainContainer: {
    fontSize: 12,
    flexDirection: 'row',
    justifyContent: 'space-between',
  },
  leftColumn: {
    width: '48%',
    paddingRight: 10,
  },
  rightColumn: {
    width: '48%',
    paddingLeft: 10,
    textAlign: 'right',
  },
  section: {
    fontSize: 11,
    marginBottom: 10,
  },
  sectionTitle: {
    fontSize: 12,
    fontWeight: 'bold',
  },
  table: {
    width: '100%',
    marginBottom: 10,
    borderStyle: 'solid',
    borderColor: '#000000',
    borderWidth: 1.5,
    borderCollapse: 'collapse',
  },
  taxTable: {
    width: '60%',
    marginBottom: 10,
    borderStyle: 'solid',
    borderColor: '#000000',
    borderWidth: 1.5,
    borderCollapse: 'collapse',
  },
  tableRow: {
    flexDirection: 'row',
    borderBottomWidth: 1,
    borderColor: '#000000',
  },
  tableCell: {
    padding: 5,
    fontSize: 10,
    textAlign: 'center',
    flexShrink: 1,
    borderRightWidth: 1,
    borderColor: '#000000',
  },
  tableCellLeftAlign: {
    textAlign: 'left',
  },
  tableCellRightAlign: {
    textAlign: 'right',
  },
  lastCell: {
    borderRightWidth: 0,
  },
  lastRow: {
    borderBottomWidth: 0,
  },
  tableHeader: {
    backgroundColor: '#eeeeee',
    fontWeight: 'bold',
  },
  qrCodeContainer: {
    position: 'absolute',
    bottom: 30,
    right: 30,
    borderWidth: 1,
    borderColor: '#000000',
    borderStyle: 'solid',
    overflow: 'hidden',
    padding: 0,
  },
  qrCodeImage: {
    width: 100,
    height: 100,
  },
});

const getInvoiceTypeDescription = (type) => {
  switch (type) {
    case '01':
      return 'Invoice';
    case '02':
      return 'Credit Note';
    case '03':
      return 'Debit Note';
    case '11':
      return 'Self-billed Invoice';
    case '12':
      return 'Self-billed Credit Note';
    case '13':
      return 'Self-billed Debit Note';
    default:
      return '';
  }
};

const EInvoice = ({ eInvoiceData, itemsData, QrCode, currentCompanyData }) => {
  if (!eInvoiceData) {
    return (
      <View style={styles.page}>
        <Text>Loading...</Text>
      </View>
    );
  }

  const pages = Array.isArray(eInvoiceData) ? eInvoiceData : [eInvoiceData];//Check for multiple data passed in for preview


  return (
    <Document>
      {pages.map((previewDoc, index) => {// map it in case there are multiple documents data passed in for preview

        const itemArray = Array.isArray(eInvoiceData) ? previewDoc.itemsData : itemsData ? itemsData : [];// get the item array for each document
        const invoiceTypeDescription = Array.isArray(eInvoiceData) ? getInvoiceTypeDescription(previewDoc.eInvoiceType) : getInvoiceTypeDescription(eInvoiceData.eInvoiceType);
        const Qr = Array.isArray(eInvoiceData) ? previewDoc.eInvoiceData?.qrCode : QrCode;// get the QrCode for each document
        const digitalSignature = Array.isArray(eInvoiceData) ? previewDoc.eInvoiceData?.digitalSignature : eInvoiceData?.digitalSignature;// get the digital signature for each document

        let totalSubtotal = 0;
        let totalSubtotalTax = 0;
        let totalTaxAmount = 0;
        let total = 0;

        return (
          <Page size="A4" style={styles.page} orientation="landscape" key={index}>
            <View style={styles.header}>
              <Text>
                {currentCompanyData.company || ""}
              </Text>
              <Text>
                {currentCompanyData.address || ""}
              </Text>
              <Text>{currentCompanyData.phoneNo || ""}</Text>
              <Text>{currentCompanyData.email || ""}</Text>
            </View>

            {/* Main Content */}
            <View style={styles.mainContainer}>
              {/* Supplier and Buyer Information */}
              <View style={styles.leftColumn}>
                <View style={styles.section}>
                  <Text>Supplier TIN: {previewDoc.supplierTIN || ""}</Text>
                  <Text>Supplier Name: {previewDoc.supplierName || ""}</Text>
                  <Text>Supplier Registration Number: {previewDoc.supplierBRN || ""}</Text>
                  <Text>Supplier SST ID: {previewDoc.supplierSSTNo || ""}</Text>
                  <Text>Supplier Business Address: {previewDoc.supplierAddress || ""}</Text>
                  <Text>Supplier Contact Number(Office): {previewDoc.supplierPhoneNo || ""}</Text>
                  <Text>Supplier Email: {previewDoc.supplierEmail || ""}</Text>
                  <Text>Supplier MSIC Code: {previewDoc.supplierMSICCodeCode || ""}</Text>
                  <Text>Supplier Business Activity Description: {previewDoc.supplierBusinessNature || ""}</Text>
                </View>
                <View style={styles.section}>
                  <Text>Buyer TIN: {previewDoc.buyerTIN || ""}</Text>
                  <Text>Buyer Business Registration Number: {previewDoc.buyerBRN || ""}</Text>
                  <Text>Buyer SST ID: {previewDoc.buyerSSTNo || ""}</Text>
                </View>
              </View>

              {/* Invoice Details */}
              <View style={styles.rightColumn}>
                <View style={styles.section}>
                  <Text style={{ ...styles.sectionTitle, fontWeight: 'bold' }}>E-INVOICE</Text>
                  <Text>e-Invoice Type: {previewDoc.eInvoiceType || ""} - {invoiceTypeDescription}</Text>
                  <Text>e-Invoice Version: {previewDoc.eInvoiceVersion || ""}</Text>
                  <Text>e-Invoice Code: {previewDoc.docNo || ""}</Text>
                  <Text>Unique Identifier: {previewDoc.IRBUUID || ""}</Text>
                  <Text>Original Invoice Ref. No.: {previewDoc.oriRefNo || ""}</Text>
                  <Text>Invoice Date: {previewDoc.docDateFormat || ""}</Text>
                </View>
              </View>
            </View>

            {/* Product/Service Details */}
            <View style={styles.table}>
              <View style={[styles.tableRow, styles.tableHeader]}>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Classification</Text>
                </View>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text>Description</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>Qty</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Unit Price</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Amount</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>Disc</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Tax Amount</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellLeftAlign }, styles.lastCell]}>
                  <Text>Total Product/Service Price (incl. tax)</Text>
                </View>
              </View>

              {itemArray.map((item, index) => {
                const price = Number(item.price) || 0;
                const quantity = Number(item.quantity) || 0;
                const taxAmount = Number(item.taxAmount) || 0;
                const discountAmount = Number(item.discountAmount) || 0;
                const subtotal = Number(item.amount) || 0;
                const amountInclTax = subtotal + taxAmount;

                totalSubtotal += subtotal;
                totalTaxAmount += taxAmount;
                totalSubtotalTax = Number(previewDoc.totalAmount) + Number(previewDoc.totalTax);

                return (
                  <View style={[styles.tableRow]} key={index}>
                    <View style={[styles.tableCell, { flex: 2 }]}>
                      <Text>{item.classificationCode || ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 3 }]}>
                      <Text>{item.description || ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 1 }]}>
                      <Text>{quantity || ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                      <Text>RM{price.toFixed(2)}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                      <Text>RM{subtotal.toFixed(2)}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 1 }]}>
                      <Text>{discountAmount ? discountAmount.toFixed(2) : ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                      <Text>RM{taxAmount.toFixed(2)}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }, styles.lastCell]}>
                      <Text>RM{amountInclTax.toFixed(2)}</Text>
                    </View>
                  </View>
                );
              })}

              {/* Subtotal details */}
              <View style={[styles.tableRow]}>
                <View style={[styles.tableCell, { flex: 2, borderRightWidth: 0 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellLeftAlign, borderRightWidth: 0 }]}>
                  <Text>Subtotal:</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text>RM{previewDoc.totalAmount}</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>-</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text>RM{previewDoc.totalTax}</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }, styles.lastCell]}>
                  <Text>RM{totalSubtotalTax.toFixed(2)}</Text>
                </View>
              </View>
              <View style={[styles.tableRow]}>
                <View style={[styles.tableCell, { flex: 2, borderRightWidth: 0 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellLeftAlign, borderRightWidth: 0 }]}>
                  <Text>Total excluding tax:</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>-</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }, styles.lastCell]}>
                  <Text>RM{totalSubtotal.toFixed(2)}</Text>
                </View>
              </View>
              <View style={[styles.tableRow]}>
                <View style={[styles.tableCell, { flex: 2, borderRightWidth: 0 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellLeftAlign, borderRightWidth: 0 }]}>
                  <Text>Tax amount(SST):</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>-</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }, styles.lastCell]}>
                  <Text>RM{previewDoc.totalTax}</Text>
                </View>
              </View>
              <View style={[styles.tableRow]}>
                <View style={[styles.tableCell, { flex: 2, borderRightWidth: 0 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellLeftAlign, borderRightWidth: 0 }]}>
                  <Text>Total including tax:</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>-</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }, styles.lastCell]}>
                  <Text>RM{totalSubtotalTax.toFixed(2)}</Text>
                </View>
              </View>
              <View style={[styles.tableRow, styles.lastRow]}>
                <View style={[styles.tableCell, { flex: 2, borderRightWidth: 0 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellLeftAlign, borderRightWidth: 0 }]}>
                  <Text>Total payable amt:</Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 1 }]}>
                  <Text>-</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }]}>
                  <Text></Text>
                </View>
                <View style={[styles.tableCell, { flex: 2, ...styles.tableCellRightAlign }, styles.lastCell]}>
                  <Text>RM{previewDoc.totalPayable}</Text>
                </View>
              </View>
            </View>

            {/* Tax Details */}
            <View style={styles.taxTable} wrap={false}>
              <View style={[styles.tableRow, styles.tableHeader]}>
                <View style={[styles.tableCell, { flex: 3 }]}>
                  <Text>Total Product/Service</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Tax Code</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Tax Type</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }]}>
                  <Text>Tax Rate</Text>
                </View>
                <View style={[styles.tableCell, { flex: 2 }, styles.lastCell]}>
                  <Text>Tax Amount</Text>
                </View>
              </View>

              {itemArray.map((item, index) => {
                const subtotal = Number(item.quantity) || 0;

                return (
                  <View style={[styles.tableRow, styles.lastRow]} key={index}>
                    <View style={[styles.tableCell, { flex: 3 }]}>
                      <Text>RM{subtotal.toFixed(2)}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2 }]}>
                      <Text>{item.taxCode || ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2 }]}>
                      <Text>{item.taxTypeCode || ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2 }]}>
                      <Text>{item.taxRate || ""}</Text>
                    </View>
                    <View style={[styles.tableCell, { flex: 2 }, styles.lastCell]}>
                      <Text>RM{(Number(item.taxAmount) || 0).toFixed(2)}</Text>
                    </View>
                  </View>
                );
              })}
            </View>

            {/* Digital Signature and Validation */}
            <View style={[styles.section, { flexDirection: "row", alignItems: "center" }]} wrap={false}>
              {/* Digital Signature Section */}
              <View style={{ flex: 1, marginRight: 10 }}>
                <Text>Digital Signature:</Text>
                <Text>{digitalSignature || ""}</Text>
                <View style={{ marginTop: 5 }}>
                  <Text>Date and Time of Validation: {previewDoc.validatedAt || ""}</Text>
                </View>
              </View>

              {/* QR Code Section */}
              <View wrap={false}>
                {Qr && (
                  <Image
                    src={Qr}
                    style={styles.qrCodeImage}
                    alt="QR Code"
                  />
                )}
              </View>
            </View>
          </Page>
        )
      })}


    </Document>
  );
};

export default EInvoice;