"use client";

import React, { useEffect, useMemo, useRef, useState } from "react";
import { FaCaretRight } from "react-icons/fa6";

import "@radix-ui/react-tooltip";

import clsx from "clsx";
import { ChevronRight } from "lucide-react";
import Image from "next/image";
import Link from "next/link";
import { usePathname } from "next/navigation";
import useSWR from "swr";
import useSWRImmutable from "swr/immutable";

import { checkAccessToken, getAuthHeaders, ORIGIN, TOOLTIP_DELAY_DURATION } from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

import erpLogoWithWordings from "../../public/erpLogo_withWordings.svg";
import erpLogo from "../../public/erpLogo.svg";
import { useMyContext } from "../app/organization/contextProvider";
import { menus } from "../data/menus";
import SearchBar from "./SearchBar";
import { Accordion, AccordionContent, AccordionItem, AccordionTrigger } from "./ui/accordion";
import { Button, buttonVariants } from "./ui/button";
import { HoverCard, HoverCardContent, HoverCardTrigger } from "./ui/hover-card";
import { ScrollArea, ScrollBar } from "./ui/scroll-area";
import { Separator } from "./ui/separator";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "./ui/tooltip";

import type { Dispatch, SetStateAction } from "react";

import type { MenuItem, SubmenuItem } from "@/lib/types";

type ModulePermissions = Record<string, string[]>;

// Data Fetcher
const fetcher = async (url: string) => {
  const username = JSON.parse(localStorage.getItem("username") ?? '""');
  const authToken = JSON.parse(localStorage.getItem("authToken") ?? '""');

  // const isValid = await checkAccessToken(username, authToken);

  // if (!isValid) {
  //   console.error("Session expired. Redirecting to login.");

  //   throw new Error("Session expired");
  // }
  const headers = getAuthHeaders();

  try {
    const res = await fetch(url, {
      method: "POST",
      headers,
    });

    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    if (res.status === 401) {
      throw new Error("A 401 error occurred while fetching the data.");
    }

    const data = await res.json();
    const jsonData = JSON.stringify(data);

    localStorage.setItem("userAccess", jsonData);

    return data;
  } catch (error) {
    console.error("Error fetching data:", error);
    throw error;
  }
};

// Menu Filter Based on User Rules
const filterMenus = (menus: MenuItem[], apiResponse: Record<string, string[]>): MenuItem[] => {
  const allowedRuleIds = Object.values(apiResponse).flat();
  allowedRuleIds.push("view-stock-physical-worksheet");
  allowedRuleIds.push("view-activity-type", "view-activity-log");

  const filterMenuItems = (items: SubmenuItem[]): SubmenuItem[] => {
    return items
      .map((item) => {
        if (item.subMenu) {
          item.subMenu = filterMenuItems(item.subMenu);
        }

        const includeItem =
          (item.ruleId && allowedRuleIds.includes(item.ruleId)) ||
          (item.subMenu && item.subMenu.length > 0);

        return includeItem ? item : null;
      })

      .filter((item) => item !== null) as SubmenuItem[];
  };

  return menus
    .map((menu) => {
      if (menu.subMenu) {
        menu.subMenu = filterMenuItems(menu.subMenu);
      }

      const includeMenu =
        (menu.ruleId && allowedRuleIds.includes(menu.ruleId)) ||
        (menu.subMenu && menu.subMenu.length > 0);

      return includeMenu ? menu : null;
    })

    .filter((menu) => menu !== null) as MenuItem[];
};

export default function Sidebar({
  showSidebar,
  onClose,
  isDashboard,
  setIsDashboard,
}: {
  showSidebar?: boolean;
  onClose?: () => void;
  isDashboard: boolean;
  setIsDashboard: Dispatch<SetStateAction<boolean>>;
}) {
  const [filteredMenus, setFilteredMenus] = useState<MenuItem[]>([]);
  const [isExpanded, setIsExpanded] = useState(false);
  const [pinnedMenu, setPinnedMenu] = useState<string | null>(null);
  const shareDataValue = useMyContext();
  const sidebarRef = useRef<HTMLDivElement>(null);

  const isResponsiveMode = showSidebar !== undefined && onClose !== undefined;

  let userID = "";
  if (typeof window !== "undefined") {
    userID = JSON.parse(localStorage.getItem("userID") ?? '""');
  }

  let apiUrl = `${ORIGIN}/user/api/user/get-user-access`;
  if (userID !== "") {
    apiUrl += `?id=${userID}`;
  }

  const [localUserAccess, setLocalUserAccess] = useState<ModulePermissions | null>(null);
  const [shouldFetch, setShouldFetch] = useState(false);

  useEffect(() => {
    if (typeof window !== "undefined") {
      const stored = localStorage.getItem("userAccess");
      const parsed = stored ? JSON.parse(stored) : null;
      setLocalUserAccess(parsed);
      setShouldFetch(!parsed || Object.keys(parsed).length === 0);
    }
  }, []);

  const { data, error, isLoading } = useSWR<ModulePermissions, Error>(
    shouldFetch ? apiUrl : null,
    fetcher,
  );

  const finalData = data || localUserAccess;

  const permisableModules = useMemo(() => finalData || {}, [finalData]);

  const deepClone = (obj) => {
    return Array.isArray(obj)
      ? obj.map(deepClone)
      : obj && typeof obj === "object"
        ? Object.keys(obj).reduce((acc, key) => {
          acc[key] = deepClone(obj[key]);
          return acc;
        }, {})
        : obj;
  };

  // useEffect(() => {
  //   if (data) {

  //     if (data.dashboard) {
  //       setIsDashboard(true);
  //     } else {
  //       setIsDashboard(false);
  //     }
  //     console.log(data)
  //     const result = filterMenus(deepClone(menus), permisableModules);
  //     setFilteredMenus(result);
  //   }
  // }, [data]);

  useEffect(() => {
    if (localUserAccess) {
      const result = filterMenus(deepClone(menus), localUserAccess);
      setFilteredMenus(result);
    }
  }, []); // run only once on mount

  useEffect(() => {
    if (!finalData) return;

    if (finalData.dashboard) {
      setIsDashboard(true);
    } else {
      setIsDashboard(false);
    }
    const result = filterMenus(deepClone(menus), finalData);
    setFilteredMenus(result);
  }, [finalData]);

  // useEffect(() => {
  //   if (data2) {
  //     if (data2.dashboard) {
  //       setIsDashboard(true);
  //     } else {
  //       setIsDashboard(false);
  //     }

  //     const result = filterMenus(deepClone(menus), permisableModules2);
  //     setFilteredMenus(result);
  //   }
  // }, [data2]);

  useEffect(() => {
    if (!isResponsiveMode) return;

    const handleClickOutside = (event: MouseEvent) => {
      if (sidebarRef.current && !sidebarRef.current.contains(event.target as Node)) {
        onClose?.();
      }
    };

    if (showSidebar) {
      document.addEventListener("mousedown", handleClickOutside);
    }

    return () => {
      document.removeEventListener("mousedown", handleClickOutside);
    };
  }, [showSidebar, onClose, isResponsiveMode]);

  useEffect(() => {
    if (isResponsiveMode && showSidebar) {
      setIsExpanded(true);
    }
  }, [showSidebar, isResponsiveMode]);

  const SystemLogo = (
    <Link href="/dashboard" className="flex h-14 items-center justify-center px-1 py-2">
      <Image
        src={isExpanded ? erpLogoWithWordings : erpLogo}
        alt="ERP Logo"
        className="w-full max-w-[7rem]"
      />
    </Link>
  );

  return (
    <aside
      ref={sidebarRef}
      className={clsx(
        "flex h-full",
        isResponsiveMode
          ? [
            "fixed inset-y-0 left-0 z-40 transition-transform",
            showSidebar ? "translate-x-0" : "-translate-x-full",
            "md:relative md:translate-x-0",
          ]
          : "relative",
      )}
      aria-label="Sidebar"
    >
      <div
        className={clsx(
          "to-grey-300 grid grid-rows-[auto_1fr] divide-y-2 divide-white overflow-y-auto bg-gradient-to-b from-erp-blue-10 via-erp-blue-8 duration-150",
          isExpanded ? "w-[17rem] overflow-x-hidden" : "w-[5rem] overflow-x-hidden",
        )}
      >
        {isExpanded ? (
          SystemLogo
        ) : (
          <TooltipProvider>
            <Tooltip>
              <TooltipTrigger asChild>{SystemLogo}</TooltipTrigger>
              <TooltipContent>Enterprise Resource Planning</TooltipContent>
            </Tooltip>
          </TooltipProvider>
        )}

        <div className="flex flex-col gap-y-2 p-1.5 py-2">
          {isExpanded && (
            <>
              <div className="px-1.5 py-0.5">
                <SearchBar />
              </div>
              <Separator className="h-0.5 bg-erp-blue-9" decorative />
            </>
          )}

          <ScrollArea className="-mx-2 max-h-[80vh] overflow-auto">
            {!isLoading && !error && filteredMenus.length > 0 && (
              <div className={clsx(!isExpanded && "flex flex-col items-center gap-y-1")}>
                {isExpanded ? (
                  <Accordion className="space-y-1" type="multiple">
                    {filteredMenus.map((menu) => (
                      <AccordionMenu menu={menu} key={menu.title} />
                    ))}
                  </Accordion>
                ) : (
                  filteredMenus.map((menu) => (
                    <HoverCardMenu
                      menu={menu}
                      key={menu.title}
                      isPinned={pinnedMenu === menu.title}
                      onPin={(menuTitle) =>
                        setPinnedMenu(pinnedMenu === menuTitle ? null : menuTitle)
                      }
                    />
                  ))
                )}
              </div>
            )}
            <ScrollBar orientation="vertical" />
          </ScrollArea>
        </div>
      </div>

      <button
        onClick={() => setIsExpanded(!isExpanded)}
        className="flex h-full items-center justify-center bg-erp-blue-3 text-erp-blue-14"
      >
        <span
          className={clsx("-mx-px transition-transform duration-300", isExpanded && "rotate-180")}
        >
          <FaCaretRight />
        </span>
      </button>
    </aside>
  );
}

function AccordionMenu({ menu }: { menu: MenuItem }) {
  const pathname = usePathname();

  let isActivePath = false;
  if (pathname.includes("setting/job-title")) {
    if (menu.title == "Setting") {
      isActivePath = true;
    }
  } else if (pathname.includes("cargo-shipping")) {
    if (menu.title == "Shipping") {
      isActivePath = true;
    }
  } else if (pathname.includes("system-account")) {
    if (menu.title == "System Account") {
      isActivePath = true;
    }
  } else if (pathname.includes("customer")) {
    if (menu.title == "Customer") {
      isActivePath = true;
    }
  } else if (pathname.includes("sales-purchase-contra")) {
    if (menu.title == "Sales") {
      isActivePath = true;
    }
  } else {
    const basePath =
      menu.title === "My Organization"
        ? "/organization"
        : `/${menu.title.toLowerCase().replace(/\s+/g, "-")}`;

    isActivePath = pathname.startsWith(basePath);
  }

  // Check if Package Type exists in the menu
  const hasPackageType = menu.subMenu?.some((item) => item.title === "Package Type");

  return (
    <AccordionItem
      className={clsx(
        isActivePath
          ? "bg-primary text-primary-foreground"
          : "text-transparent data-[state=open]:bg-erp-blue-3 data-[state=open]:text-primary",
        "overflow-hidden text-nowrap rounded-sm border-b-0",
      )}
      value={menu.title}
    >
      <AccordionTrigger
        className={cn(
          buttonVariants({ size: "sm", variant: "ghost" }),
          "h-12 justify-between hover:no-underline",
          isActivePath
            ? "bg-primary text-primary-foreground hover:bg-transparent hover:text-current"
            : "text-primary hover:text-primary data-[state=open]:bg-erp-blue-3 data-[state=open]:text-primary",
        )}
      >
        <div className={clsx("flex items-center justify-start gap-x-4 font-bold")}>
          {menu.icon && <menu.icon className="size-8" aria-hidden="true" />}
          {menu.title}
        </div>
      </AccordionTrigger>
      <AccordionContent className="px-1 pb-0">
        <Separator
          className={cn("h-0.5", isActivePath ? "bg-erp-blue-9" : "bg-erp-blue-8")}
          decorative
        />
        <div className="mx-1.5 my-2 flex flex-col gap-y-0.5">
          {menu.subMenu?.map((item, index) =>
            item.href ? (
              <React.Fragment key={index}>
                {(item.title === "Stock Item" ||
                  item.title === "Customer" ||
                  item.title === "Job Order Category" ||
                  item.title === "Supplier" ||
                  item.title === "Asset" ||
                  item.title === "Package Type" ||
                  (!hasPackageType &&
                    (item.title === "Stock Category" || item.title === "Service Category"))) && (
                    <Separator
                      className={cn("h-0.5", isActivePath ? "bg-erp-blue-10" : "bg-erp-blue-7")}
                      decorative
                    />
                  )}
                <Link
                  href={item.href}
                  className={cn(
                    buttonVariants({ size: "sm", variant: "ghost" }),
                    (pathname === item.href || pathname.startsWith(item.href + "/")) &&
                    "bg-secondary text-secondary-foreground",
                    "w-full justify-start font-semibold hover:text-primary",
                  )}
                  key={index}
                >
                  {item.title}
                </Link>
                {(item.title === "Customer" ||
                  item.title === "Supplier" ||
                  item.title === "Asset") && (
                    <Separator
                      className={cn("h-0.5", isActivePath ? "bg-erp-blue-10" : "bg-erp-blue-7")}
                      decorative
                    />
                  )}
              </React.Fragment>
            ) : (
              item.subMenu?.length && (
                <Accordion type="single" collapsible key={index}>
                  <AccordionItem className="border-b-0" value={item.title}>
                    <AccordionTrigger
                      className={cn(
                        buttonVariants({ size: "sm", variant: "ghost" }),
                        "justify-between font-semibold hover:text-primary hover:no-underline data-[state=open]:bg-secondary data-[state=open]:text-primary",
                      )}
                    >
                      {item.title}
                    </AccordionTrigger>
                    <AccordionContent>
                      <div className="my-1 ml-6 flex flex-col gap-y-0.5">
                        {item.subMenu.map(
                          (subItem, index) =>
                            subItem.href && (
                              <Link
                                href={subItem.href}
                                className={cn(
                                  buttonVariants({
                                    size: "sm",
                                    variant: "ghost",
                                  }),
                                  (pathname === subItem.href ||
                                    pathname.startsWith(subItem.href + "/")) &&
                                  "bg-secondary text-secondary-foreground",
                                  "h-auto w-full justify-start py-1.5 font-[550] hover:text-primary",
                                )}
                                key={index}
                              >
                                {subItem.title}
                              </Link>
                            ),
                        )}
                      </div>
                    </AccordionContent>
                  </AccordionItem>
                </Accordion>
              )
            ),
          )}
        </div>
      </AccordionContent>
    </AccordionItem>
  );
}

function HoverCardMenu({
  menu,
  isPinned,
  onPin,
}: {
  menu: MenuItem;
  isPinned: boolean;
  onPin: (menuTitle: string) => void;
}) {
  const pathname = usePathname();
  const [pinnedSubMenu, setPinnedSubMenu] = useState<string | null>(null);

  let isActivePath = false;
  if (pathname.includes("setting/job-title")) {
    if (menu.title == "Setting") {
      isActivePath = true;
    }
  } else if (pathname.includes("cargo-shipping")) {
    if (menu.title == "Shipping") {
      isActivePath = true;
    }
  } else if (pathname.includes("system-account")) {
    if (menu.title == "System Account") {
      isActivePath = true;
    }
  } else if (pathname.includes("customer")) {
    if (menu.title == "Customer") {
      isActivePath = true;
    }
  } else if (pathname.includes("sales-purchase-contra")) {
    // Only activate Sales module for sales-purchase-contra route
    if (menu.title == "Sales") {
      isActivePath = true;
    }
  } else {
    const basePath =
      menu.title === "My Organization"
        ? "/organization"
        : `/${menu.title.toLowerCase().replace(/\s+/g, "-")}`;

    isActivePath = pathname.startsWith(basePath);
  }

  // Check if Package Type exists in the menu
  const hasPackageType = menu.subMenu?.some((item) => item.title === "Package Type");

  return (
    <HoverCard openDelay={TOOLTIP_DELAY_DURATION} open={isPinned ? true : undefined}>
      <HoverCardTrigger asChild>
        <div className="flex w-12 flex-col items-center">
          <Button
            variant="ghost"
            size="icon"
            className={clsx(
              "h-[2.75rem] w-full hover:bg-primary hover:text-primary-foreground",
              isActivePath
                ? "bg-primary text-primary-foreground"
                : "text-primary data-[state=open]:bg-primary data-[state=open]:text-primary-foreground",
              isPinned && "ring-2 ring-primary ring-offset-1",
            )}
            onClick={() => onPin(menu.title)}
          >
            <menu.icon className="size-8" />
          </Button>
          <span
            className="w-full truncate text-center text-[9px] text-primary opacity-100"
            title={menu.shortName}
          >
            {menu.shortName}
          </span>
        </div>
      </HoverCardTrigger>

      <HoverCardContent
        side="right"
        align="start"
        className="w-auto min-w-[12.5rem] bg-secondary px-2 py-3 text-secondary-foreground"
        onInteractOutside={(e) => {
          if (!isPinned) return;
          onPin(menu.title);
        }}
      >
        <ScrollArea className="max-h-[80vh] overflow-auto px-2 py-3">
          <div className="flex flex-col gap-y-0.5">
            <h4 className="mb-1 px-2 font-bold">{menu.title}</h4>
            {menu.subMenu?.map((item, index) =>
              item.href ? (
                <React.Fragment key={index}>
                  {(item.title === "Stock Item" ||
                    item.title === "Customer" ||
                    item.title === "Job Order Category" ||
                    item.title === "Supplier" ||
                    item.title === "Asset" ||
                    item.title === "Package Type" ||
                    (!hasPackageType &&
                      (item.title === "Stock Category" || item.title === "Service Category"))) && (
                      <Separator className="h-0.5 bg-erp-blue-10" decorative />
                    )}
                  <Link
                    href={item.href}
                    className={cn(
                      buttonVariants({ size: "sm", variant: "ghost" }),
                      (pathname === item.href || pathname.startsWith(item.href + "/")) &&
                      "bg-secondary text-secondary-foreground",
                      "justify-start",
                    )}
                    key={index}
                  >
                    {item.title}
                  </Link>
                  {(item.title === "Customer" ||
                    item.title === "Supplier" ||
                    item.title === "Asset") && (
                      <Separator className="h-0.5 bg-erp-blue-10" decorative />
                    )}
                </React.Fragment>
              ) : (
                item.subMenu?.length && (
                  <HoverCard
                    openDelay={TOOLTIP_DELAY_DURATION}
                    key={index}
                    open={pinnedSubMenu === item.title ? true : undefined}
                  >
                    <HoverCardTrigger
                      className={cn(
                        buttonVariants({ size: "sm", variant: "ghost" }),
                        item.href === pathname && "relative bg-secondary text-secondary-foreground",
                        "cursor-pointer justify-between data-[state=open]:bg-secondary data-[state=open]:text-secondary-foreground",
                        pinnedSubMenu === item.title && "ring-1 ring-primary",
                      )}
                      onClick={() =>
                        setPinnedSubMenu(pinnedSubMenu === item.title ? null : item.title)
                      }
                    >
                      {item.title}
                      <ChevronRight className="size-4" />
                    </HoverCardTrigger>
                    <HoverCardContent
                      side="right"
                      sideOffset={8}
                      align="start"
                      alignOffset={-2}
                      className="w-auto min-w-[12.5rem] bg-secondary px-2 py-3 text-secondary-foreground"
                      onInteractOutside={(e) => {
                        if (pinnedSubMenu !== item.title) return;
                        setPinnedSubMenu(null);
                      }}
                    >
                      <ScrollArea className="max-h-[80vh] overflow-auto px-2 py-3">
                        <div className="flex flex-col gap-y-0.5">
                          {item.subMenu.map(
                            (subItem, index) =>
                              subItem.href && (
                                <Link
                                  href={subItem.href}
                                  className={cn(
                                    buttonVariants({
                                      size: "sm",
                                      variant: "ghost",
                                    }),
                                    (pathname === subItem.href ||
                                      pathname.startsWith(subItem.href + "/")) &&
                                    "bg-secondary text-secondary-foreground",
                                    "justify-start",
                                  )}
                                  key={index}
                                >
                                  {subItem.title}
                                </Link>
                              ),
                          )}
                        </div>
                        <ScrollBar orientation="vertical" />
                      </ScrollArea>
                    </HoverCardContent>
                  </HoverCard>
                )
              ),
            )}
          </div>
          <ScrollBar orientation="vertical" />
        </ScrollArea>
      </HoverCardContent>
    </HoverCard>
  );
}
