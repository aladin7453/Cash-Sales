"use client";
import React, { useState, useEffect } from 'react';
import { FaMinus, FaPlus } from 'react-icons/fa6';
import ConfirmationDialog from './ConfirmationDialog';
import { notFound, useSearchParams } from "next/navigation";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import { Button } from "@/components/ui/button";
import { 
  Tooltip, 
  TooltipTrigger, 
  TooltipContent, 
  TooltipProvider 
} from "@/components/ui/tooltip";
import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  onAdd?: () => void;
  showAddButton?: boolean; // New prop to control Add button visibility
};

export default function DropdownTableToolbar<TData>({ table, onAdd, showAddButton = false }: Props<TData>) {
  return (
    <div className="flex items-center justify-between p-1.5">
      {showAddButton && (
        <div className="flex flex-col items-center">
          <Button
            type="button"
            className="size-8"
            variant="ghost"
            size="icon"
            onClick={onAdd}
          >
            <FaPlus className="size-5.5" />
          </Button>
          <span className="text-[11px]/none font-medium text-black">Add</span>
        </div>
      )}
      <div className="flex-1 flex justify-center">
          <Pagination table={table} />
      </div>
      <div className="grid items-center text-erp-blue-14 pr-1">
        <Refresh />
      </div>
    </div>
  );
}