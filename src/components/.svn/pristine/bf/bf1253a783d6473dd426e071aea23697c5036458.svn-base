    borderStyle: "solid",
    borderColor: "#000000",
    // borderBottomWidth: 1,
  },
  tableRow: {
    flexDirection: "row",
    borderColor: "#000000",
    borderBottomWidth: 1,
  },
  tableHeader: {
    backgroundColor: "#deebf7",
