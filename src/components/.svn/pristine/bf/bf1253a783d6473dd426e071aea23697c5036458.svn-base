const PurchaseReport = ({
  type,
  data,
  purchaseReportData,
  generatedReport,
  purchaseReportColumns,
  orientation = 'portrait',
  adtReportName,
  checkboxIsPurchase,
  checkboxIsPayment,
}: {
  type: string;
  data?: any;
  purchaseReportData?: any;
  generatedReport?: any;
  purchaseReportColumns?: any[];
  orientation?: 'portrait' | 'landscape';
  adtReportName: string;
  checkboxIsPurchase: boolean;
  checkboxIsPayment: boolean;
}) => {
  let image64 = data?.currentCompany?.logoLink[0]?.base64;

  // Format the date range
  const formatDateRange = () => {
    if (!purchaseReportData?.startDate || !purchaseReportData?.endDate)
      return "";

    const startDate = moment
      .unix(Number(purchaseReportData.startDate))
      .format("YYYY-MM-DD");
    const endDate = moment
      .unix(Number(purchaseReportData.endDate))
      .format("YYYY-MM-DD");

    return `${startDate} to ${endDate}`;
  };

  let finalRows = data?.rows || generatedReport || [];

  const isLevel2 = type === "Purchase Multi - Debit Note Listing - Level 2" || type === "Purchase Multi - Goods Received Listing - Level 2" ||
    type === "Purchase Multi - Purchase Order Listing - Level 2" || type === "Purchase Multi - Purchase Invoice Listing - Level 2" || type === "Purchase Outstanding Cash Purchase Listing - Level 2 (with SO Info)";
  //type === "Supplier Analysis By Document - Level 2" ||
  if (isLevel2 && finalRows.length > 0) {
    const transformedRows: any[] = [];

    const groups: Record<string, any> = {};

    finalRows.forEach((item: any) => {
      const key = item.supplierName || "Unknown";

      // const key = item.docNo || "Unknown";

      if (!groups[key]) {
        groups[key] = {
          supplierName: item.supplierName,
          supplierCode: item.supplierCode,
          docNo: item.docNo,
          docDateFormat: item.docDateFormat,

          items: [],
          totals: {
            bf: 0,
            invoice: 0,
            debitNote: 0,
            creditNote: 0,
            payment: 0,
            contra: 0,
            cf: 0,
            totalAmount: 0,
            totalDiscount: 0,
            amountAfterDiscount: 0,
            totalTax: 0,
            totalSubtotalTax: 0,
          }
        };
      }

      const bf = parseFloat(item.localBalanceBringForward || 0);
      const invoice = parseFloat(item.invoiceLocalNetTotal || 0);
      const debitNote = parseFloat(item.debitNoteLocalNetTotal || 0);
      const creditNote = parseFloat(item.creditNoteLocalNetTotal || 0);
      const payment = parseFloat(item.localSupplierPayment || 0);
      const contra = parseFloat(item.contraAmountNetTotal || 0);
      const cf = parseFloat(item.localCurrentAmount || 0);
      const totalAmount = parseFloat(item.totalAmount || 0);
      const totalDiscount = parseFloat(item.totalDiscount || 0);
      const amountAfterDiscount = parseFloat(item.amountAfterDiscount || 0);
      const totalTax = parseFloat(item.totalTax || 0);
      const totalSubtotalTax = parseFloat(item.totalSubtotalTax || 0);


      groups[key].items.push(item);
      groups[key].totals.bf += bf;
      groups[key].totals.invoice += invoice;
      groups[key].totals.debitNote += debitNote;
      groups[key].totals.creditNote += creditNote;
      groups[key].totals.payment += payment;
      groups[key].totals.contra += contra;
      groups[key].totals.cf += cf;
      groups[key].totals.totalAmount += totalAmount;
      groups[key].totals.totalDiscount += totalDiscount;
      groups[key].totals.amountAfterDiscount += amountAfterDiscount;
      groups[key].totals.totalTax += totalTax;
      groups[key].totals.totalSubtotalTax += totalSubtotalTax;
    });

    let globalIndex = 1;
    Object.values(groups).forEach((group: any) => {

      transformedRows.push({
        _rowType: 'header',
        _index: globalIndex++,
        supplierCode: group.supplierCode,
        supplierName: group.supplierName,
        docNo: group.docNo,
        docDateFormat: group.docDateFormat
      });

      group.items.forEach((item: any) => {
        transformedRows.push({
          _rowType: 'item',
          ...item
        });
      });

      transformedRows.push({
        _rowType: 'subtotal',
        supplierName: group.supplierName, // Use supplierName for subtotal label
        supplierCode: group.supplierCode,
        docNo: group.docNo,
        docDateFormat: group.docDateFormat,

        subtotalBF: group.totals.bf,
        subtotalInvoice: group.totals.invoice,
        subtotalDebitNote: group.totals.debitNote,
        subtotalCreditNote: group.totals.creditNote,
        subtotalPayment: group.totals.payment,
        subtotalContra: group.totals.contra,
        subtotalCF: group.totals.cf,
        subtotalTotalAmount: group.totals.totalAmount,
        subtotalTotalDiscount: group.totals.totalDiscount,
        subtotalAmountAfterDiscount: group.totals.amountAfterDiscount,
        subtotalTotalTax: group.totals.totalTax,
        subtotalTotalSubtotalTax: group.totals.totalSubtotalTax,
      });
    });

    finalRows = transformedRows;
  }
  const rows = finalRows;
  // const rows = data?.rows || generatedReport || [];

  // Dynamic styles based on orientation
  const getPageStyles = () => ({
    ...styles.page,
    padding: orientation === 'landscape' ? 20 : 30,
  });

  const getTableCellStyles = () => ({
    ...styles.tableCell,
    fontSize: orientation === 'landscape' ? 6 : 7,
    padding: orientation === 'landscape' ? 3 : 5,
  });

  const getTableCellNoStyles = () => ({
    ...styles.tableCellNo,
    fontSize: orientation === 'landscape' ? 6 : 7,
    padding: orientation === 'landscape' ? 3 : 5,
  });

  const getHeaderStyles = () => ({
    ...styles.header,
    fontSize: orientation === 'landscape' ? 8 : 9,
    marginLeft: orientation === 'landscape' ? 120 : 150,
  });

  const getLogoStyles = () => ({
    ...styles.logoContainer,
    width: orientation === 'landscape' ? 80 : 100,
    height: orientation === 'landscape' ? 80 : 100,
  });

  const getLogoImageStyles = () => ({
    ...styles.logoImage,
    width: orientation === 'landscape' ? 80 : 100,
    height: orientation === 'landscape' ? 80 : 100,
  });

  const getSummaryStyles = () => ({
    ...styles.summaryBox,
    padding: orientation === 'landscape' ? 3 : 5,
  });

  const getTableCellSOStyles = () => ({
    ...styles.tableCellSO,
    fontSize: orientation === 'landscape' ? 6 : 7,
    padding: orientation === 'landscape' ? 3 : 5,
  });

  const getTableCellSOItemCodeStyles = () => ({
    ...styles.tableCellSOItemCode,
    fontSize: orientation === 'landscape' ? 6 : 7,
    padding: orientation === 'landscape' ? 3 : 5,
  });

  // Common header content with dynamic styles
  const renderHeader = () => (
    <>
      <View style={getLogoStyles()}>
        {image64 ? (
          <Image
            src={{
              uri: image64,
              method: "GET",
              headers: { "Cache-Control": "no-cache" },
              body: "",
            }}
            style={getLogoImageStyles()}
          />
        ) : null}
      </View>

      <View style={getHeaderStyles()}>
        <Text>
          {data?.currentCompany?.company ?? ""}
          {data?.currentCompany?.BRN ? ` (${data.currentCompany.BRN})` : ""}
        </Text>
        <Text style={styles.headerText}>
          {data?.currentCompany?.address ?? ""}
        </Text>
        <View style={styles.headerRow}>
          {data?.currentCompany?.phoneNo && (
            <Text style={styles.headerText}>
              Phone No.: {data.currentCompany.phoneNo}
            </Text>
          )}
          {data?.currentCompany?.email && (
            <Text style={styles.headerText}>
              Email: {data.currentCompany.email}
            </Text>
          )}
        </View>
      </View>

      <View>
        <View style={styles.firstSeparator} />
      </View>

      <View>
        <Text style={[styles.sectionTitle, { textAlign: "center" }]}>
          {type.toUpperCase()}
        </Text>
        {type === "Supplier Post Dated Cheque Listing" && (
          <Text style={[styles.sectionTitle, { textAlign: "center" }]}>
            AS AT {data?.pdfTitle ?? ""}
          </Text>
        )}
        {(type === "Supplier Bills And Payment Analysis" || type === "Supplier Analysis By Document" || type === "Supplier Document (Interbank GIRO) Listing" || type === "Purchase Analysis By Document") && (
          <Text style={[styles.sectionTitle, { textAlign: "center" }]}>
            AS AT {data?.toDate ?? ""}
          </Text>
        )}
      </View>

      <View style={{ marginTop: orientation === 'landscape' ? 20 : 30 }}>
        <Text style={{ fontSize: orientation === 'landscape' ? 6 : 7, textAlign: "left" }}>
          Generated By: {data?.currentCompany?.currentUser ?? data?.currentUser ?? ""}
        </Text>
        <Text style={{ fontSize: orientation === 'landscape' ? 6 : 7, textAlign: "left" }}>
          {type !== "Supplier Post Dated Cheque Listing" && type !== "Supplier Bills And Payment Analysis" && type !== "Supplier Analysis By Document" ? "Date Range: " : ""}
          {type !== "Supplier Post Dated Cheque Listing" && type !== "Supplier Bills And Payment Analysis" && type !== "Supplier Analysis By Document" ? formatDateRange() : ""}
        </Text>
      </View>
    </>
  );

  // Common table header with dynamic styles
  const renderTableHeader = () => (
    <View style={[styles.tableRow, styles.tableHeader]}>
      {purchaseReportColumns?.map((column, index) => (
        <Text
          key={index}
          style={
            column.header === "No" ? getTableCellNoStyles() : getTableCellStyles()
          }
        >
          {column.header}
        </Text>
      ))}
    </View>
  );

  const renderDynamicValue = (prefix: string, month: string) => {
    if (!data?.summary) return "";
    const regex = new RegExp(`^${prefix}_[0-9]{4}_${month}$`, "i");
    const key = Object.keys(data.summary).find((k) => regex.test(k));
    return key ? data.summary[key] : "";
  };

  // Summary box content with dynamic styles
  const renderSummaryBox = () => (
    <View style={getSummaryStyles()}>
      <Text style={styles.summaryTitle}>Summary: </Text>
      <View style={{ flexDirection: "row", gap: orientation === 'landscape' ? 6 : 10 }}>
        {type === "Supplier Monthly Purchase Report" ? (
          <>
            <View>
              <Text style={styles.summaryText}>
                Total Purchase Amount:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalSubtotalTaxReport ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Total Paid to Supplier:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalPaidAmountReport ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Outstanding Payables:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalOutstandingReport ?? ""}
                </Text>
              </View>
            </View>
          </>
        ) : type === "Supplier Payment Report" ? (
          <>
            <View>
              <Text style={styles.summaryText}>
                Total No. Of Documents:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.total ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>Total Amount Paid:</Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalPaidAmountReport ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Average Payment Monthly:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.averageMonthlyPayment ?? ""}
                </Text>
              </View>
            </View>
          </>
        ) : type === "Purchase Document Listing" || type === "Purchase Multi - Debit Note Listing - Level 2" || type === "Purchase Multi - Goods Received Listing - Level 2" ||
          type === "Purchase Multi - Purchase Order Listing - Level 2" || type === "Purchase Multi - Purchase Invoice Listing - Level 2" ? (
          <>
            <View style={{ flexDirection: "row", gap: orientation === 'landscape' ? 4 : 6 }}>
              <View>
                <Text style={styles.summaryText}>
                  Total No.Of Document:
                </Text>
                <View style={styles.summaryField2}>
                  <Text style={styles.summaryText}>
                    {data?.total ?? ""}
                  </Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>
                  Total Purchase Amount:
                </Text>
                <View style={styles.summaryField2}>
                  <Text style={styles.summaryText}>
                    {data?.summary?.totalAmountReport ?? ""}
                  </Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Tax:</Text>
                <View style={styles.summaryField2}>
                  <Text style={styles.summaryText}>
                    {data?.summary?.totalTaxReport ?? ""}
                  </Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Discount:</Text>
                <View style={styles.summaryField2}>
                  <Text style={styles.summaryText}>
                    {data?.summary?.totalDiscountReport ?? ""}
                  </Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>
                  Total Amount After Tax:
                </Text>
                <View style={styles.summaryField2}>
                  <Text style={styles.summaryText}>
                    {data?.summary?.totalSubtotalTaxReport ?? ""}
                  </Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>
                  Total Amount After Discount:
                </Text>
                <View style={styles.summaryField2}>
                  <Text style={styles.summaryText}>
                    {data?.summary?.totalAmountAfterDiscountReport ?? ""}
                  </Text>
                </View>
              </View>
            </View>
          </>
        ) : type === "Supplier Balance Report" ? (
          <>
            {purchaseReportData.reportTypeName === "supplierBalanceReportMultiBalanceSummary" ? (
              <>
                <View>
                  <Text style={styles.summaryText}>
                    Count of Supplier:
                  </Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>
                      {data?.total ?? ""}
                    </Text>
                  </View>
                </View>
                {/* <View>
                  <Text style={styles.summaryText}>Total Current Balance:</Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>
                      {data?.summary?.totalCurrentBalance ?? ""}
                    </Text>
                  </View>
                </View> */}
                <View>
                  <Text style={styles.summaryText}>
                    Total Amount:
                  </Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>
                      {data?.summary?.totalCurrentBalanceCarryForward ?? ""}
                    </Text>
                  </View>
                </View>
              </>
            ) : (
              <>
                <View>
                  <Text style={styles.summaryText}>
                    Count of Supplier:
                  </Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>
                      {data?.total ?? ""}
                    </Text>
                  </View>
                </View>
                <View>
                  <Text style={styles.summaryText}>Total Current Balance:</Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>
                      {data?.summary?.totalCurrentBalance ?? ""}
                    </Text>
                  </View>
                </View>
                <View>
                  <Text style={styles.summaryText}>
                    Total C/F Balance:
                  </Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>
                      {data?.summary?.totalCurrentBalanceCarryForward ?? ""}
                    </Text>
                  </View>
                </View>
              </>
            )}
          </>
        ) : type === "Supplier Due Document Listing" ? (
          <>
            <View>
              <Text style={styles.summaryText}>
                Total Count of No.:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.total ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Total Amount:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalNetTotal ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Total Payment:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalPaidAmount ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Total Outstanding:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalOutstandingAmount ?? ""}
                </Text>
              </View>
            </View>
          </>
        ) : type === "Supplier Aging Report" || type === "Supplier Statement Report" ? (
          <>
            <View>
              <Text style={styles.summaryText}>
                Total Count of No.:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.total ?? ""}
                </Text>
              </View>
            </View>
            <View>
              <Text style={styles.summaryText}>
                Total Outstanding Balance:
              </Text>
              <View style={styles.summaryField}>
                <Text style={styles.summaryText}>
                  {data?.summary?.totalOutstandingAmount ?? ""}
                </Text>
              </View>
            </View>
          </>
        ) : type === "Outstanding Purchase Document Listing" || type === "Purchase Outstanding Cash Purchase Listing - Level 2 (with SO Info)" ? (
          <>
            <View style={{ flexDirection: "row", gap: orientation === 'landscape' ? 4 : 6 }}>
              <View>
                <Text style={styles.summaryText}>Total No. of Document:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.total ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Orig. Qty:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalOriginalQuantity ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total O/S Qty:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalOSQuantity ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total O/S Amt:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalOSAmount ?? ""}</Text>
                </View>
              </View>
              {/* <View>
                <Text style={styles.summaryText}>Total Purchase Amount:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalAmountReport ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Discount:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalDiscountReport ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Subtotal:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalSubtotalReport ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Tax:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalTaxReport ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Subtotal (Tax):</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalSubtotalTaxReport ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Outstanding Amount:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalOutstandingAmountReport ?? ""}</Text>
                </View>
              </View> */}
            </View>
          </>
        ) : type === "Purchase Price History Report" ? (
