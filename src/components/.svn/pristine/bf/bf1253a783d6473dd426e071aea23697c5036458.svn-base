        ) : type === "Purchase Analysis By Document" ? (
          <>
            <View style={{ flexDirection: "row", flexWrap: "wrap", gap: orientation === 'landscape' ? 6 : 10 }}>
              {/* <View style={{ flexDirection: "row", gap: orientation === 'landscape' ? 6 : 10 }}> */}
              <View>
                <Text style={styles.summaryText}>Total Count of No.:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.total ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Purchase Invoice:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalPurInv ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Cash Purchase:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalCashPur ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Credit Note:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalCN ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total Debit Note:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalDN ?? ""}</Text>
                </View>
              </View>
              <View>
                <Text style={styles.summaryText}>Total:</Text>
                <View style={styles.summaryField}>
                  <Text style={styles.summaryText}>{data?.summary?.totalTotalAmt ?? ""}</Text>
                </View>
              </View>
            </View>
          </>
        ) : type === "Yearly Purchase Analysis" || type.includes("Yearly Purchase Analysis - Level 2") ? (
          (() => {
            let grandTotalPurchase = 0;
            let grandTotalQuantity = 0;

            const relevantRows = (rows || []).filter((r: any) => !r._rowType || r._rowType === 'item');

            relevantRows.forEach((row: any) => {
              const pAmt = parseFloat(row.totalPurchaseAmount || row.totallocalPurchaseAmount || "0");
              const pQty = parseFloat(row.totalQuantity || "0");

              grandTotalPurchase += isNaN(pAmt) ? 0 : pAmt;
              grandTotalQuantity += isNaN(pQty) ? 0 : pQty;
            });

            return (
              <View style={{ flexDirection: "row", gap: orientation === 'landscape' ? 6 : 10 }}>
                <View>
                  <Text style={styles.summaryText}>Total Count of No.:</Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>{data?.total ?? (relevantRows.length || 0)}</Text>
                  </View>
                </View>

                <View>
                  <Text style={styles.summaryText}>Total Purchase Amount:</Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>{formatDecimal(grandTotalPurchase)}</Text>
                  </View>
                </View>

                <View>
                  <Text style={styles.summaryText}>Total Quantity:</Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryText}>{grandTotalQuantity.toFixed(0)}</Text>
                  </View>
                </View>
              </View>
            );
          })()
        ) : (
          <>
            <Text style={styles.summaryText}>No Summary!</Text>
          </>
        )}
      </View>
    </View>
  );

  // Format decimal values to 2 decimal places with thousand separators
  const formatDecimal = (value: any) => {
    return formatNumberWithCommas(value, 2);
  };

  const isPurchaseOrPaymentColumn = (
    column: { accessorKey?: string; header?: string },
    value: unknown
  ): boolean => {
    if (!column?.accessorKey) return false;

    const key = column.accessorKey.toLowerCase();
    const numericPrefixes = ["purchase_", "localpurchase_", "payment_", "localpayment_"];

    const matchesKeyword = numericPrefixes.some(prefix => key.startsWith(prefix));

    const isNumber =
      typeof value === "number" ||
      (!isNaN(parseFloat(String(value))) && value !== "");

    return matchesKeyword && isNumber;
  };


  // Helper for Level 2 columns
  const renderLevel2Row = (item: any) => {
    const commonStyle = getTableCellStyles();
    const noStyle = getTableCellNoStyles();
    const mergedStyle = { ...getTableCellStyles(), flex: 16, textAlign: 'right' };

    //Header Row
    if (item._rowType === 'header') {
      // if(type === "Supplier Analysis By Document - Level 2"){
      //   return (
      //     <View style={styles.tableRow} wrap={false}>
      //       <Text style={noStyle}>{item._index}</Text>
      //       <Text style={[commonStyle, styles.boldText, {borderRightColor: "#ffffff" }]}>{item.supplierName}</Text>
      //       <Text style={[commonStyle, styles.boldText, {borderRightColor: "#ffffff" }]}>{item.supplierCode}</Text>

      //       <Text style={[commonStyle,{borderRightColor: "#ffffff" }]}></Text>
      //       <Text style={[commonStyle,{borderRightColor: "#ffffff" }]}></Text>
      //       <Text style={[commonStyle,{borderRightColor: "#ffffff" }]}></Text>
      //       <Text style={[commonStyle,{borderRightColor: "#ffffff" }]}></Text>
      //       <Text style={[commonStyle,{borderRightColor: "#ffffff" }]}></Text>
      //       <Text style={[commonStyle,{borderRightColor: "#ffffff" }]}></Text>
      //       <Text style={commonStyle}></Text>
      //     </View>   
      //   );
      // } else 
      if (type === "Purchase Multi - Debit Note Listing - Level 2" || type === "Purchase Multi - Goods Received Listing - Level 2" || type === "Purchase Multi - Purchase Order Listing - Level 2" ||
        type === "Purchase Multi - Purchase Invoice Listing - Level 2") {
        return (
          <View style={styles.tableRow} wrap={false}>
            <Text style={noStyle}>{item._index}</Text>
            <Text style={[commonStyle, styles.boldText, { borderRightColor: "#ffffff" }]}>{item.supplierName}</Text>
            <Text style={[commonStyle, styles.boldText, { borderRightColor: "#ffffff" }]}>{item.docDateFormat}</Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={commonStyle}></Text>
          </View>
        );
      } else if (type === "Purchase Outstanding Cash Purchase Listing - Level 2 (with SO Info)") {
        return (
          <View style={styles.tableRow} wrap={false}>
            <Text style={noStyle}>{item._index}</Text>
            <Text style={[commonStyle, styles.boldText, { borderRightColor: "#ffffff" }]}>{item.supplierName}</Text>
            <Text style={[commonStyle, styles.boldText, { borderRightColor: "#ffffff" }]}>{item.docDateFormat}</Text>

            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={[commonStyle, { borderRightColor: "#ffffff" }]}></Text>
            <Text style={commonStyle}></Text>
          </View>
        );
      }

      //Subtotal Row
    } else if (item._rowType === 'subtotal') {
      // if(type === "Supplier Analysis By Document - Level 2"){
      //   return (
      //     <View style={[styles.tableRow, styles.subtotalRow]} wrap={false}>
      //       <Text style={[noStyle, { borderRightWidth: 1,borderRightColor: "#deebf7", borderLeftWidth: 1, borderColor: "#000000" }]}></Text>
      //       <Text style={[commonStyle, { borderRightWidth: 1,borderRightColor: "#deebf7", borderColor: "#000000" }]}></Text>

      //       <Text style={[commonStyle, { borderRightWidth: 1,borderColor: "#000000", textAlign: "left" }]}>
      //         <Text style={[commonStyle , styles.boldText]}>Subtotal of {item.supplierName}</Text>
      //       </Text>

      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalBF)}</Text> 
      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalInvoice)}</Text> 
      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalDebitNote)}</Text>
      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalCreditNote)}</Text>
      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalPayment)}</Text>
      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalContra)}</Text>
      //       <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalCF)}</Text>
      //     </View>
      //   );
      // } else 
      if (type === "Purchase Multi - Debit Note Listing - Level 2" || type === "Purchase Multi - Goods Received Listing - Level 2" || type === "Purchase Multi - Purchase Order Listing - Level 2" || type === "Purchase Multi - Purchase Invoice Listing - Level 2") {
        return (
          <View style={[styles.tableRow, styles.subtotalRow]} wrap={false}>
            <Text style={[noStyle, { borderRightWidth: 1, borderRightColor: "#deebf7", borderLeftWidth: 1, borderColor: "#000000" }]}></Text>

            <Text style={[commonStyle, { borderRightWidth: 1, borderRightColor: "#deebf7", borderColor: "#000000" }]}></Text>
            <Text style={[commonStyle, { borderRightWidth: 1, borderRightColor: "#deebf7", borderColor: "#000000", textAlign: "left" }]}>
              <Text style={[commonStyle, styles.boldText]}>Subtotal of {item.supplierName}</Text>
            </Text>
            <Text style={[commonStyle, { borderRightWidth: 1, borderColor: "#000000" }]}></Text>

            <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalTotalAmount)}</Text>
            <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalTotalDiscount)}</Text>
            <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalAmountAfterDiscount)}</Text>
            <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalTotalTax)}</Text>
            <Text style={[commonStyle, { borderColor: "#000000" }]}>{formatDecimal(item.subtotalTotalSubtotalTax)}</Text>
          </View>
        );
      }

      //Normal row
    }
    // else if (type === "Supplier Analysis By Document - Level 2") {
    //   return (
    //     <View style={styles.tableRow} wrap={false}>
    //        <Text style={noStyle}></Text> {/* No */}
    //        <Text style={commonStyle}>{item.supplierName}</Text> 
    //        <Text style={commonStyle}>{item.supplierCode}</Text> 
    //        <Text style={commonStyle}>{formatDecimal(item.localBalanceBringForward)}</Text>
    //        <Text style={commonStyle}>{formatDecimal(item.invoiceLocalNetTotal)}</Text>
    //        <Text style={commonStyle}>{formatDecimal(item.debitNoteLocalNetTotal)}</Text>
    //        <Text style={commonStyle}>{formatDecimal(item.creditNoteLocalNetTotal)}</Text>
    //        <Text style={commonStyle}>{formatDecimal(item.localSupplierPayment)}</Text>
    //        <Text style={commonStyle}>{formatDecimal(item.contraAmountNetTotal)}</Text>
    //        <Text style={commonStyle}>{formatDecimal(item.localCurrentAmount)}</Text>
    //     </View>
    //   );
    // } 
    else if (type === "Purchase Multi - Debit Note Listing - Level 2" || type === "Purchase Multi - Goods Received Listing - Level 2" ||
      type === "Purchase Multi - Purchase Order Listing - Level 2" || type === "Purchase Multi - Purchase Invoice Listing - Level 2") {
      return (
        <View style={styles.tableRow} wrap={false}>
          <Text style={noStyle}></Text> {/* No */}
          <Text style={commonStyle}>{item.docNo}</Text>
          <Text style={commonStyle}>{item.docDateFormat}</Text>
          <Text style={commonStyle}>{item.supplierName}</Text>
          <Text style={commonStyle}>{formatDecimal(item.totalAmount)}</Text>
          <Text style={commonStyle}>{formatDecimal(item.totalDiscount)}</Text>
          <Text style={commonStyle}>{formatDecimal(item.amountAfterDiscount)}</Text>
          <Text style={commonStyle}>{formatDecimal(item.totalTax)}</Text>
          <Text style={commonStyle}>{formatDecimal(item.totalSubtotalTax)}</Text>
        </View>
      );
    } else if (type === "Purchase Outstanding Cash Purchase Listing - Level 2 (with SO Info)") {
      return (
        <View style={styles.tableRow} wrap={false}>
          <Text style={noStyle}></Text> {/* No */}
          <Text style={commonStyle}>{item.itemCode}</Text>
          <Text style={commonStyle}>{item.supplierName}</Text>
          <Text style={commonStyle}>{item.description}</Text>
          <Text style={commonStyle}>{formatDecimal(item.price)}</Text>
          <Text style={commonStyle}>{item.deliveryDateFormat}</Text>
          <Text style={commonStyle}>{formatDecimal(item.originalQuantity)}</Text>
          <Text style={commonStyle}>{formatDecimal(item.osQuantity)}</Text>
          <Text style={commonStyle}>{item.docDateFormat}</Text>
          <Text style={commonStyle}>{item.docNo}</Text>
          <Text style={commonStyle}>{formatDecimal(item.transferQuantity)}</Text>
        </View>
      );
    }
  };
  if (type.includes("Yearly Purchase Analysis")) {
    const groupedData = (data?.rows || []).reduce((acc: any, row: any) => {
      const key = row.itemCode || row.itemType || "Unknown";

      if (!acc[key]) {
        acc[key] = {
          name: `Item Code:${row.itemCode} , Item Type:${row.itemType}`,
          rows: [],
          totals: {}
        };
      }

      acc[key].rows.push(row);

      // Accumulate totals for dynamic month columns and main totals
      Object.keys(row).forEach(k => {
        const match = k.match(/^([A-Za-z]{3})[-_](\d{2})$/);
        if (match || k === 'totallocalPurchaseAmount' || k === 'totalQuantity') {
          const val = parseFloat(row[k] || 0);
          acc[key].totals[k] = (acc[key].totals[k] || 0) + (isNaN(val) ? 0 : val);
        }
      });

      return acc;
    }, {});

    return (
      <Document title={type}>
        <Page size="A4" orientation={orientation} style={getPageStyles()}>
          <View fixed>{renderHeader()}</View>

          {Object.values(groupedData).map((group: any, groupIndex) => (
            <View key={groupIndex} style={{ marginBottom: 10 }} wrap={false}>
              {/* Group Title */}
              <Text style={styles.groupTitle}>
                {group.name}
              </Text>

              {/* Table */}
              <View style={styles.table}>
                {/* Header */}
                <View style={[styles.tableRow, styles.tableHeader]}>
                  {purchaseReportColumns?.map((column, index) => (
                    <Text
                      key={index}
                      style={column.header === "No" ? getTableCellNoStyles() : getTableCellStyles()}
                    >
                      {column.header}
                    </Text>
                  ))}
                </View>

                {/* Rows */}
                {group.rows.map((row: any, rowIndex: number) => (
                  <View key={rowIndex} style={styles.tableRow}>
                    {purchaseReportColumns?.map((column, colIndex) => {
                      if (column.header === "No") {
                        return (
                          <Text key={colIndex} style={getTableCellNoStyles()}>
                            {rowIndex + 1}
                          </Text>
                        );
                      }
                      const val = row[column.accessorKey];
                      const isNumeric =
                        typeof val === 'number' ||
                        (!isNaN(parseFloat(String(val))) && val !== "" && (column.header !== "Item Code" && column.header !== "Item Type"));

                      return (
                        <Text key={colIndex} style={getTableCellStyles()}>
                          {isNumeric ? formatDecimal(val) : (val || "")}
                        </Text>
                      );
                    })}
                  </View>
                ))}

                {/* Subtotal Row */}
                <View style={[styles.tableRow, styles.subtotalRow]}>
                  {purchaseReportColumns?.map((column, colIndex) => {
                    if (column.header === "No") {
                      return <Text key={colIndex} style={getTableCellNoStyles()}></Text>;
                    }

                    if (column.header === "Item Code" || (colIndex === 1 && !column.header.toLowerCase().includes("qty"))) {
                      return (
                        <Text key={colIndex} style={[getTableCellStyles(), styles.boldText, { textAlign: 'left' }]}>
                          Subtotal:
                        </Text>
                      );
                    }

                    const key = column.accessorKey;
                    const totalVal = group.totals[key];

                    if (totalVal !== undefined) {
                      return (
                        <Text key={colIndex} style={[getTableCellStyles(), styles.boldText]}>
                          {formatDecimal(totalVal)}
                        </Text>
                      );
                    }

                    return <Text key={colIndex} style={getTableCellStyles()}></Text>;
                  })}
                </View>
              </View>
            </View>
          ))}

          <View
            render={({ pageNumber, totalPages }) =>
              pageNumber === totalPages ? renderSummaryBox() : null
            }
            style={{ width: "100%" }}
          />

          <View fixed style={styles.footerContainer}>
            <View style={styles.footerLine} />
            <View
              style={{
                flexDirection: "row",
                justifyContent: "space-between",
                paddingTop: 5,
              }}
            >
              <Text style={styles.footerText}>
                Date Generated: {moment().format("YYYY-MM-DD")}
              </Text>
              <Text
                style={styles.footerText}
                render={({ pageNumber, totalPages }) =>
                  `Page ${pageNumber} of ${totalPages}`
                }
              />
            </View>
          </View>
        </Page>
      </Document>
    );
  } else if (type.includes("Supplier Analysis By Document - Level 2")) {
    const groupedData = (data?.rows || []).reduce((acc: any, row: any) => {
      const key = row.supplierName || row.supplierCode || "Unknown";

      if (!acc[key]) {
        acc[key] = {
          name: `Supplier Name:${row.supplierName} , Supplier Code:${row.supplierCode}`,
          rows: [],
          totals: {}
        };
      }

      acc[key].rows.push(row);

      // Accumulate totals for dynamic month columns and main totals
      Object.keys(row).forEach(k => {
        const match = k.match(/^([A-Za-z]{3})[-_](\d{2})$/);
        if (match || k === 'totallocalPurchaseAmount' || k === 'totalQuantity') {
          const val = parseFloat(row[k] || 0);
          acc[key].totals[k] = (acc[key].totals[k] || 0) + (isNaN(val) ? 0 : val);
        }
      });

      return acc;
    }, {});

    return (
      <Document title={type}>
        <Page size="A4" orientation={orientation} style={getPageStyles()}>
          <View fixed>{renderHeader()}</View>

          {Object.values(groupedData).map((group: any, groupIndex) => (
            <View key={groupIndex} style={{ marginBottom: 10 }} wrap={false}>
              {/* Group Title */}
              <Text style={styles.groupTitle}>
                {group.name}
              </Text>

              {/* Table */}
              <View style={styles.table}>
                {/* Header */}
                <View style={[styles.tableRow, styles.tableHeader]}>
                  {purchaseReportColumns?.map((column, index) => (
                    <Text
                      key={index}
                      style={column.header === "No" ? getTableCellNoStyles() : getTableCellStyles()}
                    >
                      {column.header}
                    </Text>
                  ))}
                </View>

                {/* Rows */}
                {group.rows.map((row: any, rowIndex: number) => (
                  <View key={rowIndex} style={styles.tableRow}>
                    {purchaseReportColumns?.map((column, colIndex) => {
                      if (column.header === "No") {
                        return (
                          <Text key={colIndex} style={getTableCellNoStyles()}>
                            {rowIndex + 1}
                          </Text>
                        );
                      }
                      const val = row[column.accessorKey];
                      const isNumeric =
                        typeof val === 'number' ||
                        (!isNaN(parseFloat(String(val))) && val !== "" && (column.header !== "Item Code" && column.header !== "Item Type"));

                      return (
                        <Text key={colIndex} style={getTableCellStyles()}>
                          {isNumeric ? formatDecimal(val) : (val || "")}
                        </Text>
                      );
                    })}
                  </View>
                ))}

              </View>
            </View>
          ))}

          <View
            render={({ pageNumber, totalPages }) =>
              pageNumber === totalPages ? renderSummaryBox() : null
            }
            style={{ width: "100%" }}
          />

          <View fixed style={styles.footerContainer}>
            <View style={styles.footerLine} />
            <View
              style={{
                flexDirection: "row",
                justifyContent: "space-between",
                paddingTop: 5,
              }}
            >
              <Text style={styles.footerText}>
                Date Generated: {moment().format("YYYY-MM-DD")}
              </Text>
              <Text
                style={styles.footerText}
                render={({ pageNumber, totalPages }) =>
                  `Page ${pageNumber} of ${totalPages}`
                }
              />
            </View>
          </View>
        </Page>
      </Document>
    );
  }

  const shouldShowColumn = (colHeader: string, isPurchase: boolean, isPayment: boolean) => {
    const hideWhenPurchase = ["Total Payment Amount", "Total Payment Amount (Local)"];
    const hideWhenPayment = ["Total Purchase Amount", "Total Purchase Amount (Local)"];

    // both checked → show all
    if (isPurchase && isPayment) return true;
    if (isPurchase && hideWhenPurchase.includes(colHeader)) return false;
    if (isPayment && hideWhenPayment.includes(colHeader)) return false;
    return true;
  };

  return (
    <Document title={type}>
      <Page size="A4" orientation={orientation} style={getPageStyles()}>
        {/* Header (fixed on every page) */}
        <View fixed>{renderHeader()}</View>

        {purchaseReportData?.reportNameType === "outstandingPurchaseInvoiceLv2DocNo" ||
          purchaseReportData?.reportNameType === "outstandingPurchaseOrderLv2DocNo" ||
          purchaseReportData?.reportNameType === "outstandingSupplierDeliveryOrderLv2DocNo" ||
          purchaseReportData?.reportNameType === "outstandingPurchaseRequisitionLv2DocNo" ||
          purchaseReportData?.reportNameType === "outstandingCashPurchaseLv2DocNo" ? (
          <View style={styles.table}>
            {/* Loop first-level group (date) */}
            {Object.values(data?.rows || {}).map((firstGroup: any) => (
              <View key={firstGroup.group} style={{ marginBottom: 10 }}>
                <Text style={{ fontFamily: "Helvetica-Bold", fontSize: 9, marginBottom: 2 }}>
                  {`Date: ${firstGroup.group}`}
                </Text>

                {/* Loop second-level group (item code) */}
                {Object.values(firstGroup.rows || {}).map((secondGroup: any) => (
                  <View key={secondGroup.group} style={{ marginBottom: 6 }}>
                    <Text style={{ fontFamily: "Helvetica-Bold", fontSize: 8, marginBottom: 2 }}>
                      {`Doc No: ${secondGroup.group}`}
                    </Text>

                    {/* Table Header */}
                    <View style={[styles.tableRow, styles.tableHeader]}>
                      {(purchaseReportColumns ?? []).map((col, idx) => (
                        <Text
                          key={idx}
                          style={col.header === "No" ? getTableCellNoStyles() : getTableCellStyles()}
                        >
                          {col.header}
                        </Text>
                      ))}
                    </View>

                    {/* Table Rows */}
                    {secondGroup.items.map((item: any, rowIdx: number) => (
                      <View key={rowIdx} style={[styles.tableRow, { borderBottomWidth: 1, borderColor: "#000" }]}>
                        {(purchaseReportColumns ?? []).map((column, colIdx) => {
                          const value = item[column.accessorKey];
                          return (
                            <Text
                              key={colIdx}
                              style={column.header === "No" ? getTableCellNoStyles() : getTableCellStyles()}
                            >
                              {column.header === "No"
                                ? rowIdx + 1
                                : typeof value === "number" || column.header.toLowerCase().includes("price")
                                  ? formatDecimal(value)
                                  : value || ""}
                            </Text>
                          );
                        })}
                      </View>
                    ))}
                  </View>
                ))}
              </View>
            ))}

            {/* Back Order Summary */}
            <View style={{ borderWidth: 1, borderColor: "#000", marginTop: 8, marginBottom: 8, padding: 8 }}>
              <Text style={{ fontFamily: "Helvetica-Bold", fontSize: 9, marginBottom: 5 }}>
                Back Order Summary
              </Text>

              {/* Header */}
              <View style={[styles.tableRow, styles.tableHeader]}>
                {["Item Code", "Description", "O/S Qty", "On Hand", "Avail. Qty", "S/O Qty", "Future Qty"].map((header, i) => (
                  <Text key={i} style={header === "Item Code" ? getTableCellSOItemCodeStyles() : getTableCellSOStyles()}>
                    {header}
                  </Text>
                ))}
              </View>

              {(data?.summaryData?.data ?? []).map((row: any, idx: number) => (
                <View key={idx} style={[styles.tableRow, { borderBottomWidth: 1, borderColor: "#000" }]}>
                  <Text style={[getTableCellStyles(), { borderLeftWidth: 1, borderColor: "#000" }]}>
                    {row.itemCode || "-"}
                  </Text>
                  <Text style={getTableCellStyles()}>{row.description || "-"}</Text>
                  <Text style={getTableCellStyles()}>{formatDecimal(row.osQuantity)}</Text>
                  <Text style={getTableCellStyles()}>{formatDecimal(row.onHand)}</Text>
                  <Text style={getTableCellStyles()}>{formatDecimal(row.availableQty)}</Text>
                  <Text style={getTableCellStyles()}>{formatDecimal(row.soQty)}</Text>
