"use client";

import { useCallback, useRef, useState } from "react";
import { CalendarIcon, Check, X } from "lucide-react";
import { IoEllipsisHorizontalSharp } from "react-icons/io5";
import moment from "moment";
import type { Row, Table as TableType } from "@tanstack/react-table";

import { Button } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import { Checkbox } from "@/components/ui/checkbox";
import { Input, NumberInputCell } from "@/components/ui/input";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu";
import { DATE_FORMAT } from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

interface FieldConfig {
  type: "text" | "number" | "date" | "dropdown" | "checkbox" | "textarea" | "readonly" | "uom" | "uom2" | "uom3";
  label?: string;
  allowDecimal?: boolean;
  allowNegative?: boolean;
  disabled?: boolean;
  options?: Array<{ value: string; label: string }>;
  colSpan?: 1 | 2;
  className?: string;
}

interface MobileFormDataTableProps<T> {
  table: TableType<T>;
  renderCard?: (row: Row<T>, isSelectionMode: boolean) => React.ReactNode;
  fieldConfigs?: Record<string, FieldConfig>;
  onFieldChange: (rowId: string, fieldId: string, value: any) => void;
  checkboxHandlers?: Record<string, (rowIndex: number, checked: boolean, row: Row<T>) => void>;
  UOMInputs?: Record<string, string>;
  setUOMInputs?: (updater: (prev: Record<string, string>) => Record<string, string>) => void;
  UOM2Inputs?: Record<string, string>;
  setUOM2Inputs?: (updater: (prev: Record<string, string>) => Record<string, string>) => void;
  UOM3Inputs?: Record<string, string>;
  setUOM3Inputs?: (updater: (prev: Record<string, string>) => Record<string, string>) => void;
  setTempRowDetailsList?: (updater: (prevList: any[]) => any[]) => void;
  renderDropdownItems?: (row: Row<T>) => React.ReactNode;
  className?: string;
  isPaid?: boolean;
}

const LONG_PRESS_DURATION = 500;

const FIELD_SECTION_MAP: Record<string, string> = {
  description: "Item Details",
  "2ndDescription": "Item Details",
  moreDescription: "Item Details",
  quantity: "Quantities & Pricing",
  quantity2: "Quantities & Pricing",
  quantity3: "Quantities & Pricing",
  price: "Quantities & Pricing",
  UOM: "Quantities & Pricing",
  UOM2: "Quantities & Pricing",
  UOM3: "Quantities & Pricing",
  itemUOM: "Quantities & Pricing",
  itemUOM2: "Quantities & Pricing",
  itemUOM3: "Quantities & Pricing",
  discountRate: "Discounts",
  discountAmount: "Discounts",
  discountRate2: "Discounts",
  discountAmount2: "Discounts",
  discountRate3: "Discounts",
  discountAmount3: "Discounts",
  date: "Dates",
  startAt: "Dates",
  endAt: "Dates",
  deliveryDate: "Dates",
  taxInclusive: "Tax & Settings",
  master: "Tax & Settings",
  showTemplate: "Tax & Settings",
  remark1: "Remarks",
  remark2: "Remarks",
  permitNo: "Other",
};

export default function MobileFormDataTable<T extends Record<string, any>>({
  table,
  renderCard,
  fieldConfigs = {},
  onFieldChange,
  checkboxHandlers = {},
  UOMInputs = {},
  setUOMInputs,
  UOM2Inputs = {},
  setUOM2Inputs,
  UOM3Inputs = {},
  setUOM3Inputs,
  setTempRowDetailsList,
  renderDropdownItems,
  className,
  isPaid = false,
}: MobileFormDataTableProps<T>) {

  // ── Selection mode ──────────────────────────
  const [isSelectionMode, setIsSelectionMode] = useState(false);
  const timerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const isLongPress = useRef(false);

  const handlePointerDown = useCallback(
    (row: Row<T>) => {
      isLongPress.current = false;
      timerRef.current = setTimeout(() => {
        isLongPress.current = true;
        setIsSelectionMode(true);
        table.resetRowSelection();
        row.toggleSelected(true);
      }, LONG_PRESS_DURATION);
    },
    [table],
  );

  const handlePointerUp = useCallback(() => {
    if (timerRef.current) { clearTimeout(timerRef.current); timerRef.current = null; }
  }, []);

  const handlePointerCancel = useCallback(() => {
    if (timerRef.current) { clearTimeout(timerRef.current); timerRef.current = null; }
  }, []);

  const handleCardClick = useCallback(
    (row: Row<T>) => {
      if (isLongPress.current) return;
      if (isSelectionMode) row.toggleSelected();
    },
    [isSelectionMode],
  );

  // Edit State
  const [editingRow, setEditingRow] = useState<Row<T> | null>(null);

  // Derive Sections
  const getSections = () => {
    const sections: Record<string, string[]> = {};
    Object.keys(fieldConfigs).forEach((key) => {
      const section = FIELD_SECTION_MAP[key] ?? "Other";
      if (!sections[section]) sections[section] = [];
      sections[section].push(key);
    });
    return sections;
  };

  // UOM Dropdown Renderer
  const renderUOMDropdown = (
    key: string,
    row: Row<T>,
    uomKey: "uom" | "uom2" | "uom3",
  ) => {
    const dropdownMap = {
      uom:  { data: row.original.UOMDropdown  || [], inputs: UOMInputs,  setInputs: setUOMInputs,  field: "UOM"  },
      uom2: { data: row.original.UOMDropdown2 || [], inputs: UOM2Inputs, setInputs: setUOM2Inputs, field: "UOM2" },
      uom3: { data: row.original.UOMDropdown3 || [], inputs: UOM3Inputs, setInputs: setUOM3Inputs, field: "UOM3" },
    };

    const { data: uomOptions, inputs, setInputs, field } = dropdownMap[uomKey];
    const isDisabled = uomOptions.length === 0 || isPaid;

    const currentValue = inputs[row.id] ?? row.original[field];

    const onChange = (selectedUOMUUID: string) => {
      const selectedUOM = uomOptions.find((uom: any) => uom.UUID === selectedUOMUUID);
      if (!selectedUOM || !setInputs || !setTempRowDetailsList) return;

      const updates: Record<string, any> = { [field]: selectedUOMUUID };
      if (uomKey === "uom") {
        updates["itemRate"] = selectedUOM.Rate;
        updates["price"]    = selectedUOM.refPrice;
      }

      Object.assign(row.original, updates);

      setInputs((prev) => ({ ...prev, [row.id]: selectedUOMUUID }));

      setTempRowDetailsList((prevList) =>
        prevList.map((item, idx) => {
          if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
            return { ...item, ...updates };
          }
          return item;
        }),
      );
    };

    return (
      <Select value={currentValue} onValueChange={onChange} disabled={isDisabled}>
        <SelectTrigger className="h-10 w-full rounded-lg border border-gray-200 bg-white text-sm text-gray-900 shadow-none focus:border-gray-400 focus:ring-0">
          <SelectValue placeholder={isDisabled ? "No UOM" : "Select UOM"} />
        </SelectTrigger>
        <SelectContent className="z-[9999] text-sm" style={{ fontSize: "14px" }}>
          {uomOptions.map((uom: any) => (
            <SelectItem key={uom.UUID} value={uom.UUID} className="text-sm text-gray-900" style={{ fontSize: "14px" }}>
              {uom.UOM || uom.UOM2 || uom.UOM3}
            </SelectItem>
          ))}
        </SelectContent>
      </Select>
    );
  };

  // Field Renderer
  const renderField = (key: string, row: Row<T>) => {
    const config = fieldConfigs[key];
    if (!config) return null;
    const value = row.original[key];

    const isStock = row.original.type === "Stock";

    switch (config.type) {
      case "uom":  return renderUOMDropdown(key, row, "uom");
      case "uom2": return isStock ? null : renderUOMDropdown(key, row, "uom2");
      case "uom3": return isStock ? null : renderUOMDropdown(key, row, "uom3");

      case "text":
      case "textarea":
        return (
          <Input
            className="h-10 rounded-lg border border-gray-200 bg-white text-sm shadow-none focus:border-gray-400 focus-visible:ring-0"
            defaultValue={value ?? ""}
            onBlur={(e) => {
              if (e.target.value !== (row.original[key] ?? "")) {
                row.original[key] = e.target.value;
                onFieldChange(row.index.toString(), key, e.target.value);
              }
            }}
            key={`${row.id}-${key}-${value}`}
            disabled={config.disabled || isPaid}
          />
        );

      case "number":
        return (
          <NumberInputCell
            className="h-10 rounded-lg border border-gray-200 bg-white text-sm shadow-none focus:border-gray-400 focus-visible:ring-0"
            value={value ?? ""}
            onValueChange={(val) => {
              row.original[key] = val;
              onFieldChange(row.index.toString(), key, val);
            }}
            disabled={config.disabled || isPaid}
            allowDecimal={config.allowDecimal}
            allowNegative={config.allowNegative}
          />
        );

      case "date":
        return (
          <Popover>
            <PopoverTrigger asChild>
              <Button
                className={cn(
                  "flex h-10 w-full justify-between rounded-lg border border-gray-200 bg-white px-3 text-left text-sm font-normal shadow-none hover:bg-gray-50",
                  !value && "text-gray-400",
                )}
                variant="outline"
                disabled={config.disabled || isPaid}
              >
                {value ? moment.unix(Number(value)).format(DATE_FORMAT) : "Pick a date"}
                <CalendarIcon className="h-4 w-4 text-gray-400" />
              </Button>
            </PopoverTrigger>
            <PopoverContent className="w-auto p-0" align="start">
              <Calendar
                mode="single"
                selected={value ? new Date(Number(value) * 1000) : undefined}
                onSelect={(date) => {
                  const ts = date ? Math.floor(date.getTime() / 1000).toString() : "";
                  row.original[key] = ts;
                  onFieldChange(row.index.toString(), key, ts);
                }}
                initialFocus
              />
            </PopoverContent>
          </Popover>
        );

      case "dropdown":
        return (
          <Select
            value={value ?? ""}
            onValueChange={(val) => {
              row.original[key] = val;
              onFieldChange(row.index.toString(), key, val);
            }}
            disabled={config.disabled || isPaid}
          >
            <SelectTrigger className="h-10 rounded-lg border border-gray-200 bg-white text-sm text-gray-900 shadow-none focus:border-gray-400">
              <SelectValue placeholder="Select option" />
            </SelectTrigger>
            <SelectContent className="text-sm" style={{ fontSize: "14px" }}>
              {config.options?.map((option) => (
                <SelectItem key={option.value} value={option.value} className="text-sm text-gray-900" style={{ fontSize: "14px" }}>{option.label}</SelectItem>
              ))}
            </SelectContent>
          </Select>
        );

      case "checkbox": {
        const handler = checkboxHandlers[key];
        return (
          <div
            className={cn(
              "flex h-10 cursor-pointer items-center gap-3 rounded-lg border border-gray-200 bg-white px-3 transition-colors",
              value === "1" && "border-blue-200 bg-blue-50",
              (config.disabled || isPaid) && "cursor-not-allowed opacity-50",
            )}
            onClick={() => {
              if (config.disabled || isPaid) return;
              const newChecked = value !== "1";
              handler && handler(row.index, newChecked, row);
            }}
          >
            <div className={cn(
              "flex h-4 w-4 items-center justify-center rounded border transition-colors",
              value === "1" ? "border-blue-500 bg-blue-500" : "border-gray-300 bg-white",
            )}>
              {value === "1" && <Check className="h-3 w-3 text-white" strokeWidth={3} />}
            </div>
            <span className="text-sm text-gray-700">{config.label || key}</span>
          </div>
        );
      }

      case "readonly":
      default:
        return (
          <Input
            value={value ?? ""}
            readOnly
            className="h-10 rounded-lg border border-gray-100 bg-gray-50 text-sm text-gray-500 shadow-none focus-visible:ring-0"
          />
        );
    }
  };

  // Render
  const rows = table.getRowModel().rows;

  if (rows.length === 0) {
    return (
      <div className="flex h-40 w-full flex-col items-center justify-center gap-2 md:hidden">
        <p className="text-sm font-medium text-gray-400">No items added</p>
      </div>
    );
  }

  const sections = getSections();
  const sectionKeys = Object.keys(sections);

  return (
    <>
      {/* Card List */}
      <div className={cn("block space-y-2 p-3 md:hidden", className)}>
        {rows.map((row) => (
          <div
            key={row.id}
            onPointerDown={() => handlePointerDown(row)}
            onPointerUp={handlePointerUp}
            onPointerCancel={handlePointerCancel}
            onClick={() => handleCardClick(row)}
            onContextMenu={(e) => e.preventDefault()}
            className={cn(
              "relative select-none transition-all duration-300 active:scale-[0.99]",
              isSelectionMode && row.getIsSelected() && "ring-2 ring-blue-500 ring-offset-1 rounded-xl",
            )}
          >
            {renderCard?.(row, isSelectionMode)}

            {/* Three Dot menu */}
            <div className="absolute right-3 top-3" onClick={(e) => e.stopPropagation()}>
              <DropdownMenu
                onOpenChange={(open) => {
                  if (open && !row.getIsSelected()) {
                    table.resetRowSelection();
                    row.toggleSelected(true);
                  }
                }}
              >
                {isSelectionMode ? (
                  <div className="flex h-7 w-7 items-center justify-center">
                    <div
                      className={cn(
                        "flex h-5 w-5 items-center justify-center rounded-full border-2 transition-colors",
                        row.getIsSelected() ? "border-blue-500 bg-blue-500" : "border-gray-300 bg-white",
                      )}
                      onClick={() => row.toggleSelected()}
                    >
                      {row.getIsSelected() && <Check className="h-3 w-3 text-white" strokeWidth={3} />}
                    </div>
                  </div>
                ) : (
                  <DropdownMenuTrigger className="flex h-7 w-7 items-center justify-center rounded-full outline-none transition-colors hover:bg-gray-100 active:bg-gray-200">
                    <IoEllipsisHorizontalSharp className="size-4 text-gray-400" />
                  </DropdownMenuTrigger>
                )}

                <DropdownMenuContent
                  align="end"
                  className="w-36 rounded-xl border border-gray-100 bg-white p-1 shadow-lg shadow-gray-100"
                >
                  <DropdownMenuItem
                    className="cursor-pointer rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
                    onSelect={(e) => {
                      e.preventDefault();
                      setEditingRow(row);
                    }}
                  >
                    Edit
                  </DropdownMenuItem>
                  {renderDropdownItems && (
                    <>
                      <DropdownMenuSeparator className="my-1 bg-gray-100" />
                      {renderDropdownItems(row)}
                    </>
                  )}
                </DropdownMenuContent>
              </DropdownMenu>
            </div>
          </div>
        ))}
      </div>

      {/* Selection Mode TO DO */}
      {isSelectionMode && (
        <div className="sticky bottom-20 z-20 mx-3 mb-2 flex items-center justify-between rounded-2xl bg-gray-900 px-4 py-3 shadow-xl md:hidden">
          <span className="text-sm font-medium text-white">
            {table.getSelectedRowModel().rows.length} selected
          </span>
          <button
            onClick={() => { setIsSelectionMode(false); table.resetRowSelection(); }}
            className="flex items-center gap-1.5 rounded-lg bg-white/10 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-white/20"
          >
            <X className="h-3.5 w-3.5" />
            Done
          </button>
        </div>
      )}

      {/* Edit Panel */}
      {editingRow && (
        <div
          className="fixed inset-0 z-[1000] flex flex-col bg-gray-50 animate-in slide-in-from-bottom-full duration-300 ease-out md:hidden"
        >
          {/* Header */}
          <div className="flex flex-shrink-0 items-center gap-x-3 border-b border-gray-100 bg-white px-3 py-4">
            <button
              onClick={() => setEditingRow(null)}
              className="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-gray-100 text-gray-500 active:bg-gray-200"
              aria-label="Close"
            >
              <X className="size-3" />
            </button>
            <div className="min-w-0 flex-1">
              {editingRow.original.itemCode && (
                <p className="truncate text-[12px] font-semibold uppercase text-blue-500">
                  {editingRow.original.itemCode}
                </p>
              )}
            </div>
          </div>

          {/* Scrollable Content */}
          <div
            className="min-h-0 flex-1 overflow-y-auto overscroll-contain"
            style={{
              WebkitOverflowScrolling: "touch",
              paddingBottom: "calc(4.5rem + env(safe-area-inset-bottom, 0px))",
            }}
          >
            <div className="space-y-3 px-3 pt-4">
              {sectionKeys.map((section) => {
                const fieldsInSection = sections[section] ?? [];
                if (fieldsInSection.length === 0) return null;

                return (
                  <div key={section} className="overflow-hidden rounded-xl bg-white shadow-sm">
                    {/* Section heading */}
                    <div className="border-b border-gray-50 px-4 py-3">
                      <h1 className="text-[11px] font-bold uppercase tracking-widest text-gray-400">
                        {section}
                      </h1>
                    </div>

                    {/* Fields Grid */}
                    <div className="grid grid-cols-2 gap-x-2.5 gap-y-4 px-4 py-4">
                      {fieldsInSection
                        .filter((key) => {
                          const config = fieldConfigs[key];
                          if (!config) return false;
                          const isStock = editingRow.original.type === "Stock";
                          if (isStock && (config.type === "uom2" || config.type === "uom3")) return false;
                          return true;
                        })
                        .map((key) => {
                          const config = fieldConfigs[key];
                          if (!config) return null;
                          const isCheckbox = config.type === "checkbox";
                          const isReadonly = config.type === "readonly";
                          const colSpanClass = config.colSpan === 2 || isCheckbox ? "col-span-2" : "";

                          return (
                            <div key={key} className={cn("flex flex-col gap-1", colSpanClass)}>
                              {!isCheckbox && (
                                <label className={cn(
                                  "text-[10px] font-semibold uppercase tracking-wider",
                                  isReadonly ? "text-gray-300" : "text-gray-400",
                                )}>
                                  {config.label || key}
                                </label>
                              )}
                              {renderField(key, editingRow)}
                            </div>
                          );
                        })}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {/* Footer */}
          <div
            className="flex-shrink-0 border-t border-gray-100 bg-white px-3 pt-3"
            style={{ paddingBottom: "calc(0.75rem + env(safe-area-inset-bottom, 0px))" }}
          >
            <button
              className="h-11 w-full rounded-xl bg-gray-900 text-[13px] font-semibold text-white active:bg-gray-700"
              onClick={() => setEditingRow(null)}
            >
              Done
            </button>
          </div>
        </div>
      )}
    </>
  );
}