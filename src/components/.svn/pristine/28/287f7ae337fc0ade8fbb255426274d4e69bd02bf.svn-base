import { openDB } from "idb";

export const dbPromise = openDB("CashSalesDB", 1, {
  upgrade(db) {
    if (!db.objectStoreNames.contains("cashSales")) {
      db.createObjectStore("cashSales", {
        keyPath: "id",
      });
    }
  },
});

export async function saveOffline(data: any) {
  const db = await dbPromise;

  await db.add("cashSales", {
    ...data,
    synced: false,
    createdAt: Date.now(),
  });
}

export async function updateOfflineCashSales(id: string, updates: any) {
  const db = await dbPromise;

  const item = await db.get("cashSales", id);
  if (!item) return;

  await db.put("cashSales", {
    ...item,
    ...updates,
  });
}

export async function getOfflineCashSales() {
  const db = await dbPromise;
  return await db.getAll("cashSales");
}

export async function deleteOfflineCashSales(id: string) {
  const db = await dbPromise;
  await db.delete("cashSales", id);
}

export async function removeOfflineCashSale() {
  const db = await dbPromise;
  await db.clear("cashSales");
}

export async function markAsSynced(id: string) {
  const db = await dbPromise;
  const item = await db.get("cashSales", id);

  if (item) {
    item.synced = true;
    await db.put("cashSales", item);
  }
}