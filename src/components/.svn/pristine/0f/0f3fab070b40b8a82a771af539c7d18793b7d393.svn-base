import { Document, Page, StyleSheet, Text, View, Image,Font } from "@react-pdf/renderer";
import moment from 'moment';

let fontsRegistered = false;

if (!fontsRegistered) {
  const isDev = process.env.NODE_ENV === "development";

  Font.register({
    family: "NotoSansSC",
    fonts: [
      { src: isDev ? "/fonts/NotoSansSC-Regular.ttf" : "/view/fonts/NotoSansSC-Regular.ttf" },
      {
        src: isDev ? "/fonts/NotoSansSC-Bold.ttf" : "/view/fonts/NotoSansSC-Bold.ttf",
        fontWeight: "bold",
      },
    ],
  });

  Font.register({
    family: "NotoSansSC-Black",
    src: isDev ? "/fonts/NotoSansSC-Black.ttf" : "/view/fonts/NotoSansSC-Black.ttf",
  });

  fontsRegistered = true;
}

const styles = StyleSheet.create({
  page: {
    flexDirection: "column",
    backgroundColor: "#FFFFFF",
    padding: 30,
    fontFamily: 'NotoSansSC' // Set the default font for the entire document
  },
  logoContainer: {
    position: "absolute",
    top: 30,
    left: 30,
    width: 100,
    height: 100,
    marginBottom: 10,
    overflow: "hidden",
    padding: 0,
  },
  logoImage: {
    width: 100,
    height: 100,
  },
  header: {
    fontSize: 9,
    marginLeft: 120,
    marginBottom: 5,
    textAlign: "left",
  },
  headerRow: {
    flexDirection: "row",
  },
  headerText: {
    fontSize: 8,
    marginRight: 10,
    marginTop: 5,
  },
  sectionTitle: {
    fontSize: 16,
    fontWeight: "bold",
    textAlign: "right",
  },
  firstSeparator: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 70,
    marginBottom: 5,
  },
  table: {
    width: "100%",
    marginTop: 10,
    marginBottom: 10,
    borderStyle: "solid",
    borderColor: "#000000",
  },
  tableRow: {
    flexDirection: "row",
    borderBottomWidth: 1,
    borderColor: "#000000",
  },
  tableHeader: {
    backgroundColor: "#deebf7",
    borderTopWidth: 1,
    fontWeight: "bold",
  },
  tableCellNo: {
    padding: 5,
    fontSize: 7,
    flex: 1,
    textAlign: "center",
    borderRightWidth: 1,
    borderLeftWidth: 1,
    borderColor: "#000000",
  },
  tableCell: {
    padding: 5,
    fontSize: 7,
    flex: 4,
    textAlign: "center",
    borderRightWidth: 1,
    borderColor: "#000000",
  },
  summaryBox: {
    backgroundColor: "#deebf7",
    padding: 10,
    marginTop: 10,
    borderRadius: 2,
  },
  summaryText: {
    fontSize: 7,
  },
  summaryTextValue: {
    fontSize: 7,
    textAlign: "right",
  },
  summaryTitle: {
    fontSize: 8,
    fontWeight: "bold",
  },
  summaryField: {
    backgroundColor: "#FFFFFF", 
    padding: 3, 
    marginTop: 2, 
    borderWidth: 1, 
    borderRadius: 3,
    borderColor: "#CCCCCC",
    width: 100,
    height: 19,
  },
    footerLine: {
    width: "100%",
    height: 1,
    backgroundColor: "#000000",
    marginTop: 5,
  },
  footerContainer: {
    position: "absolute",
    bottom: 10,
    left: 30,
    right: 30,
  },
  footerText: {
    fontSize: 7,
  },
});

function renderHeader(data, type, stockReportData, styles, image64, formatDateRange) {
  return (
    <>
      <View style={styles.header}>
        <Text>{data?.currentCompany?.company ?? ""} ({data?.currentCompany?.BRN ?? ""})</Text>
        <Text style={styles.headerText}>{data?.currentCompany?.address ?? ""}</Text>
        <View style={styles.headerRow}>
          <Text style={styles.headerText}>Phone No.: {data?.currentCompany?.phoneNo ?? ""}</Text>
          <Text style={styles.headerText}>Email: {data?.currentCompany?.email ?? ""}</Text>
        </View>
      </View>
      <View>
        <View style={styles.firstSeparator} />
      </View>
      <View>
        <Text style={[styles.sectionTitle, { textAlign: "center" }]}>STOCK {type.toUpperCase()} REPORT</Text>
      </View>
      <View style={{ marginTop: 40 }}>
        <Text style={{ fontSize: 7, textAlign: "left" }}>
          Generated By: {data?.currentUser ?? ""}
        </Text>
        <Text style={{ fontSize: 7, textAlign: "left" }}>
          Date Range: {formatDateRange()}
        </Text>
      </View>
    </>
  );
}

function renderFooter(styles) {
  return (
    <View fixed style={styles.footerContainer}>
      <View style={styles.footerLine} />
      <View style={{ flexDirection: "row", justifyContent: "space-between", paddingTop: 5 }}>
        <Text style={styles.footerText}>
          Date Generated: {moment().format("DD-MM-YYYY")}
        </Text>
        <Text
          style={styles.footerText}
          render={({ pageNumber, totalPages }) => `Page ${pageNumber} of ${totalPages}`}
        />
      </View>
    </View>
  );
}

const StockReport = ({
  type,
  data,
  stockReportData,
  generatedReport,
  stockReportColumns,
}: {
  type: string;
  data?: any;
  stockReportData?: any;
  generatedReport,
  stockReportColumns?: any[];
}) => {
  let image64 = data?.currentCompany?.logoLink[0]?.base64;

  // Format the date range
  const formatDateRange = () => {
    if (!stockReportData?.startDate || !stockReportData?.endDate) return "";
    const startDate = moment.unix(Number(stockReportData.startDate)).format('DD-MM-YYYY');
    const endDate = moment.unix(Number(stockReportData.endDate)).format('DD-MM-YYYY');
    return `${startDate} to ${endDate}`;
  };

  const totalStockValue = Number(data?.summary?.totalStockCostReport) || 0;
  const totalQuantity = Number(data?.summary?.totalQuantity) || 0;
  const totalPhysicalQuantity = data?.rows?.reduce((sum, row) => sum + (parseFloat(row.totalPhysicalQuantity) || 0), 0);
  const totalVarianceQuantity = Number(data?.summary?.totalVarianceQuantity) || 0;
  const totalNoOfDocuments = data?.total;

  return (
    <Document>
      <Page size="A4" orientation="landscape" style={styles.page} wrap>
        {/* Logo - absolute position, always at top left, fixed for every page */}
        <View fixed style={styles.logoContainer}>
          {image64 ? (
            <Image
              src={{ uri: image64, method: "GET", headers: { "Cache-Control": "no-cache" }, body: "" }}
              style={styles.logoImage}
            />
          ) : null}
        </View>
        {/* Header (fixed on every page) */}
        <View fixed>{renderHeader(data, type, stockReportData, styles, image64, formatDateRange)}</View>

        {/* Dynamic Table */}
        <View style={styles.table} wrap>
          {/* Table Header (fixed on every page) */}
          <View fixed style={[styles.tableRow, styles.tableHeader]}>
            {stockReportColumns?.map((column, index) => {
              // For aging columns, use dynamic header
              if (["age1", "age2", "age3", "age4"].includes(column.accessorKey)) {
                const agingDay = stockReportData?.agingDay || "30";
                let header = "Qty";
                if (column.accessorKey === "age1") {
                  if (agingDay === "30") header = "Qty (0–30)";
                  else if (agingDay === "60") header = "Qty (0–60)";
                  else if (agingDay === "90") header = "Qty (0–90)";
                } else if (column.accessorKey === "age2") {
                  if (agingDay === "30") header = "Qty (31–60)";
                  else if (agingDay === "60") header = "Qty (61–120)";
                  else if (agingDay === "90") header = "Qty (91–180)";
                } else if (column.accessorKey === "age3") {
                  if (agingDay === "30") header = "Qty (61–90)";
                  else if (agingDay === "60") header = "Qty (121–180)";
                  else if (agingDay === "90") header = "Qty (181–270)";
                } else if (column.accessorKey === "age4") {
                  if (agingDay === "30") header = "Qty (90+)";
                  else if (agingDay === "60") header = "Qty (180+)";
                  else if (agingDay === "90") header = "Qty (270+)";
                }
                return (
                  <Text key={index} style={styles.tableCell}>{header}</Text>
                );
              }
              // Default header
              return (
                <Text key={index} style={column.header === "No" ? styles.tableCellNo : styles.tableCell}>
                  {column.header}
                </Text>
              );
            })}
          </View>
          {/* Table Rows */}
          {data?.rows?.map((item, rowIndex) => (
            <View style={styles.tableRow} wrap={false} key={item.UUID}>
              {stockReportColumns?.map((column, colIndex) => {
                // For aging columns, render value in its own cell
                if (["age1", "age2", "age3", "age4"].includes(column.accessorKey)) {
                  return (
                    <Text key={colIndex} style={styles.tableCell}>
                      {insertZeroWidthSpace(item[column.accessorKey])}
                    </Text>
                  );
                }
                // Default render for other columns
                return (
                  <Text key={colIndex} style={column.header === "No" ? styles.tableCellNo : styles.tableCell}>
                    {column.header === "No" ? rowIndex + 1 : insertZeroWidthSpace(item[column.accessorKey])}
                  </Text>
                );
              })}
            </View>
          ))}
        </View>

        {/* Summary Box: only show if type is not 'Aging' */}
        {type !== "Aging" && (
          <View style={styles.summaryBox}>
            <Text style={styles.summaryTitle}>Summary: </Text>
            <View style={{ marginTop: 5 }}>
              {type === "Item" ? (
                <>
                  <Text style={styles.summaryText}>Total Stock Value (Cost):</Text>
                  <View style={styles.summaryField}>
                    <Text style={styles.summaryTextValue}>{totalStockValue}</Text>
                  </View>
                </>
              ) : type === "Adjustment" ? (
                <>
                  <View style={{ flexDirection: "row", gap: 10 }}>
                    <View>
                      <Text style={styles.summaryText}>Total Quantity Adjusted:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total No. Of Documents:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalNoOfDocuments}</Text>
                      </View>
                    </View>
                  </View>
                </>
              ) : type === "Issued" ? (
                <>
                  <View style={{ flexDirection: "row", gap: 10 }}>
                    <View>
                      <Text style={styles.summaryText}>Total Quantity Issued:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total No. Of Documents:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalNoOfDocuments}</Text>
                      </View>
                    </View>
                  </View>
                </>
              ) : type === "Received" ? (
                <>
                  <View style={{ flexDirection: "row", gap: 10 }}>
                    <View>
                      <Text style={styles.summaryText}>Total Quantity Received:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total No. Of Documents:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalNoOfDocuments}</Text>
                      </View>
                    </View>
                  </View>
                </>
              ) : type === "Requisition" ? (
                <>
                  <View style={{ flexDirection: "row", gap: 10 }}>
                    <View>
                      <Text style={styles.summaryText}>Total Quantity Requested:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total No. Of Documents:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalNoOfDocuments}</Text>
                      </View>
                    </View>
                  </View>
                </>
              ) : type === "Take" ? (
                <>
                  <View style={{ flexDirection: "row", gap: 10 }}>
                    <View>
                      <Text style={styles.summaryText}>Total Quantity Counted:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total Variance:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalVarianceQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total No. Of Documents:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalNoOfDocuments}</Text>
                      </View>
                    </View>
                  </View>
                </>
              ) : type === "Transfer" ? (
                <>
                  <View style={{ flexDirection: "row", gap: 10 }}>
                    <View>
                      <Text style={styles.summaryText}>Total Quantity Transferred:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalQuantity}</Text>
                      </View>
                    </View>
                    <View>
                      <Text style={styles.summaryText}>Total No. Of Documents:</Text>
                      <View style={styles.summaryField}>
                        <Text style={styles.summaryTextValue}>{totalNoOfDocuments}</Text>
                      </View>
                    </View>
                  </View>
                </>
              ) : (
                <>
                  <Text style={styles.summaryText}>No Summary!</Text>
                </>
              )}
            </View>
          </View>
        )}

        {/* Footer (fixed on every page) */}
        {renderFooter(styles)}
      </Page>
    </Document>
  );
};

export default StockReport;

// Prevent overflow for long strings
function insertZeroWidthSpace(str) {
  if (typeof str !== "string") str = String(str ?? "");
  // For comma-separated values, break each part if long
  if (str.includes(",")) {
    return str.split(",").map((part, idx, arr) => {
      part = part.trim();
      // Break long numbers or alphanumerics after 8 chars
      if ((/^\d+$/.test(part) && part.length > 10) || (/^[\w\d\-]+$/.test(part) && part.length > 12)) {
        part = part.replace(/(.{10})/g, '$1-\n');
      }
      return part + (idx < arr.length - 1 ? ',\n' : '');
    }).join("");
  }
  // For long numbers only
  if (/^\d+$/.test(str) && str.length > 8) {
    return str.replace(/(.{12})/g, '$1-\n');
  }
  // For long alphanumeric strings without spaces
  if (/^[\w\d\-]+$/.test(str) && str.length > 12) {
    return str.replace(/(.{12})/g, '$1-\n');
  }
  // For Chinese characters
  return str.replace(/([\u4e00-\u9fa5])/g, '$1\u200B');
}