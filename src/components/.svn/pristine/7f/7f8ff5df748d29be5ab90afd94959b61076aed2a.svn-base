"use client";

import { HiOutlineFilter } from "react-icons/hi";

import TableHeadColumnTextFilter from "@/components/data-table/TableHeadColumnTextFilter";

import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "../ui/dropdown-menu";

import type { Table } from "@tanstack/react-table";

interface MobileActionGroupEndProps<T> {
  table: Table<T>;
  config: {
    searchColumn: string; // e.g., "docNo"
    searchPlaceholder: string; // e.g., "Search Doc No."
    sortColumn: string; // e.g., "docNo"
  };
  children?: React.ReactNode; // For additional mobile actions if needed
}

export default function MobileActionGroupEnd<T extends Record<string, any>>({
  table,
  config,
  children,
}: MobileActionGroupEndProps<T>) {
  return (
    <div className="block flex w-full items-center gap-2 md:hidden">
      <div className="min-w-[150px] flex-1 [&_input]:!h-9 [&_input]:rounded-full [&_input]:border-none [&_input]:!bg-white [&_input]:px-3 [&_input]:py-1 [&_input]:text-[10px] [&_input]:shadow-md [&_input]:outline-none [&_input]:transition-all [&_input]:duration-300 [&input]:ease-in-out">
        <TableHeadColumnTextFilter
          column={table.getColumn(config.searchColumn)}
          table={table}
          placeholder={config.searchPlaceholder}
        />
      </div>

      <DropdownMenu>
        <DropdownMenuTrigger className="flex size-7.5 shrink-0 items-center justify-center rounded-full border-2 border-transparent bg-white text-erp-blue-14 shadow-md transition-all duration-300 ease-in-out data-[state=open]:border-blue-300">
          <HiOutlineFilter className="size-3.5 text-[#1E1E1E]" />
        </DropdownMenuTrigger>
        <DropdownMenuContent className="min-w-[150px] [&_[role='menuitem']]:text-[clamp(11px,1.2vw,14px)]">
          <DropdownMenuLabel>Sort by</DropdownMenuLabel>
          <DropdownMenuSeparator />
          <DropdownMenuItem
            onClick={() => {
              table.getColumn(config.sortColumn)?.toggleSorting(false); // Asc
            }}
          >
            Ascending
          </DropdownMenuItem>
          <DropdownMenuItem
            onClick={() => {
              table.getColumn(config.sortColumn)?.toggleSorting(true); // Desc
            }}
          >
            Descending
          </DropdownMenuItem>
        </DropdownMenuContent>
      </DropdownMenu>
    </div>
  );
}
