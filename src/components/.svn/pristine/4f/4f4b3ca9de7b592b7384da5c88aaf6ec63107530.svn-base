"use client";

import React from "react";
import { FaFileImport } from "react-icons/fa6";

import { cn } from "@/lib/utils/cn";

import { useTransferFromAPI } from "./hook/useTransferFromAPI";
import { useTransferFromConfig } from "./hook/useTransferFromConfig";
import { useTransferFromState } from "./hook/useTransferFromState";
import TransferFromDetailsPopover from "./TransferFromDetailsPopover";
import TransferFromDialog from "./TransferFromDialog";
import TransferFromDocumentPopover from "./TransferFromDocumentPopover";

import type { TransferFromButtonProps } from "./types";

export default function TransferFromButton<TData>({
  table,
  id,
  config,
  slug,
  onTransferComplete,
  refreshTable,
  filterConfig, // Add filterConfig prop
  isMobile,
  forceEnabled
}: TransferFromButtonProps<TData>) {
  const processedConfig = useTransferFromConfig(config);
  const { fetchDocuments, fetchDocumentDetails } = useTransferFromAPI(processedConfig);
  const {
    dialogOpen,
    documentPopoverOpen,
    detailsPopoverOpen,
    selectedDocType,
    selectedDocUUID,
    documentsData,
    itemsData,
    setDialogOpen,
    setDocumentPopoverOpen,
    setDetailsPopoverOpen,
    setSelectedDocType,
    setSelectedDocUUID,
    setDocumentsData,
    setItemsData,
    resetState,
  } = useTransferFromState();

  const handleDialogOpen = () => {
    setDialogOpen(true);
  };

  const handleSourceSelect = async (docType: string) => {
    setSelectedDocType(docType);
    setDialogOpen(false);
    setDocumentPopoverOpen(true);

    // Fetch documents when source is selected
    const documents = await fetchDocuments(docType);
    setDocumentsData(documents);
  };

  const handleDocumentSelect = async (docUUID: string | string[]) => {
    const uuids = Array.isArray(docUUID) ? docUUID : [docUUID];

    setSelectedDocUUID(uuids[0]);
    setDocumentPopoverOpen(false);

    const results = await Promise.all(
      uuids.map(async (uuid) => {
        const items = await fetchDocumentDetails(uuid, selectedDocType);

        const sourceDoc = documentsData.find((doc) => doc.UUID === uuid);
        const sourceDocNo = sourceDoc?.docNo || "";

        return items.map((item) => ({
          ...item,
          _sourceDocUUID: uuid,
          _sourceDocNo: sourceDocNo,
        }));
      })
    );

    setItemsData(results.flat());
    setDetailsPopoverOpen(true);
  };

  const isDisabled = table ? table.getSelectedRowModel().rows.length >= 1 : slug !== "new";

  return (
    <>
      <button
        className={
          isMobile
            ? "group flex size-9 shrink-0 items-center justify-center rounded-full bg-white shadow-md"
            : "group flex flex-col items-center gap-y-1 disabled:cursor-not-allowed"
        }
        onClick={handleDialogOpen}
        disabled={forceEnabled ? false : isDisabled}
      >
        {isMobile ? (
          <FaFileImport className="size-4.5 text-erp-blue-11 group-disabled:text-erp-gray-5" />
        ) : (
          <FaFileImport
            className={cn(
              "text-erp-blue-11 group-disabled:text-erp-gray-5",
              table ? "size-5.5" : "size-4.5",
            )}
          />
        )}

        {!isMobile && (
          <span
            className={`${table ? "text-[11px]/none font-medium group-disabled:text-erp-gray-5" : "text-[11px]/none font-medium"}`}
          >
            {processedConfig.buttonText}
          </span>
        )}
      </button>

      <TransferFromDialog
        open={dialogOpen}
        setOpen={setDialogOpen}
        sources={processedConfig.sources}
        onSourceSelect={handleSourceSelect}
        title={processedConfig.dialogTitle}
        filterConfig={filterConfig} // Pass filterConfig
      />

      <TransferFromDocumentPopover
        open={documentPopoverOpen}
        setOpen={setDocumentPopoverOpen}
        setOpenDialog={setDialogOpen}
        setOpenDetailsPopover={setDetailsPopoverOpen}
        columns={processedConfig.documentColumns}
        data={documentsData}
        docType={selectedDocType}
        onDocumentSelect={handleDocumentSelect}
        fetchDocuments={fetchDocuments}
        title={processedConfig.documentPopoverTitle}
        filterConfig={filterConfig} // Pass filterConfig
      />

      <TransferFromDetailsPopover
        open={detailsPopoverOpen}
        setOpen={setDetailsPopoverOpen}
        setOpenDocumentPopover={setDocumentPopoverOpen}
        columns={processedConfig.itemColumns}
        data={itemsData}
        id={id}
        docType={selectedDocType}
        docUUID={selectedDocUUID}
        config={processedConfig}
        onTransferComplete={onTransferComplete}
        refreshTable={refreshTable}
        fetchDocumentDetails={(docUUID) =>
          fetchDocumentDetails(docUUID, selectedDocType).then(setItemsData)
        }
        title={processedConfig.detailsPopoverTitle}
      />
    </>
  );
}
