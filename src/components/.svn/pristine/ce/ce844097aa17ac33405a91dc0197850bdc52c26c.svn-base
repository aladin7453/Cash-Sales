"use client";

import { useRouter } from "next/navigation";
import { FaPenToSquare } from "react-icons/fa6";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  destination: string;
};

export default function EditButton<TData>({ table, destination }: Props<TData>) {
  const router = useRouter();

  return (
    <button
      className="group flex flex-col items-center gap-y-1 disabled:cursor-not-allowed"
      onClick={() => router.push(destination)}
      disabled={!(table.getSelectedRowModel().rows.length === 1)}
    >
      <FaPenToSquare className="size-5.5 text-erp-blue-11 group-disabled:text-erp-gray-5" />
      <span className="text-[11px]/none font-medium group-disabled:text-erp-gray-5">Edit</span>
    </button>
  );
}
