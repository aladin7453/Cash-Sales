type Props = {
  previewType: string;
  module: string;
  model: string;
  doc_id: string;
  showEInvoiceButton?: boolean;
  data?: any;
};

const fetcher = async (url: string) => {
  const headers = getAuthHeaders();

  const res = await fetch(url, { headers });

  if (!res.ok) {
    if (res.status === 401) {
      throw new Error("Session expired");
    } else {
      const error: any = new Error("Failed to fetch data");
      error.status = res.status;
      throw error;
    }
  }

  return res.json();
};

const canShowEInvoice = (documentType: string): boolean => {
  const allowedTypes = [
    "SALES INVOICE",
    "SALES CREDIT NOTE",
    "SALES DEBIT NOTE",
    "CONSOLIDATED INVOICE",
    "PURCHASE INVOICE",
    "PURCHASE DEBIT NOTE",
    "PURCHASE CREDIT NOTE",
    "CASH SALES",
  ];
  return allowedTypes.includes(documentType);
};

const canShowItemizedService = (documentType: string): boolean => {
  const allowedTypes = ["CASH SALES", "SALES INVOICE", "CONSOLIDATED INVOICE"];
  return allowedTypes.includes(documentType);
};

const canShowSummaryService = (documentType: string): boolean => {
  const allowedTypes = ["CASH SALES", "SALES INVOICE", "CONSOLIDATED INVOICE"];
  return allowedTypes.includes(documentType);
};

const canShowSummaryService2 = (documentType: string): boolean => {
  const allowedTypes = ["CASH SALES", "SALES INVOICE", "CONSOLIDATED INVOICE"];
  return allowedTypes.includes(documentType);
};

const canShowProformaInvoice = (documentType: string): boolean => {
  const allowedTypes = ["SALES ORDER"];

  return allowedTypes.includes(documentType);
};

const canShowCargoManifest = (documentType: string): boolean => {
  return documentType === "BILL OF LADING";
};

const canShowInwardManifest = (documentType: string): boolean => {
  return documentType === "BILL OF LADING";
};

const canShowTemplate1 = (documentType: string): boolean => {
  const allowedTypes = ["SALES INVOICE", "SALES DELIVERY ORDER", "CONSOLIDATED INVOICE"];

  return allowedTypes.includes(documentType);
};

const canShowQuotationMultiUOM = (documentType: string): boolean => {
  const allowedTypes = ["QUOTATION"];

  return allowedTypes.includes(documentType);
};

const canShowCargoTemplate1 = (documentType: string): boolean => {
  const allowedTypes = ["BOOKING"];

  return allowedTypes.includes(documentType);
};

const canShowCargoTemplate2 = (documentType: string): boolean => {
  const allowedTypes = ["BOOKING"];

  return allowedTypes.includes(documentType);
};

const canShowItemizedBalance = (documentType: string): boolean => {
  const allowedTypes = ["SALES DELIVERY ORDER"];

  return allowedTypes.includes(documentType);
};

const canShowNormal = (documentType: string): boolean => {
  const allowedTypes = ["CUSTOMER PAYMENT"];

  return allowedTypes.includes(documentType);
};

export default function PreviewButton({
  module,
  model,
  doc_id,
  previewType,
  showEInvoiceButton = true,
  data,
}: Props) {
  const headers = getAuthHeaders();

  const [showPreviewDialog, setShowPreviewDialog] = useState(false);
  const [showPreviewPDFDialog, setShowPreviewPDFDialog] = useState(false);
  const [showDefault1ItemizedCG, setShowDefault1ItemizedCG] = useState(false);
  const [showEInvoiceDialog, setShowEInvoiceDialog] = useState(false);
  const [showSummaryService, setShowSummaryService] = useState(false);
  const [showService2SummaryRemark1, setShowService2SummaryRemark1] = useState(false);
  const [showService4SummaryRemark1TIN, setShowService4SummaryRemark1TIN] = useState(false);
  const [showService3SummaryRemark2, setShowService3SummaryRemark2] = useState(false);
  const [showService2SummaryIDRemark1, setShowService2SummaryIDRemark1] = useState(false);
  const [showService5Summary, setShowService5Summary] = useState(false);
  const [showSummaryService2, setShowSummaryService2] = useState(false);
  const [showService2SummaryBRN, setShowService2SummaryBRN] = useState(false);
  const [showService2Summary, setShowService2Summary] = useState(false);
  const [showService2TaxSummary, setShowService2TaxSummary] = useState(false);
  const [showItemizedService, setShowItemizedService] = useState(false);
  const [showService1Itemized, setShowService1Itemized] = useState(false);
  const [showService1ItemizedRelationship, setShowService1ItemizedRelationship] = useState(false);
  const [showSimplifiedPDFDialog, setShowSimplifiedPDFDialog] = useState(false);
  const [showCargoManifestDialog, setShowCargoManifestDialog] = useState(false);
  const [showInwardManifestDialog, setShowInwardManifestDialog] = useState(false);
  const [showTemplate1Dialog, setShowTemplate1Dialog] = useState(false);
  const [showDefault2ItemizedCG, setShowDefault2ItemizedCG] = useState(false);
  const [showTemplate2Dialog, setShowTemplate2Dialog] = useState(false);
  const [showNormal2Dialog, setShowNormal2Dialog] = useState(false);
  const [showDefault1SummaryCG, setShowDefault1SummaryCG] = useState(false);
  const [showCargoTemplate1Dialog, setShowCargoTemplate1Dialog] = useState(false);
  const [showCargoTemplate2Dialog, setShowCargoTemplate2Dialog] = useState(false);
  const [showTemplate3Dialog, setShowTemplate3Dialog] = useState(false);
  const [showQuotationMultiUOMDialog, setShowQuotationMultiUOMDialog] = useState(false);
  const [showPreviewNormalPDFDialog, setShowPreviewNormalPDFDialog] = useState(false);
  const [selectedTemplate, setSelectedTemplate] = useState(1);
  const [currentBankAccount, setCurrentBankAccount] = useState(null);
  const [eInvoiceData, setEInvoiceData] = useState(null);
  const [previewData, setPreviewData] = useState(null);
  const [itemsData, setItemsData] = useState(null);
  const [currentCompanyData, setCurrentCompanyData] = useState(null);
  const [currentUser, setCurrentUser] = useState(null);
  const [PDFPreviewType, setPDFPreviewType] = useState(null);
  const [QrCode, setQrCode] = useState(null);
  const [isProformaInvoice, setIsProformaInvoice] = useState(false);
  const [eInvoiceStatus, setEInvoiceStatus] = useState(null);
  const [previewTemplatePDFData, setPreviewTemplatePDFData] = useState(null);
  const [isPreviewTemplatePDFOpen, setIsPreviewTemplatePDFOpen] = useState(false);
  const [isPDFLoading, setIsPDFLoading] = useState(false);
  const [pdfUrl, setPdfUrl] = useState<string | null>(null);
  const [documentType, setDocumentType] = useState("");

  const [showDOItemizedBalance1, setShowDOItemizedBalance1] = useState(false);
  const [showDOItemizedBalance1CG, setShowDOItemizedBalance1CG] = useState(false);

  const [showDOItemizedBalance2, setShowDOItemizedBalance2] = useState(false);
  const [showDOItemizedBalance2CG, setShowDOItemizedBalance2CG] = useState(false);

  const [totalVolume, setTotalVolume] = useState<string | null>(null);
  const [totalWeight, setTotalWeight] = useState<string | null>(null);

  const currentAccount = JSON.parse(localStorage.getItem("currentAccount") || "null");
  const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");

  // Loading states
  const [isLoadingEInvoice, setIsLoadingEInvoice] = useState(false);
  const [isLoadingPDFPreview, setIsLoadingPDFPreview] = useState(false);
  const [isLoadingSimplifiedPDF, setIsLoadingSimplifiedPDF] = useState(false);
  const [isLoadingCargoManifest, setIsLoadingCargoManifest] = useState(false);
  const [isLoadingInwardManifest, setIsLoadingInwardManifest] = useState(false);
  const [isLoadingTemplate1, setIsLoadingTemplate1] = useState(false);
  const [isLoadingTemplate2, setIsLoadingTemplate2] = useState(false);
  const [isLoadingTemplate3, setIsLoadingTemplate3] = useState(false);
  const [isLoadingNormal2, setIsLoadingNormal2] = useState(false);
  const [isLoadingCargoTemplate1, setIsLoadingCargoTemplate1] = useState(false);
  const [isLoadingCargoTemplate2, setIsLoadingCargoTemplate2] = useState(false);
  const [isLoadingQuotationMultiUOM, setIsLoadingQuotationMultiUOM] = useState(false);

  const [isMobileDevice, setIsMobileDevice] = useState(false);

  useEffect(() => {
    const ua = navigator.userAgent || "";

    const hasTouch = navigator.maxTouchPoints > 0 || "ontouchstart" in window;

    const smallScreen = window.screen.width <= 1280;

    const isDesktopUA = /Windows NT|Macintosh|X11|Linux x86_64/i.test(ua);

    // Treat touch devices with small screens as mobile/POS
    const isMobileOrPOS = hasTouch && smallScreen;

    setIsMobileDevice(isMobileOrPOS);

    console.log({
      ua,
      hasTouch,
      smallScreen,
      isDesktopUA,
      isMobileOrPOS,
      width: window.screen.width,
      height: window.screen.height,
      maxTouchPoints: navigator.maxTouchPoints,
    });
  }, []);

  let username: string = "";
  let authToken: string = "";
  let loginUser: string = "";
  username = JSON.parse(localStorage.getItem("username") || '""');
  authToken = JSON.parse(localStorage.getItem("authToken") || '""');
  loginUser = JSON.parse(localStorage.getItem("userFullName") || '"');

  const { toast } = useToast();

  const displayMessage = (response: any) => {
    if (response.status === 403) {
      toast({
        variant: "destructive",
        title: "Access Denied",
        description: "You do not have access towards this content.",
      });
    }
  };

  // Add state for description preferences
  const [descriptionPreferences, setDescriptionPreferences] = useState(() => {
    try {
      const saved = localStorage.getItem("preview.description.preference");
      return saved
        ? JSON.parse(saved)
        : {
            description: true,
            secondDescription: true,
            moreDescription: true,
          };
    } catch {
      return {
        description: true,
        secondDescription: true,
        moreDescription: true,
      };
    }
  });

  // Add state for agent preferences
  const [agentPreferences, setAgentPreferences] = useState(() => {
    try {
      const saved = localStorage.getItem("preview.agent.preference");
      return saved
        ? JSON.parse(saved)
        : {
            salesAgent: true,
            servicingAgent: true,
            collectionAgent: true,
          };
    } catch {
      return {
        salesAgent: true,
        servicingAgent: true,
        collectionAgent: true,
      };
    }
  });

  const {
    data: documentList,
    error,
    isLoading,
  } = useSWRImmutable(
    currentAccount && currentCompany
      ? `https://1ofis.infollective.com/application/backend/site/api/site/get-update-module-has-template-data?module=${previewType}&account=${currentAccount?.account}&company=${currentCompany.UUID}`
      : null,
    fetcher,
    {
      shouldRetryOnError: false,
    },
  );

  useEffect(() => {
    if (isPreviewTemplatePDFOpen && previewTemplatePDFData) {
      setIsPDFLoading(true);
      generatePdf();
    }
  }, [isPreviewTemplatePDFOpen, previewTemplatePDFData]);

  const generatePdf = async () => {
    const blob = new Blob([previewTemplatePDFData], { type: "application/pdf" });
    setPdfUrl(window.URL.createObjectURL(blob));
    setIsPDFLoading(false);
  };

  // Effect to save default preferences when dialog opens and no preference exists
  useEffect(() => {
    if (showPreviewDialog) {
      const savedDescription = localStorage.getItem("preview.description.preference");
      const savedAgent = localStorage.getItem("preview.agent.preference");

      if (!savedDescription) {
        const defaultPreferences = {
          description: true,
          secondDescription: true,
          moreDescription: true,
        };
        localStorage.setItem("preview.description.preference", JSON.stringify(defaultPreferences));
      }

      if (!savedAgent) {
        const defaultAgentPreferences = {
          salesAgent: true,
          servicingAgent: true,
          collectionAgent: true,
        };
        localStorage.setItem("preview.agent.preference", JSON.stringify(defaultAgentPreferences));
      }
    }
  }, [showPreviewDialog]);

  const previewTemplatePDF = async (documentType: string, documentName: string) => {
    setDocumentType(documentName);
    setIsPreviewTemplatePDFOpen(true);
    setIsPDFLoading(true);

    var form_data = new FormData();

    const previewData = {
      ...data,
      loginUser: loginUser,
    };

    form_data.append("previewData", JSON.stringify(previewData));
    form_data.append("UUIDs", "");
    form_data.append("docDate", "");

    const response = await axios.post(
      `https://1ofis.infollective.com/application/backend/site/api/site/preview-pdf?module=${previewType}&account=${currentAccount?.account}&company=${currentCompany.UUID}&fileName=${documentType}`,
      form_data,
      {
        method: "GET",
        responseType: "arraybuffer",
        auth: {
          username: username,
          password: authToken,
        },
      },
    );

    if (isMobileDevice) {
      const blob = new Blob([response.data], {
        type: "application/pdf",
      });

      const url = URL.createObjectURL(blob);

      setPdfUrl(url);
      setIsPDFLoading(false);
    } else {
      setPreviewTemplatePDFData(response.data);
    }
  };

  // Function to handle checkbox changes
  const handlePreferenceChange = (key: string, checked: boolean) => {
    const newPreferences = {
      ...descriptionPreferences,
      [key]: checked,
    };
    setDescriptionPreferences(newPreferences);
    localStorage.setItem("preview.description.preference", JSON.stringify(newPreferences));
  };

  // Function to handle agent checkbox changes
  const handleAgentPreferenceChange = (key: string, checked: boolean) => {
    const newPreferences = {
      ...agentPreferences,
      [key]: checked,
    };
    setAgentPreferences(newPreferences);
    localStorage.setItem("preview.agent.preference", JSON.stringify(newPreferences));
  };

  var form_data = new FormData();
  form_data.append("UUIDs[]", doc_id);

  const previewEInvoice = async () => {
    setShowEInvoiceDialog(true);
    setIsLoadingEInvoice(true);

    try {
      const response = await fetch(
        `${
          module.includes("purchase") || module.includes("supplier")
            ? `${ORIGIN}/${module}/api/${model}/preview-pdf?id=${doc_id}&type=EInvoice`
            : `${ORIGIN}/${module}/api/${model}/preview-pdf?type=EInvoice`
        }`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setEInvoiceData(responseData.data);
      setItemsData(responseData.itemsData);
      setQrCode(responseData.qrCode);
      setCurrentCompanyData(responseData.currentCompany);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingEInvoice(false);
    }
  };

  const previewItemizedServiceTemplate = async (variant: number) => {
    switch (variant) {
      case 1:
        setShowItemizedService(true);
        break;
      case 2:
        setShowService1Itemized(true);
        break;
      case 3:
        setShowService1ItemizedRelationship(true);
        break;
    }
    setIsLoadingPDFPreview(true);

    try {
      const response = await fetch(
        variant === 3
          ? `${ORIGIN}/${module}/api/${model}/preview-pdf?type=itemizedRelationshipServiceTemplate`
          : `${ORIGIN}/${module}/api/${model}/preview-pdf?type=itemizedServiceTemplate`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setPDFPreviewType(previewType);
      setPreviewData(
        previewType === "BILL OF LADING"
          ? {
              ...responseData.previewData.billOfLading,
              ...responseData.previewData.billOfLadingHasParty,
            }
          : responseData.data,
      );
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
      setQrCode(responseData.qrCode);
      setEInvoiceStatus(responseData.eInvoiceStatus);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingPDFPreview(false);
    }
  };

  const previewSummaryServiceTemplate = async (variant: number) => {
    switch (variant) {
      case 1:
        setShowSummaryService(true);
        break;
      case 2:
        setShowService2SummaryRemark1(true);
        break;
      case 3:
        setShowService4SummaryRemark1TIN(true);
        break;
      case 4:
        setShowService3SummaryRemark2(true);
        break;
      case 5:
        setShowService2SummaryIDRemark1(true);
        break;
      case 6:
        setShowService5Summary(true);
        break;
    }
    setIsLoadingPDFPreview(true);

    try {
      const response = await fetch(
        `${ORIGIN}/${module}/api/${model}/preview-pdf?type=summaryServiceTemplate1`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setPDFPreviewType(previewType);
      setPreviewData(
        previewType === "BILL OF LADING"
          ? {
              ...responseData.previewData.billOfLading,
              ...responseData.previewData.billOfLadingHasParty,
            }
          : responseData.data,
      );
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
      setQrCode(responseData.qrCode);
      setEInvoiceStatus(responseData.eInvoiceStatus);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingPDFPreview(false);
    }
  };

  const previewSummaryServiceTemplate2 = async (variant: number) => {
    switch (variant) {
      case 1:
        setShowSummaryService2(true);
        break;
      case 2:
        setShowService2SummaryBRN(true);
        break;
      case 3:
        setShowService2Summary(true);
        break;
      case 4:
        setShowService2TaxSummary(true);
    }
    setIsLoadingPDFPreview(true);

    try {
      const response = await fetch(
        `${ORIGIN}/${module}/api/${model}/preview-pdf?type=summaryServiceTemplate2`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setPDFPreviewType(previewType);
      setPreviewData(
        previewType === "BILL OF LADING"
          ? {
              ...responseData.previewData.billOfLading,
              ...responseData.previewData.billOfLadingHasParty,
            }
          : responseData.data,
      );
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
      setQrCode(responseData.qrCode);
      setEInvoiceStatus(responseData.eInvoiceStatus);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingPDFPreview(false);
    }
  };

  const previewPDFTemplate = async (variant: number) => {
    variant === 1 ? setShowPreviewPDFDialog(true) : setShowDefault1ItemizedCG(true);
    setIsLoadingPDFPreview(true);

    try {
      const response = await fetch(
        // temporarily not enable multiple preview for job and purchase
        `${module.includes("purchase") || module.includes("supplier") ? `${ORIGIN}/${module}/api/${model}/preview-pdf?id=${doc_id}&type=EInvoice` : `${ORIGIN}/${module}/api/${model}/preview-pdf?type=EInvoice`}`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setPDFPreviewType(previewType);
      setPreviewData(
        previewType === "BILL OF LADING"
          ? {
              ...responseData.previewData.billOfLading,
              ...responseData.previewData.billOfLadingHasParty,
            }
          : responseData.data,
      );
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
      setEInvoiceData(responseData.eInvoiceData);
      setQrCode(responseData.qrCode);
      setEInvoiceStatus(responseData.eInvoiceStatus);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingPDFPreview(false);
    }
  };

  const previewPDFDOItemizedTemplate1 = async (variant: number) => {
    variant === 1 ? setShowDOItemizedBalance1(true) : setShowDOItemizedBalance1CG(true);
    setIsLoadingPDFPreview(true);

    try {
      const response = await fetch(`${ORIGIN}/${module}/api/${model}/preview-pdf?type=EInvoice`, {
        method: "POST",
        headers,
        body: form_data,
      });

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setPDFPreviewType(previewType);
      setPreviewData(responseData.data);
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
      setEInvoiceData(responseData.eInvoiceData);
      setQrCode(responseData.qrCode);
      setEInvoiceStatus(responseData.eInvoiceStatus);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingPDFPreview(false);
    }
  };

  const previewPDFDOItemizedTemplate2 = async (variant: number) => {
    variant === 1 ? setShowDOItemizedBalance2(true) : setShowDOItemizedBalance2CG(true);
    setIsLoadingPDFPreview(true);

    try {
      const response = await fetch(`${ORIGIN}/${module}/api/${model}/preview-pdf?type=EInvoice`, {
        method: "POST",
        headers,
        body: form_data,
      });

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }

      const responseData = await response.json();

      setPDFPreviewType(previewType);
      setPreviewData(responseData.data);
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
      setEInvoiceData(responseData.eInvoiceData);
      setQrCode(responseData.qrCode);
      setEInvoiceStatus(responseData.eInvoiceStatus);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingPDFPreview(false);
    }
  };

  const simplifiedPDFTemplate = async () => {
    setShowSimplifiedPDFDialog(true);
    setIsLoadingSimplifiedPDF(true);

    try {
      const response = await fetch(`${ORIGIN}/${module}/api/${model}/preview-pdf`, {
        method: "POST",
        headers,
        body: form_data,
      });

      displayMessage(response);

      if (!response.ok) {
        throw new Error("Failed");
      }
      const responseData = await response.json();

      setPDFPreviewType("Invoice");
      setPreviewData(responseData.data);
      setItemsData(responseData.itemsData);
      setCurrentCompanyData(responseData.currentCompany);
      setCurrentUser(responseData.currentUser);
    } catch (error) {
      console.error("Error:", error);
    } finally {
      setIsLoadingSimplifiedPDF(false);
    }
  };

