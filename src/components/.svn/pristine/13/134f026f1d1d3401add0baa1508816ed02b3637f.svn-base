  page: {
    flexDirection: "column",
    backgroundColor: "#FFFFFF",
    padding: 30,
    fontFamily: 'NotoSansSC'
  },
  logoContainer: {
    position: "absolute",
    top: 5,
    left: 20,
    width: 100,
    height: 100,
    marginBottom: 60,
    overflow: "hidden",
    padding: 0,
  },
  logoImage: {
    width: 100,
