import clsx from "clsx";
import { ChevronLeftIcon, ChevronRightIcon } from "lucide-react";

import { DEFAULT_DATA_TABLE_PAGE_SIZE } from "@/lib/constants";

import { Button } from "../ui/button";
import { Input } from "../ui/input";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "../ui/select";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  totalNumOfRows?: number;
};

export function Pagination<TData>({ table, totalNumOfRows }: Props<TData>) {
  const paginationSelectOptions = [DEFAULT_DATA_TABLE_PAGE_SIZE, 50, 100, 200];

  const pageIndex = table.getState().pagination.pageIndex;
  const pageSize = table.getState().pagination.pageSize;
  const totalRows = totalNumOfRows ?? table.getFilteredRowModel().rows.length;
  const pageCount = table.getPageCount();

  const start = pageIndex * pageSize + 1;
  const end = Math.min((pageIndex + 1) * pageSize, totalRows);

  const renderPageButtons = () => {
    const pages = [];

    if (pageCount <= 5) {
      for (let i = 0; i < pageCount; i++) {
        pages.push(
          <Button
            key={i}
            variant="outline"
            type="button"
            className={clsx(
              "size-7 px-0",
              pageIndex === i
                ? "bg-erp-blue-14 text-white hover:bg-erp-blue-14 hover:text-white"
                : "font-normal",
            )}
            onClick={() => table.setPageIndex(i)}
          >
            {i + 1}
          </Button>,
        );
      }
    } else {
      if (pageIndex < 2) {
        for (let i = 0; i < 3; i++) {
          pages.push(
            <Button
              key={i}
              variant="outline"
              type="button"
              className={clsx(
                "size-7 px-0",
                pageIndex === i
                  ? "bg-erp-blue-14 text-white hover:bg-erp-blue-14 hover:text-white"
                  : "font-normal",
              )}
              onClick={() => table.setPageIndex(i)}
            >
              {i + 1}
            </Button>,
          );
        }
        pages.push(
          <span className="px-2 text-xs" key="ellipsis">
            ...
          </span>,
        );
        pages.push(
          <Button
            key={pageCount - 2}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(pageCount - 2)}
          >
            {pageCount - 1}
          </Button>,
        );
        pages.push(
          <Button
            key={pageCount - 1}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(pageCount - 1)}
          >
            {pageCount}
          </Button>,
        );
      } else if (pageIndex >= 2 && pageIndex <= pageCount - 3) {
        pages.push(
          <Button
            key={0}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(0)}
          >
            1
          </Button>,
        );
        if (pageIndex > 2) {
          pages.push(
            <span className="px-2 text-xs" key="start-ellipsis">
              ...
            </span>,
          );
        }
        pages.push(
          <Button
            key={pageIndex - 1}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(pageIndex - 1)}
          >
            {pageIndex}
          </Button>,
        );
        pages.push(
          <Button
            key={pageIndex}
            variant="outline"
            type="button"
            className="size-7 bg-erp-blue-14 px-0 font-normal text-white hover:bg-erp-blue-14 hover:text-white"
            onClick={() => table.setPageIndex(pageIndex)}
          >
            {pageIndex + 1}
          </Button>,
        );
        pages.push(
          <Button
            key={pageIndex + 1}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(pageIndex + 1)}
          >
            {pageIndex + 2}
          </Button>,
        );
        if (pageIndex < pageCount - 3) {
          pages.push(
            <span className="px-2 text-xs" key="end-ellipsis">
              ...
            </span>,
          );
        }
        pages.push(
          <Button
            key={pageCount - 1}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(pageCount - 1)}
          >
            {pageCount}
          </Button>,
        );
      } else {
        pages.push(
          <Button
            key={0}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(0)}
          >
            1
          </Button>,
        );
        pages.push(
          <Button
            key={1}
            variant="outline"
            type="button"
            className="size-7 px-0 font-normal"
            onClick={() => table.setPageIndex(1)}
          >
            2
          </Button>,
        );
        pages.push(
          <span className="px-2 text-xs" key="start-ellipsis">
            ...
          </span>,
        );
        for (let i = pageCount - 3; i < pageCount; i++) {
          pages.push(
            <Button
              key={i}
              variant="outline"
              type="button"
              className={clsx(
                "size-7 px-0",
                pageIndex === i
                  ? "bg-erp-blue-14 text-white hover:bg-erp-blue-14 hover:text-white"
                  : "font-normal",
              )}
              onClick={() => table.setPageIndex(i)}
            >
              {i + 1}
            </Button>,
          );
        }
      }
    }

    return pages;
  };

  return (
    <div className="flex items-center gap-x-1">
      <div className="flex items-center gap-x-2">
        <div className="text-xs">{`${start} – ${end} of ${totalRows}`}</div>
        <Select value={`${pageSize}`} onValueChange={(value) => table.setPageSize(+value)}>
          <SelectTrigger className="h-7 w-14 bg-background p-2">
            <SelectValue placeholder={pageSize} />
          </SelectTrigger>
          <SelectContent>
            {paginationSelectOptions.map((numOfRows) => (
              <SelectItem key={numOfRows} value={`${numOfRows}`}>
                {numOfRows}
              </SelectItem>
            ))}
          </SelectContent>
        </Select>
      </div>
      <Button
        variant="outline"
        size="icon"
        type="button"
        className="size-7 px-0"
        onClick={() => table.previousPage()}
        disabled={!table.getCanPreviousPage()}
      >
        <span className="sr-only">Go to previous page</span>
        <ChevronLeftIcon size={20} className="text-erp-blue-14" />
      </Button>
      {renderPageButtons()}
      <Button
        variant="outline"
        size="icon"
        type="button"
        className="size-7 px-0"
        onClick={() => table.nextPage()}
        disabled={!table.getCanNextPage()}
      >
        <span className="sr-only">Go to next page</span>
        <ChevronRightIcon size={20} className="text-erp-blue-14" />
      </Button>
      <Input
        type="number"
        placeholder="Go"
        onChange={(e) => {
          const page = e.target.value ? Number(e.target.value) - 1 : 0;
          table.setPageIndex(page);
        }}
        className="h-7 w-12 [-moz-appearance:textfield] placeholder:italic [&::-webkit-inner-spin-button]:m-0 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:m-0 [&::-webkit-outer-spin-button]:appearance-none"
      />
    </div>
  );
}
