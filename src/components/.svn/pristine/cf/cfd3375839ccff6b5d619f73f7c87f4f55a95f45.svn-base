"use client";

import React, { useRef, useState } from "react";
import { FaPaperclip, FaTrash, FaPencilAlt } from "react-icons/fa";
import { zodResolver } from "@hookform/resolvers/zod";
import { useForm } from "react-hook-form";
import { z } from "zod";
import { CalendarIcon, GripVertical } from "lucide-react";
import moment from "moment";
import { Calendar } from "@/components/ui/calendar";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { DATE_FORMAT } from "@/lib/constants";
import { Button } from "@/components/ui/button";
import { Checkbox } from "@/components/ui/checkbox";
import { cn } from "@/lib/utils/cn";
import { ScrollArea } from "@/components/ui/scroll-area";
import {
    Dialog,
    DialogContent,
    DialogHeader,
    DialogTitle,
} from "@/components/ui/dialog";
import {
    Form,
    FormControl,
    FormField,
    FormItem,
    FormLabel,
    FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import {
    Select,
    SelectContent,
    SelectItem,
    SelectTrigger,
    SelectValue,
} from "@/components/ui/select";
import { Textarea } from "@/components/ui/textarea";
import { toast } from "@/components/ui/use-toast";

export type CustomFieldType =
    | "Attachments"
    | "Check Box"
    | "Color Picker"
    | "Date"
    | "Images"
    | "Medium Text"
    | "Options"
    | "Short Text"
    | "Text Editor";

export interface CustomFieldDefinition {
    fieldKey: string;
    dataName: string;
    dataType: CustomFieldType;
    defaultValue: string;
}

const DATA_TYPES: CustomFieldType[] = [
    "Attachments",
    "Check Box",
    "Color Picker",
    "Date",
    "Images",
    "Medium Text",
    "Options",
    "Short Text",
    "Text Editor",
];

const DEFAULT_VALUES: Record<CustomFieldType, string> = {
    Attachments: "",
    "Check Box": "false",
    "Color Picker": "#FFFFFF",
    Date: String(Math.floor(Date.now() / 1000)),
    Images: "",
    "Medium Text": "",
    Options: "1,2,3",
    "Short Text": "",
    "Text Editor": "",
};

const TYPE_BADGE_CLASS: Record<CustomFieldType, string> = {
    "Short Text": "bg-blue-50 text-blue-700 border-blue-200",
    "Medium Text": "bg-blue-50 text-blue-700 border-blue-200",
    "Text Editor": "bg-blue-50 text-blue-700 border-blue-200",
    Date: "bg-green-50 text-green-700 border-green-200",
    "Check Box": "bg-teal-50 text-teal-700 border-teal-200",
    "Color Picker": "bg-amber-50 text-amber-700 border-amber-200",
    Options: "bg-purple-50 text-purple-700 border-purple-200",
    Images: "bg-orange-50 text-orange-700 border-orange-200",
    Attachments: "bg-orange-50 text-orange-700 border-orange-200",
};

const SECTIONS = [
    {
        key: "basic",
        label: "Basic Info",
        types: new Set<CustomFieldType>(["Short Text", "Date", "Medium Text"]),
    },
    {
        key: "pickers",
        label: "Selections",
        types: new Set<CustomFieldType>(["Color Picker", "Check Box", "Options"]),
    },
    {
        key: "rich",
        label: "Rich Content",
        types: new Set<CustomFieldType>(["Text Editor", "Images", "Attachments"]),
    },
] as const;

function toFieldKey(name: string): string {
    return name
        .toLowerCase()
        .replace(/\s+/g, "_")
        .replace(/[^a-z0-9_]/g, "");
}

function RowPreview({ field }: { field: CustomFieldDefinition }) {
    switch (field.dataType) {
        case "Short Text":
        case "Medium Text":
        case "Text Editor":
            return (
                <div className="flex h-6 items-center rounded border border-gray-200 bg-gray-50 px-2 text-[11px] text-gray-400 w-full max-w-[180px]">
                    {field.defaultValue || field.dataName}
                </div>
            );
        case "Date": {
            const ts = field.defaultValue ? Number(field.defaultValue) : Math.floor(Date.now() / 1000);
            return (
                <div className="inline-flex items-center gap-1.5 rounded border border-gray-200 bg-gray-50 px-2 py-0.5 text-[11px] text-gray-500">
                    <CalendarIcon className="size-3" />
                    {moment.unix(ts).format(DATE_FORMAT)}
                </div>
            );
        }
        case "Check Box": {
            const checked = field.defaultValue === "true";
            return (
                <div className="inline-flex items-center gap-1.5 text-[11px] text-gray-500">
                    <div className={cn("flex h-3.5 w-3.5 items-center justify-center rounded border text-white", checked ? "border-blue-400 bg-blue-400" : "border-gray-300 bg-white")}>
                        {checked && <span className="text-[8px]">✓</span>}
                    </div>
                    {checked ? "Yes" : "No"}
                </div>
            );
        }
        case "Color Picker": {
            const hex = field.defaultValue || "#FFFFFF";
            return (
                <div className="inline-flex items-center gap-1.5 text-[11px] text-gray-500">
                    <div className="h-4 w-4 rounded border border-gray-200" style={{ background: hex }} />
                    <span className="font-mono">{hex.toUpperCase()}</span>
                </div>
            );
        }
        case "Options": {
            const opts = (field.defaultValue || "1,2,3").split(",").map((s) => s.trim()).filter(Boolean);
            return (
                <div className="flex flex-wrap gap-1">
                    {opts.map((opt, i) => (
                        <span key={opt} className={cn("rounded-full border px-2 py-0.5 text-[10px]", i === 0 ? "border-blue-300 bg-blue-50 text-blue-600" : "border-gray-200 text-gray-500")}>
                            {opt}
                        </span>
                    ))}
                </div>
            );
        }
        case "Images":
            return (
                <div className="inline-flex items-center gap-1.5 rounded border border-dashed border-gray-200 px-2 py-0.5 text-[11px] text-gray-400">
                    <span>📷</span> Add image
                </div>
            );
        case "Attachments":
            return (
                <div className="inline-flex items-center gap-1.5 rounded border border-dashed border-gray-200 px-2 py-0.5 text-[11px] text-gray-400">
                    <FaPaperclip className="size-3" /> Attach file
                </div>
            );
        default:
            return null;
    }
}

interface DefaultValueInputProps {
    dataType: CustomFieldType;
    value: string;
    onChange: (v: string) => void;
}

function DefaultValueInput({ dataType, value, onChange }: DefaultValueInputProps) {
    switch (dataType) {
        case "Short Text":
            return (
                <div>
                    <Input value={value} maxLength={45} placeholder="Leave blank for empty" onChange={(e) => onChange(e.target.value)} className="h-8 text-sm" />
                    <p className="mt-1 text-[11px] text-gray-400">Max 45 characters</p>
                </div>
            );
        case "Medium Text":
            return (
                <div>
                    <Textarea value={value} maxLength={200} placeholder="Leave blank for empty" onChange={(e) => onChange(e.target.value)} className="h-[60px] resize-none text-sm" />
                    <p className="mt-1 text-[11px] text-gray-400">Max 200 characters</p>
                </div>
            );
        case "Text Editor":
            return <Textarea value={value} placeholder="Leave blank for empty" onChange={(e) => onChange(e.target.value)} className="h-[60px] resize-none text-sm" />;
        case "Check Box":
            return (
                <div className="flex items-center gap-x-2">
                    <Checkbox checked={value === "true"} onCheckedChange={(checked) => onChange(checked ? "true" : "false")} />
                    <span className="text-sm text-gray-500">{value === "true" ? "Checked by default" : "Unchecked by default"}</span>
                </div>
            );
        case "Date": {
            const timestamp = value ? Number(value) : Math.floor(Date.now() / 1000);
            const [open, setOpen] = useState(false);
            return (
                <Popover modal open={open} onOpenChange={(o) => {
                    setOpen(o);
                    if (!o) document.body.style.pointerEvents = "auto";
                }}>
                    <PopoverTrigger asChild>
                        <Button type="button" variant="outline" className="h-8 w-full justify-start px-3 text-sm font-normal">
                            {moment.unix(timestamp).format(DATE_FORMAT)}
                            <CalendarIcon className="ml-auto size-3.5 text-gray-400" />
                        </Button>
                    </PopoverTrigger>
                    <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                            mode="single"
                            selected={moment.unix(timestamp).toDate()}
                            onSelect={(date) => {
                                if (!date) return;
                                onChange(String(Math.floor(date.getTime() / 1000)));
                                setOpen(false);
                            }}
                            initialFocus
                            defaultMonth={moment.unix(timestamp).toDate()}
                        />
                    </PopoverContent>
                </Popover>
            );
        }
        case "Color Picker":
            return (
                <div className="flex items-center gap-x-3">
                    <input type="color" value={value || "#FFFFFF"} onChange={(e) => onChange(e.target.value)} className="h-8 w-12 cursor-pointer rounded border border-gray-200 p-0.5" />
                    <span className="font-mono text-sm text-gray-500">{(value || "#FFFFFF").toUpperCase()}</span>
                </div>
            );
        case "Options":
            return (
                <div>
                    <Input value={value} placeholder="Low,Medium,High" onChange={(e) => onChange(e.target.value)} className="h-8 text-sm" />
                    <p className="mt-1 text-[11px] text-gray-400">Comma-separated. First option is selected by default.</p>
                </div>
            );
        case "Images":
        case "Attachments":
            return <p className="text-[11px] text-gray-400">Always starts empty — no default needed.</p>;
        default:
            return null;
    }
}

const fieldFormSchema = z.object({
    dataName: z.string().min(1, "Field name is required").trim(),
    dataType: z.enum(DATA_TYPES as [CustomFieldType, ...CustomFieldType[]]),
    defaultValue: z.string().default(""),
});

type FieldFormValues = z.infer<typeof fieldFormSchema>;

interface FieldDialogProps {
    open: boolean;
    onOpenChange: (v: boolean) => void;
    initial?: CustomFieldDefinition | null;
    onSave: (def: CustomFieldDefinition) => void;
    existingKeys: string[];
}

function FieldDialog({ open, onOpenChange, initial, onSave, existingKeys }: FieldDialogProps) {
    const isEdit = Boolean(initial);
    const dialogForm = useForm<FieldFormValues>({
        resolver: zodResolver(fieldFormSchema),
        defaultValues: {
            dataName: initial?.dataName ?? "",
            dataType: initial?.dataType ?? "Short Text",
            defaultValue: initial?.defaultValue ?? "",
        },
    });

    React.useEffect(() => {
        if (open) {
            dialogForm.reset({
                dataName: initial?.dataName ?? "",
                dataType: initial?.dataType ?? "Short Text",
                defaultValue: initial?.defaultValue ?? DEFAULT_VALUES[initial?.dataType ?? "Short Text"],
            });
        }
    }, [open, initial]);

    const watchedType = dialogForm.watch("dataType");

    React.useEffect(() => {
        if (!initial || initial.dataType !== watchedType) {
            dialogForm.setValue("defaultValue", DEFAULT_VALUES[watchedType] ?? "");
        }
    }, [watchedType]);

    const handleSubmit = (values: FieldFormValues) => {
        const key = toFieldKey(values.dataName);
        if (!isEdit && existingKeys.includes(key)) {
            dialogForm.setError("dataName", { message: "A field with this name already exists." });
            return;
        }
        onSave({
            fieldKey: initial?.fieldKey ?? key,
            dataName: values.dataName,
            dataType: values.dataType,
            defaultValue: values.defaultValue ?? "",
        });
        onOpenChange(false);
    };

    const noDefault = watchedType === "Images" || watchedType === "Attachments";

    return (
        <Dialog open={open} onOpenChange={onOpenChange}>
            <DialogContent className="sm:max-w-md min-h-[400px] flex flex-col">
                <DialogHeader>
                    <DialogTitle>{isEdit ? "Edit custom field" : "Add custom field"}</DialogTitle>
                </DialogHeader>
                <Form {...dialogForm}>
                    <form onSubmit={dialogForm.handleSubmit(handleSubmit)} className="flex flex-col flex-1 gap-y-4 overflow-hidden">
                        <div className="space-y-4">
                            <FormField
                                control={dialogForm.control}
                                name="dataName"
                                render={({ field }) => (
                                    <FormItem>
                                        <FormLabel className="text-sm font-medium">Field name</FormLabel>
                                        <FormControl>
                                            <Input {...field} placeholder="e.g. Project Code" className="h-8 text-sm" />
                                        </FormControl>
                                        <FormMessage />
                                    </FormItem>
                                )}
                            />
                            <FormField
                                control={dialogForm.control}
                                name="dataType"
                                render={({ field }) => (
                                    <FormItem>
                                        <FormLabel className="text-sm font-medium">Data type</FormLabel>
                                        <Select value={field.value} onValueChange={field.onChange}>
                                            <FormControl>
                                                <SelectTrigger className="h-8 text-sm">
                                                    <SelectValue placeholder="Select type" />
                                                </SelectTrigger>
                                            </FormControl>
                                            <SelectContent>
                                                <ScrollArea className="h-[150px]" onWheel={(e) => e.stopPropagation()}>
                                                    {DATA_TYPES.map((t) => (
                                                        <SelectItem key={t} value={t} className={cn("text-sm cursor-pointer transition-colors duration-150", "hover:bg-blue-50 hover:text-blue-600", field.value === t && "bg-blue-50 text-blue-600 font-medium")}>
                                                            {t}
                                                        </SelectItem>
                                                    ))}
                                                </ScrollArea>
                                            </SelectContent>
                                        </Select>
                                        <FormMessage />
                                    </FormItem>
                                )}
                            />
                        </div>

                        <div className="flex-1">
                            {!noDefault && (
                                <FormField
                                    control={dialogForm.control}
                                    name="defaultValue"
                                    render={({ field }) => (
                                        <FormItem>
                                            <FormLabel className="text-sm font-medium">Default value</FormLabel>
                                            <FormControl>
                                                <DefaultValueInput dataType={watchedType} value={field.value ?? ""} onChange={field.onChange} />
                                            </FormControl>
                                            <FormMessage />
                                        </FormItem>
                                    )}
                                />
                            )}
                        </div>
                        <div className="flex justify-end gap-x-2 border-t pt-4">
                            <Button type="button" variant="outline" size="sm" onClick={() => onOpenChange(false)}>Cancel</Button>
                            <Button type="submit" size="sm">Save field</Button>
                        </div>
                    </form>
                </Form>
            </DialogContent>
        </Dialog >
    );
}

interface SectionTableProps {
    sectionKey: string;
    label: string;
    fields: CustomFieldDefinition[];
    allFields: CustomFieldDefinition[];
    onChange: (fields: CustomFieldDefinition[]) => void;
    onEdit: (field: CustomFieldDefinition) => void;
    onDelete: (fieldKey: string) => void;
}

function SectionTable({ sectionKey, label, fields, allFields, onChange, onEdit, onDelete }: SectionTableProps) {
    const dragIndex = useRef<number | null>(null);
    const [open, setOpen] = useState(true);

    const handleDragStart = (index: number) => {
        dragIndex.current = index;
    };

    const handleDragOver = (e: React.DragEvent, index: number) => {
        e.preventDefault();
        if (dragIndex.current === null || dragIndex.current === index) return;

        // Reorder within this section only
        const reordered = [...fields];
        const [moved] = reordered.splice(dragIndex.current, 1);
        reordered.splice(index, 0, moved);
        dragIndex.current = index;

        const sectionKeys = new Set(reordered.map((f) => f.fieldKey));
        const others = allFields.filter((f) => !sectionKeys.has(f.fieldKey));

        const firstSectionIdx = allFields.findIndex((f) => sectionKeys.has(f.fieldKey));
        const merged = [...others.slice(0, firstSectionIdx), ...reordered, ...others.slice(firstSectionIdx)];
        onChange(merged);
    };

    const handleDragEnd = () => {
        dragIndex.current = null;
    };

    return (
        <div className="overflow-hidden rounded-lg border border-gray-200 bg-white">
            <button
                type="button"
                onClick={() => setOpen((o) => !o)}
                className="flex w-full items-center justify-between border-b border-gray-100 bg-gray-50/60 px-4 py-2 text-left transition-colors hover:bg-gray-100/60"
            >
                <div className="flex items-center gap-x-2">
                    <span className="text-[11px] font-semibold uppercase tracking-wider text-gray-500">{label}</span>
                    <span className="rounded-full border border-gray-200 bg-white px-1.5 py-0.5 text-[10px] font-medium text-gray-400">
                        {fields.length}
                    </span>
                </div>
                <svg className={cn("size-3.5 text-gray-400 transition-transform duration-200", !open && "-rotate-90")} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                    <path strokeLinecap="round" strokeLinejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </button>

            {open && (
                fields.length === 0 ? (
                    <div className="flex flex-col items-center gap-y-1 py-6 text-center">
                        <span className="text-[12px] text-gray-300">No fields in this section.</span>
                    </div>
                ) : (
                    <table className="w-full border-collapse text-left">
                        <thead>
                            <tr className="border-b border-gray-100 bg-gray-50/40">
                                <th className="w-8 px-3 py-2" />
                                <th className="px-3 py-2 text-[11px] font-medium text-gray-400">Field name</th>
                                <th className="w-[130px] px-3 py-2 text-[11px] font-medium text-gray-400">Type</th>
                                <th className="w-[200px] px-3 py-2 text-[11px] font-medium text-gray-400">Preview</th>
                                <th className="w-[72px] px-3 py-2 text-center text-[11px] font-medium text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {fields.map((field, idx) => (
                                <tr
                                    key={field.fieldKey}
                                    draggable
                                    onDragStart={() => handleDragStart(idx)}
                                    onDragOver={(e) => handleDragOver(e, idx)}
                                    onDragEnd={handleDragEnd}
                                    className="group border-b border-gray-100 last:border-b-0 hover:bg-gray-50/60 transition-colors"
                                >
                                    <td className="px-3 py-2">
                                        <GripVertical className="size-3.5 text-gray-300 group-hover:text-gray-400 cursor-grab" />
                                    </td>
                                    <td className="px-3 py-2">
                                        <span className="text-[12px] font-medium text-gray-700">{field.dataName}</span>
                                    </td>
                                    <td className="px-3 py-2">
                                        <span className={cn("inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium", TYPE_BADGE_CLASS[field.dataType])}>
                                            {field.dataType}
                                        </span>
                                    </td>
                                    <td className="px-3 py-2">
                                        <RowPreview field={field} />
                                    </td>
                                    <td className="px-3 py-2">
                                        <div className="flex items-center justify-center gap-x-1">
                                            <button
                                                type="button"
                                                onClick={() => onEdit(field)}
                                                aria-label={`Edit ${field.dataName}`}
                                                className="flex h-6 w-6 items-center justify-center rounded text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600"
                                            >
                                                <FaPencilAlt className="size-3" />
                                            </button>
                                            <button
                                                type="button"
                                                onClick={() => onDelete(field.fieldKey)}
                                                aria-label={`Delete ${field.dataName}`}
                                                className="flex h-6 w-6 items-center justify-center rounded text-gray-400 transition-colors hover:bg-red-50 hover:text-red-500"
                                            >
                                                <FaTrash className="size-3" />
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                )
            )}
        </div>
    );
}

interface CustomizeFieldsProps {
    fields: CustomFieldDefinition[];
    onChange: (fields: CustomFieldDefinition[]) => void;
    maxFields?: number;
}

export function CustomizeFields({ fields, onChange, maxFields }: CustomizeFieldsProps) {
    const [dialogOpen, setDialogOpen] = useState(false);
    const [editing, setEditing] = useState<CustomFieldDefinition | null>(null);
    const existingKeys = fields.map((f) => f.fieldKey);
    const isAtLimit = maxFields !== undefined && fields.length >= maxFields;

    const handleAdd = () => { if (isAtLimit) return; setEditing(null); setDialogOpen(true); };
    const handleEdit = (field: CustomFieldDefinition) => { setEditing(field); setDialogOpen(true); };

    const handleDelete = (fieldKey: string) => {
        // onChange(fields.filter((f) => f.fieldKey !== fieldKey));
        toast({ title: "This field is currently in use and cannot be removed." });
    };

    const handleSave = (def: CustomFieldDefinition) => {
        if (editing) {
            onChange(fields.map((f) => (f.fieldKey === def.fieldKey ? def : f)));
            toast({ title: "Field updated" });
        } else {
            onChange([...fields, def]);
            toast({ title: "Field added" });
        }
    };

    const totalFields = fields.length;

    return (
        <>
            <div className="flex flex-col gap-y-3">
                {/* Top bar */}
                <div className="flex items-center justify-between">
                    <span className="rounded-full bg-blue-50 px-2 py-0.5 text-[10px] font-medium text-blue-600 border border-blue-100">
                        {totalFields} {totalFields === 1 ? "field" : "fields"}
                    </span>
                    <Button
                        type="button"
                        size="sm"
                        disabled={isAtLimit}
                        className="h-7 gap-x-1 text-[11px] bg-blue-500 hover:bg-blue-600 text-white border-none"
                        onClick={handleAdd}
                    >
                        + Add field
                    </Button>
                </div>

                {/* Limit warning */}
                {isAtLimit && (
                    <p className="text-[11px] text-amber-600 bg-amber-50 border border-amber-200 rounded-md px-3 py-1.5">
                        You've reached the maximum limit of {maxFields} fields.
                    </p>
                )}

                {/* 3 section tables */}
                {SECTIONS.map((section) => {
                    const sectionFields = fields.filter((f) => section.types.has(f.dataType));
                    return (
                        <SectionTable
                            key={section.key}
                            sectionKey={section.key}
                            label={section.label}
                            fields={sectionFields}
                            allFields={fields}
                            onChange={onChange}
                            onEdit={handleEdit}
                            onDelete={handleDelete}
                        />
                    );
                })}
            </div>

            <FieldDialog
                open={dialogOpen}
                onOpenChange={setDialogOpen}
                initial={editing}
                onSave={handleSave}
                existingKeys={existingKeys}
            />
        </>
    );
}