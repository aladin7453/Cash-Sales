"use client";

import React from "react";
import { FaFileExport } from "react-icons/fa6";

import { useTransferToAPI } from "./hooks/useTransferToAPI";
import { useTransferToConfig } from "./hooks/useTransferToConfig";
import { useTransferToState } from "./hooks/useTransferToState";
import TransferToDialog from "./TransferToDialog";
import TransferToPopover from "./TransferToPopover";

import type { TransferToButtonProps } from "./types";

export default function TransferToButton<TData>({
  table,
  id,
  config,
}: TransferToButtonProps<TData>) {
  const processedConfig = useTransferToConfig(config);
  const { fetchItems } = useTransferToAPI(processedConfig);
  const {
    dialogOpen,
    popoverOpen,
    selectedDocType,
    itemData,
    setDialogOpen,
    setPopoverOpen,
    setSelectedDocType,
    setItemData,
    resetState,
  } = useTransferToState();

  const handleDialogOpen = () => {
    setDialogOpen(true);
  };

  const handleDestinationSelect = async (docType: string) => {
    setSelectedDocType(docType);
    setDialogOpen(false);
    setPopoverOpen(true);

    // Fetch items when popover opens
    const items = await fetchItems(id);
    setItemData(items);
  };

  const isDisabled = table
    ? table.getSelectedRowModel().rows.length !== 1 ||
      table.getSelectedRowModel().rows[0].getValue("valid") !== "1"
    : false;

  return (
    <>
      <button
        className="group flex flex-col items-center gap-y-1 disabled:cursor-not-allowed"
        onClick={handleDialogOpen}
        disabled={isDisabled}
      >
        <FaFileExport
          className={`${table ? "size-5.5" : "size-4.5"} text-erp-blue-11 group-disabled:text-erp-gray-5`}
        />
        <span
          className={`${table ? "text-[11px]/none" : "text-[11px]/none"} font-medium group-disabled:text-erp-gray-5`}
        >
          {processedConfig.buttonText}
        </span>
      </button>

      <TransferToDialog
        open={dialogOpen}
        setOpen={setDialogOpen}
        destinations={processedConfig.destinations}
        onDestinationSelect={handleDestinationSelect}
        title={processedConfig.dialogTitle}
      />

      <TransferToPopover
        open={popoverOpen}
        setOpen={setPopoverOpen}
        columns={processedConfig.columns}
        data={itemData}
        fetchItems={() => fetchItems(id).then(setItemData)}
        id={id}
        docType={selectedDocType}
        config={processedConfig}
      />
    </>
  );
}
