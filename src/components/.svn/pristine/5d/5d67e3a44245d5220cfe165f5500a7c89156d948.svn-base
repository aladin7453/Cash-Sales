"use client";

import clsx from "clsx";
import React, { useState } from "react";
import { FaFileExport } from "react-icons/fa6";

import { toast } from "@/components/ui/use-toast";
import { getAuthHeaders, ORIGIN, TOOLTIP_DELAY_DURATION } from "@/lib/constants";
import { showLoadingToast } from "@/lib/utils/showLoadingToast";

import { Button } from "../ui/button";
import { Input } from "../ui/input";
import { Label } from "../ui/label";
import { Popover, PopoverContent, PopoverTrigger } from "../ui/popover";
import { RadioGroup, RadioGroupItem } from "../ui/radio-group";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "../ui/select";
import { Separator } from "../ui/separator";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "../ui/tooltip";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  module?: string; // Add module prop for API endpoint
  mainModule?: string; // new prop for main module
};

type ExportRangeOptions = "option-all" | "option-page" | "option-row";

export default function Export<TData>({ table, module, mainModule }: Props<TData>) {
  const inputNumberStyle = clsx("h-7 w-20 text-black disabled:bg-erp-gray-8");

  const [selectedValue, setSelectedValue] = useState<ExportRangeOptions>("option-all");
  const [selectedFormat, setSelectedFormat] = useState("normal");

  const [pageFrom, setPageFrom] = useState("1");
  const [pageTo, setPageTo] = useState("1");
  const [rowFrom, setRowFrom] = useState("1");
  const [rowTo, setRowTo] = useState("1");

  if (!module) {
    return null;
  }

  const totalPages = table.getPageCount();
  const totalDisplayedRows = table.getRowModel().rows.length;

  const handleValueChange = (value: ExportRangeOptions) => {
    setSelectedValue(value);
  };

  const handleExportFile = async (type: string) => {
    if (!module) return;

    const { id, dismiss } = showLoadingToast("Downloading...");

    try {
      const headers = getAuthHeaders();
      const exportUrl = `${ORIGIN}/universal/export-excel?generateType=${selectedFormat}&fileType=${type}`;
      const formData = new FormData();
      const pagination = table.getState().pagination;

      formData.append("param[itemType]", "itemDetails");
      formData.append("param[module]", module);

      if (mainModule) {
        formData.append("param[mainModule]", mainModule);
      }

      const columnFilters = table.getState().columnFilters || [];
      const sorting = table.getState().sorting || [];

      const validFilter = columnFilters.find((row) => row.id === "valid");
      const validValue = validFilter ? `${validFilter.value}` : "";

      formData.append("param[valid]", validValue);

      const columnFiltersWithoutValid = columnFilters.filter((f) => f.id !== "valid");

      const filteredRows = table.getFilteredRowModel().rows;

      let exportType = "all";

      if (selectedValue === "option-page") {
        exportType = "page";
      } else if (selectedValue === "option-row") {
        exportType = "row";

        const currentPageIndex = pagination.pageIndex;
        const pageSize = pagination.pageSize;
        const startOffset = currentPageIndex * pageSize;

        const from = startOffset + (parseInt(rowFrom, 10) - 1);
        const to = startOffset + (parseInt(rowTo, 10) - 1);

        for (let i = from; i <= to; i++) {
          if (filteredRows[i]?.original?.UUID) {
            formData.append("param[UUIDs][]", filteredRows[i].original.UUID);
          }
        }
      }

      formData.append("param[exportType]", exportType);

      if (columnFiltersWithoutValid.length > 0) {
        formData.append(
          "param[filter]",
          JSON.stringify(
            columnFiltersWithoutValid.reduce((acc, curr) => {
              acc[curr.id] = curr.value;
              return acc;
            }, {}),
          ),
        );
      }

      formData.append(
        "param[sort]",
        sorting.length > 0 && sorting[0].id !== "totalRecord" ? sorting[0].id : "createdAt",
      );

      formData.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      if (selectedValue === "option-page") {
        const pageSize = pagination.pageSize;
        const fromPage = parseInt(pageFrom, 10);
        const toPage = parseInt(pageTo, 10);

        const limit = (toPage - fromPage + 1) * pageSize;
        const offset = (fromPage - 1) * pageSize;

        formData.append("param[limit]", `${limit}`);
        formData.append("param[offset]", `${offset}`);
      }

      const response = await fetch(exportUrl, {
        method: "POST",
        headers,
        body: formData,
      });

      const data = await response.json();

      if (data.link || data.file) {
        window.location.href = data.link || data.file;

        toast({
          title: "Export successful",
          description: "Your file is being downloaded",
        });
      } else {
        toast({
          title: "Export Failed",
          description: data.message || "Something went wrong. Please try again.",
          variant: "destructive",
        });
      }
    } catch (error) {
      console.error("Error during export:", error);
    } finally {
      dismiss();
    }
  };

  return (
    <Popover>
      <TooltipProvider delayDuration={TOOLTIP_DELAY_DURATION}>
        <Tooltip>
          <TooltipTrigger asChild>
            <PopoverTrigger asChild>
              <div className="mx-1 flex flex-col items-center">
                <Button
                  variant="ghost"
                  size="icon"
                  className="size-8 hover:text-erp-blue-14 aria-expanded:bg-erp-blue-14 aria-expanded:text-white"
                >
                  <FaFileExport className="size-5.5" />
                </Button>
                <span className="text-[11px]/none font-medium text-black">Export</span>
              </div>
            </PopoverTrigger>
          </TooltipTrigger>
          <TooltipContent>
            <p className="font-medium">Export</p>
          </TooltipContent>
        </Tooltip>
      </TooltipProvider>
      <PopoverContent className="w-[22rem]" align="end">
        <div className="flex flex-col gap-y-4 text-erp-blue-14">
          <div className="space-y-4">
            <h4 className="font-semibold leading-none">Export</h4>

            {module === "salesInvoice" && (
              <>
                <div>
                  <Select value={selectedFormat} onValueChange={setSelectedFormat}>
                    <SelectTrigger id="format-select" className="w-full">
                      <SelectValue placeholder="Select Format" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="normal">Sales Invoice (General Format)</SelectItem>
                      <SelectItem value="sqlFormat">Sales Invoice (SQL Sales Invoice)</SelectItem>
                      <SelectItem value="sqlCustomerFormat">
                        Sales Invoice (SQL Customer Invoice)
                      </SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </>
            )}

            <p className="text-sm text-muted-foreground">
              Choose the range and file type to download.
            </p>
          </div>
          <RadioGroup value={selectedValue} onValueChange={handleValueChange}>
            <div className="flex h-7 items-center gap-x-2">
              <RadioGroupItem value="option-all" id="option-all" />
              <Label htmlFor="option-all">All</Label>
            </div>
            <div className="flex items-center gap-x-2">
              <RadioGroupItem value="option-page" id="option-page" />
              <div className="flex w-full items-center justify-between">
                <Label htmlFor="option-page">Page</Label>
                <div className="flex items-center gap-x-2">
                  <Input
                    value={pageFrom}
                    onChange={(e) => setPageFrom(e.target.value)}
                    className={inputNumberStyle}
                    type="number"
                    disabled={selectedValue !== "option-page"}
                    min={1}
                    max={totalPages}
                    onBlur={(e) => {
                      let val = Number(e.target.value);

                      if (val < 1) val = 1;
                      else if (val > totalPages) val = totalPages;

                      setPageFrom(String(val));

                      if (Number(pageTo) < val) {
                        setPageTo(String(val));
                      }
                    }}
                  />
                  <span className="text-sm">to</span>
                  <Input
                    value={pageTo}
                    onChange={(e) => setPageTo(e.target.value)}
                    className={inputNumberStyle}
                    type="number"
                    disabled={selectedValue !== "option-page"}
                    min={Number(pageFrom) || 1}
                    max={totalPages}
                    onBlur={(e) => {
                      let val = Number(e.target.value);

                      if (val < Number(pageFrom)) val = Number(pageFrom);
                      else if (val > totalPages) val = totalPages;

                      setPageTo(String(val));
                    }}
                  />
                </div>
              </div>
            </div>
            <div className="flex items-center gap-x-2">
              <RadioGroupItem value="option-row" id="option-row" />
              <div className="flex w-full items-center justify-between">
                <Label htmlFor="option-row">Row</Label>
                <div className="flex items-center gap-x-2">
                  <Input
                    value={rowFrom}
                    onChange={(e) => setRowFrom(e.target.value)}
                    className={inputNumberStyle}
                    type="number"
                    disabled={selectedValue !== "option-row"}
                    min={1}
                    max={totalDisplayedRows}
                    onBlur={(e) => {
                      let val = Number(e.target.value);

                      if (val < 1) val = 1;
                      else if (val > totalDisplayedRows) val = totalDisplayedRows;

                      setRowFrom(String(val));

                      if (Number(rowTo) < val) {
                        setRowTo(String(val));
                      }
                    }}
                  />
                  <span className="text-sm">to</span>
                  <Input
                    value={rowTo}
                    onChange={(e) => setRowTo(e.target.value)}
                    className={inputNumberStyle}
                    type="number"
                    disabled={selectedValue !== "option-row"}
                    min={Number(rowFrom) || 1}
                    max={totalDisplayedRows}
                    onBlur={(e) => {
                      let val = Number(e.target.value);

                      if (val < Number(rowFrom)) val = Number(rowFrom);
                      else if (val > totalDisplayedRows) val = totalDisplayedRows;

                      setRowTo(String(val));
                    }}
                  />
                </div>
              </div>
            </div>
          </RadioGroup>

          <Separator />

          <div className="flex justify-evenly">
            <Button
              variant="ghost"
              size="sm"
              className="h-8 border border-erp-blue-13 hover:bg-erp-blue-13 hover:text-white"
              onClick={() => handleExportFile("xls")}
            >
              Download .xls
            </Button>
            {module === "salesInvoice" && (
              <Button
                variant="ghost"
                size="sm"
                className="h-8 border border-erp-blue-13 hover:bg-erp-blue-13 hover:text-white"
                onClick={() => handleExportFile("csv")}
              >
                Download .csv
              </Button>
            )}
          </div>
        </div>
      </PopoverContent>
    </Popover>
  );
}
