"use client";

import type { Row, Table as TableType } from "@tanstack/react-table";
import { cn } from "@/lib/utils/cn";
import Skeleton from "@/components/ui/skeleton";

interface MobileDataTableProps<T> {
  table: TableType<T>;
  renderCard: (row: Row<T>) => React.ReactNode;
  className?: string;
  isLoading?: boolean;
  skeletonCount?: number;
}

export default function MobileDataTable<T>({
  table,
  renderCard,
  className,
  isLoading = true,
  skeletonCount = 6,
}: MobileDataTableProps<T>) {
  const rows = table.getRowModel().rows;

  if (isLoading) {
    return (
      <div className={cn("block space-y-2 px-2 md:hidden", className)}>
        {Array.from({ length: skeletonCount }).map((_, i) => (
          <div
            key={i}
            className="w-full rounded-lg border bg-white shadow-sm p-3"
          >
            <div className="flex items-center justify-between">
              <Skeleton className="h-3 w-[80px]" />
              <Skeleton className="h-4 w-4 rounded-full" />
            </div>
            <div className="flex items-center justify-between mt-1.5">
              <Skeleton className="h-5 w-[150px]" />
              <Skeleton className="h-5 w-[70px] rounded-2xl" />
            </div>
            <div className="grid grid-cols-3 gap-x-3 mt-2">
              <Skeleton className="h-4 w-full" />
              <Skeleton className="h-4 w-full" />
              <Skeleton className="h-4 w-full" />
            </div>
            <hr className="mt-2" />
            <div className="grid grid-cols-[1fr_auto] items-end mt-3 gap-x-3">
              <div className="flex flex-col gap-y-2">
                <Skeleton className="h-4 w-[150px]" />
                <Skeleton className="h-4 w-[150px]" />
                <Skeleton className="h-4 w-[150px]" />
              </div>
              <div className="flex flex-col gap-y-1 items-end">
                <Skeleton className="h-3 w-[60px]" />
                <Skeleton className="h-5 w-[100px]" />
              </div>
            </div>
          </div>
        ))}
      </div>
    );
  } else if (rows.length === 0) {
    return (
      <div className="absolute z-[30] flex justify-center items-center w-full h-full md:hidden">
        <p>No data</p>
      </div>
    );
  }

  return (
    <div className={cn("block space-y-2 px-2 md:hidden", className)}>
      {table.getRowModel().rows.map((row) => (
        <div key={row.id}>{renderCard(row)}</div>
      ))}
    </div>
  );
}
