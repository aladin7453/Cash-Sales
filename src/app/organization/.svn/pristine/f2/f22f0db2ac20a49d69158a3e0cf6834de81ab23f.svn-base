"use client";

import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import type { ColumnDef } from "@tanstack/react-table";

export type UserList = {
  UUID: string;
  user: string;
  employeeID: string;
  company: string;
  department: string;
  jobTitle: string;
  location: string;
  employmentType: string;
  supervisor: string;
  mentor: string;
  startDate: string;
  endDate: string;
  exitReason: string;
  remark: string;
  attachment: string;
  createdAt: string;
  createdBy: string;
  updatedAt: string;
  updatedBy: string;
  valid: "0" | "1";
  _version: string;
  _actionUUID: string;
  Username: string;
  fullname: string;
  title: string;
  phoneNo: string;
  email: string;
  companyName: string;
  departmentName: string;
  jobTitleName: string;
  locationName: string;
  createdAtFormat: string;
  updatedAtFormat: string;
  CreatedByUsername: string;
  UpdatedByUsername: string;
  accessControl: string;
};

export const userListColumns: ColumnDef<UserList>[] = [
  {
    accessorKey: "Username",
    header: "Username",
    filterFn: "includesString",
  },
  {
    accessorKey: "fullname",
    header: "Full Name",
    filterFn: "includesString",
  },
  {
    accessorKey: "title",
    header: "Title",
    filterFn: "includesString",
  },
  {
    accessorKey: "phoneNo",
    header: "Phone Number",
    filterFn: "includesString",
  },
  {
    accessorKey: "email",
    header: "Email",
    filterFn: "includesString",
  },
  {
    accessorKey: "departmentName",
    header: "Department",
    filterFn: "includesString",
  },
  {
    accessorKey: "jobTitleName",
    header: "Job Title",
    filterFn: "includesString",
  },
  {
    accessorKey: "locationName",
    header: "Location",
    filterFn: "includesString",
  },
  {
    accessorKey: "companyName",
    header: "Base Company",
    filterFn: "includesString",
  },
  {
    accessorKey: "createdAtFormat",
    header: "Created At",
    filterFn: "includesString",
  },
  {
    accessorKey: "CreatedByUsername",
    header: "Created By",
    filterFn: "includesString",
  },
  {
    accessorKey: "updatedAtFormat",
    header: "Updated At",
    filterFn: "includesString",
  },
  {
    accessorKey: "UpdatedByUsername",
    header: "Updated By",
    filterFn: "includesString",
  },
  {
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as UserList["valid"];
      return validity ? "Valid" : "Invalid";
    },
    // Custom filter function that first convert the row's numeric boolean
    // value to string, then check if the string contains the filterValue
    filterFn: filterWithStringConversion,
  },
  {
    id: "accessControl",
    accessorKey: "accessControl",
    header: "Access Control",
    filterFn: "includesString",
  },
];
