import TreeView, { flattenTree } from "react-accessible-treeview";
import { FaCheckSquare, FaMinusSquare, FaSquare } from "react-icons/fa";
import { FaAngleDown, FaAngleUp } from "react-icons/fa6";
import { React } from "react"
import { Input } from "@/components/ui/input";
import { cn } from "@/lib/utils/cn";

import { modules } from "./modules";

const data = flattenTree(modules);

export default function ModuleTreeView() {
  return (
    <div>
      <div className="box-content select-none p-5">
        <TreeView
          data={data}
          multiSelect
          propagateSelect
          propagateSelectUpwards
          togglableSelect
          onKeyDown={(evt) => {
            evt.stopPropagation();
          }}
          nodeRenderer={({
            element,
            isBranch,
            isExpanded,
            isSelected,
            isHalfSelected,
            getNodeProps,
            level,
            handleSelect,
            handleExpand,
          }) => {
            return (
              <div
                {...getNodeProps({ onClick: handleExpand })}
                className="mb-1.5 flex items-center gap-x-4"
                style={{ marginLeft: 40 * (level - 1) }}
              >
                <CheckBoxIcon
                  className={cn(
                    "size-6 cursor-pointer align-middle",
                    isSelected || isHalfSelected ? "text-erp-blue-12" : "text-white",
                  )}
                  onClick={(e: any) => {
                    handleSelect(e);
                    e.stopPropagation();
                  }}
                  variant={isHalfSelected ? "some" : isSelected ? "all" : "none"}
                />
                <div className="flex w-full items-center justify-between rounded-md bg-white px-4 py-3 ring-1 ring-erp-gray-3">
                  <div className="flex basis-3/4 items-center gap-x-3">
                    {isBranch && <ArrowIcon isOpen={isExpanded} className="text-erp-blue-11" />}
                    <span className={cn("text-sm text-gray-700", level === 1 && "font-semibold")}>
                      {element.name}
                    </span>
                  </div>
                  <div className="flex basis-1/4 items-center gap-x-2">
                    {isBranch ? <PriceDisplay /> : <PriceInput />}
                    {isBranch ? <PriceDisplay /> : <PriceInput />}
                  </div>
                </div>
              </div>
            );
          }}
        />
      </div>
    </div>
  );
}

function PriceDisplay() {
  return (
    <div className="flex h-7 w-full gap-x-0.5 px-3 py-2 text-right text-sm">
      <span className="text-erp-blue-12">1000.00</span>
      <span className="text-red-500">(-100.00)</span>
    </div>
  );
}

function PriceInput() {
  return (
    <Input type="number" className={cn("h-7 text-right")} onClick={(e) => e.stopPropagation()} />
  );
}

const ArrowIcon = ({ isOpen, className }: { isOpen: boolean; className?: string }) => {
  return isOpen ? <FaAngleUp className={className} /> : <FaAngleDown className={className} />;
};

const CheckBoxIcon = ({
  variant,
  ...rest
}: {
  variant: "all" | "none" | "some";
  [key: string]: any;
}) => {
  switch (variant) {
    case "all":
      return <FaCheckSquare {...rest} />;
    case "none":
      return <FaSquare {...rest} />;
    case "some":
      return <FaMinusSquare {...rest} />;
    default:
      return null;
  }
};
