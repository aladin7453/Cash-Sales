"use client";

import React, { useEffect, useState } from "react";
import { FaMinus, FaPlus } from "react-icons/fa6";
import ConfirmationDialog from "./ConfirmationDialog";
import { notFound, useSearchParams } from "next/navigation";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import { useToast } from "@/components/ui/use-toast";
import { Button } from "@/components/ui/button";
import {
  Tooltip,
  TooltipTrigger,
  TooltipContent,
  TooltipProvider,
} from "@/components/ui/tooltip";
import type { Table } from "@tanstack/react-table";
import { AssetAssignmentDetails } from "./columns";

type Props<TData> = {
  table: Table<TData>;
  onAdd?: () => void;
  revalidateAssetAssignmentDetails: () => void;
  setTempRowAssetAssignmentDetails: () => void;
  setTempRowAssetAssignmentDetailsData: (data: any, overwrite: boolean) => void;
  tempRowAssetAssignmentDetails: any;
};

export default function AssetAssignmentDetailsDataTableToolbar<TData>({
  table,
  onAdd,
  tempRowAssetAssignmentDetails,
  setTempRowAssetAssignmentDetailsData,
  setTempRowAssetAssignmentDetails,
  revalidateAssetAssignmentDetails,
}: Props<TData>) {
  const headers = getAuthHeaders();
  const { toast } = useToast();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");

  const [showConfirmationDialog, setShowConfirmationDialog] = useState(false);

  const handleDeleteConfirmation = async () => {
    // Perform deletion logic here
    var form_data = new FormData();
    const selectedRows = table.getSelectedRowModel().rows;

    const deletedIndex = selectedRows.map((item) => item.index);
    const updatedData = [...tempRowAssetAssignmentDetails];
    const filteredData = updatedData.filter(
      (item, key) => !deletedIndex.includes(key)
    );
    setTempRowAssetAssignmentDetails(filteredData);
    selectedRows.forEach((row, index) => {
      if (row["original"]["UUID"]) {
        form_data.append(`UUIDs[]`, row["original"]["UUID"]);
      }
    });

    const consistUUID = selectedRows.filter((item) => {
      return item.original.UUID;
    });

    if (id) {
      setShowConfirmationDialog(false);
    } else {
      const deletedIndex = selectedRows.map((item) => {
        return item.index;
      });
      const remainRows = tempRowAssetAssignmentDetails.filter(
        (item, index) => !deletedIndex.includes(index)
      );
      setTempRowAssetAssignmentDetailsData(remainRows, true);
      setShowConfirmationDialog(false);
    }
  };

  const handleAddRow = () => {
    var newRow = {
      asset: "",
      quantity: "1",
      locationCode: "",
      remark1: "",
      remark2: "",
      project: "",
      attachment: "",
    };
    setTempRowAssetAssignmentDetailsData(newRow, false);
  };

  return (
    <>
      <div className="flex items-center justify-between p-1.5">
        <div className="flex items-center gap-x-1 pl-2">
          <div className="flex items-center gap-x-1 text-erp-blue-14">
            <div className="flex flex-col items-center">
              <TooltipProvider delayDuration={0}>
                <Tooltip>
                  <TooltipTrigger asChild>
                    <Button
                      className="size-8"
                      variant="ghost"
                      size="icon"
                      onClick={handleAddRow}
                    >
                      <FaPlus className="size-5.5" />
                    </Button>
                  </TooltipTrigger>
                  <TooltipContent>Add asset assignment</TooltipContent>
                </Tooltip>
              </TooltipProvider>
              <span className="text-[11px]/none font-medium text-black">
                Add
              </span>
            </div>

            {/* Remove Button */}
            <div className="flex flex-col items-center">
              <Button
                className="size-8"
                variant="ghost"
                size="icon"
                onClick={() => setShowConfirmationDialog(true)}
              >
                <FaMinus className="size-5.5" />
              </Button>
              <span className="text-[11px]/none font-medium text-black">
                Remove
              </span>
            </div>
          </div>
        </div>

        {/* Pagination Section */}
        <Pagination table={table} />

        {/* ActionGroupEnd */}
        <div className="flex items-center gap-x-3 pr-2 text-erp-blue-14">
          {/* Other actions */}
          <Refresh refreshTable={revalidateAssetAssignmentDetails} />
          <ColumnVisibilityToggle table={table} />
        </div>
      </div>
      <ConfirmationDialog
        open={showConfirmationDialog}
        setOpen={setShowConfirmationDialog}
        onConfirm={handleDeleteConfirmation}
      />
    </>
  );
}
