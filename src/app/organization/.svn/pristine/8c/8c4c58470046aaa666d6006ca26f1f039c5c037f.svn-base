"use client";

import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import type { ColumnDef } from "@tanstack/react-table";

export type ContactDetails = {
  UUID: string;
  user: string;
  contact: string;
  title: string;
  relationship: string;
  phoneNo: string;
  email: string;
  address: any;
  attachment: string;
  description: any;
  createdAt: string;
  createdBy: string;
  updatedAt: string;
  updatedBy: string;
  valid: "0" | "1";
  _version: string;
  _actionUUID: string;
  createdAtFormat: string;
  updatedAtFormat: string;
  createdByUsername: string;
  updatedByUsername: string;
  attachmentLink: Array<{
    name: string;
    link: string;
  }>;
};

export const ContactDetailsColumns: ColumnDef<ContactDetails>[] = [
  {
    accessorKey: "contact",
    header: "Contact",
    filterFn: "includesString",
  },
  {
    accessorKey: "title",
    header: "Title",
    filterFn: "includesString",
  },
  {
    accessorKey: "relationship",
    header: "Relationship",
    filterFn: "includesString",
  },
  {
    accessorKey: "phoneNo",
    header: "Phone",
    filterFn: "includesString",
  },
  {
    accessorKey: "email",
    header: "Email",
    filterFn: "includesString",
  },
  {
    accessorKey: "address",
    header: "Address",
    filterFn: "includesString",
  },
  {
    accessorKey: "attachment",
    header: "Attachment (.pdf, .png, .jpg, .jpeg)",
    cell: ({ row }) => {
      const tempFiles = row.original.attachmentFiles;
      if (tempFiles && tempFiles.length > 0) {
        return tempFiles
          .map((file, index) => {
            // Create a blob URL for preview
            const fileUrl = URL.createObjectURL(file);
            return (
              <a
                key={`temp-${index}`}
                href={fileUrl}
                target="_blank"
                rel="noopener noreferrer"
                style={{ color: "blue", marginRight: "5px" }}
                onClick={(e) => {
                  // Cleanup URL object after navigation starts
                  setTimeout(() => URL.revokeObjectURL(fileUrl), 1000);
                }}
              >
                {file.name}
              </a>
            );
          })
          .reduce((prev, curr) => [prev, ", ", curr]);
      }

      const attachments = JSON.parse(row.original.attachment);
      const attachmentLinks = row.original.attachmentLink;

      return attachments && attachments.length > 0 ? (
        attachments
          .map((att, index) => {
            const link = attachmentLinks.find((al) => al.name === att.Name);
            return link ? (
              <a
                key={index}
                href={link.link}
                target="_blank"
                rel="noopener noreferrer"
                style={{ color: "blue" }}
              >
                {att.Name}
              </a>
            ) : (
              <span key={index}>{att.Name}</span>
            );
          })
          .reduce((prev, curr) => [prev, ", ", curr])
      ) : (
        <span>No attachment</span>
      );
    },
    filterFn: "includesString",
  },
  {
    accessorKey: "description",
    header: "Remark",
    filterFn: "includesString",
  },
  {
    accessorKey: "createdAtFormat",
    header: "Created At",
    filterFn: "includesString",
  },
  {
    accessorKey: "createdByUsername",
    header: "Created By",
    filterFn: "includesString",
  },
  {
    accessorKey: "updatedAtFormat",
    header: "Updated At",
    filterFn: "includesString",
  },
  {
    accessorKey: "updatedByUsername",
    header: "Updated By",
    filterFn: "includesString",
  },
  {
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as ContactDetails["valid"];
      return validity === "1" ? "Valid" : "Invalid";
    },
    filterFn: filterWithStringConversion,
  },
];
