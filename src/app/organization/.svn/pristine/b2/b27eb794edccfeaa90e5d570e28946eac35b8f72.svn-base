    accessorKey: "nationality",
    header: "Nationality",
    filterFn: "includesString",
  },
  {
    id: "race",
    accessorKey: "race",
    header: "Race",
    filterFn: "includesString",
  },
  {
    id: "religion",
    accessorKey: "religion",
    header: "Religion",
    filterFn: "includesString",
  },
  {
    id: "maritalStatus",
    accessorKey: "maritalStatus",
    header: "Marital Status",
    filterFn: "includesString",
  },
  {
    id: "phoneNo",
    accessorKey: "phoneNo",
    header: "Phone No.",
    filterFn: "includesString",
  },
  {
    id: "email",
    accessorKey: "email",
    header: "Email",
    filterFn: "includesString",
  },
  {
    id: "address",
    accessorKey: "address",
    header: "Address",
    filterFn: "includesString",
  },
  {
    id: "webAccess",
    accessorKey: "webAccess",
    header: "Web Access",
    cell: ({ row }) => {
      const validity = row.getValue("webAccess") as User["webAccess"];
      return validity === "1" ? "Access" : "Denied";
    },
    filterFn: "includesString",
  },
  {
    id: "licenseNo",
    accessorKey: "licenseNo",
    header: "License No.",
    filterFn: "includesString",
  },
  {
    id: "lastRenewalDateFormat",
    accessorKey: "lastRenewalDateFormat",
    header: "Last Renewal Date",
    accessorFn: (row) => toStringAccessorFn(row, "lastRenewalDateFormat"),
    filterFn: "includesString",
  },
  {
    id: "expirationDateFormat",
    accessorKey: "expirationDateFormat",
    header: "Expiration Date",
    accessorFn: (row) => toStringAccessorFn(row, "expirationDateFormat"),
    filterFn: "includesString",
  },
  // {
  //   id: "vehicleOwner",
  //   accessorKey: "vehicleOwner",
  //   header: "Vehicle Owner",
  // },
  // {
  //   id: "plateNo",
