  {
    id: "createdAtFormat",
    accessorKey: "createdAtFormat",
    header: "Created at",
    accessorFn: (row) => toStringAccessorFn(row, "createdAtFormat"),
    filterFn: "includesString",
  },
  {
    id: "createdByUsername",
    accessorKey: "createdByUsername",
    header: "Created by",
    filterFn: "includesString",
  },
  {
    id: "updatedAtFormat",
    accessorKey: "updatedAtFormat",
    header: "Updated at",
    accessorFn: (row) => toStringAccessorFn(row, "updatedAtFormat"),
    filterFn: "includesString",
  },
  {
    id: "updatedByUsername",
    accessorKey: "updatedByUsername",
    header: "Updated by",
    filterFn: "includesString",
  },
  {
    id: "role",
    accessorKey: "role",
    header: "Role",
    filterFn: "includesString",
  },
  {
    id: "valid",
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as User["valid"];
      return validity === "1" ? "Valid" : "Invalid";
    },
    filterFn: "includesString",
  },
];

export const columns: ColumnDef<User>[] = rawColumns.map((col) => {
  if (typeof col.header === "string") {
    const sizes = autoWordSize(col.header);

    return {
      ...col,
      sizes,
      size: sizes, //applied automatically
      minSize: 50,
    };
  }

  return col;
});
