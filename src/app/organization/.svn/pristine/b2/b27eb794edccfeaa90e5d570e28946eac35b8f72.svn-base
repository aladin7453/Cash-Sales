  {
    id: "username",
    accessorKey: "username",
    header: "Username",
    filterFn: "includesString",
  },
  {
    id: "description",
    accessorKey: "description",
    header: "Description",
    cell: ({ row }) => <DescriptionCellTooltip row={row} />,
    filterFn: "includesString",
  },
  {
    id: "fullName",
    accessorKey: "fullName",
    header: "Full Name",
    filterFn: "includesString",
  },
  {
    id: "gender",
    accessorKey: "gender",
    header: "Gender",
    filterFn: "includesString",
  },
