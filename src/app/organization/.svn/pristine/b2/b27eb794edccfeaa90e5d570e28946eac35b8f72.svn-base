"use client";

import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import { autoWordSize } from "@/lib/constants";
import toStringAccessorFn from "@/lib/utils/data-table/toStringAccessorFn";

import type { ColumnDef } from "@tanstack/react-table";

export const accountStatus = ["Active", "Suspended", "Terminated"] as const;

export type User = {
  UUID: string;
  account: string;
  userGroup: string;
  username: string;
  description: string;
  fullName: string;
  gender: string;
  title: string;
  DOB: string;
  NRIC: string;
  nationality: string;
  race: string;
  religion: string;
  maritalStatus: string;
  phoneNo: string;
  email: string;
  address: string;
  licenseNo: string;
  licenseClass: string;
  lastRenewalDate: string;
  expirationDate: string;
  vehicleOwner: string;
  plateNo: string;
  brand: string;
  model: string;
  color: string;
  year: string;
  vehicleRemark: string;
  createdAt: string;
  createdBy: string;
  updatedAt: string;
  updatedBy: string;
  valid: "0" | "1";
  _version: string;
  _actionUUID: string;
  profileImage: string;
  attempts: string;
  role: string;
  webAccess: "0" | "1";
  id: string;
  lastRenewalDateFormat: string;
  expirationDateFormat: string;
  DOBFormat: string;
  createdAtFormat: string;
  updatedAtFormat: string;
  userGroupuserGroup: string;
  accountName: string;
  createdByUsername: string;
  updatedByUsername: string;
  accessControl: string;
};

export const rawColumns: ColumnDef<User>[] = [
  // {
  //   id: "accountName",
