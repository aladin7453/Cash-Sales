    header: "Title",
    filterFn: "includesString",
  },
  {
    id: "DOBFormat",
    accessorKey: "DOBFormat",
    header: "DOB",
    accessorFn: (row) => toStringAccessorFn(row, "DOBFormat"),
    filterFn: "includesString",
  },
  {
    id: "NRIC",
    accessorKey: "NRIC",
    header: "NRIC",
    accessorFn: (row) => toStringAccessorFn(row, "NRIC"),
    filterFn: "includesString",
  },
  {
