import {
  flexRender,
  getCoreRowModel,
  getFilteredRowModel,
  getPaginationRowModel,
  getSortedRowModel,
  useReactTable,
} from "@tanstack/react-table";
import { useEffect, useRef, useState, useMemo } from "react";
import { FaMagnifyingGlass } from "react-icons/fa6";
import {
  ColumnFiltersState,
  PaginationState,
  SortingState,
} from "@tanstack/react-table";

import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import {
  Dialog,
  DialogClose,
  DialogContent,
  DialogFooter,
  DialogTitle,
} from "@/components/ui/dialog";
import { Separator } from "@/components/ui/separator";
import {
  Table,
  TableBody,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { useToast } from "@/components/ui/use-toast";
import { Button } from "@/components/ui/button";
import LoadingUI from "@/components/LoadingUI";
import DropdownTable from "@/components/data-table/DropdownTable";
import {
  getAuthHeaders,
  ORIGIN,
  checkAccessToken,
  DEFAULT_DATA_TABLE_PAGE_SIZE,
} from "@/lib/constants";
import { cn } from "@/lib/utils/cn";
import useSWR from "swr";

import { columns } from "./column";
import DynamicSection from "./dynamicSection";

let tokenValidationPromise: Promise<boolean> | null = null;

const validateToken = async () => {
  if (!tokenValidationPromise) {
    const username = JSON.parse(localStorage.getItem("username") || "null");
    const authToken = JSON.parse(localStorage.getItem("authToken") || "null");

    tokenValidationPromise = checkAccessToken(username, authToken);
  }

  return tokenValidationPromise;
};

const fetcher = async (
  url: string,
  options: { method?: string; body?: FormData } = {}
) => {
  const isValid = await validateToken();

  if (!isValid) {
    console.error("Session expired. Redirecting to login.");
    throw new Error("Session expired");
  }

  const headers = getAuthHeaders();

  return fetch(url, {
    method: options.method || "GET",
    headers,
    ...(options.body ? { body: options.body } : {}),
  }).then(async (res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    try {
      return await res.json();
    } catch (error) {
      throw new Error("Failed to parse response JSON");
    }
  });
};

const AccessControl = ({
  form,
  onSave,
  selectedRuleTemplate,
  grantAllPermissions,
  revokeAllPermissions,
  rules,
}) => {
  type PermissionAction = {
    value: boolean;
    disabled: boolean;
  };

  type SubModulePermissions = Record<string, PermissionAction>;
  type CategoryPermissions = Record<string, SubModulePermissions>;
  type PermissionsMap = Record<string, CategoryPermissions>;

  const headers = getAuthHeaders();
  const { toast } = useToast();
  const [selectedAccounts, setSelectedAccounts] = useState([]);

  const [columnFilters, setColumnFilters] = useState<ColumnFiltersState>([]);
  const [pagination, setPagination] = useState<PaginationState>({
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });
  const [sorting, setSorting] = useState<SortingState>([
    { id: "createdAt", desc: true },
  ]);

  const { data: accessTableData, isLoading } = useSWR(
    [`${ORIGIN}/user/api/user/generate-access-table`],
    ([url]) => {
      const params = new FormData();

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append(
        "param[offset]",
        `${pagination.pageIndex * pagination.pageSize}`
      );

      const columnFiltersWithoutValid = columnFilters.filter(
        (filter) => filter.id !== "valid"
      );
      params.append(
        "param[filter]",
        columnFiltersWithoutValid.length > 0
          ? JSON.stringify(
              columnFiltersWithoutValid.reduce<Record<string, unknown>>(
                (acc, curr) => {
                  acc[curr.id] = curr.value;
                  return acc;
                },
                {}
              )
            )
          : "{}"
      );

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc"
      );
      params.append(
        "param[valid]",
        columnFilters.find((row) => row.id === "valid")?.value || ""
      );
      params.append(
        "param[sort]",
        sorting.length > 0 ? sorting[0].id : "createdAt"
      );

      return fetcher(url, {
        method: "POST",
        body: params,
      });
    }
  );

  const [loadingProgress, setLoadingProgress] = useState<number>(0);
  const [isLoadedSuccessfully, setIsLoadedSuccessfully] =
    useState<boolean>(false);

  useEffect(() => {
    if (isLoading || !accessTableData) {
      setLoadingProgress(90);
    } else {
      setIsLoadedSuccessfully(true);
    }
  }, [isLoading, accessTableData]);

  const buildPermissionsFromApi = (data: any[]) => {
    const defaultKeys = [
      "view",
      "create",
      "update",
      "throw",
      "restore",
      "delete",
      "preview",
      "transfer-from",
      "transfer-to",
      "export",
      "confirm",
      "verify",
      "assignment",
      "progress",
      "generate-qr-code",
      "disable",
      "download",
      "print",
    ];

    const normalizeKey = (key: string) =>
      key.trim().toLowerCase().replace(/\s+/g, "-");

    const isCapitalized = (str: string) => /^[A-Z]/.test(str.trim());

    const normalizeRules = (rules: string[], module: string) => {
      const allowedActions: Set<string> = new Set();
      const moduleKey = normalizeKey(module);

      rules.forEach((rule) => {
        let action = "";
        let ruleModuleKey = "";

        if (
          rule.startsWith("transfer-from-") ||
          rule.startsWith("transfer-to-")
        ) {
          const parts = rule.split("-");
          action = `${parts[0]}-${parts[1]}`;
          ruleModuleKey = normalizeKey(parts.slice(2).join("-"));
        } else {
          const parts = rule.split("-");
          action = parts[0];
          ruleModuleKey = normalizeKey(parts.slice(1).join("-"));
        }

        if (ruleModuleKey === moduleKey) {
          allowedActions.add(action);
        }
      });

      return allowedActions;
    };

    const buildNode = (module: any, allowChildren: boolean): any => {
      const allowedActions = normalizeRules(module.rules || [], module.module);

      const actionsWithMetadata: Record<string, any> = {};
      defaultKeys.forEach((key) => {
        if (allowedActions.has(key)) {
          actionsWithMetadata[key] = { value: false, disabled: false };
        } else {
          actionsWithMetadata[key] = { value: false, disabled: true };
        }
      });

      const result: any = {
        ...actionsWithMetadata,
      };

      if (allowChildren && Array.isArray(module.children)) {
        const children: Record<string, any> = {};
        module.children.forEach((child) => {
          const childKey = normalizeKey(child.module);
          const includeChildChildren = isCapitalized(child.module);
          children[childKey] = buildNode(child, includeChildChildren);
        });
        if (Object.keys(children).length > 0) {
          result.children = children;
        }
      }

      return result;
    };

    const permissions: Record<string, any> = {};

    data.forEach((category) => {
      const categoryKey = normalizeKey(category.module);
      if (!permissions[categoryKey]) {
        permissions[categoryKey] = {};
      }
      if (Array.isArray(category.children)) {
        category.children.forEach((childModule) => {
          const subKey = normalizeKey(childModule.module);
          const allowChildren = isCapitalized(childModule.module);
          permissions[categoryKey][subKey] = buildNode(
            childModule,
            allowChildren
          );
        });
      }
    });

    return permissions;
  };

  const [permissions, setPermissions] = useState<PermissionsMap>({});

  const applyRuleToPermissions = (
    permissions: Record<string, any>,
    ruleValue: string
  ) => {
    const normalizeKey = (key: string) =>
      key.trim().toLowerCase().replace(/\s+/g, "-");

    let action = "";
    let moduleKey = "";

    if (
      ruleValue.startsWith("transfer-from-") ||
      ruleValue.startsWith("transfer-to-")
    ) {
      const parts = ruleValue.split("-");
      action = `${parts[0]}-${parts[1]}`;
      moduleKey = normalizeKey(parts.slice(2).join("-"));
    } else {
      const [actionPart, ...rest] = ruleValue.split("-");
      action = normalizeKey(actionPart);
      moduleKey = normalizeKey(rest.join("-"));
    }

    const traverse = (node: any, path: string[]): boolean => {
      const currentPath = normalizeKey(path.join("/"));
      const lastSegment = path[path.length - 1];

      const isMatch =
        normalizeKey(lastSegment) === moduleKey || currentPath === moduleKey;

      if (isMatch && node[action] && node[action].disabled === false) {
        node[action].value = true;
        return true;
      }

      if (node.children) {
        for (const childKey in node.children) {
          if (traverse(node.children[childKey], [...path, childKey])) {
            return true;
          }
        }
      }

      return false;
    };

    for (const categoryKey in permissions) {
      const category = permissions[categoryKey];

      for (const subKey in category) {
        const node = category[subKey];
        traverse(node, [subKey]);
      }
    }
  };

  useEffect(() => {
    const buildAndFetchPermissions = async () => {
      if (!accessTableData || !Array.isArray(accessTableData)) return;

      const parsedPermissions = buildPermissionsFromApi(accessTableData);

      const data = rules;
      const updated = JSON.parse(JSON.stringify(parsedPermissions));
      const appliedRules = new Set();

      (data.rule || []).forEach((ruleValue: string) => {
        if (typeof ruleValue !== "string") return;
        if (appliedRules.has(ruleValue)) return;
        appliedRules.add(ruleValue);

        applyRuleToPermissions(updated, ruleValue);
      });

      setPermissions(updated);
    };

    buildAndFetchPermissions();
  }, [accessTableData, rules]);

  const [expandedSections, setExpandedSections] = useState<
    Record<string, boolean>
  >({});

  const table = useReactTable({
    columns,
    data: [],
    autoResetPageIndex: false,
    getCoreRowModel: getCoreRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    getSortedRowModel: getSortedRowModel(),
  });

  const toggleSection = (section) => {
    setExpandedSections((prev) => ({
      ...prev,
      [section]: !prev[section],
    }));
  };

  const getPermissionPath = (
    permissions: Record<string, any>,
    category: string,
    subCategory: string,
    childCategory?: string
  ) => {
    let node = permissions?.[category]?.[subCategory];

    if (!node) return null;

    if (childCategory) {
      const keys = childCategory.split("/");

      for (const key of keys) {
        node = node.children?.[key];
        if (!node) break;
      }
    }

    return node || null;
  };

  const handleCheckboxChange = (
    category: string,
    subCategory: string,
    action: string,
    childCategory?: string
  ) => {
    setPermissions((prevPermissions) => {
      const updatedPermissions = JSON.parse(JSON.stringify(prevPermissions));
      let target = getPermissionPath(updatedPermissions, category, subCategory);

      if (!target) return updatedPermissions;

      // Handle third-level
      if (childCategory && target.children?.[childCategory]) {
        target = target.children[childCategory];
      }

      if (action === "toggleAll") {
        const allChecked = Object.values(target).every(
          (a: any) => typeof a === "object" && a.value
        );
        Object.keys(target).forEach((key) => {
          if (target[key]?.disabled === false) {
            target[key].value = !allChecked;
          }
        });
      } else {
        if (
          Object.prototype.hasOwnProperty.call(target, action) &&
          target[action].disabled === false
        ) {
          target[action].value = !target[action].value;
        }
      }

      return updatedPermissions;
    });
  };

  useEffect(() => {
    if (onSave) {
      onSave(permissions, selectedAccounts);
    }
  }, [onSave, permissions, selectedAccounts]);

  useEffect(() => {
    if (grantAllPermissions) {
      setPermissions((prevPermissions) => {
        const updatedPermissions = JSON.parse(JSON.stringify(prevPermissions));

        const setAllToTrue = (obj) => {
          Object.keys(obj).forEach((key) => {
            if (typeof obj[key] === "object" && obj[key] !== null) {
              if ("value" in obj[key] && "disabled" in obj[key]) {
                if (!obj[key].disabled) {
                  obj[key].value = true;
                }
              } else {
                setAllToTrue(obj[key]);
              }
            }
          });
        };

        setAllToTrue(updatedPermissions);
        return updatedPermissions;
      });
    }
  }, [grantAllPermissions]);

  useEffect(() => {
    if (revokeAllPermissions) {
      setPermissions((prevPermissions) => {
        const updatedPermissions = JSON.parse(JSON.stringify(prevPermissions));

        const setAllToFalse = (obj) => {
          Object.keys(obj).forEach((key) => {
            if (typeof obj[key] === "object" && obj[key] !== null) {
              if ("value" in obj[key] && "disabled" in obj[key]) {
                if (!obj[key].disabled) {
                  obj[key].value = false;
                }
              } else {
                setAllToFalse(obj[key]);
              }
            }
          });
        };

        setAllToFalse(updatedPermissions);
        return updatedPermissions;
      });
    }
  }, [revokeAllPermissions]);

  return (
    <div>
      <Form {...form}>
        <FormField
          control={form.control}
          name="account"
          render={({ field }) => (
            <FormItem className="col-span-4 row-span-1 grid hidden h-full grid-rows-[auto_1fr] space-y-1">
              <FormLabel>UUID:</FormLabel>
              <FormControl>
                <Input className="h-7" {...field} readOnly={true} />
              </FormControl>
              <FormMessage />
            </FormItem>
          )}
        />
        <div className="flex items-center justify-between mb-5">
          <h1>Access Control Rights - {selectedRuleTemplate}</h1>
        </div>

        <Separator className="bg-erp-blue-11" />
        <ScrollArea className="h-[400px] overflow-auto">
          <Table className="border-separate border-spacing-[3px] whitespace-nowrap border bg-erp-gray-1">
            <TableHeader className="sticky top-0">
              {table.getHeaderGroups().map((headerGroup) => (
                <TableRow key={headerGroup.id}>
                  {headerGroup.headers.map((header) => (
                    <TableHead
                      className={cn(
                        "h-16 bg-erp-blue-11 px-2.5 font-normal",
                        header.column.id === "description"
                          ? "flex-[2]"
                          : "flex-1"
                      )}
                      style={{
                        minWidth:
                          header.column.id === "description"
                            ? "200px"
                            : "100px",
                      }}
                      key={header.id}
                    >
                      <div className="flex flex-col gap-y-0.5">
                        <div
                          className={cn(
                            "flex items-center gap-x-0.5 text-white",
                            header.column.getCanSort()
                              ? "cursor-pointer select-none"
                              : ""
                          )}
                          onClick={header.column.getToggleSortingHandler()}
                        >
                          <span className="font-bold">
                            {header.isPlaceholder
                              ? null
                              : flexRender(
                                  header.column.columnDef.header,
                                  header.getContext()
                                )}
                          </span>
                        </div>
                      </div>
                    </TableHead>
                  ))}
                </TableRow>
              ))}
            </TableHeader>

            <TableBody>
              {Object.keys(permissions).map((category) => (
                <DynamicSection
                  key={category}
                  category={category}
                  sectionPermissions={permissions[category]}
                  handleCheckboxChange={handleCheckboxChange}
                  expandedSections={expandedSections}
                  toggleSection={toggleSection}
                />
              ))}
            </TableBody>
          </Table>
          <ScrollBar orientation="horizontal" />
        </ScrollArea>

        {!isLoadedSuccessfully && <LoadingUI progressValue={loadingProgress} />}
      </Form>
    </div>
  );
};

export default AccessControl;
