"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { notFound, useRouter, useSearchParams } from "next/navigation";
import React, { useEffect, useRef, useState } from "react";
import { useForm } from "react-hook-form";
import { FaMagnifyingGlass } from "react-icons/fa6";
import { z } from "zod";

import DropdownTable from "@/components/data-table/DropdownTable";
import CancelButton from "@/components/form/ActionButton/Cancel";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import LoadingUI from "@/components/LoadingUI";
import { Checkbox } from "@/components/ui/checkbox";
import { Dialog, DialogClose, DialogContent } from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Textarea } from "@/components/ui/textarea";
import { useToast } from "@/components/ui/use-toast";
import { DATE_FORMAT, getAuthHeaders, ORIGIN } from "@/lib/constants";

import { UserList } from "./columns";

import type { Dispatch, SetStateAction } from "react";

// import { userListData } from "./data";

type Props = {
  open: boolean;
  setOpen: Dispatch<SetStateAction<boolean>>;
  row?: string;
  setTempRowUserListData: (data: any, overwrite: boolean) => void;
  revalidateUserListData: () => void;
  setCompanyData: Dispatch<SetStateAction<UserList[]>>;
  slug: string;
};

const UserListFormSchema = z.object({
  UUID: z.union([z.string(), z.literal("")]),
  user: z.union([z.string(), z.literal("")]),
  fullname: z.string().optional().nullable(),
  jobTitle: z.string().optional().nullable(),
  jobTitleName: z.string().optional().nullable(),
  remark: z.string().optional().nullable(),
  title: z.string().optional().nullable(),
  phoneNo: z.string().optional().nullable(),
  companyName: z.string().optional().nullable(),
  email: z.string().optional().nullable(),
  baseCompany: z.string().optional().nullable(),
  department: z.string().optional().nullable(),
  departmentName: z.string().optional().nullable(),
  valid: z.union([z.string(), z.literal("")]),
});

export default function UserDetailsFormPopover({
  open,
  setOpen,
  row,
  setTempRowUserListData,
  revalidateUserListData,
  slug,
  accountId,
}: Props) {
  const router = useRouter();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const data: any = row;
  const { toast } = useToast();
  const headers = getAuthHeaders();

  const [showTableFullName, setShowTableFullName] = useState(false);
  const [showTableDepartment, setshowTableDepartment] = useState(false);
  const [showTableJobTitle, setShowTableJobTitle] = useState(false);

  const [fullNameDropdownTableData, setFullNameDropdownTableData] = useState([]);
  const [departmentDropdownTableData, setdepartmentDropdownTableData] = useState([]);
  const [jobTitleDropdownTableData, setJobTitleDropdownTableData] = useState([]);

  const [fullNameFilter, setFullNameFilter] = useState("");
  const [departmentFilter, setDepartmentFilter] = useState("");
  const [jobTitleFilter, setJobTitleFilter] = useState("");

  const dropdownFullNameColumns = [
    { accessorKey: "fullName", header: "Full Name" },
    { accessorKey: "title", header: "Title" },
    { accessorKey: "phoneNo", header: "Phone No" },
    { accessorKey: "email", header: "Email" },
  ];
  const dropdownDepartmentColumns = [
    { accessorKey: "departmentID", header: "ID" },
    { accessorKey: "department", header: "Department" },
    { accessorKey: "description", header: "Description" },
  ];
  const dropdownJobTitleColumns = [
    { accessorKey: "jobTitleID", header: "ID" },
    { accessorKey: "jobTitle", header: "Job Title" },
    { accessorKey: "description", header: "Description" },
  ];

  const inputRef = useRef(null);
  const dropdownRef = useRef(null);

  const [isSaving, setIsSaving] = useState(false);

  const handleClickOutside = (event) => {
    if (
      dropdownRef.current &&
      !dropdownRef.current.contains(event.target) &&
      inputRef.current !== event.target
    ) {
      setShowTableFullName(false);
      setshowTableDepartment(false);
      setShowTableJobTitle(false);
    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);

    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);

  const form = useForm<z.infer<typeof UserListFormSchema>>({
    resolver: zodResolver(UserListFormSchema),
    defaultValues: {
      UUID: data?.UUID ?? "",
      user: data?.user ?? "",
      fullname: data?.fullname ?? "",
      jobTitle: data?.jobTitle ?? "",
      jobTitleName: data?.jobTitleName ?? "",
      remark: data?.remark ?? "",
      title: data?.title ?? "",
      phoneNo: data?.phoneNo ?? "",
      company: data?.company ?? "",
      companyName: data?.companyName ?? "",
      email: data?.email ?? "",
      baseCompany: data?.baseCompany ?? "",
      department: data?.department ?? "",
      departmentName: data?.departmentName ?? "",
      valid: data?.valid ?? "1",
    },
  });

  const updateUserListData = async (data) => {
    try {
      setIsSaving(true);

      const formData = new FormData();

      for (var key in data) {
        formData.append(`companyHasUser[${key}]`, data[key]);
      }

      const response = await fetch(
        `${ORIGIN}/company/api/company/update-company-has-user-data?id=${id}`,
        {
          method: "POST",
          headers,
          body: formData,
        },
      );

      if (!response.ok) {
        const errorData = await response.json();

        if (response.status === 403) {
          toast({
            title: errorData.message,
            variant: "destructive",
            duration: 2000,
          });
        }

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData) {
        toast({
          title: responseData.message,
          description: "User list data added successfully",
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error updating user list data:", error);
    } finally {
      setIsSaving(false);
    }
  };

  const onSubmit = async (values) => {
    if (!values) return;

    try {
      setIsSaving(true);

      const newData = { ...values };

      if (id && slug === "edit") {
        await updateUserListData(newData);

        revalidateUserListData();
      } else {
        setTempRowUserListData(newData, false);
      }

      handleReset();
      setOpen(false);
    } catch {
      console.error("Error submitting form:", error);
    } finally {
      setIsSaving(false);
    }
  };

  const handleReset = () => {
    form.reset({
      UUID: "",
      user: "",
      fullname: "",
      jobTitle: "",
      remark: "",
      title: "",
      phoneNo: "",
      company: "",
      email: "",
      baseCompany: "",
      department: "",
      valid: "1",
    });
  };

  useEffect(() => {
    if (open) {
      !data && handleReset();
    }
  }, [open]);

  const handleFullNameSearchChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const value = e.target.value;
    setFullNameFilter(value);
    form.setValue("fullname", value);

    if (!showTableFullName) setShowTableFullName(true);
  };

  const handleDepartmentSearchChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const value = e.target.value;
    setDepartmentFilter(value);
    form.setValue("departmentName", value);

    if (!showTableDepartment) setshowTableDepartment(true);
  };

  const handleJobTitleSearchChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const value = e.target.value;
    setJobTitleFilter(value);
    form.setValue("jobTitleName", value);

    if (!showTableJobTitle) setShowTableJobTitle(true);
  };

  const toggleTableFullName = async () => {
    setshowTableDepartment(false);
    setShowTableJobTitle(false);

    var account = accountId;
    account ? (account = account) : (account = "");

    if (!showTableFullName) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-user-by-account?id=${account}`, {
          headers,
        });
        if (!response.ok) {
          throw new Error("Failed to fetch user list drop-down data");
        }
        const accountData = await response.json();
        setFullNameDropdownTableData(accountData.rows);
        setShowTableFullName(true);
      } catch (error) {
        console.error("Error fetching user list drop-down data:", error);
      }
    } else {
      setShowTableFullName(false);
    }
  };

  const toggleTableDepartment = async () => {
    setShowTableFullName(false);
    setShowTableJobTitle(false);

    if (!showTableDepartment) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-department-by-company?id=${id}`, {
          headers,
        });
        if (!response.ok) {
          throw new Error("Failed to fetch user list drop-down data");
        }
        const departmentData = await response.json();
        setdepartmentDropdownTableData(departmentData.rows);
        setshowTableDepartment(true);
      } catch (error) {
        console.error("Error fetching user list drop-down data:", error);
      }
    } else {
      setshowTableDepartment(false);
    }
  };

  const toggleTableJobTitle = async () => {
    setShowTableFullName(false);
    setshowTableDepartment(false);

    var id = form.getValues("department");

    if (!showTableJobTitle) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-job-title-by-department?id=${id}`, {
          headers,
        });
        if (!response.ok) {
          throw new Error("Failed to fetch user list drop-down data");
        }
        const jobTitleData = await response.json();
        setJobTitleDropdownTableData(jobTitleData.rows);
        setShowTableJobTitle(true);
      } catch (error) {
        console.error("Error fetching user list drop-down data:", error);
      }
    } else {
      setShowTableJobTitle(false);
    }
  };

  const onClickRowFullName = (row) => {
    form.setValue("UUID", "");
    form.setValue("user", row.UUID);
    form.setValue("fullname", row.fullName);
    form.setValue("title", row.title);
    form.setValue("company", row.UUID);
    form.setValue("companyName", row.companyName);
    form.setValue("phoneNo", row.phoneNo);
    form.setValue("email", row.email);

    setShowTableFullName(false);
  };

  const onClickRowDepartment = (row) => {
    form.setValue("department", row.UUID);
    form.setValue("departmentName", row.department);

    setshowTableDepartment(false);
  };

  const onClickRowJobTitle = (row) => {
    form.setValue("jobTitle", row.UUID);
    form.setValue("jobTitleName", row.jobTitle);

    setShowTableJobTitle(false);
  };

  return (
    <Dialog open={open} onOpenChange={setOpen} className="m-1.5">
      <DialogContent className="max-w-6xl bg-erp-blue-3 p-2">
        <Form {...form}>
          <form className="space-y-2" onSubmit={form.handleSubmit(onSubmit)}>
            <div className="flex items-center justify-between pr-4">
              <div className="grid auto-cols-fr grid-flow-col gap-x-1.5">
                <SaveButton />
                <ResetButton onClick={handleReset} />
                <DialogClose asChild>
                  <CancelButton />
                </DialogClose>
              </div>

              <FormField
                control={form.control}
                name="valid"
                render={({ field }) => (
                  <FormItem className="flex items-center gap-x-1.5 space-y-0">
                    <FormControl>
                      <Checkbox
                        checked={field.value === "1"}
                        onCheckedChange={(state) => field.onChange(state ? 1 : 0)}
                      />
                    </FormControl>
                    <FormLabel>Valid</FormLabel>
                  </FormItem>
                )}
              />
            </div>

            <div className="space-y-2.5 bg-white p-3 pt-2">
              <h2 className="text-sm font-bold">User</h2>
              <div className="grid grid-flow-col-dense  grid-cols-1 items-start gap-x-8 gap-y-2.5 md:grid-cols-4 ">
                <FormField
                  control={form.control}
                  name="UUID"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid hidden h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>UUID:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} readOnly={true} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="user"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid hidden h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>User:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} readOnly={true} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="fullname"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Full Name:</FormLabel>
                      <FormControl className="relative">
                        <div className="relative">
                          <Input
                            className="h-7.5 pr-8"
                            {...field}
                            onClick={() => toggleTableFullName()}
                            onChange={handleFullNameSearchChange}
                            ref={inputRef}
                            autoComplete="off"
                          />
                          <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <FaMagnifyingGlass className="text-gray-400" />{" "}
                            {/* Using the search icon */}
                          </div>
                          {showTableFullName && (
                            <div
                              ref={dropdownRef}
                              className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                            >
                              <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                <DropdownTable
                                  columns={dropdownFullNameColumns}
                                  data={fullNameDropdownTableData}
                                  onClickRow={onClickRowFullName}
                                  filterValue={fullNameFilter}
                                />
                              </ScrollArea>
                            </div>
                          )}
                        </div>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="title"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Title:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-7.5"
                          {...field}
                          readOnly
                          style={{ backgroundColor: "#f2f2f2", color: "gray" }}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="companyName"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Company:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-7.5"
                          {...field}
                          readOnly
                          style={{ backgroundColor: "#f2f2f2", color: "gray" }}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="company"
                  render={({ field }) => (
                    <FormItem className="flex hidden flex-col space-y-1">
                      <FormControl className="relative">
                        <Input className="h-7.5 pr-8" {...field} readOnly={true} />
                      </FormControl>
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="departmentName"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Department:</FormLabel>
                      <FormControl className="relative">
                        <div className="relative">
                          <Input
                            className="h-7.5 pr-8"
                            {...field}
                            onClick={() => toggleTableDepartment()}
                            onChange={handleDepartmentSearchChange}
                            ref={inputRef}
                            autoComplete="off"
                          />
                          <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <FaMagnifyingGlass className="text-gray-400" />{" "}
                            {/* Using the search icon */}
                          </div>
                          {showTableDepartment && (
                            <div
                              ref={dropdownRef}
                              className="absolute right-0 top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                            >
                              <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                <DropdownTable
                                  columns={dropdownDepartmentColumns}
                                  data={departmentDropdownTableData}
                                  onClickRow={onClickRowDepartment}
                                  filterValue={departmentFilter}
                                />
                              </ScrollArea>
                            </div>
                          )}
                        </div>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="department"
                  render={({ field }) => (
                    <FormItem className="flex hidden flex-col space-y-1">
                      <FormControl className="relative">
                        <Input className="h-7.5 pr-8" {...field} readOnly={true} />
                      </FormControl>
                    </FormItem>
                  )}
                />
              </div>

              <div className="grid grid-flow-col-dense  grid-cols-1 items-start gap-x-8 gap-y-2.5 md:grid-cols-4 ">
                <FormField
                  control={form.control}
                  name="jobTitleName"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Job Title:</FormLabel>
                      <FormControl className="relative">
                        <div className="relative">
                          <Input
                            className="h-7.5 pr-8"
                            {...field}
                            onClick={() => toggleTableJobTitle()}
                            onChange={handleJobTitleSearchChange}
                            ref={inputRef}
                            autoComplete="off"
                          />
                          <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <FaMagnifyingGlass className="text-gray-400" />{" "}
                            {/* Using the search icon */}
                          </div>
                          {showTableJobTitle && (
                            <div
                              ref={dropdownRef}
                              className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                            >
                              <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                <DropdownTable
                                  columns={dropdownJobTitleColumns}
                                  data={jobTitleDropdownTableData}
                                  onClickRow={onClickRowJobTitle}
                                  filterValue={jobTitleFilter}
                                />
                              </ScrollArea>
                            </div>
                          )}
                        </div>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="jobTitle"
                  render={({ field }) => (
                    <FormItem className="flex hidden flex-col  space-y-1">
                      <FormControl className="relative">
                        <Input className="h-7.5 pr-8" {...field} readOnly={true} />
                      </FormControl>
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="phoneNo"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Phone Number:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-7.5"
                          {...field}
                          readOnly
                          style={{ backgroundColor: "#f2f2f2", color: "gray" }}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="email"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Email:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-7.5"
                          {...field}
                          readOnly
                          style={{ backgroundColor: "#f2f2f2", color: "gray" }}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="baseCompany"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Base Company:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-7.5"
                          {...field}
                          readOnly
                          style={{ backgroundColor: "#f2f2f2", color: "gray" }}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>

              <div className="grid grid-flow-col-dense  grid-cols-1 items-start gap-x-8 gap-y-2.5 md:grid-cols-4 ">
                <FormField
                  control={form.control}
                  name="remark"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Remark:</FormLabel>
                      <FormControl>
                        <Textarea
                          className="h-7"
                          {...field}
                          moduleName="companyHasUser"
                          fieldName="remark"
                          columnName="Remark"
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>
            </div>
          </form>
        </Form>
        {isSaving && <LoadingUI />}
      </DialogContent>
    </Dialog>
  );
}
