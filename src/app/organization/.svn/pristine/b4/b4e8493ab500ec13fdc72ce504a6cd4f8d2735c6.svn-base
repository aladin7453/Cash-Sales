"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { useForm } from "react-hook-form";
import { z } from "zod";

import CancelButton from "@/components/form/ActionButton/Cancel";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import { Checkbox } from "@/components/ui/checkbox";
import { Dialog, DialogClose, DialogContent } from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";

import type { Dispatch, SetStateAction } from "react";

type Props = {
  open: boolean;
  setOpen: Dispatch<SetStateAction<boolean>>;
};

type SetGlobalForbiddenMessageFormData = z.infer<
  typeof setGlobalForbiddenMessageFormSchema
>;

const setGlobalForbiddenMessageFormSchema = z.object({
  title: z.string().min(1, {
    message: "Title cannot be empty.",
  }),
  message: z.string(),
  valid: z.union([z.literal("0"), z.literal("1")]).default("1"),
});

export default function SetGlobalForbiddenMessageFormPopover({
  open,
  setOpen,
}: Props) {
  const form = useForm<SetGlobalForbiddenMessageFormData>({
    resolver: zodResolver(setGlobalForbiddenMessageFormSchema),
    defaultValues: {
      title: "",
      message: "",
      valid: "1",
    },
  });

  const handleReset = () => {
    form.reset({
      title: "",
      message: "",
      valid: "1",
    });
  };

  return (
    <Dialog open={open} onOpenChange={setOpen} className="m-2">
      <DialogContent className="max-w-6xl bg-erp-blue-3 p-2">
        <Form {...form}>
          <form className="space-y-2" onSubmit={() => {}}>
            <div className="flex items-center justify-between pr-4">
              <div className="grid auto-cols-fr grid-flow-col gap-x-1.5">
                <SaveButton />
                <ResetButton onClick={handleReset} />
                <DialogClose asChild>
                  <CancelButton />
                </DialogClose>
              </div>
              <FormField
                control={form.control}
                name="valid"
                render={({ field }) => (
                  <FormItem className="flex items-center gap-x-1.5 space-y-0">
                    <FormControl>
                      <Checkbox
                        checked={field.value === "1"}
                        onCheckedChange={(state) =>
                          field.onChange(state ? "1" : "0")
                        }
                      />
                    </FormControl>
                    <FormLabel>Valid</FormLabel>
                  </FormItem>
                )}
              />
            </div>
            <div className="space-y-2.5 bg-white p-3 pt-2">
              <h2 className="text-sm font-bold">Forbidden Message - Global</h2>
              <div className="flex flex-col gap-y-2.5">
                <FormField
                  control={form.control}
                  name="title"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Title:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="message"
                  render={({ field }) => (
                    <FormItem className="col-span-3 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Message:</FormLabel>
                      <FormControl>
                        <Textarea {...field} maxLength={255} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>
            </div>
          </form>
        </Form>
      </DialogContent>
    </Dialog>
  );
}
