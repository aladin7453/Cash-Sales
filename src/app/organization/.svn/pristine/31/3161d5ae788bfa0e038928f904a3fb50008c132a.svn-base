"use client";

import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";

type Params = {
  form: any;
};

function generateYearArray() {
  const currentYear = new Date().getFullYear();
  const startYear = currentYear - 30;
  const numberOfYears = 40; // 30 years before and 10 years after
  const years = [];

  for (let i = startYear; i <= currentYear + 10; i++) {
    years.push({ label: `${i}`, value: `${i}` });
  }

  return years;
}

const yearList = generateYearArray();
const vehicleOwner = [
  { label: "Company", value: "Company" },
  { label: "Personal", value: "Personal" },
  { label: "Others", value: "Others" },
];

export default function VehicleDetailsForm({ form }: Params) {
  return (
    <Card className="h-auto shadow-md">
      <CardHeader className="pb-3">
        <CardTitle className="text-lg font-bold">Vehicle Details</CardTitle>
      </CardHeader>
      <CardContent>
        <Form {...form}>
          <form className="space-y-2.5">
            <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-4">
              <FormField
                control={form.control}
                name="vehicleOwner"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Vehicle Owner:</FormLabel>
                    <Select value={field.value} onValueChange={field.onChange}>
                      <SelectTrigger className="h-7.5 w-full">
                        <SelectValue placeholder="Select status" />
                      </SelectTrigger>
                      <SelectContent>
                        {vehicleOwner &&
                          vehicleOwner.map((item) => (
                            <SelectItem key={item.value} value={item.value}>
                              {item.label}
                            </SelectItem>
                          ))}
                      </SelectContent>
                    </Select>
                    <FormMessage />
                  </FormItem>
                )}
              />
              <FormField
                control={form.control}
                name="plateNo"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Plate No:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="user"
                        fieldName="plateNo"
                        columnName="Plate No"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="brand"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Brand:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="user"
                        fieldName="brand"
                        columnName="Brand"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
              <FormField
                control={form.control}
                name="model"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Model:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="user"
                        fieldName="model"
                        columnName="Model"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
            <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-4">
              <FormField
                control={form.control}
                name="color"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Color:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="user"
                        fieldName="color"
                        columnName="Color"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
              <FormField
                control={form.control}
                name="year"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Year:</FormLabel>
                    <div className="relative">
                      <Select
                        value={field.value}
                        onValueChange={field.onChange}
                      >
                        <SelectTrigger className="h-7.5 w-full">
                          <SelectValue placeholder="Select status" />
                        </SelectTrigger>
                        <SelectContent className="absolute top-full z-10 mt-2 max-h-48 overflow-y-auto">
                          {yearList &&
                            yearList.map((item) => (
                              <SelectItem key={item.value} value={item.value}>
                                {item.label}
                              </SelectItem>
                            ))}
                        </SelectContent>
                      </Select>
                    </div>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}
