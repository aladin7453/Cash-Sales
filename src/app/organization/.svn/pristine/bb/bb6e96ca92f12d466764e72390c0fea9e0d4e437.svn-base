"use client";

import {
  ColumnFiltersState,
  flexRender,
  getCoreRowModel,
  getExpandedRowModel,
  getFilteredRowModel,
  PaginationState,
  SortingState,
  useReactTable,
} from "@tanstack/react-table";
import { ChevronDown, ChevronUp } from "lucide-react";
import { useEffect, useMemo, useState } from "react";
import useSWR from "swr";

import NoResultsTableRow from "@/components/data-table/NoResultsTableRow";
import TableHeadColumnTextFilter from "@/components/data-table/TableHeadColumnTextFilter";
import LoadingUI from "@/components/LoadingUI";
import { Checkbox } from "@/components/ui/checkbox";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import {
  checkAccessToken,
  DEFAULT_DATA_TABLE_PAGE_SIZE,
  getAuthHeaders,
  getCurrentCompanyUUID,
  ORIGIN,
} from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

import {
  buildFlatPermissionMap,
  buildPermissionKey,
  buildSectionsFromBackend,
  normalizeKey,
  parseRule,
} from "../standard/utils/permissionUtils";

import type { ColumnDef } from "@tanstack/react-table";

import type { Section } from "./sections";

type SelectScopeProps = {
  moduleKey: string;
  value?: string;
  onChange: (v: string) => void;
};

interface SelectDepartmentProps {
  value?: string;
  onChange: (value: string) => void;
  departmentData: { UUID: string; departmentID: string; department: string }[];
}

export type Action =
  | typeof VIEW_ACTION
  | (typeof STANDARD_ACTIONS)[number]
  | (typeof DOCUMENT_ACTIONS)[number]
  | (typeof E_INVOICE_ACTIONS)[number];

// type Row = {
//   name: string;
//   allowedActions: Action[];
//   children?: Row[];
// };

const VIEW_ACTION = "View";

const STANDARD_ACTIONS = [
  "Create",
  "Update",
  "Clone",
  "Throw",
  "Restore",
  "Reset",
  "Delete",
  "Download",
  "Auth",
  "Bill",
  "Export",
  "Preview",
  "Print",
  "Assignment",
  "Progress",
  "Confirm",
  "Verify",
  "Compulsary",
  "Generate-QR-Code",
  "Disable",
  "Upload",
] as const;

const DOCUMENT_ACTIONS = ["Transfer-To", "Transfer-From"] as const;

const E_INVOICE_ACTIONS = ["Generate", "Edit", "Submit", "Cancel", "Share"] as const;

const SCOPE_OPTION = [
  { id: "personal", name: "Personal" },
  { id: "personal-supervisor", name: "Personal + Supervisor" },
  { id: "personal-subordinate", name: "Personal + Subordinate" },
  { id: "all", name: "All" },
];

let tokenValidationPromise: Promise<boolean> | null = null;

const validateToken = async () => {
  if (!tokenValidationPromise) {
    const username = JSON.parse(localStorage.getItem("username") || "null");
    const authToken = JSON.parse(localStorage.getItem("authToken") || "null");

    tokenValidationPromise = checkAccessToken(username, authToken);
  }

  return tokenValidationPromise;
};

const fetcher = async (url: string, options: { method?: string; body?: FormData } = {}) => {
  const isValid = await validateToken();

  if (!isValid) {
    console.error("Session expired. Redirecting to login.");
    throw new Error("Session expired");
  }

  const headers = getAuthHeaders();

  return fetch(url, {
    method: options.method || "GET",
    headers,
    ...(options.body ? { body: options.body } : {}),
  }).then(async (res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    try {
      return await res.json();
    } catch (error) {
      throw new Error("Failed to parse response JSON");
    }
  });
};

export default function StandardActionDataTable({
  form,
  userUUID,
  selectedUserCompany,
  grantAllPermissions,
  revokeAllPermissions,
  setGrantAllPermissions,
  setRevokeAllPermissions,
  scopes,
  setScopes,
  departments,
  setDepartments,
  permissionsData,
  setPermissionsData,
  rules,
  setRules,
  permissions,
  setPermissions,
  baseRules,
  setBaseRules,
  setBaseScopes,
  setBaseDepartmentScopes,
  isUpdateRBAC,
  setIsUpdateRBAC,
  departmentDropdownData,
  setDepartmentDropdownData,
}) {
  type PermissionAction = {
    value: boolean;
    disabled: boolean;
  };

  type SubModulePermissions = Record<string, PermissionAction>;
  type CategoryPermissions = Record<string, SubModulePermissions>;
  type PermissionsMap = Record<string, CategoryPermissions>;

  // const data: StandardAction[] = defaultData;
  // const columns = useMemo(() => standardActionColumns, []);
  const headers = getAuthHeaders();
  const [selectedAccounts, setSelectedAccounts] = useState([]);
  const [columnFilters, setColumnFilters] = useState<ColumnFiltersState>([]);
  const [pagination, setPagination] = useState<PaginationState>({
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });
  const [sorting, setSorting] = useState<SortingState>([{ id: "createdAt", desc: true }]);
  const [errorMessage, setErrorMessage] = useState("");

  const {
    data: accessTableData,
    error,
    isLoading,
  } = useSWR([`${ORIGIN}/user/api/user/generate-access-table`], ([url]) => {
    const params = new FormData();

    params.append("param[limit]", `${pagination.pageSize}`);
    params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

    const columnFiltersWithoutValid = columnFilters.filter((filter) => filter.id !== "valid");
    params.append(
      "param[filter]",
      columnFiltersWithoutValid.length > 0
        ? JSON.stringify(
            columnFiltersWithoutValid.reduce<Record<string, unknown>>((acc, curr) => {
              acc[curr.id] = curr.value;
              return acc;
            }, {}),
          )
        : "{}",
    );

    params.append("param[order]", sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc");
    params.append("param[valid]", columnFilters.find((row) => row.id === "valid")?.value || "");
    params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");

    params.append("user", userUUID);
    params.append("company", selectedUserCompany);

    return fetcher(url, {
      method: "POST",
      body: params,
    });
  });

  const [loadingProgress, setLoadingProgress] = useState<number>(0);
  const [isLoadedSuccessfully, setIsLoadedSuccessfully] = useState<boolean>(false);
  const [isDataLoading, setIsDataLoading] = useState(false);

  useEffect(() => {
    if (isLoading || !accessTableData) {
      setLoadingProgress(90);
    } else {
      setIsLoadedSuccessfully(true);
    }
  }, [isLoading, accessTableData]);

  useEffect(() => {
    if (error) {
      setErrorMessage(error.message);
    }
  }, [error]);

  useEffect(() => {
    const toggleTableDepartment = async () => {
      const formData = new FormData();
      formData.append("table[]", "department");

      try {
        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
          method: "POST",
          headers,
          body: formData,
        });

        if (!response.ok) throw new Error("Failed to fetch department drop-down data");

        const departmentData = await response.json();
        setDepartmentDropdownData(departmentData.rows);
      } catch (error) {
        console.error("Error fetching department drop-down data:", error);
      }
    };

    toggleTableDepartment();
  }, []);

  const defaultKeys = [
    "view",
    "create",
    "update",
    "throw",
    "restore",
    "delete",
    "download",
    "auth",
    "bill",
    "print",
    "preview",
    "transfer-from",
    "transfer-to",
    "export",
    "confirm",
    "verify",
    "compulsary",
    "assignment",
    "progress",
    "generate-qr-code",
    "disable",
    "upload",
  ];

  const buildPermissionsFromApi = (data: any[], userRules: string[] = []) => {
    const userRuleSet = new Set(userRules.map((r) => normalizeKey(r)));

    const normalizeRules = (rules: string[], module: string) => {
      const normalized: Record<string, boolean> = {};
      const allowedActions: Set<string> = new Set();
      const currentModuleKey = normalizeKey(module);

      rules.forEach((rule) => {
        const parsed = parseRule(rule);
        if (!parsed) return;

        const actionKey = parsed.action;
        const moduleKey = normalizeKey(parsed.module);
        if (moduleKey !== currentModuleKey) return;

        allowedActions.add(actionKey);
      });

      return { allowedActions };
    };

    const permissions: Record<string, any> = {};

    data.forEach((category) => {
      const categoryKey = normalizeKey(category.module);
      if (!permissions[categoryKey]) {
        permissions[categoryKey] = {};
      }

      if (!category.children && Array.isArray(category.rules)) {
        const subKey = normalizeKey(category.module);
        const { allowedActions } = normalizeRules(category.rules || [], category.module);

        const actionsWithMetadata: Record<string, any> = {};
        defaultKeys.forEach((key) => {
          const ruleKey = `${key}-${subKey}`;
          const hasRule = userRuleSet.has(ruleKey);
          actionsWithMetadata[key] = {
            value: hasRule,
            disabled: !allowedActions.has(key),
          };
        });

        permissions[categoryKey][subKey] = {
          ...actionsWithMetadata,
          children: {},
        };
      }

      if (Array.isArray(category.children)) {
        category.children.forEach((subModule) => {
          const subKey = normalizeKey(subModule.module);
          const { allowedActions } = normalizeRules(subModule.rules || [], subModule.module);

          const actionsWithMetadata: Record<string, any> = {};
          defaultKeys.forEach((key) => {
            const ruleKey = `${key}-${subKey}`;
            const hasRule = userRuleSet.has(ruleKey);
            actionsWithMetadata[key] = {
              value: hasRule,
              disabled: !allowedActions.has(key),
            };
          });

          permissions[categoryKey][subKey] = {
            ...actionsWithMetadata,
            children: {},
          };

          if (Array.isArray(subModule.children)) {
            subModule.children.forEach((childModule) => {
              const childKey = normalizeKey(childModule.module);
              const { allowedActions: childAllowed } = normalizeRules(
                childModule.rules || [],
                childModule.module,
              );

              const childActions: Record<string, any> = {};
              defaultKeys.forEach((key) => {
                const ruleKey = `${key}-${childKey}`;
                const hasRule = userRuleSet.has(ruleKey);
                childActions[key] = {
                  value: hasRule,
                  disabled: !childAllowed.has(key),
                };
              });

              permissions[categoryKey][subKey].children[childKey] = {
                ...childActions,
                children: {},
              };
            });
          }
        });
      }
    });

    return permissions;
  };

  const applyRuleToPermissions = (permissions: Record<string, any>, ruleValue: string) => {
    const normalizeKey = (key: string) => key.trim().toLowerCase().replace(/\s+/g, "-");

    ruleValue = normalizeKey(ruleValue);

    let action = "";
    let moduleKey = "";

    const matchedAction = defaultKeys.find((key) => ruleValue.startsWith(`${key}-`));

    if (matchedAction) {
      action = matchedAction;
      moduleKey = ruleValue.slice(action.length + 1);
    } else {
      const [actionPart, ...rest] = ruleValue.split("-");
      action = normalizeKey(actionPart);
      moduleKey = normalizeKey(rest.join("-"));
    }

    const traverse = (node: any, path: string[]): boolean => {
      const currentPath = normalizeKey(path.join("/"));
      const lastSegment = path[path.length - 1];

      const isMatch = normalizeKey(lastSegment) === moduleKey || currentPath === moduleKey;

      if (isMatch && node[action] && node[action].disabled === false) {
        node[action].value = true;
        return true;
      }

      if (node.children) {
        for (const childKey in node.children) {
          if (traverse(node.children[childKey], [...path, childKey])) {
            return true;
          }
        }
      }

      return false;
    };

    for (const categoryKey in permissions) {
      const category = permissions[categoryKey];

      for (const subKey in category) {
        const node = category[subKey];
        traverse(node, [subKey]);
      }
    }
  };

  const [dynamicSections, setDynamicSections] = useState<Section[]>([]);

  useEffect(() => {
    if (!accessTableData || !Array.isArray(accessTableData)) return;

    const parsedSections = buildSectionsFromBackend(accessTableData);
    const initialPermissions = buildFlatPermissionMap(accessTableData);

    setDynamicSections(parsedSections);
    setPermissions(initialPermissions);
  }, [accessTableData]);

  const flattenPermissions = (permTree: any): Record<string, boolean> => {
    const flat: Record<string, boolean> = {};

    const walk = (obj: any, parentKey = "") => {
      for (const key in obj) {
        if (key === "children") {
          walk(obj[key], parentKey);
          continue;
        }

        if (typeof obj[key] === "object" && "value" in obj[key]) {
          const compositeKey = `${key}-${parentKey}`;
          flat[compositeKey] = obj[key].value;
        }

        if (typeof obj[key] === "object") {
          walk(obj[key], key);
        }
      }
    };

    walk(permTree);
    return flat;
  };

  const SCOPE_OPTION_VALUES = ["personal", "personal-supervisor", "personal-subordinate", "all"];

  const parseUserHasScope = (scopeArray: string[]) => {
    const scopeMap: Record<string, string> = {};

    for (const scope of scopeArray) {
      for (const option of SCOPE_OPTION_VALUES) {
        if (scope.endsWith(option)) {
          const moduleKey = scope.slice(0, scope.length - option.length - 1);
          scopeMap[moduleKey] = option;
          break;
        }
      }
    }

    return scopeMap;
  };

  const parseDepartmentScope = (departmentScopeArray: string[], departmentData: any[]) => {
    const scopeMap: Record<string, string> = {};

    if (!Array.isArray(departmentScopeArray) || departmentScopeArray.length === 0) return scopeMap;

    for (const scope of departmentScopeArray) {
      const lastDashIndex = scope.lastIndexOf("-");
      if (lastDashIndex === -1) continue;

      const moduleKey = scope.slice(0, lastDashIndex);
      const departmentID = scope.slice(lastDashIndex + 1);

      if (moduleKey && departmentID) {
        const exists = departmentData.some(
          (d) => d.departmentID.toLowerCase() === departmentID.toLowerCase(),
        );

        if (exists) {
          scopeMap[moduleKey] = departmentID;
        }
      }
    }

    return scopeMap;
  };

  const applyPermissions = (rawRules) => {
    const parsedPermissions = buildPermissionsFromApi(accessTableData);
    const updated = JSON.parse(JSON.stringify(parsedPermissions));
    const updatedActions = new Set();
    const normalizedRules = {};

    (rawRules.userHasRule || []).forEach((ruleValue: string) => {
      if (typeof ruleValue !== "string") return;
      if (updatedActions.has(ruleValue)) return;
      updatedActions.add(ruleValue);

      applyRuleToPermissions(updated, ruleValue);
      normalizedRules[ruleValue] = 1;
    });

    const flatUpdated = flattenPermissions(updated);
    setBaseRules?.(normalizedRules);
    setPermissions(flatUpdated);
    setPermissionsData(updated);
  };

  const SelectScope: React.FC<SelectScopeProps> = ({ moduleKey, value = "", onChange }) => {
    const [localValue, setLocalValue] = useState<string>(value);
    const [keyer, setKeyer] = useState<string>(value);

    useEffect(() => {
      if (value === localValue) return;

      setLocalValue("");

      const t = setTimeout(() => {
        setLocalValue(value);
        setKeyer(value);
      }, 0);

      return () => clearTimeout(t);
    }, [value]);

    const handleChange = (v: string) => {
      setLocalValue(v);
      setKeyer(v);
      onChange(v);
    };

    return (
      <Select key={keyer} value={localValue || ""} onValueChange={handleChange}>
        <SelectTrigger className="h-7 border-0">
          <SelectValue placeholder="Select a scope">
            {SCOPE_OPTION.find((o) => o.id === localValue)?.name}
          </SelectValue>
        </SelectTrigger>

        <SelectContent>
          {SCOPE_OPTION.map((option) => (
            <SelectItem key={option.id} value={option.id}>
              {option.name}
            </SelectItem>
          ))}
        </SelectContent>
      </Select>
    );
  };

  const SelectDepartment: React.FC<SelectDepartmentProps> = ({
    value = "",
    onChange,
    departmentData = [],
  }) => {
    const [localValue, setLocalValue] = useState<string>(value);
    const [keyer, setKeyer] = useState<string>(value);

    useEffect(() => {
      if (value === localValue) return;

      setLocalValue("");
      const t = setTimeout(() => {
        setLocalValue(value);
        setKeyer(value);
      }, 0);

      return () => clearTimeout(t);
    }, [value]);

    const handleChange = (v: string) => {
      setLocalValue(v);
      setKeyer(v);
      onChange(v);
    };

    return (
      <Select
        key={keyer}
        value={localValue || ""}
        onValueChange={handleChange}
        onOpenAutoFocus={(e) => e.preventDefault()}
      >
        <SelectTrigger className="h-7 border-0">
          <SelectValue placeholder="Select a department">
            {departmentData.find((d) => d.departmentID === localValue)?.department}
          </SelectValue>
        </SelectTrigger>

        <SelectContent>
          <ScrollArea className="h-48">
            {departmentData.length > 0 ? (
              departmentData.map((dept) => (
                <SelectItem key={dept.UUID} value={dept.departmentID}>
                  {dept.department}
                </SelectItem>
              ))
            ) : (
              <div className="p-2 text-center text-sm text-gray-400">No departments available</div>
            )}
          </ScrollArea>
        </SelectContent>
      </Select>
    );
  };

  useEffect(() => {
    const fetchAndBuildPermissions = async () => {
      if (!accessTableData || !Array.isArray(accessTableData) || !userUUID || rules?.userHasRule)
        return;

      try {
        setIsDataLoading(true);

        const response = await fetch(
          `${ORIGIN}/user/api/user/get-update-user-has-rule-data?id=${userUUID}&company=${selectedUserCompany}`,
          {
            method: "GET",
            headers,
          },
        );

        if (!response.ok) throw new Error("Failed to fetch user permissions");

        const data = await response.json();

        if (data.userHasScope) {
          const parsedScopes = parseUserHasScope(data.userHasScope);
          setScopes(parsedScopes);
          setBaseScopes(parsedScopes);
        }

        if (data.userHasDepartmentScope) {
          const parsedDepartmentScopes = parseDepartmentScope(
            data.userHasDepartmentScope,
            departmentDropdownData,
          );
          setDepartments(parsedDepartmentScopes);
          setBaseDepartmentScopes(parsedDepartmentScopes);
        }

        applyPermissions(data);
        setIsDataLoading(false);
      } catch (error) {
        console.error("Error fetching user permissions:", error);
        const fallback = buildPermissionsFromApi(accessTableData);
        setPermissions(flattenPermissions(fallback));
        setIsDataLoading(false);
      } finally {
        setIsDataLoading(false);
      }
    };

    fetchAndBuildPermissions();
  }, [accessTableData, userUUID, selectedUserCompany]);

  useEffect(() => {
    if (!accessTableData || !Array.isArray(accessTableData) || !rules?.userHasRule?.length) return;
    applyPermissions(rules);
  }, [rules]);

  useEffect(() => {
    const fetchVerifyUser = async () => {
      try {
        const response = await fetch(
          `${ORIGIN}/user/api/user/verify-user-has-update-rbac?view=user`,
          {
            method: "GET",
            headers,
          },
        );

        if (!response.ok) throw new Error("Failed to fetch verify user data");

        const data = await response.json();

        if (data === true) {
          setIsUpdateRBAC(true);
        } else {
          setIsUpdateRBAC(false);
        }
      } catch (error) {
        console.error("Error fetching verify user data:", error);
        setIsUpdateRBAC(false);
      }
    };

    fetchVerifyUser();
  }, []);

  useEffect(() => {
    if (grantAllPermissions) {
      setPermissions((prev) => {
        const updated: Record<string, boolean> = {};
        for (const key in prev) {
          updated[key] = true;
        }
        return updated;
      });
      setGrantAllPermissions(false);
    }
  }, [grantAllPermissions]);

  useEffect(() => {
    if (revokeAllPermissions) {
      setPermissions((prev) => {
        const updated: Record<string, boolean> = {};
        for (const key in prev) {
          updated[key] = false;
        }
        return updated;
      });
      setRevokeAllPermissions(false);
    }
  }, [revokeAllPermissions]);

  const togglePermission = (access: string, action: Action) => {
    const key = buildPermissionKey(action, access);
    setPermissions((prev) => {
      const newValue = !prev[key];

      setPermissionsData((prevData) => {
        const newData = JSON.parse(JSON.stringify(prevData));

        const normalize = (str: string) => str.trim().toLowerCase().replace(/\s+/g, "-");

        const targetAccess = normalize(access);

        const updateNode = (node: any, path: string[] = []) => {
          if (!node || typeof node !== "object") return;

          const currentKey = path.length > 0 ? normalize(path[path.length - 1]) : null;
          const isTargetMatch = currentKey === targetAccess;

          if (isTargetMatch && node[action] && typeof node[action] === "object") {
            node[action].value = newValue;
          }

          if (node.children) {
            for (const childKey in node.children) {
              updateNode(node.children[childKey], [...path, childKey]);
            }
          }
        };

        for (const categoryKey in newData) {
          const modules = newData[categoryKey];

          for (const moduleKey in modules) {
            if (normalize(moduleKey) === targetAccess) {
              if (modules[moduleKey][action]) {
                modules[moduleKey][action].value = newValue;
              }
            }

            updateNode(modules[moduleKey]);
          }
        }

        return newData;
      });

      return {
        ...prev,
        [key]: newValue,
      };
    });
  };

  const prepareRows = (sections: Section[]): Section[] => {
    return sections.map((section) => ({
      ...section,
      children: section.children ? prepareRows(section.children) : [],
    }));
  };

  const rows = useMemo(() => prepareRows(dynamicSections), [dynamicSections]);

  const toDisplayLabel = (key: string): string =>
    key
      .split("-")
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(" ");

  const columns = useMemo<ColumnDef<Section>[]>(() => {
    return [
      {
        accessorKey: "all",
        header: "All",
        cell: ({ row }) => {
          const { access, allowedActions, children } = row.original;

          const getAllRulesRecursive = (node: any): string[] => {
            let rules: string[] = [];

            if (node.allowedActions?.length) {
              rules.push(
                ...node.allowedActions.map((action) => buildPermissionKey(action, node.access)),
              );
            }

            if (Array.isArray(node.children)) {
              node.children.forEach((child) => {
                rules.push(...getAllRulesRecursive(child));
              });
            }

            return rules;
          };

          const allRules = getAllRulesRecursive(row.original);

          if (!allRules.length) return null;

          const allChecked = allRules.every((key) => !!permissions[key]);
          const someChecked = allRules.some((key) => !!permissions[key]);
          const indeterminate = someChecked && !allChecked;

          const toggleAllForRow = (checked: boolean) => {
            setPermissions((prev) => {
              const updated = { ...prev };
              allRules.forEach((key) => (updated[key] = checked));
              return updated;
            });

            setPermissionsData((prevData) => {
              const newData = JSON.parse(JSON.stringify(prevData));

              const updateNode = (node: any) => {
                if (!node || typeof node !== "object") return;

                node.allowedActions?.forEach((action: string) => {
                  const key = buildPermissionKey(action, node.access);
                  if (node[action]) node[action].value = checked;
                });

                if (Array.isArray(node.children)) {
                  node.children.forEach(updateNode);
                }
              };

              for (const categoryKey in newData) {
                const modules = newData[categoryKey];
                for (const moduleKey in modules) {
                  updateNode(modules[moduleKey]);
                }
              }

              return newData;
            });
          };

          return (
            <Checkbox
              className="border-erp-blue-11 data-[state=checked]:bg-erp-blue-11"
              checked={allChecked}
              onCheckedChange={(value) => toggleAllForRow(value === true)}
            />
          );
        },

        meta: { rowSpan: 2 },
      },
      {
        accessorKey: "access",
        header: "Access",
        cell: ({ row, getValue }) => {
          const rawValue = getValue() as string;
          const displayLabel = toDisplayLabel(rawValue);

          return (
            <div className="min-w-80" style={{ paddingLeft: `${row.depth * 2.5 + 0.5}rem` }}>
              <div
                className={cn(
                  "flex items-center gap-x-3",
                  row.depth === 0 && "font-semibold",
                  row.depth === 0 && row.getIsExpanded() && "text-erp-blue-13",
                )}
              >
                {row.getCanExpand() && (
                  <div className="flex items-center justify-center">
                    <button
                      onClick={(e) => {
                        row.toggleExpanded();
                        e.stopPropagation();
                      }}
                      className="cursor-pointer text-erp-blue-12"
                    >
                      {!row.getIsExpanded() ? (
                        <ChevronUp size={16} strokeWidth={2.5} />
                      ) : (
                        <ChevronDown size={16} strokeWidth={2.5} />
                      )}
                    </button>
                  </div>
                )}
                {displayLabel}
              </div>
            </div>
          );
        },
        meta: { rowSpan: 2 },
      },
      {
        accessorKey: "scope",
        header: () => <div className="w-52">Data Scope</div>,
        cell: ({ row }) => {
          const { hasScope } = row.original;
          if (!hasScope || row.depth === 0) return null;

          const moduleKey = row.original.access;
          return (
            <SelectScope
              moduleKey={moduleKey}
              value={scopes[moduleKey]}
              onChange={(v) => setScopes((prev) => ({ ...prev, [moduleKey]: v }))}
            />
          );
        },
        meta: { rowSpan: 2 },
      },
      {
        accessorKey: "departmentScope",
        header: () => <div className="w-52">Department Scope</div>,
        cell: ({ row }) => {
          if (row.depth === 0) return null;

          const moduleKey = row.original.access;
          return (
            <SelectDepartment
              value={departments[moduleKey]}
              departmentData={departmentDropdownData}
              onChange={(v) => setDepartments((prev) => ({ ...prev, [moduleKey]: v }))}
            />
          );
        },
      },
      {
        accessorKey: "view",
        header: "View",
        cell: ({ row }) => {
          const action = "View";
          const { access, allowedActions } = row.original;
          if (!allowedActions?.includes(action)) return null;

          const id = buildPermissionKey(action, access);
          return (
            <Checkbox
              className="border-erp-blue-11 data-[state=checked]:bg-erp-blue-11"
              checked={permissions[id] || false}
              onCheckedChange={() => togglePermission(access, action)}
            />
          );
        },
        meta: { rowSpan: 2 },
      },
      {
        header: "Standard Action",
        columns: STANDARD_ACTIONS.map((action) => ({
          header: action,
          id: action,
          cell: ({ row }) => {
            const { access, allowedActions } = row.original;
            if (!allowedActions?.includes(action)) return null;

            const id = buildPermissionKey(action, access);
            return (
              <Checkbox
                className="border-erp-blue-11 data-[state=checked]:bg-erp-blue-11"
                checked={permissions[id] || false}
                onCheckedChange={() => togglePermission(access, action)}
              />
            );
          },
        })),
      },
      {
        header: "Document Action",
        columns: DOCUMENT_ACTIONS.map((action) => ({
          header: action,
          id: action,
          cell: ({ row }) => {
            const { access, allowedActions } = row.original;
            if (!allowedActions?.includes(action)) return null;

            const id = buildPermissionKey(action, access);
            return (
              <Checkbox
                className="border-erp-blue-11 data-[state=checked]:bg-erp-blue-11"
                checked={permissions[id] || false}
                onCheckedChange={() => togglePermission(access, action)}
              />
            );
          },
        })),
      },
      {
        header: "e-Invoice",
        columns: E_INVOICE_ACTIONS.map((action) => ({
          header: action,
          id: action,
          cell: ({ row }) => {
            const { access, allowedActions } = row.original;
            if (!allowedActions?.includes(action)) return null;

            const id = buildPermissionKey(action, access);
            return (
              <Checkbox
                className="border-erp-blue-11 data-[state=checked]:bg-erp-blue-11"
                checked={permissions[id] || false}
                onCheckedChange={() => togglePermission(access, action)}
              />
            );
          },
        })),
      },
    ];
  }, [permissions]);

  const table = useReactTable({
    data: rows,
    columns,
    getSubRows: (row) => row.children,
    getCoreRowModel: getCoreRowModel(),
    getExpandedRowModel: getExpandedRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
  });

  return (
    <ScrollArea className="-m-1.5 h-[72cqh] w-[calc(100vw-202px)]">
      <Table className="border-separate border-spacing-1.5 whitespace-nowrap">
        <TableHeader className="sticky top-0">
          {table.getHeaderGroups().map((headerGroup) => (
            <TableRow key={headerGroup.id}>
              {headerGroup.headers.map((header) => {
                const columnRelativeDepth = header.depth - header.column.depth;
                if (columnRelativeDepth > 1) {
                  return null;
                }

                let rowSpan = 1;
                if (header.isPlaceholder) {
                  const leafs = header.getLeafHeaders();
                  rowSpan = leafs[leafs.length - 1].depth - header.depth;
                }

                return (
                  <TableHead
                    className="h-8 min-w-24 rounded-md bg-erp-blue-11 p-1 text-center font-normal"
                    colSpan={header.colSpan}
                    rowSpan={rowSpan}
                    key={header.id}
                  >
                    <div className="flex flex-col gap-y-1.5">
                      <div className="flex items-center justify-center gap-x-0.5 font-bold text-white">
                        {flexRender(header.column.columnDef.header, header.getContext())}
                      </div>
                      {(header.column.id === "access" ||
                        header.column.id === "scope" ||
                        header.column.id === "departmentScope") && (
                        <TableHeadColumnTextFilter column={header.column} table={table} />
                      )}
                    </div>
                  </TableHead>
                );
              })}
            </TableRow>
          ))}
        </TableHeader>
        <TableBody>
          {table.getRowModel().rows?.length ? (
            table.getRowModel().rows.map((row) => (
              <TableRow
                data-state={row.getIsSelected() && "selected"}
                // onClick={onRowSelection(row)}
                key={row.id}
              >
                {row.getVisibleCells().map((cell) => (
                  <TableCell
                    className={cn(
                      "h-8 rounded-md border border-erp-gray-4",
                      !(cell.column.id === "scope" || cell.column.id === "departmentScope")
                        ? "p-1"
                        : "p-0",
                    )}
                    key={cell.id}
                  >
                    <div
                      className={cn(
                        "flex items-center",
                        !(
                          cell.column.id === "access" ||
                          cell.column.id === "scope" ||
                          cell.column.id === "departmentScope"
                        )
                          ? "justify-center"
                          : "justify-start",
                      )}
                    >
                      {flexRender(cell.column.columnDef.cell, cell.getContext())}
                    </div>
                  </TableCell>
                ))}
              </TableRow>
            ))
          ) : (
            <NoResultsTableRow
              columns={columns}
              message={errorMessage ? errorMessage : "Error fetching data"}
            />
          )}
          {(isLoading || isDataLoading) && <LoadingUI />}
        </TableBody>
      </Table>
      <ScrollBar orientation="horizontal" />
    </ScrollArea>
  );
}
