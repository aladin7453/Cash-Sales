"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { ColumnFiltersState, PaginationState, SortingState } from "@tanstack/react-table";
import { notFound, useRouter, useSearchParams } from "next/navigation";
import { useEffect, useState } from "react";
import { useForm } from "react-hook-form";
import {
  FaClipboard,
  FaHandshakeSimple,
  FaLayerGroup,
  FaMobile,
  FaTableList,
  FaUniversalAccess,
} from "react-icons/fa6";
import useSWRImmutable from "swr/immutable";
import { z } from "zod";

import CancelButton from "@/components/form/ActionButton/Cancel";
import CloneButton from "@/components/form/ActionButton/Clone";
import DeleteButton from "@/components/form/ActionButton/Delete";
import NewButton from "@/components/form/ActionButton/New";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import DriverDetails from "@/components/icons/svg-repo/DriverDetails";
import JobScope from "@/components/icons/svg-repo/JobScope";
import PersonalDetails from "@/components/icons/svg-repo/PersonalDetails";
import TopActionBar from "@/components/layouts/TopActionBar";
import LoadingUI from "@/components/LoadingUI";
import { Button } from "@/components/ui/button";
import { Checkbox } from "@/components/ui/checkbox";
import {
  Dialog,
  DialogClose,
  DialogContent,
  DialogFooter,
  DialogTitle,
} from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Separator } from "@/components/ui/separator";
import { TabsNavigator } from "@/components/ui/TabsNavigator";
import { useToast } from "@/components/ui/use-toast";
import {
  DEFAULT_DATA_TABLE_PAGE_SIZE,
  getAuthHeaders,
  getCurrentAccount,
  getCurrentCompanyUUID,
  ORIGIN,
} from "@/lib/constants";

import { useMyContext } from "../contextProvider";
import { changelogColumns } from "./changelog/columns";
import RuleTemplateChangelogDataTable from "./changelog/DataTable";
import RBACTabs from "./RBAC/tabs";

import type { RuleTemplate } from "../columns";

type PageParams = {
  params: { slug: string };
};

const validRoutes = ["new", "edit", "clone"] as const;

const fetcher = async (url: string) => {
  const headers = getAuthHeaders();

  return fetch(url, { headers }).then(async (res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    try {
      return await res.json();
    } catch (error) {
      throw new Error("Failed to parse response JSON");
    }
  });
};

type ValidRoute = (typeof validRoutes)[number];

export type ProfileImageAttachment = {
  name: string;
  link: string;
};

const userFormSchema = z.object({
  // account: z.string().min(1).nonempty({
  //   message: "Please select a status.",
  // }),
  // accountName: z.string().min(1).nonempty({
  //   message: "Please select a status.",
  // }),
  // username: z.string().min(1).nonempty({
  //   message: "Please select a status.",
  // }),
  // validity: z.union([z.literal(0), z.literal(1)]).default(1),
});

function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

export default function UserDetailsPage({ params }: PageParams) {
  const router = useRouter();
  const slug = params.slug;
  const headers = getAuthHeaders();
  const { toast } = useToast();

  const searchParams = useSearchParams();

  const id = searchParams.get("id");
  const [formResetKey, setFormResetKey] = useState(0);

  const [ruleTemplateData, setRuleTemplateData] = useState<RuleTemplate | null | undefined>(null);
  const [isSaving, setIsSaving] = useState(false);
  const [permissions, setPermissions] = useState<Record<string, boolean>>({});
  const [showSaveTemplateForm, setShowSaveTemplateForm] = useState(false);
  const shareDataValue = useMyContext();
  const resetForm = () => {
    setFormResetKey((prevKey) => prevKey + 1);
  };
  const companyUUID = getCurrentCompanyUUID();
  const currentAccount = getCurrentAccount();

  const [columnFilters, setColumnFilters] = useState<ColumnFiltersState>([]);
  const [pagination, setPagination] = useState<PaginationState>({
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });
  const [sorting, setSorting] = useState<SortingState>([{ id: "createdAt", desc: true }]);

  if (!isValidRoute(slug)) {
    notFound();
  }

  const {
    data: ruleTemplate,
    error,
    isLoading,
    isValidating,
    mutate: mutateUserData,
  } = useSWRImmutable(
    id ? `${ORIGIN}/rule_template/api/rule-template/get-update-rule-template-data?id=${id}` : null,
    fetcher,
    { revalidateOnFocus: false },
  );

  const [changelogData, setChangelogData] = useState(null);

  const handleTableParamsChange = (
    newFilters: ColumnFiltersState,
    newPagination: PaginationState,
    newSorting: SortingState,
  ) => {
    setColumnFilters(newFilters);
    setPagination(newPagination);
    setSorting(newSorting);
  };

  useEffect(() => {
    if (ruleTemplate) {
      setRuleTemplateData(ruleTemplate.data);
      if (ruleTemplate.historyData) {
        const historyData = {
          ruleTemplate: ruleTemplate.historyData || {
            rows: [],
          },
        };
        setChangelogData(historyData);
      }
    }
  }, [ruleTemplate]);

  const tabs = [
    {
      id: "rbac",
      name: "RBAC",
      shortName: "RBAC",
      icon: FaUniversalAccess,
    },

    ...(slug !== "new"
      ? [
          {
            id: "changelog",
            name: "Changelog",
            shortName: "Changelog",
            icon: FaTableList,
          },
        ]
      : []),
  ];

  const handleSubmit = async () => {
    try {
      setIsSaving(true);
      await form.trigger();
      await form.handleSubmit(onSubmit)();
    } catch (error) {
      console.error("Form submission error:", error);
      setIsSaving(false);
    }
  };

  const form = useForm<z.infer<typeof userFormSchema>>({
    resolver: zodResolver(userFormSchema),
    defaultValues: {},
  });

  const onSubmit = async () => {
    var saveType =
      slug == "clone" ? `create-data?c_id=1` : id ? `update-rule-template?id=${id}` : `create-data`;

    const userHasRule: Record<string, any> = {};
    const ruleTemplateName =
      slug == "new" || "clone" || "edit"
        ? form.getValues("ruleTemplate")
        : ruleTemplate.data.ruleTemplate;

    const defaultKeys = [
      "view",
      "create",
      "update",
      "throw",
      "restore",
      "delete",
      "download",
      "auth",
      "bill",
      "print",
      "preview",
      "transfer-from",
      "transfer-to",
      "export",
      "confirm",
      "verify",
      "compulsary",
      "assignment",
      "progress",
      "generate-qr-code",
      "disable",
      "upload",
    ];

    Object.entries(permissions).forEach(([ruleKey, isChecked]) => {
      if (!isChecked) return;

      let action: string | null = null;
      let moduleKey: string | null = null;

      const sortedKeys = [...defaultKeys].sort((a, b) => b.length - a.length);

      for (const key of sortedKeys) {
        if (ruleKey.startsWith(`${key}-`)) {
          action = key;
          moduleKey = ruleKey.slice(key.length + 1);
          break;
        }
      }

      if (!action || !moduleKey) {
        console.warn(`Unrecognized ruleKey format: ${ruleKey}`);
        return;
      }

      const fullActionKey = ruleKey;

      if (!userHasRule[fullActionKey]) {
        userHasRule[fullActionKey] = {};
      }
    });

    const formData = new FormData();
    formData.append("ruleTemplate[rule]", JSON.stringify({ userHasRule }));
    formData.append("ruleTemplate[account]", currentAccount);
    formData.append("ruleTemplate[company]", companyUUID);
    formData.append("ruleTemplate[ruleTemplate]", ruleTemplateName);

    try {
      const response = await fetch(`${ORIGIN}/rule_template/api/rule-template/${saveType}`, {
        method: "POST",
        headers,
        body: formData,
      });

      const responseData = await response.json();
      if (responseData && responseData.item) {
        const url = `/organization/rule-template/edit?item=${responseData.item}&id=${responseData.data}`;
        setShowSaveTemplateForm(false);
        router.push(url);
        shareDataValue?.setRefreshSideBar?.(true);
        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (responseData.message) {
        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        setShowSaveTemplateForm(false);
        router.push(`/organization/rule-template/clone?id=${id}`);
        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error creating new rule template data:", error);
      toast({
        title: `${error.message}`,
        duration: 2000,
      });
    } finally {
      setShowSaveTemplateForm(false);
      setIsSaving(false);
    }
  };

  useEffect(() => {
    form.reset(ruleTemplateData || {});
  }, [ruleTemplateData, form]);

  const handleSave = async () => {
    handleSubmit();
  };

  return (
    <div className="relative flex h-full flex-col">
      <TopActionBar
        left={
          <>
            <SaveButton
              onSubmit={
                slug == "new" || "clone" || "edit"
                  ? () => setShowSaveTemplateForm(true)
                  : handleSave
              }
            />
            {id && slug !== "clone" && <NewButton destination="/organization/rule-template/new" />}
            {id && slug !== "clone" && (
              <CloneButton destination={`/organization/rule-template/clone?id=${id}`} />
            )}
            <CancelButton onClick={() => router.push(`/organization/rule-template/`)} />
          </>
        }
      />
      <Form {...form}>
        <div className="grid h-full grid-cols-[1fr_auto] gap-x-2 overflow-hidden">
          <ScrollArea className="h-full">
            <div id="rbac" className="mt-2">
              <RBACTabs
                userUUID={id}
                rules={ruleTemplateData}
                permissions={permissions}
                setPermissions={setPermissions}
              />
            </div>

            {slug !== "new" && (
              <div id="changelog" className="mt-2">
                <RuleTemplateChangelogDataTable
                  columns={changelogColumns}
                  initialData={changelogData}
                  onTableParamsChange={handleTableParamsChange}
                />
              </div>
            )}
          </ScrollArea>

          <TabsNavigator tabs={tabs} initialActiveTabId="rbac" />
        </div>
        {isLoading && <LoadingUI />}
      </Form>

      <Dialog open={showSaveTemplateForm} onOpenChange={setShowSaveTemplateForm}>
        <DialogContent className="max-w-l rounded-md bg-white p-6">
          <Form {...form}>
            <form className="space-y-4" onSubmit={(e) => e.preventDefault()}>
              <DialogTitle className="text-center text-2xl font-bold">
                Save RBAC Template
              </DialogTitle>

              <Separator className="bg-erp-blue-11" />

              <FormField
                control={form.control}
                name="ruleTemplate"
                render={({ field }) => (
                  <FormItem className="block">
                    <FormLabel className="w-36 text-left text-sm font-semibold">
                      Template Name:
                    </FormLabel>
                    <FormControl className="space-y-5">
                      <Input className="h-8 w-full" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <div className="mt-[5px] flex justify-center gap-4 p-10">
                <Button
                  type="button"
                  variant="ghost"
                  onClick={() => {
                    setShowSaveTemplateForm(false);
                  }}
                  className="h-10 w-40 bg-erp-blue-14 text-white hover:bg-erp-blue-13 hover:text-white"
                >
                  Cancel
                </Button>
                <Button
                  type="button"
                  onClick={handleSubmit}
                  className="h-10 w-40 border border-erp-blue-14 bg-white text-erp-blue-14"
                >
                  OK
                </Button>
              </div>
            </form>
          </Form>
          {isSaving && <LoadingUI />}
        </DialogContent>
      </Dialog>
      {(isLoading || isValidating || isSaving) && <LoadingUI />}
    </div>
  );
}
