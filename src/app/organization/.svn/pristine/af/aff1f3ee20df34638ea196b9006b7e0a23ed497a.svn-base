"use client";

import { format, fromUnixTime } from "date-fns";
import { CalendarIcon } from "lucide-react";
import moment from "moment";
import { useState } from "react";

import { Button } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { DATE_FORMAT } from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

type Params = {
  form: any;
};

const licenseClass = [
  { label: "A", value: "A" },
  { label: "A1", value: "A1" },
  { label: "B", value: "B" },
  { label: "B1", value: "B1" },
  { label: "B2", value: "B2" },
  { label: "C", value: "C" },
  { label: "D", value: "D" },
  { label: "DA", value: "DA" },
  { label: "E", value: "E" },
  { label: "E1", value: "E1" },
  { label: "E2", value: "E2" },
  { label: "F", value: "F" },
  { label: "G", value: "G" },
  { label: "H", value: "H" },
  { label: "I", value: "I" },
  { label: "M", value: "M" },
];

export function DriverLicenseDetailsForm({ form }: Params) {
  const [isPopoverOpen, setIsPopoverOpen] = useState(false); // State to manage popover visibility

  return (
    <Card className="h-auto shadow-md">
      <CardHeader className="pb-3">
        <CardTitle className="text-lg font-bold">Driver License Details</CardTitle>
      </CardHeader>
      <CardContent>
        <Form {...form}>
          <form>
            <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-4">
              <FormField
                control={form.control}
                name="licenseNo"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>License No:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="user"
                        fieldName="licenseNo"
                        columnName="License No"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="licenseClass"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>License Class:</FormLabel>

                    <Popover>
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            variant="outline"
                            size="sm"
                            className="h-7.5 w-full justify-start"
                          >
                            {field.value?.length
                              ? field.value.join(", ")
                              : "Click here to select license class"}
                          </Button>
                        </FormControl>
                      </PopoverTrigger>

                      <PopoverContent className="w-56 p-2">
                        <div className="space-y-2">
                          {licenseClass.map((item) => {
                            const checked = field.value?.includes(item.value);

                            return (
                              <label
                                key={item.value}
                                className="flex cursor-pointer items-center space-x-2"
                              >
                                <input
                                  type="checkbox"
                                  className="h-4 w-4"
                                  checked={checked}
                                  onChange={(e) => {
                                    if (e.target.checked) {
                                      field.onChange([...(field.value || []), item.value]);
                                    } else {
                                      field.onChange(
                                        field.value.filter((value: string) => value !== item.value),
                                      );
                                    }
                                  }}
                                />
                                <span className="text-sm">{item.label}</span>
                              </label>
                            );
                          })}
                        </div>
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="lastRenewalDate"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Last Renewal Date:</FormLabel>
                    <Popover>
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            className={cn(
                              "flex h-7.5 w-full",
                              !field.value && "text-muted-foreground",
                            )}
                            variant="outline"
                            size="sm"
                          >
                            {field.value
                              ? moment.unix(field.value).format(DATE_FORMAT)
                              : "Pick a date"}
                            <CalendarIcon className="ml-auto h-4 w-4" />
                          </Button>
                        </FormControl>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={field.value ? moment.unix(field.value).toDate() : undefined}
                          onSelect={(date) => {
                            const unixTimestamp = date ? Math.floor(date.getTime() / 1000) : "";
                            field.onChange(unixTimestamp.toString());
                          }}
                          initialFocus
                          defaultMonth={new Date()}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="expirationDate"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Expiration Date:</FormLabel>
                    <Popover>
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            className={cn(
                              "flex h-7.5 w-full",
                              !field.value && "text-muted-foreground",
                            )}
                            variant="outline"
                            size="sm"
                          >
                            {field.value
                              ? moment.unix(field.value).format(DATE_FORMAT)
                              : "Pick a date"}
                            <CalendarIcon className="ml-auto h-4 w-4" />
                          </Button>
                        </FormControl>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={field.value ? moment.unix(field.value).toDate() : undefined}
                          onSelect={(date) => {
                            const unixTimestamp = date ? Math.floor(date.getTime() / 1000) : "";
                            field.onChange(unixTimestamp.toString());
                          }}
                          initialFocus
                          defaultMonth={new Date()}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}
