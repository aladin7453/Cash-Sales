// CompanyDataTableToolbar.tsx
"use client";

import React, { useEffect, useState } from "react";
import type { Table } from "@tanstack/react-table";

import CloneButton from "@/components/data-table/ActionButton/Clone";
import DeleteButton from "@/components/data-table/ActionButton/Delete";
import EditButton from "@/components/data-table/ActionButton/Edit";
import NewButton from "@/components/data-table/ActionButton/New";
import RestoreButton from "@/components/data-table/ActionButton/Restore";
import TrashButton from "@/components/data-table/ActionButton/Trash";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import Validity from "@/components/data-table/Validity";

import SettingFormPopover from "./[slug]/setting/SettingFormPopover"; // Import SettingFormPopover
import SettingButton from "./setting"; // Import SettingButton

type Props<TData> = {
  table: Table<TData>;
  defaultColumns?: VisibilityState;
  totalNumOfRows?: number; // Add totalNumOfRows prop for server-side filtering
  refreshTable: () => void; // Define refreshTable prop type
  dataStatusBadgeDisplay?: React.ReactNode;
};

export default function CompanyDataTableToolbar<TData>({
  table,
  defaultColumns,
  refreshTable,
  totalNumOfRows,
  dataStatusBadgeDisplay,
}: Props<TData>) {
  const [isPopoverOpen, setPopoverOpen] = useState(false); // State for popover visibility

  // Example selected row data (this should be replaced with actual selected row data)
  const selectedRowData = {
    UUID: "",
    prefix: "",
    runningDigitNo: "",
    nextNo: "",
    output: "",
  };

  const handleSettingClick = () => {
    setPopoverOpen(true); // Open the popover when SettingButton is clicked
  };

  return (
    <div className="flex items-center justify-between p-1.5">
      <ActionGroupStart
        table={table}
        refreshTable={refreshTable}
        handleSettingClick={handleSettingClick}
      />

      <Pagination table={table}  totalNumOfRows={totalNumOfRows}/>

      <ActionGroupEnd
        table={table}
        defaultColumns={defaultColumns}
        refreshTable={refreshTable}
        dataStatusBadgeDisplay={dataStatusBadgeDisplay}
      />

      {/* Render SettingFormPopover */}
      <SettingFormPopover
        open={isPopoverOpen}
        setOpen={setPopoverOpen}
        row={selectedRowData}
        revalidateSettingData={() => {
          /* Handle revalidation */
        }}
        setTempRowSettingData={() => {
          /* Handle temp row data */
        }}
      />
    </div>
  );
}

function ActionGroupStart<TData>({
  table,
  refreshTable,
  handleSettingClick,
}: Props<TData> & { handleSettingClick: () => void }) {
  const [selectedRow, setSelectedRow] = useState("");
  const [companyName, setCompanyName] = useState("");

  const selectedRowModel = table.getSelectedRowModel();

  useEffect(() => {
    if (selectedRowModel.rows.length === 1) {
      setSelectedRow(selectedRowModel.rows[0].original.UUID);
      setCompanyName(selectedRowModel.rows[0].original.company);
    }
  }, [selectedRowModel]);

  return (
    <div className="flex flex-wrap items-center justify-start gap-x-2 p-1">
      <NewButton destination="/organization/company/new" />
      <EditButton
        table={table}
        destination={`/organization/company/edit?item=${companyName}&id=${selectedRow}`}
      />
      <CloneButton
        table={table}
        destination={`/organization/company/clone?id=${selectedRow}`}
      />
      <TrashButton
        table={table}
        module={"company"}
        model={"company"}
        refreshTable={refreshTable}
      />
      <RestoreButton
        table={table}
        module={"company"}
        model={"company"}
        refreshTable={refreshTable}
      />
      <DeleteButton
        table={table}
        module={"company"}
        model={"company"}
        refreshTable={refreshTable}
      />
    </div>
  );
}

function ActionGroupEnd<TData>({
  table,
  defaultColumns,
  refreshTable,
  dataStatusBadgeDisplay,
}: Props<TData>) {
  return (
    <div className="relative flex items-center gap-x-1 pr-1.5 text-erp-blue-14">
      <span className="absolute -left-32">{dataStatusBadgeDisplay}</span>

      <Export table={table} module={"company"} mainModule={"organization"} />
      <Refresh
        refreshTable={refreshTable}
        resetRowSelection={() => table.resetRowSelection()}
      />
      <Validity table={table} />
      <ColumnVisibilityToggle table={table} defaultColumns={defaultColumns} />
    </div>
  );
}
