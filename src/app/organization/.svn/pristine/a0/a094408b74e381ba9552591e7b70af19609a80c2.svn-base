"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { notFound, useRouter, useSearchParams } from "next/navigation";
import React, { useEffect, useLayoutEffect, useRef, useState } from "react";
import { useForm } from "react-hook-form";
import { FaCircleXmark, FaFileCirclePlus } from "react-icons/fa6";
import { z } from "zod";

import CancelButton from "@/components/form/ActionButton/Cancel";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import LoadingUI from "@/components/LoadingUI";
import { Checkbox } from "@/components/ui/checkbox";
import { Dialog, DialogClose, DialogContent } from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { useToast } from "@/components/ui/use-toast";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { getFileToBase64 } from "@/lib/utils/commonFunction";

import type { Dispatch, SetStateAction } from "react";

import type { CustomInformation } from "../custom-information/columns";

type Props = {
  open: boolean;
  setOpen: Dispatch<SetStateAction<boolean>>;
  revalidateCustomInfoData: () => void;
  setTempRowCustomInfoData: (data: any, overwrite: boolean) => void;
  setCompanyData: Dispatch<SetStateAction<CustomInformation[]>>;
  row?: any;
  tempRowCustomInfo?: any[];
  slug: string;
};

const customInformationFormSchema = z.object({
  UUID: z.union([z.string(), z.literal("")]),
  fieldName: z.string().min(2, {
    message: "Field Name must be at least 2 characters.",
  }),
  fieldValue: z.string().min(2, {
    message: "Field Value must be at least 2 characters.",
  }),
  attachment: z.custom((value) => {
    if (!value || !value[0]) {
      return "Attachment is required.";
    }
    return true;
  }),
  valid: z.union([z.string(), z.literal("")]),
});

export default function CustomInformationFormPopover({
  open,
  setOpen,
  row,
  tempRowCustomInfo,
  setTempRowCustomInfoData,
  revalidateCustomInfoData,
  slug,
}: Props) {
  const router = useRouter();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const data: any = row;
  const { toast } = useToast();
  const headers = getAuthHeaders();

  const [customInfoFiles, setCustomInfoFiles] = useState<any[]>([]);
  const [fileError, setFileError] = useState<string | null>(null);
  const fileInputRef = useRef(null);

  const [isSaving, setIsSaving] = useState(false);

  const handleChooseFileClick = () => {
    fileInputRef.current.click();
  };

  useEffect(() => {
    if (data && data.attachmentLink) {
      setCustomInfoFiles(data.attachmentLink);
    }

    if (data && data.attachmentFiles) {
      setCustomInfoFiles(data.attachmentFiles);
    }

    return () => {};
  }, [data]);

  function handleDeleteFile(index) {
    var newCustomInfoFiles = [...customInfoFiles];

    newCustomInfoFiles.splice(index, 1);

    setCustomInfoFiles(newCustomInfoFiles);
  }

  const form = useForm<z.infer<typeof customInformationFormSchema>>({
    resolver: zodResolver(customInformationFormSchema),
    defaultValues: {
      UUID: data?.UUID !== undefined ? data.UUID : "",
      fieldName: data?.fieldName !== undefined ? data.fieldName : "",
      fieldValue: data?.fieldValue !== undefined ? data.fieldValue : "",
      attachment: data?.attachment ? [new File([], data.attachment)] : null,
      valid: data?.valid ?? "1",
    },
  });

  const validateFileType = (file: File): boolean => {
    const allowedTypes = [".pdf", ".png", ".jpg", ".jpeg"];
    const fileExtension = "." + file.name.split(".").pop()?.toLowerCase();
    return allowedTypes.includes(fileExtension);
  };

  const handleFileChange = (event) => {
    const fileList = Array.from(event.target.files);

    // Validate file types
    for (const file of fileList) {
      if (!validateFileType(file)) {
        setFileError("Only (.pdf, .png, .jpg, .jpeg) files are allowed.");
        return;
      }
    }

    setFileError(null);
    const mergeArray: any = [...customInfoFiles, ...fileList];
    setCustomInfoFiles(mergeArray);
  };

  const updateCustomInfoData = async (data) => {
    var counter = 0;

    try {
      setIsSaving(true);

      const formData = new FormData();

      for (var key in data) {
        if (key !== "attachment") {
          formData.append(`companyHasCustomInfo[${key}]`, data[key]);
        }
      }

      for (const fileData of customInfoFiles) {
        if (fileData.size) {
          var base64: any = await getFileToBase64(fileData);

          formData.append(`companyHasCustomInfo[attachment][${counter}][Name]`, fileData.name);
          formData.append(`companyHasCustomInfo[attachment][${counter}][File]`, base64);
        } else {
          formData.append(`companyHasCustomInfo[attachment][${counter}][Name]`, fileData.name);
          formData.append(`companyHasCustomInfo[attachment][${counter}][File]`, " ");
        }

        counter++;
      }

      const response = await fetch(
        `${ORIGIN}/company/api/company/update-company-has-custom-info-data?id=${id}`,
        {
          method: "POST",
          headers,
          body: formData,
        },
      );

      if (!response.ok) {
        const errorData = await response.json();

        if (response.status === 403) {
          toast({
            title: errorData.message,
            variant: "destructive",
            duration: 2000,
          });
        }

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData) {
        toast({
          title: responseData.message,
          description: "Custom information added successfully",
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error updating custom information data:", error);
    } finally {
      setIsSaving(false);
    }
  };

  const onSubmit = async (values) => {
    if (!values) return;

    try {
      if (fileError) {
        toast({
          title: fileError,
          variant: "destructive",
          duration: 2000,
        });
        return;
      }

      setIsSaving(true);

      const newData: any = { ...values };

      if (id && slug === "edit") {
        await updateCustomInfoData(newData);

        revalidateCustomInfoData();
      } else {
        newData.attachmentFiles = customInfoFiles;

        setTempRowCustomInfoData(newData, false);
      }

      handleReset();
      setCustomInfoFiles([]);
      setOpen(false);
    } catch (error) {
      console.error("Error submitting form:", error);
    } finally {
      setIsSaving(false);
    }
  };

  const handleReset = () => {
    form.reset({
      UUID: "",
      fieldName: "",
      fieldValue: "",
      attachment: null,
      valid: "1",
    });
    setFileError(null);
  };

  useEffect(() => {
    if (open) {
      !data && handleReset();
      !data && setCustomInfoFiles([]);
    }
  }, [open]);

  return (
    <Dialog open={open} onOpenChange={setOpen} className="m-2">
      <DialogContent className="max-w-6xl bg-erp-blue-3 p-2">
        <Form {...form}>
          <form className="space-y-2" onSubmit={form.handleSubmit(onSubmit)}>
            <div className="flex items-center justify-between pr-4">
              <div className="grid auto-cols-fr grid-flow-col gap-x-1.5">
                <SaveButton />
                <ResetButton onClick={handleReset} />
                <DialogClose asChild>
                  <CancelButton />
                </DialogClose>
              </div>
              <FormField
                control={form.control}
                name="valid"
                render={({ field }) => (
                  <FormItem className="flex items-center gap-x-1.5 space-y-0">
                    <FormControl>
                      <Checkbox
                        checked={field.value === "1"}
                        onCheckedChange={(state) => field.onChange(state ? 1 : 0)}
                      />
                    </FormControl>
                    <FormLabel>Valid</FormLabel>
                  </FormItem>
                )}
              />
            </div>

            <div className="space-y-2.5 bg-white p-3 pt-2">
              <h2 className="text-sm font-bold">Custom Information</h2>
              <div className="grid grid-cols-3 gap-x-6 gap-y-2.5">
                <FormField
                  control={form.control}
                  name="UUID"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid hidden h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>UUID:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} readOnly={true} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="fieldName"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Field Name:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-7"
                          {...field}
                          moduleName="companyHasCustomInfo"
                          fieldName="fieldName"
                          columnName="Field Name"
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>

              <div className="grid grid-flow-col-dense  grid-cols-1 items-start gap-x-8 gap-y-2.5 md:grid-cols-3 ">
                <FormField
                  control={form.control}
                  name="fieldValue"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Field Value:</FormLabel>
                      <FormControl>
                        <Input
                          className="h-14"
                          {...field}
                          moduleName="companyHasCustomInfo"
                          fieldName="fieldValue"
                          columnName="Field Value"
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>

              <div>
                <FormField
                  control={form.control}
                  name="attachment"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>
                        <div style={{ display: "flex", alignItems: "center" }}>
                          Attachment:{" "}
                          <button type="button" onClick={handleChooseFileClick}>
                            <FaFileCirclePlus
                              style={{ marginLeft: "5px" }}
                              className="text-erp-blue-14"
                            />
                          </button>
                        </div>
                      </FormLabel>

                      <FormControl>
                        <Input
                          id="attachments"
                          type="file"
                          multiple
                          onChange={handleFileChange}
                          ref={fileInputRef}
                          className="hidden"
                        />
                      </FormControl>

                      <FormMessage />
                    </FormItem>
                  )}
                />

                {fileError && <div className="mt-1 text-sm text-red-500">{fileError}</div>}

                {/* You can render the files here */}
                {customInfoFiles &&
                  customInfoFiles.map((file, index) => (
                    <div key={index}>
                      <a
                        href={file.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        style={{ color: "blue" }}
                      >
                        {file.name}
                      </a>

                      <button
                        type="button"
                        onClick={() => handleDeleteFile(index)}
                        style={{ color: "red" }}
                      >
                        <FaCircleXmark
                          style={{
                            verticalAlign: "bottom",
                            marginLeft: "2px",
                            marginTop: "2px",
                          }}
                          title={"Remove"}
                        />
                      </button>
                    </div>
                  ))}
              </div>
            </div>
          </form>
        </Form>
        {isSaving && <LoadingUI />}
      </DialogContent>
    </Dialog>
  );
}
