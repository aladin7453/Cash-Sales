import React, { useState } from "react";
import { useForm } from "react-hook-form";
import { FaGlobe } from "react-icons/fa";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";

import { useSearchParams, useRouter } from "next/navigation";

import { getAuthHeaders, ORIGIN } from "@/lib/constants";

import CancelButton from "@/components/form/ActionButton/Cancel";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import { useToast } from "@/components/ui/use-toast";
import { Dialog, DialogClose, DialogContent } from "@/components/ui/dialog";
import { Input } from "@/components/ui/input";
import { Tabs, TabsTrigger, TabsList, TabsContent } from "@/components/ui/tabs";
import {
  Tooltip,
  TooltipContent,
  TooltipProvider,
  TooltipTrigger,
} from "@/components/ui/tooltip";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";

import { IoMdRefresh } from "react-icons/io";
import { SVGModule } from "./SVGRepo";

type Props = {
  open: boolean;
  setOpen: Dispatch<SetStateAction<boolean>>;
  row: any;
  revalidateSettingData: () => void;
  setTempRowSettingData: (data: any, overwrite: boolean) => void;
};

const SettingFormSchema = z.object({
  UUID: z.union([z.string(), z.literal("")]),
  user: z.union([z.string(), z.literal("")]),
  settingUUID: z.union([z.string(), z.literal("")]),
  prefix: z
    .string()
    .min(1, { message: "Prefix must be at least 1 character." }),
  runningDigitNo: z
    .string()
    .min(1, { message: "Running Digit No must be at least 1 character." }),
  nextNo: z
    .string()
    .min(1, { message: "Next No must be at least 1 character." }),
  output: z.string().min(0, { message: "" }),
  search: z.string().optional(),
});

export default function SettingFormPopover({
  open,
  setOpen,
  row,
  setTempRowSettingData,
  revalidateSettingData,
  accountId,
}: Props) {
  const router = useRouter();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const data = row;
  const { toast } = useToast();
  const headers = getAuthHeaders();

  // New state to track the selected tab
  const [activeTab, setActiveTab] = useState("moduleSettings");

  const tabs = [
    {
      id: "moduleSettings",
      name: "Module Settings", // Tooltip text
      icon: SVGModule, // SVG icon from your repo
    },
    {
      id: "globalSettings",
      name: "Global Settings", // Tooltip text
      icon: FaGlobe, // SVG icon from your repo
    },
  ];

  const form = useForm<z.infer<typeof SettingFormSchema>>({
    resolver: zodResolver(SettingFormSchema),
    defaultValues: {
      UUID: data?.UUID ?? "",
      prefix: data?.prefix ?? "",
      runningDigitNo: data?.runningDigitNo ?? "",
      nextNo: data?.nextNo ?? "",
      output: data?.output ?? "",
      search: "",
    },
  });

  const updateSettingData = async (data) => {
    try {
      const formData = new FormData();
      for (var key in data) {
        formData.append(`companyHasSetting[${key}]`, data[key]);
      }

      const response = await fetch(
        `${ORIGIN}/stock_group/api/stock-group/create-authorized-user?stockGroupUUID=${id}`,
        {
          method: "POST",
          headers,
          body: formData,
        }
      );

      if (!response.ok) {
        const errorData = await response.json();
        if (response.status === 403) {
          toast({ title: errorData.message, duration: 2000 });
        }
        throw new Error("Failed to fetch data");
      }
      const responseData = await response.json();
      if (responseData) {
        toast({ title: responseData.message, duration: 2000 });
      }
    } catch (error) {
      console.error("Error updating user list data:", error);
    }
  };

  const onSubmit = async (values) => {
    if (!values) return;

    const newData = { ...values };
    if (id) {
      await updateSettingData(newData);
      revalidateSettingData();
    } else {
      setTempRowSettingData(newData, false);
    }
    handleReset();
    setOpen(false);
  };

  const handleReset = () => {
    form.reset({
      UUID: "",
      prefix: "",
      runningDigitNo: "",
      nextNo: "",
      output: "",
      search: "",
    });
  };

  const resetField = (fieldName) => {
    form.setValue(fieldName, "");
  };

  return (
    <Dialog open={open} onOpenChange={setOpen} className="m-2">
      <DialogContent
        className="max-w-6xl p-2"
        style={{ backgroundColor: "#FFF3CD" }}
      >
        <div className="flex">
          {/* Form content */}
          <div className="flex-grow">
            <Form {...form}>
              <form
                className="space-y-2"
                onSubmit={form.handleSubmit(onSubmit)}
              >
                <div className="flex items-center justify-between pr-4">
                  <div className="grid auto-cols-fr grid-flow-col gap-x-1.5">
                    <SaveButton />
                    <ResetButton onClick={handleReset} />
                    <DialogClose asChild>
                      <CancelButton />
                    </DialogClose>
                  </div>
                  <FormField
                    control={form.control}
                    name="search"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormControl>
                          <Input
                            className="h-5"
                            placeholder="Search for Settings"
                            {...field}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />
                </div>

                {/* Conditionally render form based on active tab */}
                {activeTab === "moduleSettings" && (
                  <div className="space-y-2.5 bg-white p-3 pt-2">
                    <h2 className="text-sm font-bold">Company Code Format</h2>
                    <div className="grid grid-flow-col-dense items-start gap-x-8 gap-y-2.5 grid-cols-1 md:grid-cols-4">
                      <FormField
                        control={form.control}
                        name="UUID"
                        render={({ field }) => (
                          <FormItem className="col-span-4 row-span-1 grid h-full hidden grid-rows-[auto_1fr] space-y-1">
                            <FormLabel>UUID:</FormLabel>
                            <FormControl>
                              <Input
                                className="h-7"
                                {...field}
                                readOnly={true}
                              />
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      <FormField
                        control={form.control}
                        name="prefix"
                        render={({ field }) => (
                          <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                            <FormLabel>Prefix:</FormLabel>
                            <FormControl>
                              <div className="relative">
                                <Input className="h-7" {...field} />
                                <button
                                  type="button"
                                  onClick={() => resetField("prefix")}
                                  className="absolute right-2 top-1/2 transform -translate-y-1/2 fill-gray-400"
                                >
                                  <IoMdRefresh className="fill-gray-400" />
                                </button>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>

                    <div className="grid grid-flow-col-dense items-start gap-x-8 gap-y-2.5 grid-cols-1 md:grid-cols-4">
                      <FormField
                        control={form.control}
                        name="runningDigitNo"
                        render={({ field }) => (
                          <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                            <FormLabel>Running Digit No:</FormLabel>
                            <FormControl>
                              <div className="relative">
                                <Input
                                  className="h-7 text-right pr-6"
                                  {...field}
                                />
                                <button
                                  type="button"
                                  onClick={() => resetField("runningDigitNo")}
                                  className="absolute right-2 top-1/2 transform -translate-y-1/2 fill-gray-400"
                                >
                                  <IoMdRefresh className="fill-gray-400" />
                                </button>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      <FormField
                        control={form.control}
                        name="nextNo"
                        render={({ field }) => (
                          <FormItem className="flex flex-col space-y-1">
                            <FormLabel>Next No:</FormLabel>
                            <FormControl>
                              <Input className="h-7 text-right" {...field} />
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>

                    <div className="grid grid-flow-col-dense items-start gap-x-8 gap-y-2.5 grid-cols-1 md:grid-cols-4">
                      <FormField
                        control={form.control}
                        name="output"
                        render={({ field }) => (
                          <FormItem className="flex flex-col space-y-1 col-span-2">
                            <FormLabel>Output:</FormLabel>
                            <FormControl>
                              <Input
                                className="h-7.5"
                                {...field}
                                readOnly
                                style={{
                                  backgroundColor: "#f2f2f2",
                                  color: "gray",
                                }}
                              />
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>
                  </div>
                )}

                {/* Render an empty space or a table when Global Settings tab is active */}
                {activeTab === "globalSettings" && (
                  <div className="space-y-2.5 bg-white p-3 pt-2">
                    {/* <h2 className="text-sm font-bold">Global Settings</h2>
                    {/* Empty content for now */}
                    {/* <div className="text-gray-500 text-center">
                      <p>No Global Settings available at the moment.</p>
                    </div> */}
                  </div>
                )}
              </form>
            </Form>
          </div>

          {/* Tabs (SVG icons) aligned to the right */}
          <div className="ml-3 flex flex-col justify-start mt-12">
            <Tabs
              defaultValue="moduleSettings"
              onValueChange={(value) => setActiveTab(value)}
            >
              <TabsList className="flex h-full flex-col justify-start bg-transparent p-0 pt-0.5">
                {tabs.map((tab) => (
                  <TooltipProvider delayDuration={0} key={tab.id}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <TabsTrigger
                          className="rounded-lg rounded-l-none bg-erp-blue-7 p-2 text-erp-blue-14 aria-selected:bg-erp-blue-11 aria-selected:text-white"
                          value={tab.id}
                        >
                          <tab.icon className="size-5" />
                        </TabsTrigger>
                      </TooltipTrigger>
                      <TooltipContent side="left">
                        <p>{tab.name}</p> {/* Display "Module Settings" */}
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                ))}
              </TabsList>
            </Tabs>
          </div>
        </div>
      </DialogContent>
    </Dialog>
  );
}
