import React from "react";

// Assuming this is your DropdownTable component
const DropdownTable = ({ data, onSelect }) => (
  <table>
    <thead>
      <tr>
        <th>Select</th>
        <th>Full Name</th>
        <th>Title</th>
        <th>Phone Number</th>
        <th>Email</th>
      </tr>
    </thead>
    <tbody>
      {data.map((row, index) => (
        <tr key={index}>
          <td>
            <input type="checkbox" onChange={() => onSelect(index)} />
          </td>
          <td>{row.fullName}</td>
          <td>{row.title}</td>
          <td>{row.phoneNumber}</td>
          <td>{row.email}</td>
        </tr>
      ))}
    </tbody>
  </table>
);

export default DropdownTable;
