                              <DropdownTable
                                columns={dropdownJobTitleColumns}
                                data={jobTitleDropdownTableData}
                                onClickRow={onClickRowJobTitle}
                              />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="baseJobTitle"
                render={({ field }) => (
                  <FormItem className="flex hidden flex-col space-y-1">
                    <FormControl className="relative">
                      <Input className="h-7.5 pr-8" {...field} readOnly />
                    </FormControl>
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="baseLocationName"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Base Location:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={toggleTableLocation}
                          ref={inputRef}
                          autoComplete="off"
                          readOnly={true}
                        />
                        <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {showTableLocation && (
                          <div
                            ref={dropdownRef}
                            className="absolute right-0 top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                          >
                            <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownLocationColumns}
                                data={baseLocationDropdownTableData}
                                onClickRow={onClickRowLocation}
                              />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="baseLocation"
                render={({ field }) => (
                  <FormItem className="flex hidden flex-col space-y-1">
                    <FormControl className="relative">
                      <Input className="h-7.5 pr-8" {...field} readOnly />
                    </FormControl>
                  </FormItem>
                )}
              /> */}

              {isDropdownEnumDataLoaded && (
                <FormField
                  control={form.control}
                  name="employmentType"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Employement Type:</FormLabel>
                      <Select defaultValue={field.value} onValueChange={field.onChange}>
                        <SelectTrigger className="h-7.5 w-full">
                          <SelectValue placeholder="Select status" />
                        </SelectTrigger>
                        <SelectContent>
                          {dropdownEnumData &&
                            dropdownEnumData.employmentType.map((item) => (
                              <SelectItem key={item.value} value={item.value}>
                                {item.label}
                              </SelectItem>
                            ))}
                        </SelectContent>
                      </Select>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              )}

              <FormField
                control={form.control}
                name="supervisorName"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Supervisor:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={() => toggleTableSupervisor()}
                          onChange={handleSupervisorSearchChange}
                          ref={inputRef}
                          autoComplete="off"
                        />
                        <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                          <FaMagnifyingGlass className="text-gray-400" />{" "}
                          {/* Using the search icon */}
                        </div>
                        {showTableSupervisor && (
                          <div
                            ref={dropdownRef}
                            className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                          >
                            <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownMentorSupervisorColumns}
                                data={supervisorDropdownTableData}
                                onClickRow={onClickRowSupervisor}
                                filterValue={supervisorFilter}
                              />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="supervisor"
                render={({ field }) => (
                  <FormItem className="flex hidden flex-col space-y-1">
                    <FormControl className="relative">
                      <Input className="h-7.5 pr-8" {...field} readOnly />
                    </FormControl>
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="mentorName"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Mentor:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={() => toggleTableMentor()}
                          onChange={handleMentorSearchChange}
                          ref={inputRef}
                          autoComplete="off"
                        />
                        <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                          <FaMagnifyingGlass className="text-gray-400" />{" "}
                          {/* Using the search icon */}
                        </div>
                        {showTableMentor && (
                          <div
                            ref={dropdownRef}
                            className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                          >
                            <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownMentorSupervisorColumns}
                                data={mentorDropdownTableData}
                                onClickRow={onClickRowMentor}
                                filterValue={mentorFilter}
                              />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="mentor"
                render={({ field }) => (
                  <FormItem className="flex hidden flex-col space-y-1">
                    <FormControl className="relative">
                      <Input className="h-7.5 pr-8" {...field} readOnly />
                    </FormControl>
                  </FormItem>
                )}
              />
            </div>

            <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
              <FormField
                control={form.control}
                name="startDate"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Start Date:</FormLabel>
                    <Popover>
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            className={cn(
                              "flex h-7.5 w-full",
                              !field.value && "text-muted-foreground",
                            )}
                            variant="outline"
                            size="sm"
                          >
                            {field.value
                              ? moment.unix(field.value).format(DATE_FORMAT)
                              : "Pick a date"}
                            <CalendarIcon className="ml-auto h-4 w-4" />
                          </Button>
                        </FormControl>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={field.value ? moment.unix(field.value).toDate() : undefined}
                          onSelect={(date) => {
                            const unixTimestamp = date ? Math.floor(date.getTime() / 1000) : "";
                            field.onChange(unixTimestamp.toString());
                          }}
                          initialFocus
                          defaultMonth={new Date()}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="endDate"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>End Date:</FormLabel>
                    <Popover>
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            className={cn(
                              "flex h-7.5 w-full",
                              !field.value && "text-muted-foreground",
                            )}
                            variant="outline"
                            size="sm"
                          >
                            {field.value
                              ? moment.unix(field.value).format(DATE_FORMAT)
                              : "Pick a date"}
                            <CalendarIcon className="ml-auto h-4 w-4" />
                          </Button>
                        </FormControl>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={field.value ? moment.unix(field.value).toDate() : undefined}
                          onSelect={(date) => {
                            const unixTimestamp = date ? Math.floor(date.getTime() / 1000) : "";
                            field.onChange(unixTimestamp.toString());
                          }}
                          initialFocus
                          defaultMonth={new Date()}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />
              {isDropdownEnumDataLoaded && (
                <FormField
                  control={form.control}
                  name="exitReason"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Quit Reason:</FormLabel>
                      <Select defaultValue={field.value} onValueChange={field.onChange}>
                        <SelectTrigger className="h-7.5 w-full">
                          <SelectValue placeholder="Select status" />
                        </SelectTrigger>
                        <SelectContent>
                          {dropdownEnumData &&
                            dropdownEnumData.exitReason.map((item) => (
                              <SelectItem key={item.value} value={item.value}>
                                {item.label}
                              </SelectItem>
                            ))}
                        </SelectContent>
                      </Select>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              )}
            </div>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}
