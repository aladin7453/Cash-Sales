"use client";

import { useRouter } from "next/navigation";
import { useEffect, useState } from "react";
import { Tab, TabList, TabPanel, Tabs } from "react-tabs";
import useSWRImmutable from "swr/immutable";

import { Card, CardContent, CardDescription, CardFooter, CardTitle } from "@/components/ui/card";
import { useToast } from "@/components/ui/use-toast";

import "react-tabs/style/react-tabs.css"; // Default styles

import { getAuthHeaders, ORIGIN } from "@/lib/constants";

import { DashboardProvider, useDashboard } from "./DashboardContext";

import "./styles.css"; // Custom style file

import AreaChart from "./areaChart";
import BarChart from "./barChart";
import BubbleChart from "./bubbleChart";
import DoughnutChart from "./doughnutChart";
import LineChart from "./lineChart";
import MeterCard from "./meterCard";
import MeterPercentageCard from "./meterPercentageCard";
import PieChart from "./pieChart";
import RadarChart from "./radarChart";
import ScatterChart from "./scatterPlotChart";

const fetcher = async (url: string) => {
  const headers = getAuthHeaders();

  return fetch(url, { headers }).then(async (res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    try {
      return await res.json();
    } catch (error) {
      throw new Error("Failed to parse response JSON");
    }
  });
};

export default function DashboardPage() {
  return <DashboardContent />;
}

function DashboardContent() {
  const { toast } = useToast();
  const router = useRouter();
  const [chartData, setChartData] = useState([]);
  const { widgetName, setWidgetName, active, setActive } = useDashboard();

  const {
    data,
    error,
    isLoading,
    mutate: mutateData,
  } = useSWRImmutable(`${ORIGIN}/dashboard/api/dashboard/get-dashboard-display-data`, fetcher);

  useEffect(() => {
    if (data) {
      const dashboardNames = Object.keys(data);

      setActive(dashboardNames[0] || "");
      setWidgetName(dashboardNames);
    }
  }, [data]);

  useEffect(() => {
    if (error) {
      if (error.message === "Session expired") {
        // toast({
        //   variant: "destructive",
        //   title: "Session Expired",
        //   description: "Your session has expired. Redirecting to login page.",
        // });
        router.push("/login");
      } else {
        console.error(error.message);
      }
    }
  }, [error, router]);

  const formatText = (text: string) => {
    if (!text) return "";

    return text
      .replace(/([A-Z])/g, " $1")
      .replace(/^./, (str) => str.toUpperCase())
      .trim();
  };

  useEffect(() => {
    if (!data || !active) return;

    const widgets = data[active];

    if (!widgets) return;

    const formattedCharts = widgets.map((widget: any) => {
      const type = widget.dashboardHasWidget.type;
      const rawData = widget.data;

      const sortedData = [...rawData].sort(
        (a, b) => new Date(a.interval + "-01").getTime() - new Date(b.interval + "-01").getTime(),
      );

      const labels = sortedData.map((item: any) => item.interval);
      const values = sortedData.map((item: any) => Number(item.total));

      let datasets;

      if (type === "Bubble Chart") {
        datasets = [
          {
            label: formatText(widget.dashboardHasWidget.filterColumn),
            data: sortedData.map((item: any) => ({
              x: new Date(item.interval + "-01").getTime(),
              y: Number(item.total),
              r: Math.max(Number(item.total) / 50, 5),
            })),
            backgroundColor: "rgba(59, 130, 246,0.5)",
          },
        ];
      } else {
        datasets = [
          {
            label: formatText(widget.dashboardHasWidget.filterColumn),
            data: values,
            borderColor: "rgba(59, 130, 246,1)",
            backgroundColor: "rgba(59, 130, 246,1)",
          },
        ];
      }

      return {
        seq: widget.dashboardHasWidget.seq,
        width: Number(widget.dashboardHasWidget.width ?? 1),
        height: Number(widget.dashboardHasWidget.height ?? 1),
        interval:
          widget.dashboardHasWidget.interval === "week"
            ? widget.dashboardHasWidget.interval
            : rawData[0]?.compareWith,
        yAxis: formatText(widget.dashboardHasWidget.filterColumn),
        type,
        icon: widget.dashboardHasWidget.icon,
        showVariance: widget.dashboardHasWidget.variance === "1",
        rawData: rawData[0],
        title: widget.dashboardHasWidget.widgetTitle,
        labels,
        datasets,
      };
    });

    setChartData(formattedCharts);
  }, [data, active]);

  return (
    <>
      <div className="p-[5px]">
        <Tabs>
          <TabPanel>
            <div className="grid auto-rows-[140px] grid-cols-12 gap-4">
              {chartData
                .sort((a: any, b: any) => Number(a.seq) - Number(b.seq))
                .map((chart: any, index) => {
                  const hasData = chart.datasets?.some((ds: any) => ds.data && ds.data.length > 0);

                  return (
                    <Card
                      key={index}
                      className="flex flex-col overflow-hidden text-sm shadow-xl"
                      style={{
                        gridColumn: `span ${chart.width || 1}`,
                        gridRow: `span ${chart.height || 1}`,
                      }}
                    >
                      {chart.type === "meter" || chart.type === "meter_percentage" ? null : (
                        <>
                          <CardTitle className="text-md pl-4 pt-2">{chart.title}</CardTitle>
                        </>
                      )}

                      <CardContent className="flex flex-1 overflow-hidden p-1">
                        <div
                          className={`flex w-full ${
                            chart.type === "meter" || chart.type === "meter_percentage"
                              ? "h-full"
                              : "justify-center"
                          }`}
                        >
                          {!hasData ? (
                            <div>
                              NO DATA AVAILABLE, PLEASE CONFIGURE AT DASHBOARD MANAGEMENT MODULE
                            </div>
                          ) : chart.type === "Line Chart" ? (
                            <LineChart
                              yAxis={chart.yAxis}
                              labels={chart.labels}
                              datasets={chart.datasets}
                            />
                          ) : chart.type === "Bar Chart" ? (
                            <BarChart
                              labels={chart.labels}
                              data={chart.datasets}
                              yAxis={chart.yAxis}
                            />
                          ) : chart.type === "Pie Chart" ? (
                            <PieChart labels={chart.labels} data={chart.datasets} />
                          ) : chart.type === "Doughnut Chart" ? (
                            <DoughnutChart labels={chart.labels} data={chart.datasets} />
                          ) : chart.type === "Area Chart" ? (
                            <AreaChart
                              yAxis={chart.yAxis}
                              labels={chart.labels}
                              datasets={chart.datasets}
                            />
                          ) : chart.type === "Scatter Plot" ? (
                            <ScatterChart
                              yAxis={chart.yAxis}
                              labels={chart.labels}
                              datasets={chart.datasets}
                            />
                          ) : chart.type === "Bubble Chart" ? (
                            <BubbleChart yAxis={chart.yAxis} datasets={chart.datasets} />
                          ) : chart.type === "Radar Chart" ? (
                            <RadarChart labels={chart.labels} datasets={chart.datasets} />
                          ) : chart.type === "meter" ? (
                            <MeterCard
                              title={formatText(chart.title)}
                              value={chart.rawData?.total}
                              lastValue={chart.rawData?.lastValue}
                              variance={chart.rawData?.variance}
                              showVariance={chart.showVariance}
                              icon={chart.icon}
                              interval={chart.interval}
                            />
                          ) : chart.type === "meter_percentage" ? (
                            <MeterPercentageCard
                              title={formatText(chart.title)}
                              value={chart.rawData?.total}
                              lastValue={chart.rawData?.lastValue}
                              variance={chart.rawData?.variance}
                              showVariance={chart.showVariance}
                              icon={chart.icon}
                              interval={chart.interval}
                            />
                          ) : null}
                        </div>
                      </CardContent>
                    </Card>
                  );
                })}
            </div>
          </TabPanel>
        </Tabs>
      </div>
    </>
  );
}
