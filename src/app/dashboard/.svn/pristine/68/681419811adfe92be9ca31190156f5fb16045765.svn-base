"use client";

import { Chart as ChartJS, Legend, LinearScale, PointElement, Tooltip } from "chart.js";
import { Bubble } from "react-chartjs-2";

ChartJS.register(LinearScale, PointElement, Tooltip, Legend);

interface BubbleDataPoint {
  x: number;
  y: number;
  r: number;
}

interface Dataset {
  label: string;
  data: BubbleDataPoint[];
  backgroundColor?: string;
}

interface BubbleChartProps {
  yAxis: string;
  datasets: Dataset[];
}

export default function BubbleChart({ yAxis, datasets }: BubbleChartProps) {
  const chartData = {
    datasets: datasets.map((ds) => ({
      ...ds,
    })),
  };

  const options = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { position: "bottom" as const },
      tooltip: {
        callbacks: {
          label: function (context: any) {
            const point = context.raw;

            const date = new Date(point.x);

            const formattedDate = date.toLocaleDateString("en-CA", {
              year: "numeric",
              month: "2-digit",
            });

            return `${formattedDate}: ${point.y} (size: ${point.r})`;
          },
        },
      },
    },
    scales: {
      x: {
        type: "time",
      },
      y: {
        title: { display: true, text: yAxis },
      },
    },
  };

  return (
    <div className="ml-4 flex w-full flex-col text-sm" style={{ height: "200px" }}>
      <Bubble data={chartData} options={options} />
    </div>
  );
}
