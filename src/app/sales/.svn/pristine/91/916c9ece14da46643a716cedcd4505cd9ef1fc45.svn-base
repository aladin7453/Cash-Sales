  customerName: string;
  customerBRN: string;
  customerID: string;
  customermembershipID: string;
  customerDescription: string;
  date: string;
};

const valueToDateFormat = (seconds) => {
  if (!seconds) return null;
  const date = new Date(seconds * 1000);
  const day = date.getDate().toString().padStart(2, "0");
  const month = (date.getMonth() + 1).toString().padStart(2, "0"); // Month is zero-based
  const year = date.getFullYear();
  if (day && month && year) return `${year}-${month}-${day}`;
  else return seconds;
};

const isDev = process.env.NODE_ENV === "development";

const urlMap = {
  quotation: isDev ? "sales/quotation" : "view/sales/quotation",
  salesOrder: isDev ? "sales/sales-order" : "view/sales/sales-order",
  deliveryOrder: isDev ? "sales/sales-delivery-order" : "view/sales/sales-delivery-order",
  jobOrder: isDev ? "job-management/job-order" : "view/job-management/job-order",
  cashSales: isDev ? "sales/cash-sales" : "view/sales/cash-sales",
  salesInvoice: isDev ? "sales/sales-invoice" : "view/sales/sales-invoice",
  salesCreditNote: isDev ? "sales/sales-credit-note" : "view/sales/sales-credit-note",
};

