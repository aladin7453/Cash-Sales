"use client";

import { endOfMonth, startOfMonth } from "date-fns";
import React, { useEffect, useState } from "react";
import { useForm } from "react-hook-form";

import { DEFAULT_DATA_TABLE_PAGE_SIZE, getAuthHeaders, ORIGIN } from "@/lib/constants";
import useLocalStorage from "@/lib/hooks/useLocalStorage";

import { columnDefinitionsByDocType, columnReportDefinitionsByDocType } from "./Generate/columns";
import DocumentListingReportDataTable from "./Generate/DataTable";
import DocumentListingReportForm from "./Report/ListingReportForm";
import SummaryForm from "./Report/SummaryForm";

import type { ColumnFiltersState, SortingState } from "@tanstack/react-table";

const COLUMN_FILTERS_KEY = "document-listing-report.table.filters";
const PAGINATION_KEY = "document-listing-report.table.pagination";
const SORTING_KEY = "document-listing-report.table.sorting";

export default function DocumentListingReportPage() {
  const [tempGeneratedReportList, setTempGeneratedReportList] = useState<any[]>([]);
  const [hasGenerated, setHasGenerated] = useState("0");
  const [showReportTable, setShowReportTable] = useState(false);
  const [previewPDF, setPreviewPDF] = useState<any>(null);
  const [salesReportData, setSalesReportData] = useState<any>(null);
  const [summaryData, setSummaryData] = useState<any>(null);
  const [isPreviewLoading, setIsPreviewLoading] = useState(false);

  const [totalCounts, setTotalCounts] = useState<{ total: number }>({ total: 0 });

  const [columnFilters, setColumnFilters] = useLocalStorage<ColumnFiltersState>(
    COLUMN_FILTERS_KEY,
    [],
  );

  const [pagination, setPagination] = useLocalStorage(PAGINATION_KEY, {
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });

  const [sorting, setSorting] = useLocalStorage<SortingState>(SORTING_KEY, []);

  const headers = getAuthHeaders();

  const filterFields = [
    "docNo",
    "docDateFormat",
    "customerName",
    "totalTax",
    "paidAmount",
    "totalAmount",
    "paymentMethodCode",
    "amountAfterDiscount",
    "totalDiscount",
    "totalSubtotalTax",
    "docValidityFormat",
    "description",
  ];

  const validDocTypes = [
    "salesInvoice",
    "salesInvoiceListing",
    "salesInvoiceListingMultiLv2DocNo",
    "deliveryOrder",
    "salesDeliveryOrderListing",
    "salesDeliveryOrderListingMultiLv2DocNo",
    "salesOrder",
    "salesOrderListing",
    "salesOrderListingMultiLv2DocNo",
    "cashSales",
    "quotation",
    "salesQuotationListing",
    "salesQuotationListingMultiLv2DocNo",
    "cashSalesListing",
    "cashSalesListingLv1",
    "cashSalesListingMultiLv2",
    "salesDebitNote",
    "salesDebitNoteListing",
    "salesDebitNoteListingMultiLv2DocNo",
    "salesCreditNote",
    "salesCreditNoteListing",
    "salesCreditNoteListingMultiLv2DocNo",
  ];

  const form = useForm({
    defaultValues: {
      customerCode: "",
      customerCodeCode: "",
      customerGroup: "",
      customerGroupName: "",
      status: "",
      startDate: Math.floor(startOfMonth(new Date()).getTime() / 1000).toString(),
      endDate: Math.floor(endOfMonth(new Date()).getTime() / 1000).toString(),
      docType: "quotation",
      valid: "1",
      groupBy_docNo: false,
      groupBy_docDateFormat: false,
      groupBy_customerCodeCode: false,
      groupBy_customerName: false,
      groupBy_description: false,
      // groupBy_totalDiscount: false,
      // groupBy_totalAmount: false,
    },
  });

  const generateReport = async (formData: any) => {
    try {
      const docType = formData.docType;

      if (!validDocTypes.includes(docType)) {
        throw new Error("Invalid document type");
      }

      const allFormValues = form.getValues();

      const filterObject = {};

      filterFields.forEach((key) => {
        if (allFormValues[key]) {
          filterObject[key] = allFormValues[key];
        }
      });

      const params = new FormData();

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");
      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      const validFormValues = form.getValues();

      const validfilterFields = ["valid"];

      const validfilterObject = {};

      validfilterFields.forEach((key) => {
        if (validFormValues[key]) {
          validfilterObject[key] = validFormValues[key];
        }
      });

      if (validFormValues.valid) {
        params.append("param[valid]", validFormValues.valid);
      }

      Object.entries(formData).forEach(([key, value]) => {
        if (value && key !== "docType") {
          params.append(`sales[${key}]`, value as string);
        }
      });

      const response = await fetch(
        `${ORIGIN}/sales_report/api/sales-report/generate-report?docType=${docType}&reportType=salesDocumentListing`,
        {
          method: "POST",
          headers,
          body: params,
        },
      );

      if (!response.ok) {
        throw new Error("Failed to generate report");
      }

      const result = await response.json();
      const rows = result.rows || [];

      setTotalCounts({ total: result.total ?? rows.length });

      form.setValue("total", result.total ?? "0");
      form.setValue("totalAmountReport", result.summary.totalAmountReport ?? "0.00");
      form.setValue("totalTaxReport", result.summary.totalTaxReport ?? "0.00");
      form.setValue("totalDiscountReport", result.summary.totalDiscountReport ?? "0.00");
      form.setValue(
        "totalAmountAfterDiscountReport",
        result.summary.totalAmountAfterDiscountReport ?? "0.00",
      );
      form.setValue("totalSubtotalTaxReport", result.summary.totalSubtotalTaxReport ?? "0.00");

      setTempGeneratedReportList(result.rows || []);
      setShowReportTable(true);
      setHasGenerated("1");
    } catch (error) {
      console.error("Error generating report:", error);
    }
  };

  const previewReport = async (formData: any) => {
    setPreviewPDF(null);
    setIsPreviewLoading(true);

    try {
      let reportName = null;

      const docType = formData.docType;

      let reportTypeName;

      // Temporary put in if else statement, might need to remove later
      if (formData.reportTypeName === "undefined" || !formData.reportTypeName) {
        reportTypeName = docType;
      } else {
        reportTypeName = formData.reportTypeName;
      }

      if (!validDocTypes.includes(reportTypeName)) {
        throw new Error("Invalid document type");
      }

      const levelMatch = reportTypeName.match(/lv(\d+)/i);
      const levelMatchMulti = /multi/i.test(reportTypeName);

      if (levelMatch) {
        if (levelMatchMulti) {
          reportName = `multi` + `Level${levelMatch[1]}`;
        } else {
          reportName = `level${levelMatch[1]}`;
        }
      }

      const allFormValues = form.getValues();

      const filterFields = [
        "docNo",
        "docDateFormat",
        "customerName",
        "totalTax",
        "paymentMethodCode",
        "amountAfterDiscount",
        "paidAmount",
        "totalAmount",
        "totalDiscount",
        "totalSubtotalTax",
        "docValidityFormat",
        "description",
      ];

      const filterObject = {};

      filterFields.forEach((key) => {
        if (allFormValues[key]) {
          filterObject[key] = allFormValues[key];
        }
      });

      const params = new FormData();

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      const validFormValues = form.getValues();

      const validfilterFields = ["valid"];

      const validfilterObject = {};

      validfilterFields.forEach((key) => {
        if (validFormValues[key]) {
          validfilterObject[key] = validFormValues[key];
        }
      });

      if (validFormValues.valid) {
        params.append("param[valid]", validFormValues.valid);
      }

      Object.entries(formData).forEach(([key, value]) => {
        if (value) params.append(`sales[${key}]`, value as string);
      });

      if (reportName) {
        // const hasItemCode = /itemcode/i.test(reportTypeName);

        params.append("sales[groupBy][0]", "docDateFormat");
        params.append("sales[groupBy][1]", "docNo");
        // params.append("sales[groupBy][1]", hasItemCode ? "itemCode" : "docNo");
      }

      const baseUrl = `${ORIGIN}/sales_report/api/sales-report/preview-pdf`;

      let url = `${baseUrl}?docType=${docType}&reportType=salesDocumentListing`;

      if (reportName) {
        url += `&reportName=${reportName}`;
      }

      const response = await fetch(url, {
        method: "POST",
        headers,
        body: params,
      });

      // const response = await fetch(
      //   `${ORIGIN}/sales_report/api/sales-report/preview-pdf?docType=${docType}&hasGenerated=${hasGenerated}&reportType=salesDocumentListing`,
      //   {
      //     method: "POST",
      //     headers,
      //     body: params,
      //   }
      // );

      if (!response.ok) {
        throw new Error("Failed to preview report");
      }

      const result = await response.json();
      const rows = result.rows || [];

      setTotalCounts({ total: result.total ?? rows.length });

      form.setValue("total", result.total ?? "0");
      form.setValue("totalAmountReport", result.summary.totalAmountReport ?? "0.00");
      form.setValue("totalTaxReport", result.summary.totalTaxReport ?? "0.00");
      form.setValue("totalDiscountReport", result.summary.totalDiscountReport ?? "0.00");
      form.setValue(
        "totalAmountAfterDiscountReport",
        result.summary.totalAmountAfterDiscountReport ?? "0.00",
      );
      form.setValue("totalSubtotalTaxReport", result.summary.totalSubtotalTaxReport ?? "0.00");

      setPreviewPDF(result);
      setSalesReportData(formData);
    } catch (error) {
      console.error("Error previewing report:", error);
    } finally {
      setIsPreviewLoading(false);
    }
  };

  const onSubmit = (data: any) => {
    setTempGeneratedReportList([]);
    setShowReportTable(false);
    generateReport(data);
  };

  return (
    <>
      <DocumentListingReportForm
        form={form}
        onSubmit={onSubmit}
        validDocTypes={validDocTypes}
        onPreview={previewReport}
        previewPDF={previewPDF}
        salesReportData={salesReportData}
        generatedReport={tempGeneratedReportList}
        salesReportColumns={columnReportDefinitionsByDocType[form.getValues().docType]}
        setSorting={setSorting}
        filterFields={filterFields}
        sorting={sorting}
      />
      <SummaryForm form={form} onSubmit={onSubmit} />
      {showReportTable && (
        <DocumentListingReportDataTable
          columns={
            columnDefinitionsByDocType[form.getValues().docType] ||
            columnDefinitionsByDocType.salesInvoice
          }
          data={tempGeneratedReportList}
          revalidateDocumentListingReport={() => generateReport(form.getValues())}
          columnFilters={columnFilters}
          setColumnFilters={setColumnFilters}
          pagination={pagination}
          setPagination={setPagination}
          sorting={sorting}
          setSorting={setSorting}
          formData={form.getValues()}
          salesReportColumns={columnDefinitionsByDocType[form.getValues().docType]}
          totalNumOfRows={+totalCounts.total}
        />
      )}
    </>
  );
}
