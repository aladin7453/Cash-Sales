type DropdownConfig = {
  tableName: string;
  columns: { accessorKey: string; header: string }[];
  valueField: string;
  displayField: string;
  formValueField: string;
  formDisplayField: string;
  additionalMappings?: { sourceField: string; targetFormField: string }[];
};

interface CollectionReportFormProps {
  form: UseFormReturn<any>;
  onSubmit: (data: any) => void;
}

export default function CollectionReportForm({ form, onSubmit }: CollectionReportFormProps) {
  return (
    <div className="rounded-sm w-full p-2 mx-auto bg-erp-blue-8 mt-2">
      <div className="rounded-sm p-4 bg-erp-blue-4">
        <Form {...form}>
          <form onSubmit={form.handleSubmit(onSubmit)}>
            <h2 className="text-md font-bold mb-4">Summary</h2>

            <div className="grid grid-flow-col-dense items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-3">
              <FormField
                control={form.control}
                name="totalPaidAmountReport"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Total Payments Received:</FormLabel>
                    <FormControl>
                      <Input 
                        className="h-7.5" 
                        {...field} readOnly
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
              
              <FormField
                control={form.control}
                name="total"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel> No. Of Customers Paid:</FormLabel>
                    <FormControl>
                      <Input 
                        className="h-7.5" 
                        {...field} readOnly
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="averageMonthlyPayment"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel> Average Payment Monthly:</FormLabel>
                    <FormControl>
                      <Input 
                        className="h-7.5" 
                        {...field} readOnly
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </form>
        </Form>
      </div>
    </div>
  );
