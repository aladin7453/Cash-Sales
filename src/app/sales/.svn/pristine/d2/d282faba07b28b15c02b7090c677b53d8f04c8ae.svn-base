export type DocumentListingReport = {
  UUID?: string;
  docNo: string;
  docDate?: string;
  orderDate?: string;
  deliveryDate?: string;
  saleDate?: string;
  description?: string;
  customerCodeCode?: string;
  customerName: string;
  totalTax?: string;
  totalSubtotal?: string;
  totalSubtotalTax?: string;
  totalPaidAmount?: string;
  balance?: string;
  createdBy?: string;
  createdByUsername?: string;
  docDateFormat?: string;
  paymentDateFormat?: string;
  validUntil?: string;
  remarks?: string;
  orderQuantity?: string;
  quantityDelivered?: string;
  totalDiscount?: string;
  amountAfterDiscount?: string;
  paymentMethod?: string;
};

export const valueToDateFormat = (value: string | number | undefined): string | null => {
  if (!value) 
    return null;

  const seconds = typeof value === "string" ? parseInt(value, 10) : value;
  
  if (isNaN(seconds)) 
    return value.toString();
  
  const date = new Date(seconds * 1000);
  const day = date.getDate().toString().padStart(2, "0");
  const month = (date.getMonth() + 1).toString().padStart(2, "0");
  const year = date.getFullYear();
  
  if (day && month && year) 
    return `${year}-${month}-${day}`;
  
  return value.toString();
};

const formatDecimal = (value: any) => {
  if (value === undefined || value === null || value === "") 
    return "0.00";
  
  const num = parseFloat(value);
  
  return isNaN(num) ? "0.00" : num.toFixed(2);
};

