export default function CustomerContraDetailsDataTableToolbar<TData>({ 
  table, 
  onAdd, 
  setTempRowCustomerContraDetailsListData, 
  tempRowCustomerContraDetailsList, 
  revalidateCustomerContraDetails,
  slug,
}: Props<TData>) {
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const headers = getAuthHeaders();

  const { toast } = useToast();
  const [showConfirmationDialog, setShowConfirmationDialog] = useState(false);

  const handleDeleteConfirmation = async() => {
    var form_data = new FormData();

    const selectedRows = table.getSelectedRowModel().rows;

    selectedRows.forEach((row, index) => {
      form_data.append(`UUIDs[${index}]`, row.original.UUID);
    });

    selectedRows.forEach((row, index) => {
      form_data.append(`outstandingAmount[${index}]`, row.original.outstanding);
    });

    // if (id && slug !== "clone") {
    //   try {
    //     const response = await fetch(`${ORIGIN}/sales_purchase_contra/api/sales-purchase-contra/remove-sales-purchase-contra-has-details`, {
    //       method: 'POST',
    //       headers,
    //       body: form_data,
    //     });

    //     if (!response.ok) {
    //       const errorData = await response.json();

    //       if (response.status === 403) {
    //         toast({
    //           title: errorData.message,
    //           duration: 2000
    //         });
    //       }
          
    //       throw new Error('Failed to fetch data');
    //     }
    //     const responseData = await response.json();
        
    //     toast({
    //       title: "Success",
    //       description: "Customer contra details removed successfully.",
    //       duration: 2000
    //     });
  
    //   } catch (error) {
    //     console.error('Error deleting customer contra details:', error);
    //     toast({
    //       title: "Failed",
    //       description: "An error occurred while removing the details.",
    //       variant: "destructive",
    //       duration: 3000
    //     });
    //   }

    //   revalidateCustomerContraDetails();
      
    //   setShowConfirmationDialog(false);
    // } else {
      const deletedIndex = selectedRows.map(item => {
        return item.index
      });

      const remainRows = tempRowCustomerContraDetailsList.filter((item, index) => !deletedIndex.includes(index));

      setTempRowCustomerContraDetailsListData(remainRows, true);
      toast({
        title: "Success",
        description: "Selected items removed successfully.",
        duration: 2000
      });
      setShowConfirmationDialog(false);
   // }
  };

  return (
    <>
      <div className="flex items-center justify-between rounded-t-md">
        {/* Mobile View (Start Action Buttons) */}
        <MobileFormTableActionGroupStart
          table={table}
          config={{
            core: {
              add: { 
                handler: () => onAdd?.(), 
                tooltip: "Add customer contra details" 
              },
              remove: { 
