                        }
                      />
                    </PopoverContent>
                  </Popover>

                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Tax Date */}
            <FormField
              control={form.control}
              name="taxDate"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Tax Date</FormLabel>
                  <Popover>
                    <PopoverTrigger asChild>
                      <FormControl>
                        <Button
                          className={cn(
                            "h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm",
                            !field.value && "text-muted-foreground",
                          )}
                          variant="outline"
                          size="lg"
                        >
                          {field.value
                            ? moment.unix(Number(field.value)).format(DATE_FORMAT)
                            : "Tax Date"}
                          <CalendarIcon className="ml-auto size-3.5 text-gray-400" />
                        </Button>
                      </FormControl>
                    </PopoverTrigger>

                    <PopoverContent className="w-auto p-0" align="start">
                      <Calendar
                        mode="single"
                        selected={
                          field.value
                            ? moment.unix(Number(field.value)).toDate()
                            : undefined
                        }
                        onSelect={(date) => {
                          if (!date) {
                            field.onChange(null);
                            return;
                          }

                          const unixTimestamp = Math.floor(date.getTime() / 1000);
                          field.onChange(unixTimestamp);
                        }}
                        initialFocus
                        defaultMonth={
                          field.value
                            ? moment.unix(Number(field.value)).toDate()
                            : new Date()
                        }
                      />
                    </PopoverContent>
                  </Popover>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Fifth Row */}
          <div className="grid grid-cols-1 items-center">
            {/* Location UUID */}
            <FormField
              control={form.control}
              name="location"
              render={({ field }) => (
                <FormItem className="hidden">
                  <FormLabel>Location UUID:</FormLabel>
                  <FormControl>
                    <Input className="h-7.5" {...field} />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Location */}
            <FormField
              control={form.control}
              name="locationCode"
              render={({ field }) => (
                <FormItem className="flex flex-col col-span-1">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Location</FormLabel>
                  <FormControl>
                    <div className="relative">
                      <Input
                        className="h-10 rounded-md px-2 pr-9 bg-white border border-gray text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                        {...field}
                        // readOnly
                        onChange={(e) =>
                          handleDropdownSearchChange("location", e.target.value)
                        }
                        onClick={() => fetchDropdownData1("location")}
                        ref={
                          dropdownState.currentDropdown === "location"
                            ? dropdownInputRef
                            : null
                        }
                        autoComplete="off"
                        placeholder="Location"
                      />
                      <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                        <FaMagnifyingGlass className="size-3 text-gray-400" />
                      </div>
                      {dropdownState.showTable &&
                        dropdownState.currentDropdown === "location" && (
                          <div
                            ref={dropdownTableRef}
                            className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                          >
                            <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownConfigs.location.columns}
                                data={dropdownState.data}
                                onClickRow={onClickRow}
                              />
                              <ScrollBar orientation="vertical" />
                            </ScrollArea>
                          </div>
                        )}
                    </div>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          <h1 className="mt-3 font-bold uppercase text-black">Mapping Reference</h1>

          {/* First Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">

            {/* SO No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">Sales Order No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" &&
                  form.getValues("salesOrder") &&
                  form.getValues("salesOrderNo") ? (
                  (() => {
                    const basePath = "/sales/sales-order";
                    const salesOrderID = form.getValues("salesOrder");
                    const salesOrderNo = form.getValues("salesOrderNo");
                    return (
                      <div>
                        <Link
                          href={`${basePath}/edit?item=${salesOrderNo}&id=${salesOrderID}`}
                          target="_blank"
                          className="flex text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                          title="Sales Order No"
                        >
                          {salesOrderNo}
                        </Link>
                      </div>
                    );
                  })()
                ) : (
                  <span className="text-muted-foreground">SO No</span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>

            {/* JO No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">Job Order No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" &&
                  form.getValues("jobOrder") &&
                  form.getValues("jobOrderNo") ? (
                  (() => {
                    const basePath = "/job-management/job-order";
                    const jobOrderID = form.getValues("jobOrder");
                    const jobOrderNo = form.getValues("jobOrderNo");
                    return (
                      <Link
                        href={`${basePath}/edit?item=${jobOrderNo}&id=${jobOrderID}`}
                        target="_blank"
                        className="flex text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                        title="Job Order No"
                      >
                        {jobOrderNo}
                      </Link>
                    );
                  })()
                ) : (
                  <span className="text-muted-foreground">JO No</span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>
          </div>

          {/* Second Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">

            {/* QT No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">Quotation No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" &&
                  form.getValues("quotation") &&
                  form.getValues("quotationNo") ? (
                  (() => {
                    const basePath = "/sales/quotation";
                    const quotationID = form.getValues("quotation");
                    const quotationNo = form.getValues("quotationNo");
                    return (
                      <Link
                        href={`${basePath}/edit?item=${quotationNo}&id=${quotationID}`}
                        target="_blank"
                        className="flex text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                        title="Quotation No"
                      >
                        {quotationNo}
                      </Link>
                    );
                  })()
                ) : (
                  <span className="text-muted-foreground">QT No</span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>

            {/* DO No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">Delivery Order No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" &&
                  form.getValues("deliveryOrder") &&
                  form.getValues("deliveryOrderNo") ? (
                  (() => {
                    const basePath = "/sales/sales-delivery-order";
                    const deliveryOrderID = form.getValues("deliveryOrder");
                    const deliveryOrderNo = form.getValues("deliveryOrderNo");
                    return (
                      <Link
                        href={`${basePath}/edit?item=${deliveryOrderNo}&id=${deliveryOrderID}`}
                        target="_blank"
                        className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                        title="Delivery Order No"
                      >
                        {deliveryOrderNo}
                      </Link>
                    );
                  })()
                ) : (
                  <span className="text-muted-foreground">DO No</span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>
          </div>

          {/* Third Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">

            {/* CN No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">Credit No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" &&
                  form.getValues("salesCreditNoteTransferred")?.length ? (
                  form
                    .getValues("salesCreditNoteTransferred")
                    .map((doc, index, array) => {
                      const basePath = "/sales/sales-credit-note";
                      return (
                        <Link
                          key={doc.UUID}
                          href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                          target="_blank"
                          className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                          title="Credit No"
                        >
                          {doc.docNo}
                          {index < array.length - 1 ? ", " : ""}
                        </Link>
                      );
                    })
                ) : (
                  <span className="text-muted-foreground">CN No</span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>

            {/* OR No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">OR No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" && form.getValues("customerPaymentDocNo")?.length ? (
                  form.getValues("customerPaymentDocNo").map((doc, index, array) => {
                    const basePath = "/sales/customer-payment";
                    return (
                      <Link
                        key={doc.customerPayment}
                        href={`${basePath}/edit?item=${doc.docNo}&id=${doc.customerPayment}`}
                        target="_blank"
                        className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                        title="OR No"
                      >
                        {doc.docNo}
                        {index < array.length - 1 ? ", " : ""}
                      </Link>
                    );
                  })
                ) : (
                  <span className="text-muted-foreground">OR No</span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>
          </div>

          {/* Forth Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">
            {/* Consolidated E-invoice No */}
            <div className="flex flex-col text-nowrap space-y-2">

              <p className="text-[11px] font-semibold tracking-wider text-black">Consolidated E-invoice No</p>

              <ScrollArea className="flex flex-col h-10 rounded-md border border-input bg-white border-gray-200 px-2 pt-[11px] text-[11px] font-normal shadow-sm">
                {slug !== "clone" &&
                  form.getValues("consolidateTo") &&
                  form.getValues("consolidatedInvoiceDocNo") ? (
                  (() => {
                    const basePath = "/sales/consolidated-invoice";
                    const consolidateToID = form.getValues("consolidateTo");
                    const consolidatedInvoiceDocNo = form.getValues(
                      "consolidatedInvoiceDocNo",
                    );
                    return (
                      <Link
                        href={`${basePath}/edit?item=${consolidatedInvoiceDocNo}&id=${consolidateToID}`}
                        target="_blank"
                        className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                        title="Consolidated E-invoice No"
                      >
                        {consolidatedInvoiceDocNo}
                      </Link>
                    );
                  })()
                ) : (
                  <span className="text-muted-foreground">
                    Consolidated E-Invoice No
                  </span>
                )}
                <ScrollBar orientation="horizontal" className="h-1.5" />
              </ScrollArea>
            </div>

            {/* UUID */}
            <div className="flex flex-col text-nowrap space-y-2">
              <FormField
                control={form.control}
                name="UUID"
                render={({ field }) => (
                  <FormItem
                    className={`flex flex-col ${slug === "clone" ? "hidden" : ""}`}
                  >
                    <FormLabel className="text-[11px] font-semibold tracking-wider text-black">UUID</FormLabel>
                    <FormControl className="relative">
                      <Input
                        className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                        {...field}
                        readOnly={true}
                        ref={inputRef}
                        autoComplete="off"
                        placeholder="UUID"
                        title="UUID"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </div>

          {/* Import And Export Good Form */}
          <ImportExportOfGoodsForm form={form} isMobile={true} />

          {/* Payment Details Form */}
          <PaymentDetailsForm form={form} isMobile={true} />
        </div>
      </>
    )
  }

  return (
    <Form {...form}>
      <form>
        <Tabs>
          <div className="flex">
            {/* Left Container*/}
            <div className="min-w-0 flex-1">
              {/* General Details*/}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">General Details</div>
                </div>

                <div className="flex flex-col gap-y-2.5 pt-1.5">

                  {/* First Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Currency UUID */}
                    <FormField
                      control={form.control}
                      name="currency"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Currency UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Currency Code */}
                    <FormField
                      control={form.control}
                      name="currencyCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 rounded-md px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      onClick={() => fetchDropdownData("currency")}
                                      onChange={(e) => {
                                        field.onChange(e);
                                        setCurrencyFilter(e.target.value);
                                      }}
                                      ref={currencyInputRef}
                                      autoComplete="off"
                                      disabled={isPaid}
                                      placeholder="Currency Code"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Currency Code</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                              </div>
                              {showCurrencyTable && (
                                <div
                                  ref={currencyDropdownRef}
                                  className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownCurrencyColumns}
                                      data={currencyDropdownData}
                                      onClickRow={onClickRowCurrency}
                                      filterValue={currencyFilter}
                                      filterColumn="currencyCode"
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Currency rate */}
                    <FormField
                      control={form.control}
                      name="currencyRate"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <NumberInputField
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    form={form}
                                    fieldName="currencyRate"
                                    value={field.value || ""}
                                    decimalPlaces={decimal}
                                    constUpdate={true}
                                    disabled={isPaid}
                                    placeholder="Currency Rate"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Currency Rate</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Second Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Project UUID */}
                    <FormField
                      control={form.control}
                      name="project"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Project UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Project */}
                    <FormField
                      control={form.control}
                      name="projectCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 rounded-md px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      onClick={() => fetchDropdownData("project")}
                                      onChange={(e) => {
                                        field.onChange(e);
                                        setProjectFilter(e.target.value);
                                      }}
                                      ref={projectInputRef}
                                      autoComplete="off"
                                      placeholder="Project"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Project</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                                {/* Using the search icon */}
                              </div>
                              {showProjectTable && (
                                <div
                                  ref={projectDropdownRef}
                                  className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownProjectColumns}
                                      data={projectDropdownData}
                                      onClickRow={onClickRowProject}
                                      filterValue={projectFilter}
                                      filterColumn="projectCode"
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Validity Days */}
                    <FormField
                      control={form.control}
                      name="docValidity"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    {...field}
                                    onChange={(e) => {
                                      form.setValue(
                                        "docValidity",
                                        e.target.value.replace(/[^0-9]/g, ""),
                                      );
                                    }}
                                    placeholder="Doc Validity Days"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Doc Validity Days</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Third Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* Shipper UUID */}
                    <FormField
                      control={form.control}
                      name="shipper"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Shipper UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Shipper */}
                    <FormField
                      control={form.control}
                      name="shipperCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 rounded-md px-2 pr-8 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      // readOnly
                                      onChange={(e) =>
                                        handleDropdownSearchChange("shipper", e.target.value)
                                      }
                                      onClick={() => fetchDropdownData1("shipper")}
                                      ref={
                                        dropdownState.currentDropdown === "shipper"
                                          ? dropdownInputRef
                                          : null
                                      }
                                      autoComplete="off"
                                      placeholder="Shipper"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Shipper</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "shipper" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.shipper.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Delivery Terms */}
                    <FormField
                      control={form.control}
                      name="deliveryTerm"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    placeholder="Delivery Terms"
                                    {...field}
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Delivery Terms</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Forth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Posting Date */}
                    <FormField
                      control={form.control}
                      name="postingDate"
                      render={({ field }) => (
                        <FormItem>
                          <Popover>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <PopoverTrigger asChild>
                                    <FormControl>
                                      <Button
                                        className={cn(
                                          "h-7.5 w-full rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out hover:bg-background/50",
                                          !field.value && "text-muted-foreground",
                                        )}
                                        variant="outline"
                                        size="lg"
                                      >
                                        {field.value
                                          ? moment.unix(Number(field.value)).format(DATE_FORMAT)
                                          : "Posting Date"}
                                        <CalendarIcon className="ml-auto size-3.5 text-gray-400" />
                                      </Button>
                                    </FormControl>
                                  </PopoverTrigger>
                                </TooltipTrigger>

                                <TooltipContent>Posting Date</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>

                            <PopoverContent className="w-auto p-0" align="start">
                              <Calendar
                                mode="single"
                                selected={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : undefined
                                }
                                onSelect={(date) => {
                                  if (!date) {
                                    field.onChange(null);
                                    return;
                                  }

                                  const unixTimestamp = Math.floor(date.getTime() / 1000);
                                  field.onChange(unixTimestamp);
                                }}
                                initialFocus
                                defaultMonth={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : new Date()
                                }
                              />
                            </PopoverContent>
                          </Popover>

                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Tax Date */}
                    <FormField
                      control={form.control}
                      name="taxDate"
                      render={({ field }) => (
                        <FormItem>
                          <Popover>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <PopoverTrigger asChild>
                                    <FormControl>
                                      <Button
                                        className={cn(
                                          "h-7.5 w-full rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out hover:bg-background/50",
                                          !field.value && "text-muted-foreground",
                                        )}
                                        variant="outline"
                                        size="lg"
                                      >
                                        {field.value
                                          ? moment.unix(Number(field.value)).format(DATE_FORMAT)
                                          : "Tax Date"}
                                        <CalendarIcon className="ml-auto size-3.5 text-gray-400" />
                                      </Button>
                                    </FormControl>
                                  </PopoverTrigger>
                                </TooltipTrigger>

                                <TooltipContent>Tax Date</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>

                            <PopoverContent className="w-auto p-0" align="start">
                              <Calendar
                                mode="single"
                                selected={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : undefined
                                }
                                onSelect={(date) => {
                                  if (!date) {
                                    field.onChange(null);
                                    return;
                                  }

                                  const unixTimestamp = Math.floor(date.getTime() / 1000);
                                  field.onChange(unixTimestamp);
                                }}
                                initialFocus
                                defaultMonth={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : new Date()
                                }
                              />
                            </PopoverContent>
                          </Popover>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Fifth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Location UUID */}
                    <FormField
                      control={form.control}
                      name="location"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Location UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Location */}
                    <FormField
                      control={form.control}
                      name="locationCode"
                      render={({ field }) => (
                        <FormItem className="col-span-1">
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 w-full rounded-md px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      // readOnly
                                      onChange={(e) =>
                                        handleDropdownSearchChange("location", e.target.value)
                                      }
                                      onClick={() => fetchDropdownData1("location")}
                                      ref={
                                        dropdownState.currentDropdown === "location"
                                          ? dropdownInputRef
                                          : null
                                      }
                                      autoComplete="off"
                                      placeholder="Location"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Location</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "location" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.location.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Voucher */}
                    <FormField
                      control={form.control}
                      name="voucherCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    placeholder="Voucher"
                                    {...field}
                                    onBlur={(e) => verifyVoucher(e.target.value)}
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Voucher</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                    {/* Voucher UUID */}
                    <FormField
                      control={form.control}
                      name="voucher"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Voucher UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                  </div>
                </div>
              </TabPanel>

              {/* Mapping Reference */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Mapping Reference</div>
                </div>

                <div className="flex flex-col gap-y-2.5 pt-1.5">

                  {/* First Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* SO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("salesOrder") &&
                          form.getValues("salesOrderNo") ? (
                          (() => {
                            const basePath = "/sales/sales-order";
                            const salesOrderID = form.getValues("salesOrder");
                            const salesOrderNo = form.getValues("salesOrderNo");
                            return (
                              <div>
                                <Link
                                  href={`${basePath}/edit?item=${salesOrderNo}&id=${salesOrderID}`}
                                  target="_blank"
                                  className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                  title="Sales Order No"
                                >
                                  {salesOrderNo}
                                </Link>
                              </div>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">SO No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>

                    {/* JO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("jobOrder") &&
                          form.getValues("jobOrderNo") ? (
                          (() => {
                            const basePath = "/job-management/job-order";
                            const jobOrderID = form.getValues("jobOrder");
                            const jobOrderNo = form.getValues("jobOrderNo");
                            return (
                              <Link
                                href={`${basePath}/edit?item=${jobOrderNo}&id=${jobOrderID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="Job Order No"
                              >
                                {jobOrderNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">JO No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Second Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* QT No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("quotation") &&
                          form.getValues("quotationNo") ? (
                          (() => {
                            const basePath = "/sales/quotation";
                            const quotationID = form.getValues("quotation");
                            const quotationNo = form.getValues("quotationNo");
                            return (
                              <Link
                                href={`${basePath}/edit?item=${quotationNo}&id=${quotationID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="Quotation No"
                              >
                                {quotationNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">QT No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>

                    {/* DO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("deliveryOrder") &&
                          form.getValues("deliveryOrderNo") ? (
                          (() => {
                            const basePath = "/sales/sales-delivery-order";
                            const deliveryOrderID = form.getValues("deliveryOrder");
                            const deliveryOrderNo = form.getValues("deliveryOrderNo");
                            return (
                              <Link
                                href={`${basePath}/edit?item=${deliveryOrderNo}&id=${deliveryOrderID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="Delivery Order No"
                              >
                                {deliveryOrderNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">DO No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Third Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* CN No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("salesCreditNoteTransferred")?.length ? (
                          form
                            .getValues("salesCreditNoteTransferred")
                            .map((doc, index, array) => {
                              const basePath = "/sales/sales-credit-note";
                              return (
                                <Link
                                  key={doc.UUID}
                                  href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                  target="_blank"
                                  className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                  title="CN No"
                                >
                                  {doc.docNo}
                                  {index < array.length - 1 ? ", " : ""}
                                </Link>
                              );
                            })
                        ) : (
                          <span className="text-muted-foreground">CN No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>

                    {/* OR No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" && form.getValues("customerPaymentDocNo")?.length ? (
                          form.getValues("customerPaymentDocNo").map((doc, index, array) => {
                            const basePath = "/sales/customer-payment";
                            return (
                              <Link
                                key={doc.customerPayment}
                                href={`${basePath}/edit?item=${doc.docNo}&id=${doc.customerPayment}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="OR No"
                              >
                                {doc.docNo}
                                {index < array.length - 1 ? ", " : ""}
                              </Link>
                            );
                          })
                        ) : (
                          <span className="text-muted-foreground">OR No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Forth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Consolidated E-invoice No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("consolidateTo") &&
                          form.getValues("consolidatedInvoiceDocNo") ? (
                          (() => {
                            const basePath = "/sales/consolidated-invoice";
                            const consolidateToID = form.getValues("consolidateTo");
                            const consolidatedInvoiceDocNo = form.getValues(
                              "consolidatedInvoiceDocNo",
                            );
                            return (
                              <Link
                                href={`${basePath}/edit?item=${consolidatedInvoiceDocNo}&id=${consolidateToID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="Consolidated E-invoice No"
                              >
                                {consolidatedInvoiceDocNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">
                            Consolidated E-Invoice No
                          </span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>

                    {/* UUID */}
                    <div className="flex flex-col text-nowrap">
                      <FormField
                        control={form.control}
                        name="UUID"
                        render={({ field }) => (
                          <FormItem
                            className={`flex flex-col space-y-1 ${slug === "clone" ? "hidden" : ""}`}
                          >
                            <FormControl className="relative">
                              <Input
                                className="h-7.5 rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                {...field}
                                readOnly={true}
                                ref={inputRef}
                                autoComplete="off"
                                placeholder="UUID"
                                title="UUID"
                              />
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>
                  </div>
                </div>
              </TabPanel>

              {/* Import & Export Goods */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Import & Export Goods</div>
                </div>

                <ImportExportOfGoodsForm form={form} isMobile={isMobile} />
              </TabPanel>

              {/* Payment Details */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Payment Details</div>
                </div>

                <PaymentDetailsForm form={form} />
              </TabPanel>
            </div>

            {/* Right - Vertical TabList */}
            <TabList className="ml-1 flex flex-col gap-y-1">
              {[
                {
                  icon: <IoDocumentOutline className="size-4.5" />,
                  label: "General Details",
                },
                {
                  icon: <HiOutlineClipboardDocumentList className="size-4.5" />,
                  label: "Mapping Reference",
                },
                {
                  icon: <FaBoxes className="size-4.5" />,
                  label: "Import & Export Goods",
                },
                {
                  icon: <FaAddressCard className="size-4.5" />,
                  label: "Payment Details",
                },
              ].map((item, index) => (
                <Tab
                  key={index}
                  className="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-y-0.5 rounded-md border border-gray-200 bg-white text-[9px] text-gray-600 outline-none transition-all duration-200 ease-in-out"
                  selectedClassName="!bg-blue-300 border-blue-300 text-white"
                >
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <span className="flex h-full w-full items-center justify-center">
                          {item.icon}
                        </span>
                      </TooltipTrigger>
                      <TooltipContent side="right" align="start">
                        {item.label}
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </Tab>
              ))}
            </TabList>
          </div>
        </Tabs>
      </form>
    </Form>
  );
}