"use client";

import { useEffect, useState, memo } from "react";
import { FaSort, FaSortDown, FaSortUp } from "react-icons/fa6";
import type { ColumnDef, Row, SortingState } from "@tanstack/react-table";
import {
  flexRender,
  getCoreRowModel,
  getFilteredRowModel,
  getPaginationRowModel,
  getSortedRowModel,
  useReactTable,
} from "@tanstack/react-table";

import { useSearchParams } from "next/navigation";

import NoResultsTableRow from "@/components/data-table/NoResultsTableRow";
import TableHeadColumnTextFilter from "@/components/data-table/TableHeadColumnTextFilter";
import { TableHeadValidityFilter } from "@/components/data-table/TableHeadValidityFilter";
import { Dialog, DialogContent } from "@/components/ui/dialog";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import { Separator } from "@/components/ui/separator";
import { useToast } from "@/components/ui/use-toast";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";

import { DEFAULT_DATA_TABLE_PAGE_SIZE, getAuthHeaders, ORIGIN, DATA_TABLE_DEFAULT_COLUMN_SIZING } from "@/lib/constants";
import { useHandleRowSelect } from "@/lib/hooks/useHandleRowSelect";
import usePreventShiftTextSelect from "@/lib/hooks/usePreventShiftTextSelect";
import { cn } from "@/lib/utils/cn";

import PackagePopoverToolbar from "./PackagePopoverToolbar";
import type { ItemList } from "./itemColumns";

// Mobile View (Imports)
import MobilePopoverDataTable from "@/components/form/MobilePopoverDataTable";

// Column Drag and Drop and Resize (Imports)
import type { MouseEvent } from "react";
import { closestCenter, DndContext } from "@dnd-kit/core";
import { restrictToHorizontalAxis } from "@dnd-kit/modifiers";
import { horizontalListSortingStrategy, SortableContext } from "@dnd-kit/sortable";
import { ColumnResizer } from "@/components/data-table/ColumnResizer";
import DragableTableHead from "@/components/data-table/DragableTableHead";
import { useColumnSizeVars } from "@/lib/hooks/useColumnSizeVars";
import { useDndSensors } from "@/lib/hooks/useDndSensors";
import useLocalStorage from "@/lib/hooks/useLocalStorage";
import getExcludedColumns from "@/lib/utils/data-table/getExcludedColumns";
import handleDndDragEnd from "@/lib/utils/data-table/handleDndDragEnd";
import type {
  ColumnOrderState,
  ColumnSizingState,
  Table as TableType,
  VisibilityState,
} from "@tanstack/react-table";

type Props = {
  open: boolean;
  setOpen: (state: boolean) => void;
  columns: ColumnDef<ItemList>[];
  data: any;
  fetchPackageData: () => void;
  revalidateSalesInvoiceDetails: () => void;
  setTempRowSalesInvoiceDetailsListData: (data: any, overwrite: boolean) => void;
  tempRowSalesInvoiceDetailsList: any;
  slug: string;
  preferenceData: any;
};

const now = new Date();
// Start = now (seconds)
const startDayTs = Math.floor(now.getTime() / 1000);

// End = end of last day of current month (seconds)
const lastDayTs = Math.floor(
  new Date(
    now.getFullYear(),
    now.getMonth() + 1,
    0,
    23, 59, 59, 999
  ).getTime() / 1000
);


// Column Drag and Drop and Resize (Local Storage Keys)
const PACKAGE_COLUMN_ORDERING_KEY = "sales-invoice.package.bs.table.ordering";
const PACKAGE_COLUMN_SIZING_KEY = "sales-invoice.package.bs.table.sizing";
const COLUMN_VISIBILITY_KEY = "sales-invoice.package.bs.table.columns";

export default function ItemPopover({
  open,
  setOpen,
  columns,
  data,
  fetchPackageData,
  revalidateSalesInvoiceDetails,
  setTempRowSalesInvoiceDetailsListData,
  tempRowSalesInvoiceDetailsList,
  slug,
  preferenceData
}: Props) {
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const { toast } = useToast();
  const headers = getAuthHeaders();

  const [sorting, setSorting] = useState<SortingState>([]);

  // Column Drag and Drop and Resize (State)
  const initialColumnOrder = columns?.filter(column => column?.id).map((column) => column.id!) || [];

  const [columnOrder, setColumnOrder] = useLocalStorage<ColumnOrderState>(
    PACKAGE_COLUMN_ORDERING_KEY,
    initialColumnOrder
  );
  const [columnSizing, setColumnSizing] = useLocalStorage<ColumnSizingState>(
    PACKAGE_COLUMN_SIZING_KEY,
    {}
  );

  const defaultColumns = ["packageCode", "packageName", "description"];
  const defaultColumnVisibility: VisibilityState = getExcludedColumns(
    columns || [],
    defaultColumns
  );

  const [columnVisibility, setColumnVisibility] = useState<VisibilityState>(() => {
    if (typeof window !== "undefined") {
      return JSON.parse(localStorage.getItem(COLUMN_VISIBILITY_KEY) || "{}");
    }
    return defaultColumnVisibility;
  });

  const table = useReactTable({
    columns,
    data,
    state: {
      sorting,
      columnVisibility,
      columnOrder: columnOrder,
      columnSizing: columnSizing,
    },
    onSortingChange: setSorting,
    onColumnVisibilityChange: setColumnVisibility,
    onColumnOrderChange: setColumnOrder,
    onColumnSizingChange: setColumnSizing,
    autoResetPageIndex: false,
    columnResizeMode: "onChange",
    defaultColumn: DATA_TABLE_DEFAULT_COLUMN_SIZING,
    enableColumnResizing: true,
    getCoreRowModel: getCoreRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    getSortedRowModel: getSortedRowModel(),
    initialState: {
      pagination: {
        pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
      },
      columnVisibility: JSON.parse(
        localStorage.getItem(COLUMN_VISIBILITY_KEY) || "{}"
      ),
    },
  });

  // Column Drag and Drop and Resize (Hooks)
  const sensors = useDndSensors();
  const columnSizeVars = useColumnSizeVars(table);

  useEffect(() => {
    localStorage.setItem(
      COLUMN_VISIBILITY_KEY,
      JSON.stringify(columnVisibility)
    );
  }, [columnVisibility]);

  const [selectedRow, setSelectedRow] = useState<string>("");

  usePreventShiftTextSelect();

  const savePackageServices = async (prop: any) => {
    try {
      var formData = new FormData();

      if (prop.table) {
        table.getSelectedRowModel().rows.forEach((row, index) => {
          formData.append(`UUIDs[${index}]`, `${row.original.UUID}`);
        });
      } else {
        formData.append(`UUIDs[0]`, `${prop.row.original.UUID}`);
      }

      const response = await fetch(
        `${ORIGIN}/sales_invoice/api/sales-invoice/load-package-has-service${id && slug !== "clone" ? `?salesInvoiceUUID=${id}` : ""}`,
        {
          method: "POST",
          headers,
          body: formData,
        }
      );

      if (!response.ok) {
        const errorData = await response.json();

        toast({
          variant: "destructive",
          title: "Error",
          description:
            errorData.message || "Failed to create fetch services data",
        });

        return;
      }

      const responseData = await response.json();

      if (id && slug !== "clone") {
        // Existing logic for when there's an ID
        revalidateSalesInvoiceDetails();
      } else {
        // New logic for when there's no ID - save to temp row data
        if (responseData.data && responseData.data.length > 0) {
          responseData.data.forEach((serviceData, index) => {
            // Get the maximum existing sequence number
            const existingData = tempRowSalesInvoiceDetailsList || [];
            const maxSeq = existingData.length > 0
              ? Math.max(...existingData.map(item => parseInt(item.seq) || 0))
              : 0;

            const item = {
              UUID: "",
              seq: (maxSeq + index + 1).toString(),
              item: serviceData.UUID,
              itemCode: serviceData.itemCode,
              itemName: serviceData.itemName,
              type: "Service",
              description: serviceData.description,
              "2ndDescription": serviceData["2ndDescription"],
              moreDescription: serviceData.moreDescription,
              itemGroup: serviceData.itemGroupCode,
              itemGroupCode: serviceData.itemGroupCodeCode,
              itemCategory: serviceData.itemCategoryCode,
              itemCategoryCode: serviceData.itemCategoryCodeCode,
              tariff: null,
              classification: serviceData.classification,
              classificationCode: serviceData.classificationCodeCode,
              permitNo: null,
              project: "", // Will be set from form if available
              quantity: serviceData.UOMDropdown && serviceData.UOMDropdown.length > 0 && serviceData.UOMDropdown[0].UOM ? 1 : "",
              quantity2: serviceData.UOMDropdown2 && serviceData.UOMDropdown2.length > 0 && serviceData.UOMDropdown2[0].UOM2 ? 1 : "",
              quantity3: serviceData.UOMDropdown3 && serviceData.UOMDropdown3.length > 0 && serviceData.UOMDropdown3[0].UOM3 ? 1 : "",
              UOM: serviceData.UOM,
              UOMDropdown: serviceData.UOMDropdown || [],
              UOMDropdown2: serviceData.UOMDropdown2 || [],
              UOMDropdown3: serviceData.UOMDropdown3 || [],
              itemRate: serviceData.Rate,
              price: serviceData.price || 0,
              discountRate: 0,
              discountAmount: 0,
              tax: null,
              deliveryDate: serviceData.deliveryDate,
              billingFrequency: serviceData.billingFrequency,
              billingInterval: serviceData.billingInterval,
              startAt: preferenceData?.data?.salesInvoiceDefaultDate == "1" ? startDayTs : "",
              endAt: preferenceData?.data?.salesInvoiceDefaultDate == "1" ? lastDayTs : "",
              remark1: "",
              remark2: "",
              master: serviceData.master,
              showTemplate: serviceData.showTemplate,
              valid: "1",
            };

            setTempRowSalesInvoiceDetailsListData(item, false);
          });
        }
      }

      revalidateSalesInvoiceDetails();
      setOpen(false);
    } catch (error) {
      console.error(`Failed to fetch services data`);

      toast({
        variant: "destructive",
        title: "Error",
        description: "Failed to fetch services data",
      });
    }
  };

  const resetPackageTable = async () => {
    await fetchPackageData();
  };

  const onDoubleClick = (row: Row<ItemList>) => {
    savePackageServices({ row: row });
  };

  const onRowSelection = useHandleRowSelect(table, onDoubleClick);

  return (
    <Dialog open={open} onOpenChange={setOpen}>
      <DialogContent className="min-h-[75vh] min-w-[75vw] max-w-3xl bg-erp-blue-3 p-2">
        <div className="h-[73cqh] w-full p-4">
          <div className="flex h-[70cqh] flex-col bg-erp-blue-3 @container-[size]">
            <h2 className="text-sm font-bold">Select Item</h2>
            <PackagePopoverToolbar
              table={table}
              setOpen={setOpen}
              savePackageServices={savePackageServices}
              fetchPackageData={fetchPackageData}
            />

            <Separator className="bg-erp-blue-11" />
            <ScrollArea className="h-[100cqh] bg-erp-gray-3">
              {/* Mobile View (Data Table) */}
              <MobilePopoverDataTable
                table={table}
                headerFields={["packageCode", "packageName"]}
                initialVisibleFields={3}
                excludeFromGrid={["packageCode", "packageName"]}
                showSelection={true}
                selectionLabel="Select"
              />

              {/* Web View (Data Table) */}
              <div className="hidden md:block">
                {/* Column Drag and Drop and Resize (DND Context) */}
                <DndContext
                  collisionDetection={closestCenter}
                  modifiers={[restrictToHorizontalAxis]}
                  onDragEnd={(event) => handleDndDragEnd(event, setColumnOrder)}
                  sensors={sensors}
                >
                  {/* Column Drag and Drop and Resize (Table) */}
                  <Table
                    className="table-fixed border-separate border-spacing-[3px] whitespace-nowrap border bg-erp-gray-1"
                    style={{ ...columnSizeVars, width: table.getTotalSize() }}
                  >
                    <TableHeader className="sticky top-0 z-10">
                      {table.getHeaderGroups().map((headerGroup) => (
                        <TableRow key={headerGroup.id}>
                          {/* Column Drag and Drop and Resize (Sortable Context) */}
                          <SortableContext
                            items={columnOrder}
                            strategy={horizontalListSortingStrategy}
                          >
                            {headerGroup.headers.map((header) => (
                              // Column Drag and Drop and Resize (Dragable Table Head)
                              <DragableTableHead
                                key={header.id}
                                header={header}
                                className="bg-erp-blue-11 font-normal"
                                style={{
                                  width: `calc(var(--header-${header?.id}-size) * 1px)`,
                                }}
                              >
                                {header.column.id === "validity" ? (
                                  <TableHeadValidityFilter table={table} />
                                ) : (
                                  <TableHeadColumnTextFilter
                                    column={header.column}
                                    table={table}
                                  />
                                )}
                                <ColumnResizer header={header} />
                              </DragableTableHead>
                            ))}
                          </SortableContext>
                        </TableRow>
                      ))}
                    </TableHeader>
                    {/* Column Drag and Drop and Resize (Table Body) */}
                    {table.getState().columnSizingInfo.isResizingColumn ? (
                      <MemoizedTableBody
                        table={table}
                        onRowSelection={onRowSelection}
                        columns={columns}
                      />
                    ) : (
                      <NonMemoizedTableBody
                        table={table}
                        onRowSelection={onRowSelection}
                        columns={columns}
                      />
                    )}
                  </Table>
                </DndContext>
              </div>
              <ScrollBar orientation="horizontal" />
            </ScrollArea>
          </div>
        </div>
      </DialogContent>
    </Dialog>
  );
}

// Column Drag and Drop and Resize (Table Body)
type TableBodyProps = {
  table: TableType<ItemList>;
  onRowSelection: (row: Row<ItemList>) => (event: MouseEvent<HTMLTableRowElement>) => void;
  columns: ColumnDef<ItemList>[];
};

function NonMemoizedTableBody({ table, onRowSelection, columns }: TableBodyProps) {
  return (
    <TableBody>
      {table.getRowModel().rows?.length ? (
        table.getRowModel().rows.map((row) => (
          <TableRow
            className="odd:bg-erp-blue-5 even:bg-erp-blue-1 hover:bg-erp-blue-7 data-[state=selected]:bg-erp-blue-17"
            data-state={row.getIsSelected() && "selected"}
            onClick={onRowSelection(row)}
            key={row.id}
          >
            {row.getVisibleCells().map((cell) => (
              <TableCell
                key={cell.id}
                className="truncate"
                title={(cell.getValue() ?? "").toString()}
                style={{
                  width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                  minWidth: cell.column.columnDef.minSize,
                }}
              >
                {flexRender(
                  cell.column.columnDef.cell,
                  cell.getContext()
                )}
              </TableCell>
            ))}
          </TableRow>
        ))
      ) : (
        <NoResultsTableRow columns={columns} />
      )}
    </TableBody>
  );
}

const MemoizedTableBody = memo(
  NonMemoizedTableBody,
  (prev, next) => prev.table.options.data === next.table.options.data
) as typeof NonMemoizedTableBody;