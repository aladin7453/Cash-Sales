import type { SortingState } from "@tanstack/react-table";

interface DocumentListingReport {
  id: string;
  name: string;
}

type DropdownConfig = {
  tableName: string;
  columns: { accessorKey: string; header: string; cell? }[];
  valueField: string;
  displayField: string;
  formValueField: string;
  formDisplayField: string;
  additionalMappings?: { sourceField: string; targetFormField: string }[];
};

// Base props interface
interface ColumnDefinitionsByDocTypeProps {
  form: UseFormReturn<any>;
  onSubmit: (data: any) => void;
  onPreview?: (data: any, isGenerated?: boolean) => void;
  previewPDF?: any;
  salesReportData?: any;
  generatedReport?: any;
  setSorting?: (s: SortingState) => void;
  filterFields?: string[];
  sorting?: any;
}

interface DocumentListingReportFormProps extends ColumnDefinitionsByDocTypeProps {
  salesReportColumns?: ColumnDef<DocumentListingReport>[];
}

