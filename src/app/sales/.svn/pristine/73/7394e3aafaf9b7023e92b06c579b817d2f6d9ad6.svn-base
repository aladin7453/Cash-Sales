    //     setShowPreviewDialog(false);
    //     setTimeout(() => { setShowPreviewDialog(true); }, 0);
    //   }

    // else if(values.docType ==="salesCreditNote"){
    //   if (columnDefinitionsByDocType.salesCreditNote) {
    //   setActivePreviewColumns(columnDefinitionsByDocType.salesCreditNote);
    //   }
