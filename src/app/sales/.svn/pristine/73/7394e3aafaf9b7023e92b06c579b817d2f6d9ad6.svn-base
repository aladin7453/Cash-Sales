      <AlertDialog open={isAlertOpen} onOpenChange={setIsAlertOpen}>
        <AlertDialogContent className="max-w-sm">
          <div className="flex flex-col items-center gap-2">
            <p className="text-md text-center text-erp-blue-14">kindly generate first.</p>
          </div>
          <AlertDialogFooter className="mt-2 flex items-center !justify-center justify-center gap-3 [&>*]:m-0">
            <AlertDialogAction className="h-9 w-24" autoFocus onClick={() => setShowDialog(false)}>
              Close
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>

      <ItemPopover
        open={dialogOpen}
        setOpen={setDialogOpen}
        columns={itemType === "service" ? ServiceColumns : StockColumns}
        // setTempRowSalesInvoiceDetailsListData={setTempRowSalesInvoiceDetailsListData}
        // tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
        // revalidateSalesInvoiceDetails={revalidateSalesInvoiceDetails}
        itemTable={itemTable}
        fetchItemData={fetchItemData}
        itemType={itemType}
        form={form}
        // updateItem={updateItem}
        itemData={itemData}
        // slug={slug}
        // preferenceData={preferenceData}
      />
    </div>
