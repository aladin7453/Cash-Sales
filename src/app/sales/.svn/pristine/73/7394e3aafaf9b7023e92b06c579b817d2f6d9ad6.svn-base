    //     setReportType("Sales Document Listing Report");
    //     setShowPreviewDialog(false);
    //     setTimeout(() => { setShowPreviewDialog(true); }, 0);
    //   }
  };

  // const handleSelectLevel1 = () => {
  // setReportType("Sales Local - Cash Sales Collection Report - Level 1");
  // setShowLevel1Dialog(true);
  // setShowPreviewDialog(false);
  // setShowOptionDialog(false);
  // };

  //Cash Sales Collection handleselect
  const handleSelectLevel1cscr = () => {
    const values = form.getValues();
    setActivePreviewColumns(columnDefinitionsByDocType.cashSalesCollection);
    if (onPreview) {
      onPreview(values, false);
    }
    setReportType("Sales Local - Cash Sales Collection Report - Level 1");
    setShowPreviewDialog(false);
    setTimeout(() => {
      setShowPreviewDialog(true);
    }, 0);
  };

  //Cash Sales handleSelect
  const handleSelectLevel0csl = () => {
    const values = form.getValues();
    if (columnDefinitionsByDocType.cashSales) {
