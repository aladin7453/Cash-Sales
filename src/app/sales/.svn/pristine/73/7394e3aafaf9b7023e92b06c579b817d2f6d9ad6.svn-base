  const [fromDateOpen, setFromDateOpen] = useState(false);
  const [toDateOpen, setToDateOpen] = useState(false);

  useEffect(() => {
    if (docType) {
      if (docType === "deliveryOrder") {
        setSelectedReportList(salesDeliveryOrderListingList);
      } else if (docType === "quotation") {
        setSelectedReportList(salesQuotationListingList);
      } else if (docType === "cashSales") {
        setSelectedReportList(cashSalesListingList);
      } else if (docType === "salesCreditNote") {
        setSelectedReportList(salesCreditNoteListingList);
      } else if (docType === "salesDebitNote") {
        setSelectedReportList(salesDebitNoteListingList);
      } else if (docType === "salesInvoice") {
        setSelectedReportList(salesInvoiceListingList);
      } else if (docType === "salesOrder") {
        setSelectedReportList(salesOrderListingList);
      }
    }
  }, [docType]);

  const handleOnAdd = async () => {
    setDialogOpen(true);

    await fetchItemData(itemType);
  };

  const itemTable = useReactTable({
    columns: itemType === "service" ? ServiceColumns : StockColumns,
    data: itemData,
    state: { sorting: itemSorting },
    onSortingChange: setItemSorting,
    autoResetPageIndex: false,
    getCoreRowModel: getCoreRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    getSortedRowModel: getSortedRowModel(),
    initialState: {
      pagination: {
        pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
      },
    },
  });

  const fetchItemData = async (itemType: string) => {
    try {
      const response = await fetch(
        `${ORIGIN}/universal/get-all-item-details?itemType=${itemType}&module=sales`,
        {
          headers,
        },
      );

      if (!response.ok) {
        throw new Error("Failed to create new service category data");
      }

      const responseData = await response.json();

      setItemType(itemType);
      setItemData(responseData.rows);
    } catch (error) {
      console.error(`Failed to fetch ${itemType} data`);
    }
  };

  return (
    <div className="mx-auto">
      <Card collapsible defaultCollapsed={false} className="shadow-md">
        <CardHeader></CardHeader>
        <CardContent>
          <Form {...form}>
            <form onSubmit={form.handleSubmit(onSubmit)}>
              <div className="grid grid-flow-row grid-cols-1 items-start gap-x-8 gap-y-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
                {/* Row 1 */}
