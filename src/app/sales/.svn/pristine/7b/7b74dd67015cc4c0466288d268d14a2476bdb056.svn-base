"use client";

import { PDFDownloadLink, PDFViewer } from "@react-pdf/renderer";
import { ColumnDef } from "@tanstack/react-table";
import { endOfMonth, startOfMonth } from "date-fns";
import { CalendarIcon } from "lucide-react";
import moment from "moment";
import React, { useEffect, useRef, useState } from "react";
import { UseFormReturn } from "react-hook-form";
import { FaMagnifyingGlass } from "react-icons/fa6";

import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import DropdownTable from "@/components/data-table/DropdownTable";
import ReportPreviewButton from "@/components/form/ActionButton/ReportPreview";
import SalesReport from "@/components/templates/sales/salesReportTemplate";
import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
  AlertDialogTrigger,
} from "@/components/ui/alert-dialog";
import { Button, buttonVariants } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import { Checkbox } from "@/components/ui/checkbox";
import {
  Dialog,
  DialogClose,
  DialogContent,
  DialogFooter,
  DialogTitle,
} from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { useToast } from "@/components/ui/use-toast";
import { DATE_FORMAT, getAuthHeaders, ORIGIN } from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

import {
  salesPriceHistory,
  salesPriceHistoryColumns,
  SalesPriceHistoryReport,
} from "../Generate/columns";

interface SalesPriceHistoryReport {
  id: string;
  name: string;
}

type DropdownConfig = {
  tableName: string;
  columns: { accessorKey: string; header: string; cell? }[];
  valueField: string;
  displayField: string;
  formValueField: string;
  formDisplayField: string;
  additionalMappings?: { sourceField: string; targetFormField: string }[];
};

// Base props interface
interface BaseSalesPriceHistoryReportFormProps {
  form: UseFormReturn<any>;
  onSubmit: (data: any) => void;
  onPreview?: (data: any, isGenerated?: boolean) => void;
  previewPDF?: any;
  salesReportData?: any;
  generatedReport?: any;
  setSorting?: (s: SortingState) => void;
}

// Component props interface
interface SalesPriceHistoryReportFormProps extends BaseSalesPriceHistoryReportFormProps {
  salesReportColumns?: ColumnDef<SalesPriceHistoryReport>[];
  filterFields?: string[];
  sorting?: any;
}

const salesPriceHistoryReportListingList = [
  { id: "salesPriceHistoryReportListing", name: "Sales Price History Listing" },
  {
    id: "salesPriceHistoryReportListingLv2",
    name: "Sales Customer Price History Listing - Level 2",
  },
];

export default function SalesPriceHistoryReportForm({
  form,
  onSubmit,
  onPreview,
  previewPDF,
  salesReportData,
  salesReportColumns = [],
  generatedReport,
  setSorting,
  filterFields,
  sorting,
}: SalesPriceHistoryReportFormProps) {
  const headers = getAuthHeaders();
  const { toast } = useToast();
  const systemAccount = JSON.parse(localStorage.getItem("system-account"));
  const values = form.getValues();
  const [dropdownState, setDropdownState] = useState({
    currentDropdown: null as string | null,
    data: [] as any[],
    originalData: [] as any[],
    showTable: false,
  });

  const dropdownInputRef = useRef(null);
  const dropdownTableRef = useRef(null);
  const [isAlertOpen, setIsAlertOpen] = useState(false);
  const [activePreviewColumns, setActivePreviewColumns] =
    useState<ColumnDef<any>[]>(salesReportColumns);
  const [selectedReportList, setSelectedReportList] = useState(salesPriceHistoryReportListingList);

  // const [showPriceHistoryOptionDialog, setShowPriceHistoryOptionDialog] = useState(false);
  // const [showOptionDialog,setShowOptionDialog] = useState(false);
  // const [showOptionDialog2,setShowOptionDialog2] = useState(false);

  const dropdownConfigs: Record<string, DropdownConfig> = {
    customer: {
      tableName: "customer",
      columns: [
        { accessorKey: "customerCode", header: "Customer Code" },
        { accessorKey: "customerGroupCode", header: "Customer Group" },
        { accessorKey: "customerName", header: "Customer Name" },
      ],
      valueField: "UUID",
      displayField: "customerName",
      formValueField: "customerCode",
      formDisplayField: "customerCodeCode",
    },
    stock: {
      tableName: "stock",
      columns: [
        { accessorKey: "stock", header: "Stock Name" },
        { accessorKey: "stockCode", header: "Stock Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "stock",
      formValueField: "stockItem",
      formDisplayField: "stockName",
    },
    stockGroup: {
      tableName: "stockGroup",
      columns: [
        { accessorKey: "stockGroup", header: "Stock Group Name" },
        { accessorKey: "stockGroupCode", header: "Stock Group Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "stockGroup",
      formValueField: "stockGroup",
      formDisplayField: "stockGroupName",
    },
    service: {
      tableName: "service",
      columns: [
        { accessorKey: "serviceName", header: "Service Name" },
        { accessorKey: "serviceCode", header: "Service Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "serviceName",
      formValueField: "serviceItem",
      formDisplayField: "serviceName",
    },
    serviceGroup: {
      tableName: "serviceGroup",
      columns: [
        // { accessorKey: "serviceGroupName", header: "Service Group Name" },
        { accessorKey: "serviceGroupCode", header: "Service Group Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "serviceGroupCode",
      formValueField: "serviceGroup",
      formDisplayField: "serviceGroupName",
    },
  };

  const handleClickOutside = (event: MouseEvent) => {
    if (
      dropdownTableRef.current &&
      !dropdownTableRef.current.contains(event.target) &&
      dropdownInputRef.current !== event.target
    ) {
      setDropdownState((prev) => ({ ...prev, showTable: false }));
    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);
    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);

  const fetchDropdownData = async (dropdownKey: string) => {
    try {
      const config = dropdownConfigs[dropdownKey];

      if (!config) return;

      const form_data = new FormData();

      form_data.append(`table[0]`, config.tableName);

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
        method: "POST",
        headers,
        body: form_data,
      });

      if (!response.ok) {
        throw new Error(`Failed to fetch ${dropdownKey} data`);
      }

      const data = await response.json();

      setDropdownState({
        currentDropdown: dropdownKey,
        data: data.rows,
        originalData: data.rows,
        showTable: true,
      });
    } catch (error) {
      console.error(`Error fetching ${dropdownKey} data:`, error);

      throw new Error(`Failed to fetch ${dropdownKey} data`);
    }
  };

  const onClickRow = (row: any) => {
    const config = dropdownConfigs[dropdownState.currentDropdown!];

    if (config) {
      form.setValue(config.formValueField, row[config.valueField]);
      form.setValue(config.formDisplayField, row[config.displayField]);

      if (config.additionalMappings) {
        config.additionalMappings.forEach((mapping) => {
          if (row[mapping.sourceField]) {
            form.setValue(mapping.targetFormField, row[mapping.sourceField]);
          }
        });
      }
    }

    setDropdownState((prev) => ({ ...prev, showTable: false }));
  };

  const handleReset = () => {
    form.reset({
      customerCode: "",
      customerCodeCode: "",
      stockItem: "",
      stockName: "",
      stockGroupCode: "",
      stockGroupName: "",
      serviceItem: "",
      serviceName: "",
      serviceGroupCode: "",
      serviceGroupName: "",
      startDate: Math.floor(startOfMonth(new Date()).getTime() / 1000).toString(),
      endDate: (() => {
        const end = endOfMonth(new Date());
        end.setHours(23, 59, 59, 999);
        return Math.floor(end.getTime() / 1000).toString();
      })(),
      itemType: "",
      docNo: "",
      docDate: "",
      itemCode: "",
      customerName: "",
      quantity: "",
      itemUOM: "",
      price: "",
      totalDiscountAmount: "",
      subtotalTax: "",
      valid: "1",
    });
    // Reset field visibility to default
    setShowStockFields(true);
    setShowServiceFields(false);
  };

  // Add function to handle Item Type changes
  const handleItemTypeChange = (value: string) => {
    form.setValue("itemType", value);

    if (value === "Stock") {
      setShowStockFields(true);
      setShowServiceFields(false);
      // Clear service fields
      form.setValue("serviceItem", "");
      form.setValue("serviceName", "");
      form.setValue("serviceGroup", "");
      form.setValue("serviceGroupName", "");
    } else if (value === "Service") {
      setShowStockFields(false);
      setShowServiceFields(true);
      // Clear stock fields
      form.setValue("stockItem", "");
      form.setValue("stockName", "");
      form.setValue("stockGroup", "");
      form.setValue("stockGroupName", "");
    } else {
      // "All" or empty - show all fields
      setShowStockFields(true);
      setShowServiceFields(true);
    }
  };

  // Validate customer selection
  const handleSubmitWithValidation = (data: any) => {
    // if (!data.customerCodeCode) {
    //   toast({
    //     variant: "destructive",
    //     title: "Customer Required",
    //     description: "Please select a customer before generating the.",
    //     duration: 5000,
    //   });
    //   return;
    // }
    onSubmit(data);
  };

  const [showPreviewDialog, setShowPreviewDialog] = useState(false);
  const [showDialog, setShowDialog] = useState(false);
  const [reportType, setReportType] = useState("Sales Price History Report");
  const [orientation, setOrientation] = useState<"portrait" | "landscape">("portrait");
  const [isVariantAvailable, setIsVariantAvailable] = useState(false);
  const [selectedReport, setSelectedReport] = useState<any>(salesPriceHistoryReportListingList);

  const handlePreview = () => {
    if (generatedReport.length == 0) {
      setIsAlertOpen(true);
      return false;
    }
    // if (!formData.customerCodeCode) {
    //   toast({
    //     variant: "destructive",
    //     title: "Customer Required",
    //     description: "Please select a customer before generating the.",
    //     duration: 5000,
    //   });
    //   return;
    // }

    // if(values){
    //   setShowPriceHistoryOptionDialog(true);
    //   return;
    // }
    // const groupByKeys = [
    //   "groupByDocNo",
    //   "groupByDocDate",
    //   "groupByCustomerName",
    //   "groupByItemCode",
    //   "groupByItemName",
    // ];

    // const selectedCount = groupByKeys.filter((key) => values[key] === true).length;
    // if (selectedCount === 1){
    //   setShowOptionDialog(true);
    //   return;
    // }else if (selectedCount === 2){
    //   setShowOptionDialog2(true);
    //   return;
    // }

    if (onPreview) {
      // onPreview(values, false);
      if (salesReportData?.reportTypeName === "salesPriceHistoryReportListingLv2") {
        setActivePreviewColumns(salesPriceHistory);
      } else {
        setActivePreviewColumns(salesPriceHistoryColumns);
      }
      onPreview(
        {
          ...values,
          reportTypeName: selectedReport,
        },
        false,
      );
    }
    setReportType("Sales Price History Report");
    setShowPreviewDialog(false);
    setTimeout(() => {
      setShowPreviewDialog(true);
    }, 0);

    // if (onPreview) {
    //   const formData = form.getValues();
    //   onPreview(formData, false);
    //   setActivePreviewColumns(salesPriceHistoryColumns);
    // }
    // setReportType("Sales Price History Report");
    // setShowPreviewDialog(false);
    // setTimeout(() => { setShowPreviewDialog(true); }, 0);
  };

  // Add state to control popover open/close for each date field
  const [fromDateOpen, setFromDateOpen] = useState(false);
  const [toDateOpen, setToDateOpen] = useState(false);
  const [docDateOpen, setDocDateOpen] = useState(false);

  useEffect(() => {
    setSelectedReportList(salesPriceHistoryReportListingList);
  }, []);

  const checkboxToColumnId: Record<string, string> = {
    groupByDocNo: "docNo",
    groupByDocDate: "docDateFormat",
    groupByCustomerName: "customerName",
    groupByItemCode: "itemCode",
    groupByItemName: "itemName",
  };
  const handleSelectLevel0 = () => {
    const values = form.getValues();
    setActivePreviewColumns(salesPriceHistoryColumns);
    if (onPreview) {
      onPreview(values, false);
    }
    setReportType("Sales Price History Report");
    setShowPreviewDialog(false);
    setTimeout(() => {
      setShowPreviewDialog(true);
    }, 0);
  };

  const handleSelectLevel2 = () => {
    const values = form.getValues();
    setActivePreviewColumns(salesPriceHistory);
    if (onPreview) {
      onPreview(values, false);
    }
    setReportType("Sales Customer Price History - Level 2");
    setShowPreviewDialog(false);
    setTimeout(() => {
      setShowPreviewDialog(true);
    }, 0);
  };

  // Add state for field visibility
  const [showStockFields, setShowStockFields] = useState(true);
  const [showServiceFields, setShowServiceFields] = useState(false);

  const handleDropdownSearchChange = (dropdownKey: string, searchTerm: string) => {
    const config = dropdownConfigs[dropdownKey];
    if (!config) return;

    form.setValue(config.formDisplayField, searchTerm);

    if (searchTerm.trim() === "") {
      // Clear related fields: hidden UUID, and additional mappings (like supplierCode)
      form.setValue(config.formValueField, ""); // clear UUID

      if (config.additionalMappings) {
        config.additionalMappings.forEach((mapping) => {
          form.setValue(mapping.targetFormField, ""); // clear mapped fields
        });
      }

      return; // Exit early — no filtering needed
    }

    if (!dropdownState.originalData || dropdownState.currentDropdown !== dropdownKey) {
      fetchDropdownData(dropdownKey);
      return;
    }

    const filtered = dropdownState.originalData.filter((row: any) =>
      row[config.displayField]?.toString().toLowerCase().includes(searchTerm.toLowerCase()),
    );

    setDropdownState((prev) => ({
      ...prev,
      data: filtered,
      showTable: true,
      currentDropdown: dropdownKey,
    }));
  };

  return (
    <div className="mx-auto">
      <Card collapsible defaultCollapsed={false} className="shadow-sm">
        <CardHeader></CardHeader>
        <CardContent>
          <Form {...form}>
            <form onSubmit={form.handleSubmit(handleSubmitWithValidation)}>
              {/* Main Filters Section */}
              <div className="mb-4">
                <h3 className="text-md mb-2 font-semibold">Main Filters:</h3>

                <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* Doc No */}
                  <FormField
                    control={form.control}
                    name="docNo"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Doc No:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Customer Field - Hidden UUID */}
                  <FormField
                    control={form.control}
                    name="customerCode"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Customer UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Customer Field - Display */}
                  <FormField
                    control={form.control}
                    name="customerCodeCode"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Customer: </FormLabel>
                        <FormControl className="relative">
                          <div className="relative">
                            <Input
                              className="h-7.5 pr-8"
                              {...field}
                              // readOnly
                              onChange={(e) =>
                                handleDropdownSearchChange("customer", e.target.value)
                              }
                              onClick={() => fetchDropdownData("customer")}
                              ref={
                                dropdownState.currentDropdown === "customer"
                                  ? dropdownInputRef
                                  : null
                              }
                              autoComplete="off"
                            />
                            <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                              <FaMagnifyingGlass className="text-gray-400" />
                            </div>
                            {dropdownState.showTable &&
                              dropdownState.currentDropdown === "customer" && (
                                <div
                                  ref={dropdownTableRef}
                                  className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownConfigs.customer.columns}
                                      data={dropdownState.data}
                                      onClickRow={onClickRow}
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                          </div>
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Item Type */}
                  <FormField
                    control={form.control}
                    name="itemType"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Item Type:</FormLabel>
                        <Select onValueChange={handleItemTypeChange} value={field.value}>
                          <FormControl>
                            <SelectTrigger className="h-7.5">
                              <SelectValue placeholder="Select Item Type" />
                            </SelectTrigger>
                          </FormControl>
                          <SelectContent>
                            <SelectItem value="Stock">Stock</SelectItem>
                            <SelectItem value="Service">Service</SelectItem>
                          </SelectContent>
                        </Select>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Stock Item Field - Code */}
                  <FormField
                    control={form.control}
                    name="stockItem"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Stock Item UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Stock Item Field Field - Display */}
                  {showStockFields && (
                    <FormField
                      control={form.control}
                      name="stockName"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Stock: </FormLabel>
                          <FormControl className="relative">
                            <div className="relative">
                              <Input
                                className="h-7.5 pr-8"
                                {...field}
                                // readOnly
                                onChange={(e) =>
                                  handleDropdownSearchChange("stock", e.target.value)
                                }
                                onClick={() => fetchDropdownData("stock")}
                                ref={
                                  dropdownState.currentDropdown === "stock"
                                    ? dropdownInputRef
                                    : null
                                }
                                autoComplete="off"
                              />
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "stock" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.stock.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  )}

                  {/* Stock Group Field - Hidden UUID */}
                  <FormField
                    control={form.control}
                    name="stockGroup"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Stock Group UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Stock Group Field - Display */}
                  {showStockFields && (
                    <FormField
                      control={form.control}
                      name="stockGroupName"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Stock Group: </FormLabel>
                          <FormControl className="relative">
                            <div className="relative">
                              <Input
                                className="h-7.5 pr-8"
                                {...field}
                                // readOnly
                                onChange={(e) =>
                                  handleDropdownSearchChange("stockGroup", e.target.value)
                                }
                                onClick={() => fetchDropdownData("stockGroup")}
                                ref={
                                  dropdownState.currentDropdown === "stockGroup"
                                    ? dropdownInputRef
                                    : null
                                }
                                autoComplete="off"
                              />
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "stockGroup" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.stockGroup.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  )}

                  {/* Service Item Field - Code */}
                  <FormField
                    control={form.control}
                    name="serviceItem"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Service Item UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Service Item Field Field - Display */}
                  {showServiceFields && (
                    <FormField
                      control={form.control}
                      name="serviceName"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Service: </FormLabel>
                          <FormControl className="relative">
                            <div className="relative">
                              <Input
                                className="h-7.5 pr-8"
                                {...field}
                                // readOnly
                                onChange={(e) =>
                                  handleDropdownSearchChange("service", e.target.value)
                                }
                                onClick={() => fetchDropdownData("service")}
                                ref={
                                  dropdownState.currentDropdown === "service"
                                    ? dropdownInputRef
                                    : null
                                }
                                autoComplete="off"
                              />
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "service" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.service.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  )}

                  {/* Service Group Field - Hidden UUID */}
                  <FormField
                    control={form.control}
                    name="serviceGroup"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Service Group UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Service Group Field - Display */}
                  {showServiceFields && (
                    <FormField
                      control={form.control}
                      name="serviceGroupName"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Service Group: </FormLabel>
                          <FormControl className="relative">
                            <div className="relative">
                              <Input
                                className="h-7.5 pr-8"
                                {...field}
                                // readOnly
                                onChange={(e) =>
                                  handleDropdownSearchChange("serviceGroup", e.target.value)
                                }
                                onClick={() => fetchDropdownData("serviceGroup")}
                                ref={
                                  dropdownState.currentDropdown === "serviceGroup"
                                    ? dropdownInputRef
                                    : null
                                }
                                autoComplete="off"
                              />
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "serviceGroup" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.serviceGroup.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  )}
                </div>

                <div className="mt-4 grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* From Date */}
                  <FormField
                    control={form.control}
                    name="startDate"
                    render={({ field }) => (
                      <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                        <FormLabel>From Date:</FormLabel>
                        <Popover open={fromDateOpen} onOpenChange={setFromDateOpen}>
                          <PopoverTrigger asChild>
                            <FormControl>
                              <Button
                                className={cn(
                                  "flex h-7.5 w-full",
                                  !field.value && "text-muted-foreground",
                                )}
                                variant="outline"
                                size="sm"
                              >
                                {field.value
                                  ? moment.unix(field.value).format(DATE_FORMAT)
                                  : moment().format(DATE_FORMAT)}
                                <CalendarIcon className="ml-auto h-4 w-4 text-gray-400" />
                              </Button>
                            </FormControl>
                          </PopoverTrigger>
                          <PopoverContent className="w-auto p-0" align="start">
                            <Calendar
                              mode="single"
                              selected={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                              onSelect={(date) => {
                                const unixTimestamp = date
                                  ? Math.floor(date.getTime() / 1000)
                                  : Math.floor(Date.now() / 1000);
                                field.onChange(unixTimestamp.toString());
                                setFromDateOpen(false);
                              }}
                              initialFocus
                              defaultMonth={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                            />
                          </PopoverContent>
                        </Popover>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* To Date */}
                  <FormField
                    control={form.control}
                    name="endDate"
                    render={({ field }) => (
                      <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                        <FormLabel>To Date:</FormLabel>
                        <Popover open={toDateOpen} onOpenChange={setToDateOpen}>
                          <PopoverTrigger asChild>
                            <FormControl>
                              <Button
                                className={cn(
                                  "flex h-7.5 w-full",
                                  !field.value && "text-muted-foreground",
                                )}
                                variant="outline"
                                size="sm"
                              >
                                {field.value
                                  ? moment.unix(field.value).format(DATE_FORMAT)
                                  : moment().format(DATE_FORMAT)}
                                <CalendarIcon className="ml-auto h-4 w-4 text-gray-400" />
                              </Button>
                            </FormControl>
                          </PopoverTrigger>
                          <PopoverContent className="w-auto p-0" align="start">
                            <Calendar
                              mode="single"
                              selected={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                              onSelect={(date) => {
                                const endOfDay = date ? new Date(date) : new Date();
                                endOfDay.setHours(23, 59, 59, 999);
                                const unixTimestamp = Math.floor(endOfDay.getTime() / 1000);
                                field.onChange(unixTimestamp.toString());
                                setToDateOpen(false);
                              }}
                              initialFocus
                              defaultMonth={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                            />
                          </PopoverContent>
                        </Popover>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>
              </div>

              {/* Separator Line */}
              <hr className="my-6 border-gray-300" />

              {/* Column Filters Section */}
              <div className="mb-4">
                <h3 className="text-md mb-2 font-semibold">Column Filters:</h3>

                <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* Doc Date */}
                  <FormField
                    control={form.control}
                    name="docDate"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Doc Date:</FormLabel>
                        <Popover open={docDateOpen} onOpenChange={setDocDateOpen}>
                          <PopoverTrigger asChild>
                            <FormControl>
                              <Button
                                className={cn(
                                  "flex h-7.5 w-full",
                                  !field.value && "text-muted-foreground",
                                )}
                                variant="outline"
                                size="sm"
                              >
                                {field.value ? moment.unix(field.value).format(DATE_FORMAT) : ""}
                                <CalendarIcon className="ml-auto h-4 w-4 text-gray-400" />
                              </Button>
                            </FormControl>
                          </PopoverTrigger>
                          <PopoverContent className="w-auto p-0" align="start">
                            <Calendar
                              mode="single"
                              selected={field.value ? moment.unix(field.value).toDate() : undefined}
                              onSelect={(date) => {
                                if (date) {
                                  const unixTimestamp = Math.floor(date.getTime() / 1000);
                                  field.onChange(unixTimestamp.toString());
                                } else {
                                  field.onChange("");
                                }
                                setDocDateOpen(false);
                              }}
                              initialFocus
                              defaultMonth={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                            />
                          </PopoverContent>
                        </Popover>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Item Code */}
                  <FormField
                    control={form.control}
                    name="itemCode"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Item Code:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Customer */}
                  <FormField
                    control={form.control}
                    name="customerName"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Customer:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Quantity */}
                  <FormField
                    control={form.control}
                    name="quantity"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Quantity:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5 text-right" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* UOM */}
                  <FormField
                    control={form.control}
                    name="itemUOM"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>UOM:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>

                <div className="mt-4 grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* Unit Price */}
                  <FormField
                    control={form.control}
                    name="price"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Unit Price:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5 text-right" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Discount */}
                  <FormField
                    control={form.control}
                    name="totalDiscountAmount"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Discount:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5 text-right" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Subtotal */}
                  <FormField
                    control={form.control}
                    name="subtotalTax"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Subtotal:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5 text-right" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>
              </div>

              {/* Group/Sort By */}
              {/* <hr className="Border-gray-300 my-6" />
              <FormLabel className="text-base font-semibold text-black-700">Group / Sort Options:</FormLabel>
              <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 mt-3">
                  
                  <FormField
                    control={form.control}
                    name="groupByDocNo"
                    render={({ field }) => (
                      <FormItem className="flex flex-row items-start space-x-3 space-y-0">
                        <FormControl>
                          <Checkbox
                            checked={field.value}
                            // onCheckedChange={field.onChange}
                            onCheckedChange={(v) => {
                              const checked = !!v;
                              field.onChange(checked);
                              setSorting?.((prev: any) => {
                                const currentSorting = Array.isArray(prev) ? prev : [];
                                const columnId = checkboxToColumnId["groupByDocNo"]; 

                                if (checked) {
                                  const asc = !!form.getValues().sortAscending;
                                  return [...currentSorting, { id: columnId, desc: asc }];
                                } else {
                                  return currentSorting.filter((item) => item.id !== columnId);
                                }
                              });
                            }}
                          />
                        </FormControl>
                        <div className="space-y-1 leading-none">
                          <FormLabel className="font-normal cursor-pointer">
                            Doc No
                          </FormLabel>
                      </div>
                      </FormItem>
                    )}
                  /> */}

              {/* Buttons */}
              <div className="mr-16 mt-6 flex flex-row justify-center space-x-4">
                <Button
                  type="button"
                  className="erp-blue-12 w-28 text-white hover:bg-blue-800"
                  onClick={form.handleSubmit(handleSubmitWithValidation)}
                >
                  Generate
                </Button>
                <Button
                  type="button"
                  className="erp-blue-12 w-28 text-white hover:bg-blue-800"
                  // onClick={handlePreview}
                  onClick={() => {
                    if (generatedReport.length == 0) {
                      setIsAlertOpen(true);
                      return false;
                    }
                    setIsVariantAvailable(true);
                  }}
                >
                  Preview
                </Button>
                <Button
                  type="button"
                  className="erp-blue-12 w-28 text-white hover:bg-blue-800"
                  onClick={handleReset}
                >
                  Reset
                </Button>
                {systemAccount === "dev" || systemAccount === "infollectivetesting" ? (
                  <>
                    <ReportPreviewButton
                      form={form}
                      formData={values}
                      previewType={"PRICING HISTORY"}
                      docType={"all"}
                      reportType={"pricingHistory"}
                      modelType={"sales"}
                      filterFields={filterFields}
                      sorting={sorting}
                      generatedReport={generatedReport}
                      setIsAlertOpen={setIsAlertOpen}
                      showPreviewDialog={showDialog}
                      setShowPreviewDialog={setShowDialog}
                      sortBy={"createdAt"}
                    />
                  </>
                ) : null}
              </div>
            </form>
          </Form>
        </CardContent>
      </Card>

      <Dialog open={isVariantAvailable} onOpenChange={setIsVariantAvailable}>
        <DialogContent className="max-w-l rounded-md bg-white p-6">
          <Form {...form}>
            <form className="space-y-4" onSubmit={(e) => e.preventDefault()}>
              <h2 className="text-center text-lg font-semibold">Select Report</h2>

              <div className="h-[160px] overflow-auto border border-gray-300 bg-white">
                {selectedReportList?.map((report) => (
                  <div
                    key={report.id}
                    onClick={() => setSelectedReport(report.id)}
                    className={`cursor-pointer px-3 py-1 text-sm
            hover:bg-blue-100
            ${selectedReport === report.id ? "bg-blue-600 text-white" : ""}`}
                  >
                    {report.name}
                  </div>
                ))}
              </div>

              <div className="mt-[10px] flex justify-center gap-4 p-10">
                <Button
                  type="button"
                  variant="ghost"
                  onClick={() => setIsVariantAvailable(false)}
                  className="h-10 w-40 bg-erp-blue-14 text-white hover:bg-erp-blue-13 hover:text-white"
                >
                  Cancel
                </Button>
                <Button
                  type="button"
                  onClick={handlePreview}
                  className="h-10 w-40 border border-erp-blue-14 bg-white text-erp-blue-14"
                >
                  OK
                </Button>
              </div>
            </form>
          </Form>
        </DialogContent>
      </Dialog>

      {/* Preview Dialog */}
      <Dialog open={showPreviewDialog} onOpenChange={setShowPreviewDialog}>
        <DialogContent className="max-w-6xl">
          <DialogTitle className="flex items-center justify-between">
            <span>{reportType} - Report Preview</span>
            <div className="flex items-center gap-2">
              <span className="text-sm text-gray-600">Orientation:</span>
              <Button
                type="button"
                variant={orientation === "portrait" ? "default" : "outline"}
                size="sm"
                onClick={() => setOrientation("portrait")}
                className="h-8 px-3"
              >
                Portrait
              </Button>
              <Button
                type="button"
                variant={orientation === "landscape" ? "default" : "outline"}
                size="sm"
                onClick={() => setOrientation("landscape")}
                className="h-8 px-3"
              >
                Landscape
              </Button>
            </div>
          </DialogTitle>
          <div className="relative h-[550px] w-full">
            {previewPDF ? (
              <PDFViewer width="100%" height="100%" className="absolute inset-0">
                <SalesReport
                  type={reportType}
                  data={previewPDF}
                  salesReportData={salesReportData}
                  salesReportColumns={activePreviewColumns}
                  generatedReport={generatedReport}
                  orientation={orientation}
                />
              </PDFViewer>
            ) : (
              <div className="flex h-full items-center justify-center">
                <p className="animate-pulse text-lg">
                  Loading preview
                  <span className="ml-1 inline-block">
                    <span>. </span>
                    <span className="animation-delay-200">. </span>
                    <span className="animation-delay-400">.</span>
                  </span>
                </p>
              </div>
            )}
          </div>

          <DialogFooter className="flex !justify-center gap-x-2">
            <PDFDownloadLink
              document={
                <SalesReport
                  type={reportType}
                  data={previewPDF}
                  salesReportData={salesReportData}
                  salesReportColumns={activePreviewColumns}
                  generatedReport={generatedReport}
                  orientation={orientation}
                />
              }
              fileName={`${previewPDF?.currentCompany?.company || ""} - ${reportType} ${orientation}.pdf`}
              className={cn(buttonVariants({ variant: "default" }), "mt-2 sm:mt-0")}
            >
              {({ loading }) => (loading ? "Preparing..." : "Download PDF")}
            </PDFDownloadLink>
            <DialogClose
              className={cn(buttonVariants({ variant: "outline" }), "mt-2 sm:mt-0")}
              onClick={() => setShowPreviewDialog(false)}
            >
              Close
            </DialogClose>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Option Dialog */}

      {/* <Dialog open={showPriceHistoryOptionDialog} onOpenChange={setShowPriceHistoryOptionDialog}>
        <DialogContent className="max-w-md">
          <DialogTitle>Select Report</DialogTitle>
          <div className="flex flex-col gap-4 py-4">
            <Button
              variant="outline"
              className="w-full justify-start text-left h-auto py-3 px-4 border-erp-blue-10 hover:bg-erp-blue-1 hover:text-erp-blue-10"
              onClick={handleSelectLevel0}>
              Sales Price History Report
            </Button>            
            <Button
              variant="outline"
              className="w-full justify-start text-left h-auto py-3 px-4 border-erp-blue-10 hover:bg-erp-blue-1 hover:text-erp-blue-10"
              onClick={handleSelectLevel2}>
              Sales Customer Price History - Level 2
            </Button>
          </div>
          <DialogFooter>
            <Button variant="ghost" onClick={() => setShowPriceHistoryOptionDialog(false)}>
              Cancel
            </Button>
          </DialogFooter>
        </DialogContent>  
      </Dialog> */}

      <AlertDialog open={isAlertOpen} onOpenChange={setIsAlertOpen}>
        <AlertDialogContent className="max-w-sm">
          <div className="flex flex-col items-center gap-2">
            <p className="text-md text-center text-erp-blue-14">kindly generate first.</p>
          </div>
          <AlertDialogFooter className="mt-2 flex items-center !justify-center justify-center gap-3 [&>*]:m-0">
            <AlertDialogAction className="h-9 w-24" autoFocus onClick={() => setShowDialog(false)}>
              Close
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </div>
  );
}
