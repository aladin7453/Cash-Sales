import { useRouter } from "next/navigation";
import { FaObjectUngroup } from "react-icons/fa6";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  isDisabled: boolean;
  destination: string;
};

const AuthorizedLocationButton = <TData,>({ table, isDisabled, destination }: Props<TData>) => {
  const router = useRouter();
  const selectedRows = table.getSelectedRowModel().rows;

  const handleClick = () => {
    if (selectedRows.length > 0) {
      const selectedRow = selectedRows[0].original.UUID;
      router.push(`${destination}?id=${selectedRow}`);
    }
  };

  return (
    <button
      onClick={handleClick}
      disabled={isDisabled}
      className="group flex flex-col items-center gap-y-1 disabled:cursor-not-allowed"
      aria-label="Authorized Location"
    >
      <FaObjectUngroup
        className={`size-5.5 ${isDisabled ? "text-erp-gray-5" : "text-erp-blue-11"}`}
      />
      <span
        className={`text-[11px]/none font-medium ${isDisabled ? "text-erp-gray-5" : "text-black"}`}
      >
        Auth
      </span>
    </button>
  );
};

export default AuthorizedLocationButton;
