"use client";

import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import type { ColumnDef } from "@tanstack/react-table";

export type CustomInformation = {
  UUID: string;
  customerTag: string;
  fieldName: string;
  fieldValue: string | null;
  attachment: string | null;
  description: string | null;
  valid: string; // API returns "1" or "0" as strings
  createdAt: string;
  createdBy: string;
  updatedAt: string | null;
  updatedBy: string | null;
  _actionUUID: string;
  _version: string;
  attachmentLink?: Array<{ name: string; link: string }>;
  attachmentFiles?: Array<{ name: string }>;
};

export const customInformationColumns: ColumnDef<CustomInformation>[] = [
  {
    id: "fieldName",
    accessorKey: "fieldName",
    header: "Field Name",
    filterFn: "includesString",
  },
  {
    id: "fieldValue",
    accessorKey: "fieldValue",
    header: "Field Value",
    filterFn: "includesString",
  },
  {
    id: "attachment",
    accessorKey: "attachment",
    header: "Attachment (.pdf, .png, .jpg, .jpeg)",
    cell: ({ row }) => {
      const attachment = row.original.attachment;
      const attachmentLinks = row.original.attachmentLink || [];
      const attachmentFiles = row.original.attachmentFiles || [];

      // Handle new records with attachmentFiles
      if (attachmentFiles.length > 0) {
        return attachmentFiles
          .map((file, index) => <span key={index}>{file.name}</span>)
          .reduce(
            (prev, curr, index) => (index === 0 ? [curr] : [prev, ", ", curr]),
            []
          );
      }

      // Handle existing records with attachment JSON
      if (!attachment) {
        return <span>No attachment</span>;
      }

      try {
        const attachments = JSON.parse(attachment);

        if (!attachments || attachments.length === 0) {
          return <span>No attachment</span>;
        }

        return attachments
          .map((att, index) => {
            const link = attachmentLinks.find((al) => al.name === att.Name);
            return link ? (
              <a
                key={index}
                href={link.link}
                target="_blank"
                rel="noopener noreferrer"
                style={{ color: "blue" }}
              >
                {att.Name}
              </a>
            ) : (
              <span key={index}>{att.Name}</span>
            );
          })
          .reduce((prev, curr) => [prev, ", ", curr]);
      } catch (error) {
        return <span>No attachment</span>;
      }
    },
    filterFn: "includesString",
  },
  {
    id: "valid",
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as string;
      return validity === "1" ? "Valid" : "Invalid";
    },
    filterFn: filterWithStringConversion,
  },
];
