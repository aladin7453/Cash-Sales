                    <FormItem>
                      <FormControl>
                        <TextEditorInline
                          value={field.value || ""}
                          onChange={(val) => field.onChange(val)}
                          className="h-[180px]"
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </TabPanel>
            </div>
          </Tabs >

          <h1 className="mt-3 font-bold uppercase text-black">File Attachment</h1>

          <div className="w-full h-full flex flex-col gap-y-2">
            {/* Upload Area */}
            <label
              htmlFor="attachments"
              className="w-full h-[200px] flex flex-col items-center justify-center gap-y-3 rounded-md border-2 border-dashed border-gray-300 bg-white px-6 shadow-sm transition-colors duration-200 hover:border-blue-400"
            >
              <BsFileEarmarkPdf className="size-7 text-gray-500" />
              <span className="text-[13px] font-normal text-gray-500">
                Click to upload file
              </span>
              <Input
                id="attachments"
                type="file"
                multiple
                onChange={handleFileChange}
                ref={fileInputRef}
                className="hidden"
              />
            </label>

            {/* File List */}
            {tempRowAttachments?.length > 0 && (
              <ScrollArea className="h-full flex-1 px-2">
                {tempRowAttachments.map((file, index) => (
                  <div className="flex min-w-0 items-center gap-x-1.5 py-1" key={index}>
                    <a
                      href={file.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="truncate text-[13px] text-blue-600 hover:text-blue-800 hover:underline"
                      title={file.name}
                    >
                      {file.name}
                    </a>

                    <button
                      type="button"
                      onClick={() => handleDeleteFile(index)}
                      className="flex-shrink-0 text-red-500 transition-all duration-300 ease-in-out hover:text-red-700"
                    >
                      <MdDelete className="size-5.5" title="Remove" />
                    </button>
                  </div>
                ))}
              </ScrollArea>
            )}
          </div>
        </div >
      </>
    )
  }

  return (
    <Card className={isExpand ? "hidden" : "w-full shadow-sm"}>
      <CardContent className="px-1.5 py-1">
        <Form {...form}>
          <form>
            {/* Tab Section*/}
            <Tabs className="flex w-full flex-col">
              <TabList className="flex">
                {["Document", "Other", "Remarks", "Attachment"].map((label) => (
                  <Tab
                    key={label}
                    className="cursor-pointer rounded-tl-md rounded-tr-md border-[1px] border-gray-200 bg-transparent px-2 py-1 text-[12px] text-black outline-none transition-all duration-300 ease-in-out"
                    selectedClassName="!bg-blue-300 border-blue-300 text-white"
                  >
                    {label}
                  </Tab>
                ))}
              </TabList>

              {/* Tab Document Details */}
              <TabPanel
                forceRender
                className="mt-0 hidden p-0"
                selectedClassName="react-tabs__tab-panel--selected"
