                                      onClick={() => fetchDropdownData("salesAgent")}
                                      ref={
                                        dropdownState.currentDropdown === "salesAgent"
                                          ? dropdownInputRef
                                          : null
                                      }
                                      autoComplete="off"
                                      placeholder="Sales Agent"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent side="top" align="start">
                                    Sales Agent
                                  </TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2.5">
