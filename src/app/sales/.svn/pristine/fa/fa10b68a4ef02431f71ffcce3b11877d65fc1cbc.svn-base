                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Job History</div>
                </div>

                <div className="flex flex-col gap-y-2.5 pt-1.5">
                  {/* First Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Estimated Working Hour */}
                    <FormField
                      control={form.control}
                      name="estimateMinute"
                      render={({ field }) => (
                        <FormItem className="flex-1">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Estimated Working Hour"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Estimated Working Hour</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Actual Working Hour */}
                    <FormField
                      control={form.control}
                      name="actualWorkingMinute"
                      render={({ field }) => (
                        <FormItem className="flex-1">
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                    {...field}
                                    readOnly
                                    placeholder="Actual Working Hour"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Actual Working Hour</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Second Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Assigned At */}
                    <FormField
                      control={form.control}
                      name="assignedAtFormat"
                      render={({ field }) => (
                        <FormItem className="flex-1">
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                    {...field}
                                    readOnly
                                    placeholder="Assigned At"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Assigned At</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Assigned By */}
                    <FormField
                      control={form.control}
                      name="assignedByFullName"
                      render={({ field }) => (
                        <FormItem className="flex-1">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Assigned By"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Assigned By</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Third Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Started At */}
                    <FormField
                      control={form.control}
                      name="startedAtFormat"
                      render={({ field }) => (
                        <FormItem className="flex flex-1 flex-col">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Started At"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Started At</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Started By */}
                    <FormField
                      control={form.control}
                      name="startedByFullName"
                      render={({ field }) => (
                        <FormItem className="flex flex-1 flex-col">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Started By"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Started By</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Fourth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Picked up At */}
                    <FormField
                      control={form.control}
                      name="pickedUpAtFormat"
                      render={({ field }) => (
                        <FormItem className="flex flex-1 flex-col">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Picked up At"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Picked up At</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Picked up By */}
                    <FormField
                      control={form.control}
                      name="pickedUpByFullName"
                      render={({ field }) => (
                        <FormItem className="flex flex-1 flex-col">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Picked up By"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Picked up By</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Fifth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Delivered At */}
                    <FormField
                      control={form.control}
                      name="deliveredAtFormat"
                      render={({ field }) => (
                        <FormItem className="flex flex-1 flex-col">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Delivered At"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Delivered At</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Delivered By */}
                    <FormField
                      control={form.control}
                      name="deliveredByFullName"
                      render={({ field }) => (
                        <FormItem className="flex flex-1 flex-col">
                          <FormControl className="relative">
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 text-[11px] px-2 bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                                      {...field}
                                      readOnly
                                      placeholder="Delivered By"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Delivered By</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>
                </div>
              </TabPanel>
            </div>

            {/* Right - Vertical TabList */}
            <TabList className="ml-1 flex flex-col gap-y-1">
              {[
                {
                  icon: <RiChatHistoryLine className="size-4.5" />,
                  label: "Job Assignment",
                },
                {
                  icon: <MdAssignmentTurnedIn className="size-4.5" />,
                  label: "Job History",
                }
              ].map((item, index) => (
                <Tab
                  key={index}
                  className="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-y-0.5 rounded-md border border-gray-200 bg-white text-[9px] text-gray-600 outline-none transition-all duration-200 ease-in-out"
                  selectedClassName="!bg-blue-300 border-blue-300 text-white"
                >
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <span className="flex h-full w-full items-center justify-center">
                          {item.icon}
                        </span>
                      </TooltipTrigger>

                      <TooltipContent side="right" align="start">
                        {item.label}
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </Tab>
              ))}
            </TabList>
          </Tabs>
        </form>
      </Form>
    </>
  );
}
