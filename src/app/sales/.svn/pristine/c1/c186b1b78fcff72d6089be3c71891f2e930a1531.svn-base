  // Column Drag and Drop and Resize (Unified Drag Handler for Both Rows and Columns)
  const handleUnifiedDragEnd = (event) => {
    const { active, over } = event;

    if (!over || active.id === over.id) return;

    // Check if it's a column drag (column IDs are simple strings like "docNo", "description")
    const isColumnDrag = columnOrder.includes(active.id as string);

    if (isColumnDrag) {
      // Handle column drag
      handleDndDragEnd(event, setColumnOrder);
    } else {
      // Handle row drag
      handleDragEnd(event);
    }
  };

  // Three Discount (Row Calculations)
  // Real-Time Total Calculations (Calculation Function)
  const calculateRowValues = (rowData: any, rowIndex: number) => {
    // Multi-UOM Calculation Logic - multiply all quantities with price
    const quantity1 = rowData.quantity ? Number(rowData.quantity) : 0;
    const quantity2 = rowData.quantity2
      ? Number(rowData.quantity2)
      : rowData.type == "Stock"
        ? 1
        : rowData.quantity2 === 0
          ? 0
          : 1;
    const quantity3 = rowData.quantity3
      ? Number(rowData.quantity3)
      : rowData.type == "Stock"
        ? 1
        : rowData.quantity3 === 0
          ? 0
          : 1;

    const price = rowData.price ? Number(rowData.price) : 0;

    // Calculate total amount: Quantity1 × Quantity2 × Quantity3 × Price
    const totalAmount =
      (quantity1 ?? (rowData.type === "Stock" ? 1 : rowData.quantity === 0 ? 0 : 1)) *
      (quantity2 ?? (rowData.type === "Stock" ? 1 : rowData.quantity2 === 0 ? 0 : 1)) *
      (quantity3 ?? (rowData.type === "Stock" ? 1 : rowData.quantity3 === 0 ? 0 : 1)) *
      price;

    // Helper function to calculate discount amount from rate
    const calculateDiscountAmount = (rate: number, baseAmount: number) => {
      return (baseAmount * rate) / 100;
    };

    // Helper function to calculate discount rate from amount
    const calculateDiscountRate = (amount: number, baseAmount: number) => {
      return baseAmount > 0 ? (amount * 100) / baseAmount : 0;
    };

    // 3-tier discount calculation - preserve amounts when both rate and amount exist
    let currentAmount = totalAmount;
    let totalDiscountAmount = 0;

    // First discount - preserve existing amount if it exists
    if (rowData.discountAmount && Number(rowData.discountAmount) > 0) {
      // Use existing amount, calculate rate if needed
      if (!rowData.discountRate || Number(rowData.discountRate) === 0) {
        rowData.discountRate = calculateDiscountRate(
          Number(rowData.discountAmount),
          currentAmount,
        ).toFixed(2);
      }
      if (slug == "transfer-to" || slug == "transfer-from") {
        if (!rowData.fullQuantityTransfer) {
          rowData.discountAmount = calculateDiscountAmount(
            Number(rowData.discountRate),
            currentAmount,
          ).toFixed(2);
        }

      }
    } else if (rowData.discountRate && Number(rowData.discountRate) > 0) {
      // Calculate amount from rate
      rowData.discountAmount = calculateDiscountAmount(
        Number(rowData.discountRate),
        currentAmount,
      ).toFixed(2);
    }

    const discountAmount1 = Number(rowData.discountAmount) || 0;

    currentAmount -= discountAmount1;
    totalDiscountAmount += discountAmount1;

    // Second discount - preserve existing amount if it exists
    if (rowData.discountAmount2 && Number(rowData.discountAmount2) > 0) {
      // Use existing amount, calculate rate if needed
      if (!rowData.discountRate2 || Number(rowData.discountRate2) === 0) {
        rowData.discountRate2 = calculateDiscountRate(
          Number(rowData.discountAmount2),
          currentAmount,
        ).toFixed(2);
      }
      if (slug == "transfer-to" || slug == "transfer-from") {
        if (!rowData.fullQuantityTransfer) {
          rowData.discountAmount2 = calculateDiscountAmount(
            Number(rowData.discountRate2),
            currentAmount,
          ).toFixed(2);
        }

      }
    } else if (rowData.discountRate2 && Number(rowData.discountRate2) > 0) {
      // Calculate amount from rate
      rowData.discountAmount2 = calculateDiscountAmount(
        Number(rowData.discountRate2),
        currentAmount,
      ).toFixed(2);
    }

    const discountAmount2 = Number(rowData.discountAmount2) || 0;

    currentAmount -= discountAmount2;
    totalDiscountAmount += discountAmount2;

    // Third discount - preserve existing amount if it exists
    if (rowData.discountAmount3 && Number(rowData.discountAmount3) > 0) {
      // Use existing amount, calculate rate if needed
      if (!rowData.discountRate3 || Number(rowData.discountRate3) === 0) {
        rowData.discountRate3 = calculateDiscountRate(
          Number(rowData.discountAmount3),
          currentAmount,
        ).toFixed(2);
      }
      if (slug == "transfer-to" || slug == "transfer-from") {
        if (!rowData.fullQuantityTransfer) {
          rowData.discountAmount3 = calculateDiscountAmount(
            Number(rowData.discountRate3),
            currentAmount,
          ).toFixed(2);
        }

      }
    } else if (rowData.discountRate3 && Number(rowData.discountRate3) > 0) {
      // Calculate amount from rate
      rowData.discountAmount3 = calculateDiscountAmount(
        Number(rowData.discountRate3),
        currentAmount,
      ).toFixed(2);
    }

    const discountAmount3 = Number(rowData.discountAmount3) || 0;

    currentAmount -= discountAmount3;
    totalDiscountAmount += discountAmount3;

    // Helper function to safely parse tax rate
    function safeParseTaxRate(value) {
      if (!value) return 0;

      const parsed = parseFloat(value);

      return isNaN(parsed) ? 0 : parsed;
    }

    // Update tax and totals
    if (taxInclusiveStates[rowIndex] === "1") {
      rowData.amount = totalAmount;
      rowData.subTotalEInvoice = totalAmount;
      rowData.subTotal = totalAmount - totalDiscountAmount;
      rowData.taxAmount = parseFloat(
        (rowData.subTotal * (safeParseTaxRate(rowData.taxRate) / 100)).toFixed(2),
      );
      rowData.subtotalTax = rowData.subTotal;
    } else {
      rowData.amount = totalAmount;
      rowData.subTotalEInvoice = totalAmount;
      rowData.subTotal = totalAmount - totalDiscountAmount;
      rowData.taxAmount = parseFloat(
        (rowData.subTotal * (safeParseTaxRate(rowData.taxRate) / 100)).toFixed(2),
      );
      rowData.subtotalTax = rowData.subTotal + rowData.taxAmount;
    }

    // Fix: Taxable Amount = (Quantity * Price) - Discount
    rowData.taxableAmount = totalAmount - totalDiscountAmount;

    rowData.amountExclTax =
      (rowData.subTotal ? Number(rowData.subTotal) : 0) +
      (rowData.feeAmount ? Number(rowData.feeAmount) : 0);

    rowData.amountInclTax =
      (rowData.subtotalTax ? Number(rowData.subtotalTax) : 0) +
      (rowData.feeAmount ? Number(rowData.feeAmount) : 0);

    // Add local tax amount calculation using form currency rate
    const currencyRate = form.getValues("currencyRate");

    rowData.localTaxAmount = rowData.taxAmount * (currencyRate ? Number(currencyRate) : 1);

    return rowData;
  };

  // Real-Time Total Calculations (useEffect)
  useEffect(() => {
    if (tableData && tableData.length > 0) {
      tableData.forEach((row, index) => { //Voucher logic
        const minQtyStored = row.voucherMinQuantity ? row.voucherMinQuantity : ""
        if (row.voucherMinQuantity && Number(row.quantity) < Number(row.voucherMinQuantity)) {
          row.voucher = ""
          row.voucherCode = ""
          row.discountRate = ""
          row.discountAmount = ""
          row.voucherMinQuantity = ""
          const checkVoucherUsedInRows = tableData.some(row => row.voucher)
          if (row.voucherOption && row.voucherOption == "Apply to all item") {
            if (!checkVoucherUsedInRows) {
              form.setValue("voucher", "")
              form.setValue("voucherCode", "")
            }

          } else {
            form.setValue("voucher", "")
            form.setValue("voucherCode", "")
          }


          toast({
            title: "Invalid Voucher",
            description: `Minimum quantity of ${minQtyStored} is required for this voucher.`,
            variant: "destructive",
            duration: 3000,
          });
        }
      })
      const updatedData = tableData.map((rowData, index) => {
        // Accurate Currency Rate Update
        const calculatedRow = calculateRowValues({ ...rowData }, index);

        // Use fetched currency rate for local tax amount calculation
        calculatedRow.localTaxAmount = calculatedRow.taxAmount * currentCurrencyRate;

        if (Number.isNaN(calculatedRow.subtotalTax)) {
          calculatedRow.subtotalTax = 0;
        }
        if (Number.isNaN(calculatedRow.taxAmount)) {
          calculatedRow.taxAmount = 0;
        }
        if (Number.isNaN(calculatedRow.localTaxAmount)) {
          calculatedRow.localTaxAmount = 0;
        }

        return calculatedRow;
      });

      tableData.forEach((row, index) => {
        row.subtotalTax = row.subtotalTax ? Number(row.subtotalTax) : 0
        row.taxAmount = row.taxAmount ? Number(row.taxAmount) : 0
        row.localTaxAmount = row.localTaxAmount ? Number(row.localTaxAmount) : 0
      })

      // Only update if there are actual changes to prevent infinite loops
      const hasChanges = updatedData.some((newRow, index) => {
        const oldRow = tableData[index];
        return (
          newRow.subtotalTax !== oldRow.subtotalTax ||
          newRow.taxAmount !== oldRow.taxAmount ||
          newRow.localTaxAmount !== oldRow.localTaxAmount
        );
      });

      if (hasChanges) {
        setTempRowSalesInvoiceDetailsList(updatedData);
      }
    }
  }, [
    tableData,
    taxInclusiveStates,
    currentCurrencyRate, // Accurate Currency Rate Update
    tempRowSalesInvoiceDetailsList,
  ]);

  const [contextMenu, setContextMenu] = useState(null);

  const handleRowRightClick = (event, row) => {
    event.preventDefault(); // prevent browser default context menu
    if (!isPaid) {
      setContextMenu({
        mouseX: event.clientX + 2,
        mouseY: event.clientY - 6,
        rowData: row,
      });
    }
  };

  const handleCloseContextMenu = () => {
    setContextMenu(null);
  };

  const handleCloneRows = () => {
    const multipleCloneRowCopy = JSON.parse(JSON.stringify(table.getSelectedRowModel().rows));
    if (multipleCloneRowCopy.length > 0) {
      setTempRowSalesInvoiceDetailsList((prev) => {
        const newList = [...prev];
        let offset = 0; // track how many rows have been inserted to adjust index
        multipleCloneRowCopy.forEach((item2, index2) => {
          const cloneIndex = item2.index + offset;
          const cloneRow = { ...item2.original, UUID: "" };
          if (
            cloneRow.voucher &&
            cloneRow.voucherOption == "Apply to single item"
          ) {
            cloneRow.voucher = "";
            cloneRow.voucherCode = "";
            cloneRow.discountRate = "";
            cloneRow.discountAmount = "";
            cloneRow.voucherMinQuantity = "";
          }
          newList.splice(cloneIndex + 1, 0, cloneRow);
          offset += 1; // increment offset
        });
        const updatedList = newList.map((item, index) => ({
          ...item,
          seq: index + 1,
        }));
        return updatedList;
      });
    } else {
      const cloneIndex = contextMenu?.rowData.index;
      const cloneRowCopy = JSON.parse(
        JSON.stringify(tempRowSalesInvoiceDetailsList.find((item, index) => index === cloneIndex)),
      );
      setTempRowSalesInvoiceDetailsList((prev) => {
        const newList = [...prev];
        cloneRowCopy.UUID = "";
        if (cloneRowCopy.voucher && cloneRowCopy.voucherOption == "Apply to single item") {
          cloneRowCopy.voucher = ""
          cloneRowCopy.voucherCode = ""
          cloneRowCopy.discountRate = ""
          cloneRowCopy.discountAmount = ""
          cloneRowCopy.voucherMinQuantity = ""
        }
        newList.splice(cloneIndex + 1, 0, cloneRowCopy);
        const updatedList = newList.map((item, index) => ({
          ...item,
          seq: index + 1,
        }));
        return updatedList;
      });
    }
    setContextMenu(null);
  };

  // pass this object to TableBody
  const rowContextMenu = {
    handleRowRightClick,
    handleCloseContextMenu,
    contextMenu,
    handleCloneRows,
  };

  // Accurate Currency Rate Update
  const fetchCurrentCurrencyRate = async (currencyUUID?: string) => {
    try {
      const targetCurrencyUUID = currencyUUID || form.getValues("currency");
      if (!targetCurrencyUUID) {
        setCurrentCurrencyRate(1);
        return;
      }

      const formData = new FormData();
      formData.append("table[0]", "currency");

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
        method: "POST",
        headers,
        body: formData,
      });

      if (response.ok) {
        const data = await response.json();
        const currency = data.rows?.find((row) => row.UUID === targetCurrencyUUID);

        if (currency && currency.exchangeRateSales) {
          setCurrentCurrencyRate(Number(currency.exchangeRateSales));
        } else {
          setCurrentCurrencyRate(1);
        }
      } else {
        setCurrentCurrencyRate(1);
      }
    } catch (error) {
      console.error("Error fetching currency rate:", error);
      setCurrentCurrencyRate(1);
    }
  };

  // Accurate Currency Rate Update2
  const fetchCurrentCurrencyRate2 = async (currencyUUID?: string) => {
    const watchedCurrencyRate = form.getValues("currencyRate");
    watchedCurrencyRate ? setCurrentCurrencyRate(watchedCurrencyRate) : setCurrentCurrencyRate(1);
  };

  // Accurate Currency Rate Update
  useEffect(() => {
    fetchCurrentCurrencyRate2();
  }, [form.watch("currencyRate")]);

  //Selection mode
  const [isSelectionMode, setIsSelectionMode] = useState(false);

  const exitSelectionMode = useCallback(() => {
    table.resetRowSelection();
    setIsSelectionMode(false);
  }, [table]);

  return (
    <Card className={isMobile ? "shadow-none rounded-none border-none p-0" : "w-full shadow-sm mb-2"}>
      <div className="flex w-full items-center justify-between p-1">
        <CardTitle className="px-1 hidden lg:block md:hidden sm:block text-nowrap text-sm font-bold">Charges Details</CardTitle>

        <SalesInvoiceDetailsDataTableToolbar
          table={table}
          onAdd={handleOnAdd}
          setTempRowSalesInvoiceDetailsListData={setTempRowSalesInvoiceDetailsListData}
          tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
          revalidateSalesInvoiceDetails={revalidateSalesInvoiceDetails}
          handleOnPackage={handleOnPackage}
          isPaid={isPaid}
          slug={slug}
          form={form}
          isMobile={isMobile}
          isSelectionMode={isSelectionMode}
          onExitSelectionMode={exitSelectionMode}
        />

      </div>
      <CardContent className="p-0">
        <div className="flex h-[70cqh] md:h-[100cqh] flex-col justify-between rounded-md bg-erp-blue-3 @container-[size] md:max-h-[477px]">
          <ScrollArea className="flex-1 min-h-0">
            {/* Mobile View (Form Data Table) */}
            <MobileFormDataTable
              table={table}
              renderCard={(row) => {
                const isService = row.original.type === "Service";

                const uom1Label = (() => {
                  const dropdown = row.original.UOMDropdown;
                  const uomId = row.original.UOM;

                  const match = dropdown?.find((u: any) => u.UUID === uomId);

                  if (match?.UOM) return match.UOM;

                  if (isService) return "No UOM available";

                  return row.original.itemUOM || row.original.UOM || "-";
                })();

                return (
                  <div className="w-full rounded-lg border bg-white p-3 shadow-sm">
                    {/* Item Name And Stock Batch */}
                    <div className="flex items-center justify-between">
                      <div className="flex flex-col gap-y-1 w-[45%]">
                        <p className="truncate text-[16px] text-[#1E1E1E]">{row.original.itemName}</p>
                        {row.original.stockBatch?.length > 0 && (
                          <p className="truncate text-[13px] text-[#1E1E1E]">
                            {row.original.stockBatch}
                          </p>
                        )}
                      </div>
                    </div>

                    <hr className="mt-2" />

                    {/* UOM, quantity, Price And Subtotal */}
                    <div className="mt-3 flex justify-between items-end">

                      {/* Left column */}
                      <div className="flex flex-col justify-center gap-y-3">
                        <div className="flex min-w-0 items-center gap-x-2">
                          <FaBoxArchive className="shrink-0 text-[#969696] size-4" />
                          <p className="truncate text-[11px] text-[#857B7B]">
                            {uom1Label}
                          </p>
                        </div>

                        <div className="flex min-w-0 items-center gap-x-2">
                          <FiBox className="shrink-0 text-[#969696] size-4" />
                          <p className="truncate text-[11px] text-[#857B7B]">
                            {row.original.quantity ?? 0}
                          </p>
                        </div>

                        <div className="flex min-w-0 items-center gap-x-2">
                          <IoLogoUsd className="shrink-0 text-[#969696] size-4" />
                          <p className="truncate text-[11px] text-[#857B7B]">
                            {row.original.price}
                          </p>
                        </div>
                      </div>

                      {/* Right column */}
                      <div className="flex flex-col">
                        <p className="text-[11px] text-[#857B7B]">Total Amount</p>
                        <p className="break-normal text-[16px] font-medium text-[#1E1E1E]">
                          {row.original.subtotalTax ? Number(row.original.subtotalTax).toFixed(2) : "0.00"}
                        </p>
                      </div>
                    </div>
                  </div>
                );
              }}
              fieldConfigs={mobileFieldConfigs}
              onFieldChange={handleMobileFieldChange}
              checkboxHandlers={mobileCheckboxHandlers}
              UOMInputs={UOMInputs}
              setUOMInputs={setUOMInputs}
              UOM2Inputs={UOM2Inputs}
              setUOM2Inputs={setUOM2Inputs}
              UOM3Inputs={UOM3Inputs}
              setUOM3Inputs={setUOM3Inputs}
              setTempRowDetailsList={setTempRowSalesInvoiceDetailsList}
              isPaid={isPaid}
              isSelectionMode={isSelectionMode}
              onSelectionModeChange={setIsSelectionMode}
            />

            {/* Web View (Data Table) */}
            <div className="hidden md:block">
              {/* Column Drag and Drop (DnD Context) */}
              <DndContext
                collisionDetection={closestCenter}
                onDragStart={handleDragStart}
                onDragEnd={handleUnifiedDragEnd}
                sensors={sensors}
              >
                {/* Row Drag and Drop (Data Table) */}
                <DragDropDataTable items={items} disabled={false} hasParentDndContext={true}>
                  {/* Column Drag and Drop and Resize (Table) */}
                  <Table
                    className="table-fixed border-separate overflow-visible whitespace-nowrap text-[12px]"
                    style={{ ...columnSizeVars, width: table.getTotalSize() }}
                  >
                    <TableHeader className="sticky top-0 z-10">
                      {table.getHeaderGroups().map((headerGroup) => (
                        <TableRow key={headerGroup.id}>
                          {/* Column Drag and Drop and Resize (Sortable Context) */}
                          <SortableContext
                            items={columnOrder}
                            strategy={horizontalListSortingStrategy}
                          >
                            {headerGroup.headers.map((header) => (
                              // Column Drag and Drop and Resize (Dragable Table Head)
                              <DragableTableHead
                                key={header.id}
                                header={header}
                                className="bg-erp-blue-11 text-[12px]"
                                style={{
                                  width: `calc(var(--header-${header?.id}-size) * 1px)`,
                                }}
                              >
                                {header.column.id === "valid" ? (
                                  <TableHeadValidityFilter table={table} />
                                ) : (
                                  <TableHeadColumnTextFilter column={header.column} table={table} />
                                )}
                                <ColumnResizer header={header} />
                              </DragableTableHead>
                            ))}
                          </SortableContext>
                        </TableRow>
                      ))}
                    </TableHeader>
                    <>
                      {/* Column Drag and Drop and Resize (Table Body) */}
                      {table.getState().columnSizingInfo.isResizingColumn ? (
                        <MemoizedTableBody
                          table={table}
                          onRowSelection={onRowSelection}
                          rowContextMenu={rowContextMenu}
                          getRowId={getRowId}
                          refreshKey={refreshKey}
                          taxInclusiveStates={taxInclusiveStates}
                          masterServiceStates={masterServiceStates}
                          showInPDFStates={showInPDFStates}
                          handleTaxInclusiveCheckedChanged={handleTaxInclusiveCheckedChanged}
                          handleMasterServiceCheckedChanged={handleMasterServiceCheckedChanged}
                          handleShowInPDFCheckedChanged={handleShowInPDFCheckedChanged}
                          descriptionInputCell={descriptionInputCell}
                          textInputCell={textInputCell}
                          numberInputCell={numberInputCell}
                          dropDownInputCell={dropDownInputCell}
                          dateInputCell={dateInputCell}
                          UOMDropdownCell={UOMDropdownCell}
                          form={form}
                          isPaid={isPaid}
                          currentCurrencyRate={currentCurrencyRate} // Accurate Currency Rate Update
                        />
                      ) : (
                        <NonMemoizedTableBody
                          table={table}
                          onRowSelection={onRowSelection}
                          rowContextMenu={rowContextMenu}
                          getRowId={getRowId}
                          refreshKey={refreshKey}
                          taxInclusiveStates={taxInclusiveStates}
                          masterServiceStates={masterServiceStates}
                          showInPDFStates={showInPDFStates}
                          handleTaxInclusiveCheckedChanged={handleTaxInclusiveCheckedChanged}
                          handleMasterServiceCheckedChanged={handleMasterServiceCheckedChanged}
                          handleShowInPDFCheckedChanged={handleShowInPDFCheckedChanged}
                          descriptionInputCell={descriptionInputCell}
                          textInputCell={textInputCell}
                          numberInputCell={numberInputCell}
                          dropDownInputCell={dropDownInputCell}
                          dateInputCell={dateInputCell}
                          UOMDropdownCell={UOMDropdownCell}
                          form={form}
                          isPaid={isPaid}
                          currentCurrencyRate={currentCurrencyRate} // Accurate Currency Rate Update
                        />
                      )}
                    </>
                  </Table>

                  {/* CONTEXT MENU */}
                  {contextMenu && (
                    <ul
                      style={{
                        position: "fixed",
                        top: contextMenu.mouseY,
                        left: contextMenu.mouseX,
                        background: "white",
                        border: "1px solid #ccc",
                        boxShadow: "0 2px 8px rgba(0,0,0,0.15)",
                        padding: "4px 0",
                        zIndex: 1000,
                        listStyle: "none",
                      }}
                      onMouseLeave={handleCloseContextMenu}
                    >
                      <li
                        style={{ padding: "4px 12px", cursor: "pointer" }}
                        onClick={handleCloneRows}
                      >
                        Clone
                      </li>
                    </ul>
                  )}
                </DragDropDataTable>
              </DndContext>
            </div>
            <ScrollBar orientation="horizontal" />
          </ScrollArea>

          {/* Web View (Totals) */}
          <div className={isMobile ? "hidden" : "flex border-t border-border bg-white"}>
            <ScrollArea>
              <div className="flex pt-1">
                <div className="flex min-w-[85px] flex-shrink-0 flex-col gap-y-1 border-r border-border p-2.5">
                  <span className="text-[12px] text-muted-foreground">Records</span>
                  <Input
                    className="text-[13px] font-medium border-none text-left w-16 h-3 bg-transparent outline-none focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={table.getRowModel().rows ? table.getRowModel().rows.length : 0}
                  />
                </div>

                <div className="flex min-w-[85px] flex-shrink-0 flex-col gap-y-1 border-r border-border p-2.5">
                  <span className="text-[12px] text-muted-foreground ">Quantity</span>
                  <Input
                    className="text-[13px] font-medium border-none text-left w-16 h-3 bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={table.getRowModel().rows ? calculateTotal("quantity") : 0}
                  />
                </div>

                <div className="flex min-w-[100px] flex-shrink-0 flex-col gap-y-1 border-r border-border p-2.5">
                  <span className="text-[12px] text-muted-foreground">Subtotal</span>
                  <Input
                    className="text-[13px] font-medium border-none text-left w-20 h-3 bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={table.getRowModel().rows ? calculateTotal("subTotal") : 0}
                  />
                </div>

                <div className="flex min-w-[100px] flex-shrink-0 flex-col gap-y-1 border-r border-border p-2.5">
                  <span className="text-[12px] text-muted-foreground">Tax amount</span>
                  <Input
                    className="text-[13px] font-medium border-none text-left w-20 h-3 bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={table.getRowModel().rows ? calculateTotal("taxAmount") : 0}
                  />
                </div>

                <div className="flex min-w-[100px] flex-shrink-0 flex-col gap-y-1 border-r border-border p-2.5">
                  <span className="text-[12px] text-muted-foreground">Subtotal (tax)</span>
                  <Input
                    className="text-[13px] font-medium border-none text-left w-20 h-3 bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={
                      table.getRowModel().rows
                        ? formatNumber(
                          parseFloat(calculateTotal("subTotal")) +
                          parseFloat(calculateTotal("taxAmount")),
                        )
                        : 0
                    }
                  />
                </div>

                <div className="flex min-w-[170px] flex-shrink-0 flex-col gap-y-1 border-r border-border p-2.5">
                  <span className="text-[12px] text-muted-foreground">
                    Subtotal (tax) - rounding
                  </span>
                  <Input
                    className="netTotal text-[13px] font-medium border-none text-left w-20 h-3 bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={table.getRowModel().rows ? calculateNetTotal(false) : 0}
                  />
                </div>

                <div className="flex min-w-[170px] flex-shrink-0 flex-col gap-y-1 p-2.5">
                  <span className="text-[12px] text-muted-foreground">Local subtotal (tax)</span>
                  <Input
                    className="localNetTotal text-[13px] font-medium border-none text-left w-20 h-3 bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 !px-0"
                    readOnly
                    value={table.getRowModel().rows ? calculateNetTotal(true) : 0}
                  />
                </div>
              </div>
              <ScrollBar orientation="horizontal" />
            </ScrollArea>
          </div>

          <ItemPopover
            open={dialogOpen}
            setOpen={setDialogOpen}
            columns={itemType === "service" ? ServiceColumns : StockColumns}
            setTempRowSalesInvoiceDetailsListData={setTempRowSalesInvoiceDetailsListData}
            tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
            revalidateSalesInvoiceDetails={revalidateSalesInvoiceDetails}
            itemTable={itemTable}
            fetchItemData={fetchItemData}
            itemType={itemType}
            form={form}
            updateItem={updateItem}
            itemData={itemData}
            slug={slug}
            preferenceData={preferenceData}
          />

          <PackagePopover
            open={packageDialogOpen}
            setOpen={setPackageDialogOpen}
            columns={PackageColumns}
            data={packageData}
            fetchPackageData={fetchPackageData}
            revalidateSalesInvoiceDetails={revalidateSalesInvoiceDetails}
            setTempRowSalesInvoiceDetailsListData={setTempRowSalesInvoiceDetailsListData}
            tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
            slug={slug}
            preferenceData={preferenceData}
          />

          {/* Selling Price History Popover (Popover) */}
          <SellingPriceHistoryPopover
            open={priceHistoryDialogOpen}
            setOpen={setPriceHistoryDialogOpen}
            itemId={selectedItemForPriceHistory}
          // preferenceData={preferenceData}
          />

          {/* Serial Number Popover (Popover) */}
          <SerialNumberPopover
            open={serialNumberDialogOpen}
            setOpen={setSerialNumberDialogOpen}
            selectedRow={selectedRowForSerialNumber}
            setTempRowDetailsList={setTempRowSalesInvoiceDetailsList}
          />
        </div>
      </CardContent>
    </Card>
  );
}

// Column Drag and Drop and Resize (Table Body)
type TableBodyProps = {
  table: TableType<UOMList>;
  onRowSelection: (row: Row<UOMList>) => (event: MouseEvent<HTMLTableRowElement>) => void;
  rowContextMenu: (row: Row<UOMList>) => (event: MouseEvent<HTMLTableRowElement>) => void;
  getRowId: (row: any, index: number) => string;
  refreshKey: number;
  taxInclusiveStates: any;
  masterServiceStates: any;
  showInPDFStates: any;
  handleTaxInclusiveCheckedChanged: (rowIndex: number, isChecked: boolean, row: any) => void;
  handleMasterServiceCheckedChanged: (rowIndex: number, isChecked: boolean, row: any) => void;
  handleShowInPDFCheckedChanged: (rowIndex: number, isChecked: boolean, row: any) => void;
  descriptionInputCell: (cell: any, className: string) => JSX.Element;
  textInputCell: (cell: any, className: string) => JSX.Element;
  numberInputCell: (cell: any, allowDecimal: boolean) => JSX.Element;
  dropDownInputCell: (cell: any) => JSX.Element;
  dateInputCell: (cell: any) => JSX.Element;
  UOMDropdownCell: (cell: any) => JSX.Element;
  form: any;
  isPaid?: boolean;
  currentCurrencyRate: number; // Accurate Currency Rate Update
};

function NonMemoizedTableBody({
  table,
  onRowSelection,
  rowContextMenu,
  getRowId,
  refreshKey,
  taxInclusiveStates,
  masterServiceStates,
  showInPDFStates,
  handleTaxInclusiveCheckedChanged,
  handleMasterServiceCheckedChanged,
  handleShowInPDFCheckedChanged,
  descriptionInputCell,
  textInputCell,
  numberInputCell,
  dropDownInputCell,
  dateInputCell,
  UOMDropdownCell,
  form,
  isPaid,
  currentCurrencyRate, // Accurate Currency Rate Update
}: TableBodyProps) {
  return (
    <TableBody>
      {table.getRowModel().rows?.length ? (
        table.getRowModel().rows.map((row, index) => {
          return (
            // Row Drag and Drop (Row)
            <DraggableRow
              key={`${getRowId(row.original, index)}-${refreshKey}`}
              id={getRowId(row.original, index)}
              className="bg-erp-blue-5 data-[state=selected]:bg-erp-blue-9"
              onClick={onRowSelection(row)}
              onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
              data-state={row.getIsSelected() && "selected"}
              disabled={false}
            >
              {row.getVisibleCells().map((cell, cellIndex) => {
                if (cell.column.id === "taxInclusive") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      <Checkbox
                        checked={taxInclusiveStates[index] === "1"}
                        onCheckedChange={(state) =>
                          handleTaxInclusiveCheckedChanged(index, state, cell.row)
                        }
                        disabled={isPaid}
                      />
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "description" ||
                  cell.column.id === "2ndDescription" ||
                  cell.column.id === "moreDescription" ||
                  cell.column.id === "customerDescription"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {descriptionInputCell(cell, "h-7.5 p-0")}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "itemName" ||
                  cell.column.id === "permitNo" ||
                  cell.column.id === "measurement" ||
                  cell.column.id === "taxExDetails" ||
                  cell.column.id === "measurement" ||
                  cell.column.id === "remark1" ||
                  cell.column.id === "remark2" ||
                  cell.column.id === "customerName" ||
                  cell.column.id === "customerBRN" ||
                  cell.column.id === "customerID" ||
                  cell.column.id === "customermembershipID"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {textInputCell(cell, "h-7.5 text-[12px]", true)}
                    </TableCell>
                  );
                } else if (
                  // Three Discount (Render)
                  cell.column.id === "price" ||
                  cell.column.id === "taxExAmount" ||
                  cell.column.id === "feeRate" ||
                  cell.column.id === "feeAmount" ||
                  cell.column.id === "discountRate" ||
                  cell.column.id === "discountAmount" ||
                  cell.column.id === "discountRate2" ||
                  cell.column.id === "discountAmount2" ||
                  cell.column.id === "discountRate3" ||
                  cell.column.id === "discountAmount3"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {numberInputCell(cell, true)}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "quantity" ||
                  cell.column.id === "quantity2" ||
                  cell.column.id === "quantity3"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {numberInputCell(cell, false)}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "classificationCode" ||
                  cell.column.id === "locationCode" ||
                  cell.column.id === "projectCode" ||
                  cell.column.id === "taxCode" ||
                  cell.column.id === "customerCodeCode" ||
                  (cell.column.id === "stockBatchCode" && row.original["type"] !== "Service")
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="relative overflow-visible text-center"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                        overflow: "visible",
                        position: "relative",
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {dropDownInputCell(cell)}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "itemUOM" ||
                  cell.column.id === "itemUOM2" ||
                  cell.column.id === "itemUOM3"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-right"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {UOMDropdownCell(cell)}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "deliveryDate" ||
                  cell.column.id === "startAt" ||
                  cell.column.id === "date" ||
                  cell.column.id === "endAt"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-right"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {dateInputCell(cell)}
                    </TableCell>
                  );
                } else if (cell.column.id === "master") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center [&:has([role=checkbox])]:pr-4"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      <Checkbox
                        checked={masterServiceStates[row.index] === "1"}
                        onCheckedChange={(state) =>
                          handleMasterServiceCheckedChanged(index, state, cell.row)
                        }
                        disabled={row.index === 0} // Disable checkbox for the first row
                      />
                    </TableCell>
                  );
                } else if (cell.column.id === "showTemplate") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="truncate text-center [&:has([role=checkbox])]:pr-4"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      <Checkbox
                        checked={showInPDFStates[row.index] === "1"}
                        onCheckedChange={(state) =>
                          handleShowInPDFCheckedChanged(index, state, cell.row)
                        }
                        disabled={row.index === 0} // Disable checkbox for the first row
                      />
                    </TableCell>
                  );
                } else {
                  return (
                    <TableCell
                      key={cell.id}
                      className="truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                      onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                    >
                      {cellIndex === 0 ? (
                        <div className="flex items-center gap-2">
                          <DragHandle
                            id={getRowId(row.original, index)}
                            className="flex-shrink-0"
                          />
                          {flexRender(cell.column.columnDef.cell, cell.getContext())}
                        </div>
                      ) : (
                        flexRender(cell.column.columnDef.cell, cell.getContext())
                      )}
                    </TableCell>
                  );
                }
              })}
            </DraggableRow>
          );
        })
      ) : (
        <NoResultsTableRow columns={table.getVisibleLeafColumns()} />
      )}
    </TableBody>
  );
}

const MemoizedTableBody = memo(
  NonMemoizedTableBody,
  (prev, next) => prev.table.options.data === next.table.options.data,
) as typeof NonMemoizedTableBody;
