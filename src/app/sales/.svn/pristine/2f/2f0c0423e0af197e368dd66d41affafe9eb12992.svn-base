"use client";

import { endOfMonth, startOfMonth } from "date-fns";
import moment from "moment";
import React, { useEffect, useState } from "react";
import { useForm } from "react-hook-form";

import SalesReport from "@/components/templates/sales/salesReportTemplate";
import { DEFAULT_DATA_TABLE_PAGE_SIZE, getAuthHeaders, ORIGIN } from "@/lib/constants";
import useLocalStorage from "@/lib/hooks/useLocalStorage";

import { cusStatement12MonthsColumns, customerStatementReportColumns } from "./Generate/columns";
import CustomerStatementReportDataTable from "./Generate/DataTable";
import CustomerStatementReportForm from "./Report/CustomerStatementReportForm";
import SummaryForm from "./Report/SummaryForm";

import type { ColumnFiltersState, SortingState } from "@tanstack/react-table";

const COLUMN_FILTERS_KEY = "customer-statement-report.table.filters";
const PAGINATION_KEY = "customer-statement-report.table.pagination";
const SORTING_KEY = "customer-statement-report.table.sorting";

export default function CustomerStatementReportPage() {
  const [tempGeneratedReportList, setTempGeneratedReportList] = useState<any[]>([]);
  const [hasGenerated, setHasGenerated] = useState("0");
  const [showReportTable, setShowReportTable] = useState(false);
  const [previewPDF, setPreviewPDF] = useState<any>(null);
  const [salesReportData, setSalesReportData] = useState<any>(null);
  const [summaryData, setSummaryData] = useState<any>(null);
  const [isPreviewLoading, setIsPreviewLoading] = useState(false);

  // Add totalCounts state with default total: 0
  const [totalCounts, setTotalCounts] = useState<{ total: number }>({ total: 0 });

  const [columnFilters, setColumnFilters] = useLocalStorage<ColumnFiltersState>(
    COLUMN_FILTERS_KEY,
    [],
  );

  const [pagination, setPagination] = useLocalStorage(PAGINATION_KEY, {
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });

  const [sorting, setSorting] = useLocalStorage<SortingState>(SORTING_KEY, []);

  const headers = getAuthHeaders();

  const filterFields = [
    "customerCode",
    "customerName",
    "currencyCode",
    "agentName",
    "countryName",
    "outstandingAmountAmount",
  ];

  const form = useForm({
    defaultValues: {
      customer: "",
      customerName: "",
      statementDate: Math.floor(startOfMonth(new Date()).getTime() / 1000).toString(),

      customerCode: "",
      currencyCode: "",
      agentName: "",
      countryName: "",
      outstandingAmountAmount: "",
      valid: "1",

      // Add summary fields
      total: "0",
      totalOutstandingAmount: "0",
    },
  });

  const generateReport = async (formData: any) => {
    try {
      // Get all form values
      const allFormValues = form.getValues();

      const filterObject = {};

      filterFields.forEach((key) => {
        // Map docDate to docDateFormat for the filter
        const formKey = key === "docDateFormat" ? "docDate" : key;

        if (allFormValues[formKey]) {
          if (key === "docDateFormat") {
            // Format docDate as YYYY-MM-DD
            const formattedDate = moment.unix(allFormValues[formKey]).format("YYYY-MM-DD");

            filterObject[key] = formattedDate;
          } else {
            filterObject[key] = allFormValues[formKey];
          }
        }
      });

      // Extract docType for URL parameter and remove from filter
      const docTypeParam = filterObject.docType || "";

      delete filterObject.docType;

      const params = new FormData();

      // Add sales[docType] explicitly
      params.append("sales[docType]", docTypeParam);

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");
      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      // Add valid parameter
      if (formData.valid) {
        params.append("param[valid]", formData.valid);
      }

      Object.entries(formData).forEach(([key, value]) => {
        if (value) {
          params.append(`sales[${key}]`, value as string);
        }
      });

      const response = await fetch(
        `${ORIGIN}/sales_report/api/sales-report/generate-report?docType=customer&reportType=customerStatement`,
        {
          method: "POST",
          headers,
          body: params,
        },
      );

      if (!response.ok) {
        throw new Error("Failed to generate customer statement report");
      }

      const result = await response.json();
      const rows = result.rows || [];

      // Set totalCounts after fetching
      setTotalCounts({ total: result.total ?? rows.length });

      // Set summary values from backend response
      form.setValue("total", result.total ?? "0");
      form.setValue("totalOutstandingAmount", result.summary?.totalOutstandingAmount ?? "0.00");

      setTempGeneratedReportList(result.rows || []);
      setShowReportTable(true);
      setHasGenerated("1");
    } catch (error) {
      console.error("Error generating customer statement report:", error);
    }
  };

  const [formDataState, setFormDataState] = useState<any>(null);
  const [salesReportColumns, setSalesReportColumns] = useState<any>(null);

  const previewReport = async (formData: any) => {
    setFormDataState(formData);
    setPreviewPDF(null);
    setIsPreviewLoading(true);

    try {
      let reportName = null;

      const reportTypeName = formData.reportTypeName;

      // const levelMatch = reportTypeName.match(/lv(\d+)/i);

      // if (levelMatch) {
      //   reportName = `level${levelMatch[1]}`;
      // }

      if (reportTypeName === "cusStatement12Months") {
        reportName = `cusStatement12Months`;
      }

      // Get all form values
      const allFormValues = form.getValues();

      const filterObject = {};

      filterFields.forEach((key) => {
        // Map docDate to docDateFormat for the filter
        const formKey = key === "docDateFormat" ? "docDate" : key;
        if (allFormValues[formKey]) {
          if (key === "docDateFormat") {
            // Format docDate as YYYY-MM-DD
            const formattedDate = moment.unix(allFormValues[formKey]).format("YYYY-MM-DD");
            filterObject[key] = formattedDate;
          } else {
            filterObject[key] = allFormValues[formKey];
          }
        }
      });

      // Extract docType for URL parameter and remove from filter
      const docTypeParam = filterObject.docType || "";

      delete filterObject.docType;

      const params = new FormData();

      // Add sales[docType] explicitly
      params.append("sales[docType]", docTypeParam);

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

      // params.append("param[limit]", `${pagination.pageSize}`);
      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      // Add valid parameter
      if (formData.valid) {
        params.append("param[valid]", formData.valid);
      }

      // Add form data to params
      Object.entries(formData).forEach(([key, value]) => {
        if (value) params.append(`sales[${key}]`, value as string);
      });

      // if (reportName) {
      //   // const hasCustomerName = /customername/i.test(reportTypeName);

      //   params.append("sales[groupBy][0]", "customerCode");
      //   params.append("sales[groupBy][1]", "customerName");
      //   // params.append("sales[groupBy][1]", hasCustomerName ? "docDateFormat" : "docNo");
      // }

      const baseUrl = `${ORIGIN}/sales_report/api/sales-report/preview-pdf`;

      let url = `${baseUrl}?docType=customer&reportType=customerStatement`;

      if (reportName) {
        url += `&reportName=${reportName}`;
      }

      const response = await fetch(url, {
        method: "POST",
        headers,
        body: params,
      });

      // const response = await fetch(
      //   `${ORIGIN}/sales_report/api/sales-report/preview-pdf?docType=customer&reportType=customerStatement`,
      //   {
      //     method: "POST",
      //     headers,
      //     body: params,
      //   }
      // );

      if (!response.ok) {
        throw new Error("Failed to preview customer statement report");
      }

      const result = await response.json();
      const rows = result.rows || [];

      // Set totalCounts after fetching
      setTotalCounts({ total: result.total ?? rows.length });

      // Set summary values from backend response
      form.setValue("total", result.total ?? "0");
      form.setValue("totalOutstandingAmount", result.summary?.totalOutstandingAmount ?? "0.00");

      setPreviewPDF(result);
      setSalesReportData(formData);
    } catch (error) {
      console.error("Error previewing customer statement report:", error);
    } finally {
      setIsPreviewLoading(false);
    }
  };

  const onSubmit = (data: any) => {
    setTempGeneratedReportList([]);
    setShowReportTable(false);

    generateReport(data);
  };

  useEffect(() => {
    if (formDataState) {
      if (formDataState.reportTypeName === "customerStatementReport") {
        setSalesReportColumns(customerStatementReportColumns);
      } else {
        setSalesReportColumns(cusStatement12MonthsColumns);
      }
    }
  }, [formDataState]);

  return (
    <>
      <CustomerStatementReportForm
        form={form}
        onSubmit={onSubmit}
        onPreview={previewReport}
        previewPDF={previewPDF}
        salesReportData={salesReportData}
        generatedReport={tempGeneratedReportList}
        salesReportColumns={salesReportColumns}
        filterFields={filterFields}
        sorting={sorting}
      />
      <SummaryForm form={form} onSubmit={onSubmit} />
      {showReportTable && (
        <CustomerStatementReportDataTable
          columns={customerStatementReportColumns}
          data={tempGeneratedReportList}
          revalidateCustomerStatementReport={() => generateReport(form.getValues())}
          columnFilters={columnFilters}
          setColumnFilters={setColumnFilters}
          pagination={pagination}
          setPagination={setPagination}
          sorting={sorting}
          setSorting={setSorting}
          formData={form.getValues()}
          totalNumOfRows={+totalCounts.total}
        />
      )}
    </>
  );
}
