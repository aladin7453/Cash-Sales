"use client";

import React from "react";
import type { ColumnDef } from "@tanstack/react-table";

export type DeliveryOrderTransferItem = {
  id: string;
  UUID: string;
  serviceGroupCode: string;
  serviceCategoryCode: string;
  serviceCode: string;
  serviceName: string;
  classification: string;
  defaultUOMSales: string;
  defaultUOMPurchase: string;
  defaultUOMService: string;
  "2ndDescription": string;
  moreDescription: string;
  attachment: string;
  description: string;
  createdAt: string;
  createdBy: string;
  updatedBy: string;
  updatedAt: string;
  valid: string;
  quantity: string;
  transferQuantity: string;
  transferableQuantity: string;
  itemCode: string;
  itemName: string;
  itemUOM: string;
  itemRate: string;
  projectCode: string;
  remark1: string;
  type: string;
};

export const deliveryOrderTransferToColumns: ColumnDef<DeliveryOrderTransferItem>[] = [
  {
    accessorKey: "type",
    header: "Type",
    filterFn: "includesString"
  },
  {
    accessorKey: "transferQuantity",
    header: "Transfer Quantity",
    filterFn: "includesString"
  },
  {
    accessorKey: "transferableQuantity",
    header: "Balance Quantity",
    cell: ({ row }) => <p className="text-right">{row.original.transferableQuantity}</p>,
    filterFn: "includesString"
  },
  {
    accessorKey: "quantity",
    header: "Original Quantity",
    cell: ({ row }) => <p className="text-right">{row.original.quantity}</p>,
    filterFn: "includesString"
  },
  {
    accessorKey: "itemCode",
    header: "Item",
    filterFn: "includesString"
  },
  {
    accessorKey: "itemName",
    header: "Item Name",
    filterFn: "includesString"
  },
  {
    accessorKey: "description",
    header: "Description",
    filterFn: "includesString"
  },
  {
    accessorKey: "2ndDescription",
    header: "2nd Description",
    filterFn: "includesString"
  },
  {
    accessorKey: "moreDescription",
    header: "More Description",
    filterFn: "includesString"
  },
  {
    accessorKey: "itemUOM",
    header: "UOM",
    filterFn: "includesString"
  },
  {
    accessorKey: "itemRate",
    header: "Rate",
    cell: ({ row }) => <p className="text-right">{row.original.itemRate}</p>,
    filterFn: "includesString"
  },
  {
    accessorKey: "projectCode",
    header: "Project",
    filterFn: "includesString"
  },
  {
    accessorKey: "remark1",
    header: "Remark",
    filterFn: "includesString"
  },
];
