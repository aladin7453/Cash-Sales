const defaultInputCell = ({ getValue, row, column: { id } }, className: string, inputType) => {
  const initialValue = getValue();
  // We need to keep and update the state of the cell normally
  const [value, setValue] = useState(initialValue);

  // When the input is blurred, we'll call update the data into the database
  const onBlur = () => { };

  const onChange = (e) => {
    row.original[id] = e.target.value;
    setValue(e.target.value);
  };

  // If the initialValue is changed external, sync it up with our state
  useEffect(() => {
    setValue(initialValue);
  }, [initialValue]);

  return (
    <Input
      className={className}
      value={value as typeof inputType}
      onChange={onChange}
      onBlur={onBlur}
    />
  );
};

const isDev = process.env.NODE_ENV === "development";

const urlMap = {
  quotation: isDev ? "sales/quotation" : `${versionPath}/sales/quotation`,
  cashSales: isDev ? "sales/cash-sales" : `${versionPath}/sales/cash-sales`,
  deliveryOrder: isDev ? "sales/delivery-order" : `${versionPath}/sales/delivery-order`,
  jobOrder: isDev ? "job-management/job-order" : `${versionPath}/job-management/job-order`,
  salesInvoice: isDev ? "sales/sales-invoice" : `${versionPath}/sales/sales-invoice`,
  salesDebitNote: isDev ? "sales/sales-debit-note" : `${versionPath}/sales/sales-debit-note`,
  salesOrder: isDev ? "sales/sales-order" : `${versionPath}/sales/sales-order`,
  salesCreditNote: isDev ? "sales/sales-credit-note" : `${versionPath}/sales/sales-credit-note`,
};

