                  href={url}
                  className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {doc.docNo}
                </a>
                {index < transferToDocuments.length - 1 && ", "}
