"use client";

import React, { useEffect, useState, useRef } from "react";
import { FaMagnifyingGlass, FaRegNoteSticky } from "react-icons/fa6";

import { DisplayCustomField, CustomFieldHandle, CustomFieldDefinition } from "@/components/DisplayCustomField";
import { Tab, TabList, TabPanel, Tabs } from "react-tabs";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import DropdownTable from "@/components/data-table/DropdownTable";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "@/components/ui/tooltip";
import { cn } from "@/lib/utils/cn";
import {
  Card,
  CardHeader,
  CardContent,
  CardTitle
} from "@/components/ui/card";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import TextEditorInline from "@/components/custom/TextEditorInline";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";
import { toast } from "@/components/ui/use-toast";
import { Button } from "@/components/ui/button";
import { useForm, FormProvider } from "react-hook-form";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog";
import ShipperDetailsForm from "../shipper-details/ShipperDetailsForm";

// Preference (Define Param)
// type Params = {
//   form: any;
// };

interface ContactFormData {
  contact: string;
  phoneNo: string;
  email: string;
  description: string;
}

const contactFormSchema = z.object({
  contact: z.string().min(1, "Contact name is required").trim(),
  phoneNo: z.string().min(1, "Phone number is required").trim(),
  email: z.string().optional(),
  description: z.string().optional(),
});

type CustomerDetailsFormProps = {
  form: any;
  isExpand?: boolean;
  setIsExpand: (v: boolean) => void;
  isMobile?: boolean;
  slug?: string;
  id?: string | null;
  docNo?: string;
  preferenceData?: any;
  customFieldRef?: React.Ref<CustomFieldHandle>;
  customFieldDefs: CustomFieldDefinition[]; 
  customFieldSavedData: Record<string, unknown>; 
  submitAttempted?: boolean;
};

export function CustomerDetailsForm({ form, setIsExpand, isExpand, isMobile, slug, id, docNo, preferenceData, customFieldRef, customFieldDefs, customFieldSavedData, submitAttempted = false }: CustomerDetailsFormProps) {
  const headers = getAuthHeaders();

  const handleClickOutside = (event) => {
    if (customerDropdownRef.current && !customerDropdownRef.current.contains(event.target) && customerCodeInputRef.current !== event.target) {
      setShowCustomerTable(false);
    }

    if (attentionDropdownRef.current && !attentionDropdownRef.current.contains(event.target) && attentionInputRef.current !== event.target) {
      setShowAttentionTable(false);
    }

    if (deliveryAttentionDropdownRef.current && !deliveryAttentionDropdownRef.current.contains(event.target) && deliveryAttentionInputRef.current !== event.target) {
      setShowDeliveryAttentionTable(false);
    }


    if (deliveryAddressDropdownRef.current && !deliveryAddressDropdownRef.current.contains(event.target) && deliveryAddressInputRef.current !== event.target) {
      setShowTableDeliveryAddress(false);
    }
  };

  useEffect(() => {
    document.body.addEventListener('click', handleClickOutside);

    return () => {
      document.body.removeEventListener('click', handleClickOutside);
    };
  }, []);

  // Customer Dropdown
  const [customerDropdownData, setCustomerDropdownData] = useState<[]>([]);
  const [showCustomerTable, setShowCustomerTable] = useState(false);
  const [customerFilter, setCustomerFilter] = useState("");
  const customerCodeInputRef = useRef(null);
  const customerDropdownRef = useRef(null);

  const dropdownCustomerColumns = [
    { accessorKey: "customerCode", header: "Customer Code" },
    { accessorKey: "customerGroupCode", header: "Customer Group" },
    { accessorKey: "customerName", header: "Customer Name" },
  ];

  const onClickRowCustomer = (row) => {
    form.setValue("customerCode", row.UUID);
    form.setValue("customerCodeCode", row.customerCode, { shouldValidate: true });
    form.setValue("customerName", row.customerName);
    form.setValue("TIN", row.TIN);
    form.setValue("BRN", row.BRN);
    form.setValue("SSTNo", row.SSTNo);
    form.setValue("customerAddress", row.address);
    form.setValue("taxExNo", row.TaxExNo);

    //Shipper
    form.setValue("shipperName", row.customerName);
    form.setValue("shipperTIN", row.TIN);
    form.setValue("shipperBRN", row.BRN);
    form.setValue("shipperSSTNo", row.SSTNo);
    form.setValue("shipperAddress", row.address);
    form.setValue("shipperTTXNo", row.TTXNo);

    if (row.creditTerm) {
      form.setValue("creditTerm", row.creditTerm);
      form.setValue("creditTermCode", row.creditTermCode);

    }

    if (row.customerHasBillingContacts && row.customerHasBillingContacts.length > 0) {
      var defaultCheck = row.customerHasBillingContacts?.find(row => row.default == "1");
    }

    defaultCheck ? form.setValue("customerAttentionName", defaultCheck.UUID) : form.setValue("customerAttentionName", "")
    defaultCheck ? form.setValue("customerAttentionNameName", defaultCheck.contact) : form.setValue("customerAttentionNameName", "");
    defaultCheck ? form.setValue("customerAttentionTel", defaultCheck.phoneNo) : form.setValue("customerAttentionTel", "");
    defaultCheck ? form.setValue("customerAttentionEmail", defaultCheck.email) : form.setValue("customerAttentionEmail", "");

    setShowCustomerTable(false);
    setCustomerFilter("");
  };

  const fetchCustomerDropdownData = async () => {
    try {
      var form_data = new FormData();

      form_data.append(`table[0]`, "customer");

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
        method: "POST",
        headers,
        body: form_data,
      });

      if (!response.ok) {
        throw new Error('Failed to fetch dropdown data');
      }

      const data = await response.json();

      setCustomerDropdownData(data.rows)
      setShowCustomerTable(true);
    } catch (error) {
      console.error('Error fetching dropdown data:', error);

      throw new Error('Failed to fetch dropdown data');
    }
  };

  // Attention Dropdown
  const [attentionDropdownData, setAttentionDropdownData] = useState<[]>([]);
  const [showAttentionTable, setShowAttentionTable] = useState(false);
  const [attentionFilter, setAttentionFilter] = useState("");
  const attentionInputRef = useRef(null);
  const attentionDropdownRef = useRef(null);

  const deliveryAttentionInputRef = useRef(null);
  const deliveryAttentionDropdownRef = useRef(null);


  const [deliveryAttentionDropdownData, setDeliveryAttentionDropdownData] = useState<[]>([]);
  const [showDeliveryAttentionTable, setShowDeliveryAttentionTable] = useState(false);
  const [deliveryAttentionFilter, setDeliveryAttentionFilter] = useState("");

  const dropdownDeliveryAttentionColumns = [
    { accessorKey: "contact", header: "Contact", },
    { accessorKey: "phoneNo", header: "Phone No.", },
    { accessorKey: "email", header: "Email", },
    { accessorKey: "description", header: "Description", },
  ];


  const fetchDeliveryAttentionDropdownData = async () => {
    try {
      const response = await fetch(`${ORIGIN}/universal/get-attention-by-customer?id=${form.getValues("customerCode")}`, {
        method: "POST",
        headers,
      });

      if (!response.ok) {
        throw new Error('Failed to fetch dropdown data');
      }

      const data = await response.json();

      setDeliveryAttentionDropdownData(data.rows);
      setShowDeliveryAttentionTable(true);
    } catch (error) {
      console.error('Error fetching dropdown data:', error);

      throw new Error('Failed to fetch dropdown data');
    }
  };

  const onClickRowDeliveryAttention = (row) => {
    form.setValue("deliveryAttention", row.contact);
    form.setValue("deliveryPhoneNo", row.phoneNo);
    form.setValue("deliveryEmail", row.email);

    setShowDeliveryAttentionTable(false);
    setAttentionFilter("");
  };

  const dropdownAttentionColumns = [
    { accessorKey: "contact", header: "Contact", },
    { accessorKey: "phoneNo", header: "Phone No.", },
    { accessorKey: "email", header: "Email", },
    { accessorKey: "description", header: "Description", },
  ];

  const onClickRowAttention = (row) => {
    form.setValue("customerAttentionName", row.UUID);
    form.setValue("customerAttentionNameName", row.contact);
    form.setValue("customerAttentionTel", row.phoneNo);
    form.setValue("customerAttentionEmail", row.email);

    setShowAttentionTable(false);
    setAttentionFilter("");
  }

  const fetchAttentionDropdownData = async () => {
    try {
      const response = await fetch(`${ORIGIN}/universal/get-attention-by-customer?id=${form.getValues("customerCode")}`, {
        method: "POST",
        headers,
      });

      if (!response.ok) {
        throw new Error('Failed to fetch dropdown data');
      }

      const data = await response.json();

      setAttentionDropdownData(data.rows);
      setShowAttentionTable(true);
    } catch (error) {
      console.error('Error fetching dropdown data:', error);

      throw new Error('Failed to fetch dropdown data');
    }
  };

  // Function for Adding a New Contact
  const [showAddAttentionDialog, setShowAddAttentionDialog] = useState(false);
  const [billingContactFiles, setBillingContactFiles] = useState<File[]>([]);
  const [isLoading, setIsLoading] = useState(false);


  const contactForm = useForm<ContactFormData>({
    resolver: zodResolver(contactFormSchema),
    defaultValues: {
      contact: "",
      phoneNo: "",
      email: "",
      description: "",
    },
  });

  const handleAddContact = async () => {
    const isValid = await contactForm.trigger();
    if (!isValid) return;

    const data = contactForm.getValues();
    const customerId = form.getValues("customerCode");
    const formData = new FormData();

    // Append contact data
    formData.append("customerHasBillingContact[contact]", data.contact);
    formData.append("customerHasBillingContact[phoneNo]", data.phoneNo);
    formData.append("customerHasBillingContact[email]", data.email);
    formData.append("customerHasBillingContact[description]", data.description || "");

    // Append files
    for (let i = 0; i < billingContactFiles.length; i++) {
      const file = billingContactFiles[i];

      if (file.size) {
        try {
          const base64 = await getFileToBase64(file);

          formData.append(`customerHasBillingContact[attachment][${i}][Name]`, file.name);
          formData.append(`customerHasBillingContact[attachment][${i}][File]`, base64);
        } catch (error) {
          console.error("Error converting file to base64:", error);

          toast({
            title: "Error",
            description: "Failed to process file attachment",
            variant: "destructive",
          });

          return;
        }
      } else {
        formData.append(`customerHasBillingContact[attachment][${i}][Name]`, file.name);
        formData.append(`customerHasBillingContact[attachment][${i}][File]`, "");
      }
    }

    setIsLoading(true);
    try {
      const response = await fetch(
        `${ORIGIN}/customer/api/customer/update-customer-has-billing-contact-data?id=${customerId}`,
        {
          method: "POST",
          headers,
          body: formData,
        }
      );

      if (!response.ok) {
        throw new Error("Failed to add new contact");
      }

      await fetchAttentionDropdownData();

      contactForm.reset();

      setBillingContactFiles([]);
      setShowAddAttentionDialog(false);

      toast({
        title: "Success",
        description: "Contact added successfully",
      });
    } catch (error) {
      console.error("Error adding new contact:", error);

      toast({
        title: "Error",
        description: "Failed to add new contact",
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  // Fetch Delivery Address Dropdown Data
  const fetchDropdownDeliveryAddress = async () => {
    const formData = new FormData();
    const customerUUID = form.getValues('customerCode');

    if (!showTableDeliveryAddress) {
      try {
        const response = await fetch(
          `${ORIGIN}/universal/get-customer-has-delivery-location-by-customer?id=${customerUUID}`,
          {
            method: "POST",
            headers,
            body: formData,
          }
        );

        if (!response.ok) {
          throw new Error("Failed to fetch attention drop-down data");
        }

        const deliveryAddressData = await response.json();

        setDeliveryAddressDropdownTableData(deliveryAddressData.rows);
        setShowTableDeliveryAddress(true);
      } catch (error) {
        console.error("Error fetching attention drop-down data:", error);
      }
    } else {
      setShowTableDeliveryAddress(false);
    }
  };

  // Delivery Address Dropdown
  const [showTableDeliveryAddress, setShowTableDeliveryAddress] = useState(false);
  const [deliveryAddressDropdownTableData, setDeliveryAddressDropdownTableData] = useState([]);
  const deliveryAddressInputRef = useRef(null);
  const deliveryAddressDropdownRef = useRef(null);

  const dropdownDeliveryAddressColumns = [
    { accessorKey: "deliveryLocation", header: "Delivery Location", },
    {
      accessorKey: "deliveryAddress", header: "Delivery Address",
      cell: ({ row }) => {
        const address = row.original.deliveryAddress || "";
        const addressStyle = {
          whiteSpace: "pre-wrap",
          wordWrap: "break-word",
        };

        return (
          <span style={addressStyle}>
            {address.length > 50 ? `${address}` : address}
          </span>
        );
      },
    },
    { accessorKey: "description", header: "Remark", cell: ({ row }) => <DescriptionCellTooltip row={row} />, },
  ];

  const onClickRowDeliveryAddress = (row) => {
    form.setValue('deliveryAddress', row.deliveryAddress);
    form.setValue("deliveryAttention", row.contact);
    form.setValue("deliveryPhoneNo", row.phoneNo);
    form.setValue("deliveryEmail", row.email);

    setShowTableDeliveryAddress(false);
  };

  const [activeTabIndex, setActiveTabIndex] = useState(0)

  //Mobile View
  if (isMobile) {
    return (
      <>
        <div className="flex flex-col gap-y-4 px-4 py-2.5 bg-gray-100/10">
          <h1 className="mt-3 font-bold uppercase text-black">Customer Details</h1>

          {/* Customer Code */}
          <FormField
            control={form.control}
            name="customerCodeCode"
            render={({ field }) => (
              <FormItem className="flex flex-col">
                <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Customer Code</FormLabel>
                <FormControl>
                  <div className="relative">
                    <Input
                      className={cn(
                        "h-10 rounded-md px-2 pr-9 bg-white border border-gray text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300",
                        form.formState.errors.customerCodeCode &&
                        "border-red-500 placeholder:text-red-500"
                      )}
                      {...field}
                      onClick={fetchCustomerDropdownData}
                      onChange={(e) => {
                        field.onChange(e);
                        setCustomerFilter(e.target.value);
                      }}
                      ref={customerCodeInputRef}
                      autoComplete="off"
                      placeholder={form.formState.errors.customerCodeCode ? "Required" : "Customer Code"}
                    />
                    <FaMagnifyingGlass className="absolute right-3 top-1/2 -translate-y-1/2 size-3 text-gray-400 pointer-events-none" />
                    {showCustomerTable && (
                      <div ref={customerDropdownRef} className="absolute top-full left-0 right-0 z-50 mt-1 rounded-md border border-gray-200 bg-white shadow-lg overflow-hidden">
                        <ScrollArea className="max-h-[200px]">
                          <DropdownTable
                            columns={dropdownCustomerColumns}
                            data={customerDropdownData}
                            onClickRow={onClickRowCustomer}
                            filterValue={customerFilter}
                            filterColumn="customerName"
                          />
                        </ScrollArea>
                      </div>
                    )}
                  </div>
                </FormControl>
              </FormItem>
            )}
          />

          {/* Second Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">
            {/* Customer Name */}
            <FormField
              control={form.control}
              name="customerName"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Customer Name</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      moduleName="salesOrder"
                      fieldName="customerName"
                      columnName="Customer Name"
                      placeholder="Customer Name"
                    />
                  </FormControl>
                </FormItem>
              )}
            />

            {/* BRN */}
            <FormField
              control={form.control}
              name="BRN"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">BRN</FormLabel>
                  <FormControl>
                    <Input className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300" {...field} placeholder="BRN" />
                  </FormControl>
                </FormItem>
              )}
            />
          </div>

          {/* Third Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">

            {/* TIN */}
            <FormField
              control={form.control}
              name="TIN"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">TIN</FormLabel>
                  <FormControl>
                    <Input className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300" {...field} placeholder="TIN" />
                  </FormControl>
                </FormItem>
              )}
            />

            {/* SST No */}
            <FormField
              control={form.control}
              name="SSTNo"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">SST No</FormLabel>
                  <FormControl>
                    <Input className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300" {...field} placeholder="SST" />
                  </FormControl>
                </FormItem>
              )}
            />

            {/* TaxEx No */}
            <FormField
              control={form.control}
              name="TTXNo"
              render={({ field }) => (
                <FormItem className="hidden">
                  <FormLabel>TaxEx No.:</FormLabel>
                  <FormControl>
                    <Input className="h-7.5" {...field} />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Billing Details */}
          <h1 className="mt-3 font-bold uppercase text-black">Billing Details</h1>

          {/* First Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">
            {/* Attention Name */}
            <FormField
              control={form.control}
              name="attentionName"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Attention</FormLabel>
                  <FormControl className="relative">
                    <div className="relative">
                      <Input
                        className="h-10 rounded-md px-2 pr-9 bg-white border border-gray text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                        {...field}
                        onClick={fetchAttentionDropdownData}
                        onChange={(e) => {
                          field.onChange(e);
                          setAttentionFilter(e.target.value);
                        }}
                        ref={attentionInputRef}
                        autoComplete="off"
                        placeholder="Attention"
                      />
                      <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                        <FaMagnifyingGlass className="size-3 text-gray-400" />
                      </div>
                      {showAttentionTable && (
                        <div
                          ref={attentionDropdownRef}
                          className="absolute right-0 top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                        ><div className="flex items-center border-t p-2 bg-white">
                            Billing Contact Details
                          </div>
                          <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                            <DropdownTable
                              columns={dropdownAttentionColumns}
                              data={attentionDropdownData}
                              onClickRow={onClickRowAttention}
                              filterValue={attentionFilter}
                              filterColumn="contact"
                            />
                            <ScrollBar orientation="vertical" />
                          </ScrollArea>
                          <div className="flex items-center justify-end border-t p-2 bg-white">
                            <Button
                              type="button"
                              variant="outline"
                              size="sm"
                              onClick={() => {
                                setShowAttentionTable(false);
                                setShowAddAttentionDialog(true);
                              }}
                            >
                              +
                              Add
                            </Button>
                          </div>
                        </div>
                      )}
                    </div>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Attention UUID */}
            <FormField
              control={form.control}
              name="attention"
              render={({ field }) => (
                <FormItem className="hidden">
                  <FormLabel>Attention UUID:</FormLabel>
                  <FormControl>
                    <Input className="h-7.5" {...field} />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Phone No */}
            <FormField
              control={form.control}
              name="phoneNo"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Phone No</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      placeholder="Phone No"
                    />
                  </FormControl>
                </FormItem>
              )}
            />
          </div>

          {/* Second Row */}
          <div className="grid grid-cols-1 items-center">
            {/* Email */}
            <FormField
              control={form.control}
              name="email"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Email</FormLabel>
                  <FormControl>
                    <Input className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      placeholder="Email" />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Third Row */}
          <FormField
            control={form.control}
            name="address"
            render={({ field }) => (
              <FormItem className="flex flex-col">
                <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Billing Address</FormLabel>
                <FormControl>
                  <Textarea
                    className="h-10 px-2 bg-white border border-gray-200 resize-none text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                    placeholder="Billing Address"
                    {...field}
                  />
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />

          {/* Delivery Details */}
          <h1 className="mt-3 font-bold uppercase text-black">Delivery Details</h1>

          {/* Delivery Address */}
          <FormField
            control={form.control}
            name="deliveryAddress"
            render={({ field }) => (
              <FormItem className="flex flex-col">
                <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Delivery Address</FormLabel>
                <FormControl className="relative">
                  <div>
                    <Textarea
                      className="h-10 bg-white border border-gray-200 resize-none px-2 pr-9 text-[12px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      onClick={fetchDropdownDeliveryAddress}
                      ref={deliveryAddressInputRef}
                      autoComplete="off"
                      placeholder="Delivery Address"
                    />
                    <div className="pointer-events-none absolute inset-y-0 bottom-[60%] right-0 flex items-center pr-3">
                      <FaMagnifyingGlass className="size-3 text-gray-400" />
                      {/* Using the search icon */}
                    </div>
                    {showTableDeliveryAddress && (
                      <div
                        ref={deliveryAddressDropdownRef}
                        className="absolute top-[50px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                      >
                        <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                          <DropdownTable
                            columns={dropdownDeliveryAddressColumns}
                            data={deliveryAddressDropdownTableData}
                            onClickRow={onClickRowDeliveryAddress}
                          />
                        </ScrollArea>
                      </div>
                    )}
                  </div>
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
