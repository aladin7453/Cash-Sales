"use client";

import React from "react";
import { UseFormReturn } from "react-hook-form";
import {
  Form,
  FormField,
  FormItem,
  FormLabel,
  FormControl,
  FormMessage,
} from "@/components/ui/form";
import { Input, NumberInputField } from "@/components/ui/input";

interface CustomerAnalysisByDocumentFormProps {
  form: UseFormReturn<any>;
  onGenerate: (data: any) => void;
  data?: any[];
}

export default function CustomerAnalysisByDocumentForm({ 
  form, 
  onGenerate,
  data = []
}: CustomerAnalysisByDocumentFormProps) {

  const totalNoOfDocuments = Number(data?.total) || 0;
  const totalQuantityRequested = Number(data?.summary?.totalQuantity) || 0;
  return (
    <div className="rounded-sm p-2 mx-auto bg-erp-blue-8 mt-2">
      <div className="rounded-sm p-4 bg-erp-blue-4">
        <Form {...form}>
          <form onSubmit={form.handleSubmit(onGenerate)}>
            <h2 className="text-md font-bold mb-4">Summary</h2>

            <div className="grid grid-flow-col-dense items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5">
              <FormField
                control={form.control}
                name="totalRecords"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Total Count of No.:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5 text-right" {...field} readOnly />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
              
              <FormField
                control={form.control}
                name="totalBFAmt"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Total B/F Amt:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5 text-right" {...field} readOnly />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="totalBFLocalAmt"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Total B/F Local Amt:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5 text-right" {...field} readOnly />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="totalInvoice"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Total Invoice:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5 text-right" {...field} readOnly />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="totalInvoiceLocal"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Total Invoice Local:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5 text-right" {...field} readOnly />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </form>
        </Form>
      </div>
    </div>
  );
