"use client";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import type { ColumnDef } from "@tanstack/react-table";
import React from "react";

export type ItemList = {
  UUID: string;
  quotation: string;
  docNo: string;
  type: number;
  description: string;
  "2ndDescription": string;
  moreDescription: string;
  itemGroup: string;
  itemCategory: string;
  tariff: string;
  classification: string;
  permitNo: string;
  project: string;
  quantity: number;
  totalSubtotaltotalSubtotal:number,
  totalTaxtotalTax:number,
  UOM: string;
  price: number;
  discountRate: number;
  discountAmount: number;
  tax: string;
  deliveryDate: string;
  billingFrequency: number;
  billingInterval: string;
  startAt: string;
  endAt: string;
  remark1: string;
  remark2: string;
  serviceName: string;
  serviceCode: string;
  createdAt: string;
  createdBy: string;
  updatedBy: string;
  updatedAt: string;
  valid: string; 
};

export const ServiceColumns: ColumnDef<ItemList>[] = [
  {
    id: "docNo",
    accessorKey: "docNo",
    header: "Doc No",
    filterFn: "includesString"
  },
  {
    id: "docDateFormat",
    accessorKey: "docDateFormat",
    header: "Doc Date",
    filterFn: "includesString"
  },
  {
    id: "customerName",
    accessorKey: "customerName",
    header: "Customer Name",
    filterFn: "includesString"
  },
  {
    id: "customerCodeCode",
    accessorKey: "customerCodeCode",
    header: "Customer Code",
    filterFn: "includesString"
  },
  {
    id: "description",
    accessorKey: "description",
    header: "Description",
    cell: ({ row }) => <DescriptionCellTooltip row={row} columnName="description"/>,
    filterFn: "includesString"
  },
  {
    id: "quantity",
    accessorKey: "quantity",
    header: "Quantity",
    cell: ({row}) => (
      <p className="text-right">{row.original.quantity}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "price",
    accessorKey: "price",
    header: "Price",
    cell: ({row}) => (
      <p className="text-right">{row.original.price}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "totalAmountAmount",
    accessorKey: "totalAmountAmount",
    header: "Amount",
    cell: ({row}) => (
      <p className="text-right">{row.original.totalAmountAmount}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "totalSubtotaltotalSubtotal",
    accessorKey: "totalSubtotaltotalSubtotal",
    header: "Subtotal",
    cell: ({row}) => (
      <p className="text-right">{row.original.totalSubtotaltotalSubtotal}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "totalTaxtotalTax",
    accessorKey: "totalTaxtotalTax",
    header: "Tax Amount",
    cell: ({row}) => (
      <p className="text-right">{row.original.totalTaxtotalTax}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "totalSubtotalTax",
    accessorKey: "totalSubtotalTax",
    header: "Subtotal (Tax)",
    cell: ({row}) => (
      <p className="text-right">{row.original.totalSubtotalTax}</p>
    ),
    filterFn: "includesString"
  },
];

