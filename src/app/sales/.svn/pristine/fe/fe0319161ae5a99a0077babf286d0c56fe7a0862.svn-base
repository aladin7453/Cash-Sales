                    forceRender
                    className="hidden"
                    selectedClassName="react-tabs__tab-panel--selected"
                  >
                    <div className="flex w-full items-center justify-between px-2 pt-1.5">
                      <CardTitle className="text-sm font-bold">Mapping Reference</CardTitle>
                    </div>

                    <div className="flex flex-col gap-y-2 pt-1.5">
                      {/* Forth Row */}
                      <div className="flex items-center justify-center gap-x-2">
                        {/* SO No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("salesOrder") &&
                              form.getValues("salesOrderNo") ? (
                              (() => {
                                const basePath = "/sales/sales-order";
                                const salesOrderID = form.getValues("salesOrder");
                                const salesOrderNo = form.getValues("salesOrderNo");
                                return (
                                  <Link
                                    href={`${basePath}/edit?item=${salesOrderNo}&id=${salesOrderID}`}
                                    target="_blank"
                                    className="flex text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Sales Order No"
                                  >
                                    {salesOrderNo}
                                  </Link>
                                );
                              })()
                            ) : (
                              <span className="text-muted-foreground">SO No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>

                        {/* JO No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("jobOrderTransferred")?.length > 0 ? (
                              (() => {
                                const basePath = "/job-management/job-order";
                                const docs = form.getValues("jobOrderTransferred");
                                return docs.map((doc, index, array) => (
                                  <Link
                                    key={doc.UUID}
                                    href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                    target="_blank"
                                    className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Job Order No"
                                  >
                                    {doc.docNo}{index < array.length - 1 ? ", " : ""}
                                  </Link>
                                ));
                              })()
                            ) : (
                              <span className="text-muted-foreground">JO No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>

                        {/* DO No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("deliveryOrderTransferred")?.length > 0 ? (
                              (() => {
                                const basePath = "/sales/sales-delivery-order";
                                const docs = form.getValues("deliveryOrderTransferred");
                                return docs.map((doc, index, array) => (
                                  <Link
                                    key={doc.UUID}
                                    href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                    target="_blank"
                                    className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Delivery Order No"
                                  >
                                    {doc.docNo}{index < array.length - 1 ? ", " : ""}
                                  </Link>
                                ));
                              })()
                            ) : (
                              <span className="text-muted-foreground">DO No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>
                      </div>

                      {/* Fifth Row */}
                      <div className="flex w-full items-center justify-center gap-x-2">
                        {/* INV No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("salesInvoiceTransferred")?.length > 0 ? (
                              (() => {
                                const basePath = "/sales/sales-invoice";
                                const docs = form.getValues("salesInvoiceTransferred");
                                return docs.map((doc, index, array) => (
                                  <Link
                                    key={doc.UUID}
                                    href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                    target="_blank"
                                    className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Sales Invoice No"
                                  >
                                    {doc.docNo}{index < array.length - 1 ? ", " : ""}
                                  </Link>
                                ));
                              })()
                            ) : (
                              <span className="text-muted-foreground">INV No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>

                        {/* CS No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("cashSalesTransferred")?.length > 0 ? (
                              (() => {
                                const basePath = "/sales/cash-sales";
                                const docs = form.getValues("cashSalesTransferred");
                                return docs.map((doc, index, array) => (
                                  <Link
                                    key={doc.UUID}
                                    href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                    target="_blank"
                                    className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Cash Sales No"
                                  >
                                    {doc.docNo}{index < array.length - 1 ? ", " : ""}
                                  </Link>
                                ));
                              })()
                            ) : (
                              <span className="text-muted-foreground">CS No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>

                        {/* DN No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("salesDebitNoteTransferred")?.length > 0 ? (
                              (() => {
                                const basePath = "/sales/sales-debit-note";
                                const docs = form.getValues("salesDebitNoteTransferred");
                                return docs.map((doc, index, array) => (
                                  <Link
                                    key={doc.UUID}
                                    href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                    target="_blank"
                                    className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Sales Debit Note No"
                                  >
                                    {doc.docNo}{index < array.length - 1 ? ", " : ""}
                                  </Link>
                                ));
                              })()
                            ) : (
                              <span className="text-muted-foreground">DN No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>
                      </div>

                      <div className="flex w-full items-center justify-start gap-x-2">
                        {/* OR No */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <ScrollArea className="flex h-7 flex-col rounded-xl border border-input bg-erp-blue-4 px-2 pt-[4px] text-[11px] font-normal">
                            {slug !== "clone" &&
                              form.getValues("customerPaymentTransferred")?.length > 0 ? (
                              (() => {
                                const basePath = "/sales/customer-payment";
                                const docs = form.getValues("customerPaymentTransferred");
                                return docs.map((doc, index, array) => (
                                  <Link
                                    key={doc.UUID}
                                    href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                                    target="_blank"
                                    className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="Customer Payment No"
                                  >
                                    {doc.docNo}{index < array.length - 1 ? ", " : ""}
                                  </Link>
                                ));
                              })()
                            ) : (
                              <span className="text-muted-foreground">OR No</span>
                            )}
                            <ScrollBar orientation="horizontal" className="h-1.5" />
                          </ScrollArea>
                        </div>
                        <div className="flex-1 invisible" /> {/* Make it align with row */}
                        <div className="flex-1 invisible" />
                      </div>

                      {/* Sixth Row */}
                      <div className="flex w-full items-center justify-center gap-x-2">
                        {/* UUID */}
                        <div className="flex flex-1 flex-col text-nowrap">
                          <FormField
                            control={form.control}
                            name="UUID"
                            render={({ field }) => (
                              <FormItem
                                className={`flex flex-col space-y-1 ${slug === "clone" ? "hidden" : ""}`}
                              >
                                <FormControl className="relative">
                                  <Input
                                    className="h-7 rounded-xl px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    {...field}
                                    readOnly={true}
                                    ref={inputRef}
                                    autoComplete="off"
                                    placeholder="UUID"
                                    title="UUID"
                                  />
                                </FormControl>
                                <FormMessage />
                              </FormItem>
                            )}
                          />
                        </div>
                      </div>
                    </div>
                  </TabPanel>
                </div>
                {/* Right - Vertical TabList */}
                <TabList className="ml-1 flex flex-col gap-y-1">
                  {[
                    {
                      icon: <IoDocumentOutline className="size-4.5" />,
                      label: "General Details",
                    },
                    {
                      icon: <HiOutlineClipboardDocumentList className="size-4.5" />,
                      label: "Mapping Reference",
                    },
                  ].map((item, index) => (
                    <Tab
                      key={index}
                      className="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-y-0.5 rounded-md border border-gray-200 bg-white text-[9px] text-gray-600 outline-none transition-all duration-200 ease-in-out"
                      selectedClassName="!bg-blue-300 border-blue-300 text-white"
                    >
                      <TooltipProvider delayDuration={1000}>
                        <Tooltip>
                          <TooltipTrigger asChild>
                            <span className="flex h-full w-full items-center justify-center">
                              {item.icon}
                            </span>
                          </TooltipTrigger>
                          <TooltipContent side="right" align="start">
                            {item.label}
                          </TooltipContent>
                        </Tooltip>
                      </TooltipProvider>
                    </Tab>
                  ))}
                </TabList>
              </div>
            </Tabs>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}