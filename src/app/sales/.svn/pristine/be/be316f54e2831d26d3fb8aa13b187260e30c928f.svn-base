"use client";

import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import type { ColumnDef } from "@tanstack/react-table";

export type ActivityLog = {
  code: string;
  name: string;
  type: string;
  description: string;
  attachment: string | null;
  valid: "0" | "1";
  attachmentLink?: {
    name: string;
    link: string;
  }[];
  attachmentFiles?: any[];
};

export const activityLogColumns: ColumnDef<ActivityLog>[] = [
  // Column Drag and Drop and Resize (Add id for each column)
  {
    id: "code",
    accessorKey: "code",
    header: "Code",
    filterFn: "includesString"
  },
  {
    id: "name",
    accessorKey: "name",
    header: "Name",
    filterFn: "includesString"
  },
  {
    id: "type",
    accessorKey: "type",
    header: "Type",
    filterFn: "includesString"
  },
  {
    id: "description",
    accessorKey: "description",
    header: "Description",
    filterFn: "includesString"
  },
  {
    id: "attachment",
    accessorKey: "attachment",
    header: "Attachment (.pdf, .png, .jpg, .jpeg)",
    cell: ({ row }) => {
      const attachment = row.original.attachment;
      const attachmentLinks = row.original.attachmentLink || [];
      const attachmentFiles = row.original.attachmentFiles || [];

      // Handle new records with attachmentFiles
      if (attachmentFiles.length > 0) {
        return attachmentFiles
          .map((file, index) => {
            const link = attachmentLinks?.find((al) => al.name === file.name);
            return link ? (
              <a
                key={index}
                href={link.link}
                target="_blank"
                rel="noopener noreferrer"
                style={{ color: "blue" }}
              >
                {file.name}
              </a>
            ) : (
              <span key={index} style={{ color: "blue" }}>
                {file.name}
              </span>
            );
          })
          .reduce(
            (prev, curr, index) => (index === 0 ? [curr] : [prev, ", ", curr]),
            []
          );
      }

      // Handle existing records with attachment JSON
      if (!attachment) {
        return <span>No attachment</span>;
      }

      try {
        const attachments = JSON.parse(attachment);

        if (!attachments || attachments.length === 0) {
          return <span>No attachment</span>;
        }

        return attachments
          .map((att, index) => {
            const link = attachmentLinks.find((al) => al.name === att.Name);
            return link ? (
              <a
                key={index}
                href={link.link}
                target="_blank"
                rel="noopener noreferrer"
                style={{ color: "blue" }}
              >
                {att.Name}
              </a>
            ) : (
              <span key={index} style={{ color: "gray" }}>
                {att.Name}
              </span>
            );
          })
          .reduce((prev, curr) => [prev, ", ", curr]);
      } catch (error) {
        return <span>No attachment</span>;
      }
    },
    filterFn: filterWithStringConversion,
  },
  {
    id: "createdAtFormat",
    accessorKey: "createdAtFormat",
    header: "Created At",
    filterFn: "includesString"
  },
  {
    id: "createdByUsername",
    accessorKey: "createdByUsername",
    header: "Created By",
    filterFn: "includesString"
  },
  {
    id: "updatedAtFormat",
    accessorKey: "updatedAtFormat",
    header: "Updated At",
    filterFn: "includesString"
  },
  {
    id: "updatedByUsername",
    accessorKey: "updatedByUsername",
    header: "Updated By",
    filterFn: "includesString"
  },
  {
    id: "valid",
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as ActivityLog["valid"];
      return validity === "1" ? "Valid" : "Invalid";
    },
    // Custom filter function that first convert the row's numeric boolean
    // value to string, then check if the string contains the filterValue
    filterFn: filterWithStringConversion,
  },
];