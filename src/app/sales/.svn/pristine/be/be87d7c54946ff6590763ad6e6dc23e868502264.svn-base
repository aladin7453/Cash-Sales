"use client";

import React, { useEffect, useRef, useState, memo } from "react";
import type { ColumnDef, Row, SortingState } from "@tanstack/react-table";
import {
  FaSort,
  FaSortDown,
  FaSortUp
} from "react-icons/fa6";
import {
  flexRender,
  getCoreRowModel,
  getFilteredRowModel,
  getPaginationRowModel,
  getSortedRowModel,
  useReactTable,
} from "@tanstack/react-table";

import { useSearchParams } from "next/navigation";

import NoResultsTableRow from "@/components/data-table/NoResultsTableRow";
import TableHeadColumnTextFilter from "@/components/data-table/TableHeadColumnTextFilter";
import { TableHeadValidityFilter } from "@/components/data-table/TableHeadValidityFilter";
import { Checkbox } from "@/components/ui/checkbox";
import { Input } from "@/components/ui/input";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import { Separator } from "@/components/ui/separator";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";

import { useHandleRowSelect } from "@/lib/hooks/useHandleRowSelect";
import usePreventShiftTextSelect from "@/lib/hooks/usePreventShiftTextSelect";
import { cn } from "@/lib/utils/cn";
import formatNumber from "@/lib/utils/data-table/formatNumber";
import {
  DEFAULT_DATA_TABLE_PAGE_SIZE,
  getAuthHeaders,
  ORIGIN,
  DATA_TABLE_DEFAULT_COLUMN_SIZING,
} from "@/lib/constants";

import DeliveryOrderDetailsDataTableToolbar from "./DataTableToolbarOld";
import { ServiceColumns, StockColumns } from "./itemColumns";
import ItemPopover from "./ItemPopover";
import { PackageColumns } from "./packageColumns";
import PackagePopover from "./PackagePopover";
import type { DeliveryOrder } from "./columns";

// Mobile View (Imports)
import MobileFormDataTable from "@/components/form/MobileFormDataTable";
import DataTableTotals from "@/components/form/MobileFormDataTableTotals";

// Drag and Drop (Imports)
import { DragDropDataTable, DraggableRow, useDragDropTable } from "@/components/data-table/row-drag-drop";

// Column Drag and Drop and Resize (Imports)
import type { MouseEvent, ColumnOrderState, ColumnSizingState, VisibilityState, Table as TableType } from "react";
import { closestCenter, DndContext } from "@dnd-kit/core";
import { horizontalListSortingStrategy, SortableContext } from "@dnd-kit/sortable";
import { ColumnResizer } from "@/components/data-table/ColumnResizer";
import DragableTableHead from "@/components/data-table/DragableTableHead";
import { useColumnSizeVars } from "@/lib/hooks/useColumnSizeVars";
import { useDndSensors } from "@/lib/hooks/useDndSensors";
import useLocalStorage from "@/lib/hooks/useLocalStorage";
import getExcludedColumns from "@/lib/utils/data-table/getExcludedColumns";
import handleDndDragEnd from "@/lib/utils/data-table/handleDndDragEnd";
import { DragHandle } from "@/components/data-table/row-drag-drop";

// Selling Price History Popover (Imports)
import SellingPriceHistoryPopover from "@/components/features/sales-purchase-transaction/selling-price-history-popover/sellingPriceHistoryPopover";

// Serial Number Popover (Imports)
import SerialNumberPopover from "@/components/features/sales-purchase-transaction/serial-number-popover/serialNumberPopover";

// Refactor Charges Details Input Cell (Imports)
import {
  UOMDropdownInputCell,
  NumberInputCellComponent,
  TextInputCellComponent,
  DescriptionInputCellComponent,
  DateInputCellComponent,
  DropdownInputCellComponent
} from "@/components/features/sales-purchase-transaction/charges-details/inputCell";

type DataTableProps = {
  columns: ColumnDef<DeliveryOrder>[];
  data: DeliveryOrder[];
  tempRowDeliveryOrderDetailsList: any;
  setTempRowDeliveryOrderDetailsList: (data: any) => void;
  revalidateDeliveryOrderDetails: () => void;
  form: any;
  deliveryOrderData: any;
  UOMDetails: any[];
  slug: string;
  preferenceData: any;
};

// Column Drag and Drop and Resize (Local Storage Keys)
const COLUMN_ORDERING_KEY = "sales-delivery-order.details.bs.table.ordering";
const COLUMN_SIZING_KEY = "sales-delivery-order.details.bs.table.sizing";
const COLUMN_VISIBILITY_KEY = "sales-delivery-order.details.bs.table.columns";

// HTML Utility Function
function stripHtml(html) {
  if (!html) return "";
  // Replace <br> and <br/> with newlines
  let text = html.replace(/<br\s*\/?>/gi, '\n');
  // Replace <p> with nothing, </p> with newline
  text = text.replace(/<p[^>]*>/gi, '').replace(/<\/p>/gi, '\n');
  // Remove all other HTML tags
  text = text.replace(/<[^>]+>/g, '');
  // Replace HTML entities
  text = text.replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&');

  return text;
};

export default function DeliveryOrderDetailsDataTable({
  columns,
  data,
  tempRowDeliveryOrderDetailsList,
  setTempRowDeliveryOrderDetailsList,
  revalidateDeliveryOrderDetails,
  form,
  deliveryOrderData,
  UOMDetails,
  slug,
  preferenceData
}: DataTableProps) {
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const headers = getAuthHeaders();

  // Column Drag and Drop and Resize (Constants)
  const initialColumnOrder = columns?.filter(column => column?.id).map((column) => column.id!) || [];
  const [columnOrder, setColumnOrder] = useLocalStorage<ColumnOrderState>(
    COLUMN_ORDERING_KEY,
    initialColumnOrder
  );
  const [columnSizing, setColumnSizing] = useLocalStorage<ColumnSizingState>(
    COLUMN_SIZING_KEY,
    {}
  );
  const defaultColumns: Array<keyof DeliveryOrder> = [
    "itemCode",
    "itemName",
    "type",
    "quantity",
    "price",
    "subtotalTax",
  ];
  const defaultColumnVisibility: VisibilityState = getExcludedColumns(
    columns || [],
    defaultColumns
  );
  const [columnVisibility, setColumnVisibility] = useLocalStorage<VisibilityState>(
    COLUMN_VISIBILITY_KEY,
    defaultColumnVisibility
  );

  // Accurate Currency Rate Update
  const [currentCurrencyRate, setCurrentCurrencyRate] = useState<number>(1);

  function setTempRowDeliveryOrderDetailsListData(data, overwrite) {
    if (overwrite) {
      // Ensure first row always has master and showTemplate set to "1"
      const updatedData = data.map((item, index) => ({
        ...item,
        master: index === 0 ? "1" : item.master || "0",
        showTemplate: index === 0 ? "1" : item.showTemplate || "0",
      }));

      setTempRowDeliveryOrderDetailsList(updatedData);
    } else {
      const newData = Array.isArray(data) ? data : [data];

      setTempRowDeliveryOrderDetailsList((tempRowDeliveryOrderDetailsList) => {
        const existingData = [...tempRowDeliveryOrderDetailsList];
        const updatedData = [...existingData, ...newData];

        // Ensure first row always has master and showTemplate set to "1"
        return updatedData.map((item, index) => ({
          ...item,
          master: index === 0 ? "1" : item.master || "0",
          showTemplate: index === 0 ? "1" : item.showTemplate || "0",
        }));
      });
    }
  }

  const [sorting, setSorting] = useState<SortingState>([]);
  const [rowSelection, setRowSelection] = useState({});

  // Drag and Drop (State & Functions)
  const [refreshKey, setRefreshKey] = useState(0);

  // Use tempRowDeliveryOrderDetailsList if it exists, otherwise use data
  const tableData = (tempRowDeliveryOrderDetailsList) || slug === "clone"
    ? tempRowDeliveryOrderDetailsList
    : data;

  const {
    items,
    activeId,
    isDragging,
    handleDragStart,
    handleDragEnd,
    getRowId,
  } = useDragDropTable({
    data: tableData,
    onReorder: (newData) => {
      // Update sequence numbers for all items based on their new order
      const dataWithUpdatedSeq = newData.map((item, index) => {
        const updatedItem = {
          ...item,
          seq: (index + 1).toString(), // Update seq to reflect new order (1-based)
        };

        // Always set first row as master and show in PDF
        if (index === 0) {
          updatedItem.master = "1";
          updatedItem.showTemplate = "1";
        }

        return updatedItem;
      });

      // Update the data immediately and force re-render
      setTempRowDeliveryOrderDetailsList(dataWithUpdatedSeq);

      // Update checkbox states based on new order
      const newMasterStates = {};
      const newShowInPDFStates = {};

      dataWithUpdatedSeq.forEach((item, index) => {
        newMasterStates[index] = item.master || "0";
        newShowInPDFStates[index] = item.showTemplate || "0";
      });

      setMasterServiceStates(newMasterStates);
      setShowInPDFStates(newShowInPDFStates);

      // Force table to update by incrementing refresh key
      setRefreshKey(prev => prev + 1);
    },
    idField: "UUID",
    disabled: false,
  });

  // Column Drag and Drop and Resize (Data Table)
  const table = useReactTable({
    columns,
    data: tableData,
    state: {
      sorting,
      columnVisibility,
      rowSelection,
      columnOrder,
      columnSizing,
    },
    onSortingChange: setSorting,
    onColumnVisibilityChange: setColumnVisibility,
    onRowSelectionChange: setRowSelection,
    onColumnOrderChange: setColumnOrder,
    onColumnSizingChange: setColumnSizing,
    enableRowSelection: true,
    autoResetPageIndex: false,
    columnResizeMode: "onChange",
    defaultColumn: DATA_TABLE_DEFAULT_COLUMN_SIZING,
    enableColumnResizing: true,
    getCoreRowModel: getCoreRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    getSortedRowModel: getSortedRowModel(),
    getRowId: (row, index) => getRowId(row, index),
    initialState: {
      pagination: {
        pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
      },
      columnVisibility: JSON.parse(localStorage.getItem(COLUMN_VISIBILITY_KEY) || "{}"),
    },
  });

  const sensors = useDndSensors();
  const columnSizeVars = useColumnSizeVars(table);

  useEffect(() => {
    localStorage.setItem(COLUMN_VISIBILITY_KEY, JSON.stringify(columnVisibility));
  }, [columnVisibility]);

  const [dialogOpen, setDialogOpen] = useState(false);
  const [itemData, setItemData] = useState([]);
  const [packageDialogOpen, setPackageDialogOpen] = useState(false);
  const [packageData, setPackageData] = useState([]);
  const [taxInclusiveStates, setTaxInclusiveStates] = useState({});
  const [masterServiceStates, setMasterServiceStates] = useState({});
  const [showInPDFStates, setShowInPDFStates] = useState({});
  const [itemType, setItemType] = useState("stock");
  const [textInputs, setTextInputs] = useState({});
  const [UOMInputs, setUOMInputs] = useState<Record<string, string>>({});
  const [UOM2Inputs, setUOM2Inputs] = useState<Record<string, string>>({});
  const [UOM3Inputs, setUOM3Inputs] = useState<Record<string, string>>({});
  const [numberInputs, setNumberInputs] = useState({});
  const [moreDescriptions, setMoreDescriptions] = useState({});
  const [showTables, setShowTables] = useState({});
  const [dropdownDatas, setDropdownDatas] = useState({});
  const [dropdownInputDatas, setDropdownInputDatas] = useState({});

  // Selling Price History Popover (State)
  const [priceHistoryDialogOpen, setPriceHistoryDialogOpen] = useState(false);
  const [selectedItemForPriceHistory, setSelectedItemForPriceHistory] = useState<string>("");

  // Serial Number Popover (State)
  const [serialNumberDialogOpen, setSerialNumberDialogOpen] = useState(false);
  const [selectedRowForSerialNumber, setSelectedRowForSerialNumber] = useState<any>(null);

  const dropdownTableColumns = {
    classificationCode: [
      { accessorKey: "classificationCode", header: "Classification Code" },
      { accessorKey: "description", header: "Description" },
    ],
    locationCode: [
      { accessorKey: "locationCode", header: "Location Code" },
      { accessorKey: "locationName", header: "Location Name" },
      { accessorKey: "locationType", header: "Location Type" },
      { accessorKey: "description", header: "Description" },
    ],
    projectCode: [
      { accessorKey: "projectCode", header: "Project Code" },
      { accessorKey: "description", header: "Description" },
    ],
    taxCode: [
      { accessorKey: "taxCode", header: "Tax Code" },
      { accessorKey: "taxTypeCode", header: "Tax Type" },
      { accessorKey: "taxRate", header: "Tax Rate" },
      { accessorKey: "description", header: "Description" },
    ],
    stockBatchCode: [
      { accessorKey: "stockBatchCode", header: "Stock Batch Code" },
      { accessorKey: "manufactureDate", header: "Manufacture Date" },
      { accessorKey: "expiryDate", header: "Expiry Date" },
      { accessorKey: "description", header: "Description" },
    ],
    customerCodeCode: [
      { accessorKey: "customerCode", header: "Customer Code" },
      { accessorKey: "customerGroupCode", header: "Customer Group" },
      { accessorKey: "customerName", header: "Customer Name" },
      { accessorKey: "BRN", header: "BRN" },
    ],
  };

  usePreventShiftTextSelect();

  const onDoubleClick = (row: Row<DeliveryOrder>) => { };

  const onRowSelection = useHandleRowSelect(table, onDoubleClick);

  const itemTable = useReactTable({
    columns: itemType === "service" ? ServiceColumns : StockColumns,
    data: itemData,
    autoResetPageIndex: false,
    getCoreRowModel: getCoreRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    initialState: {
      pagination: {
        pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
      },
    },
  });

  const handleOnAdd = async () => {
    setDialogOpen(true);

    await fetchItemData(itemType);
  };

  const fetchItemData = async (itemType: string) => {
    try {
      const apiUrl = currentCompanyUUID
        ? `${ORIGIN}/universal/get-all-item-details?itemType=${itemType}&byCompany=${currentCompanyUUID}`
        : `${ORIGIN}/universal/get-all-item-details?itemType=${itemType}`;

      const response = await fetch(apiUrl, {
        method: "POST",
        headers,
      });

      if (!response.ok) {
        throw new Error("Failed to create new service category data");
      }
      const responseData = await response.json();
      setItemData(responseData.rows);
      setItemType(itemType);
    } catch (error) {
      console.error(`Failed to fetch ${itemType} data`);
    }
  };

  const handleOnPackage = async () => {
    setPackageDialogOpen(true);

    fetchPackageData();
  };

  const fetchPackageData = async () => {
    try {
      const response = await fetch(`${ORIGIN}/universal/get-all-package`, {
        headers: headers,
      });

      if (!response.ok) {
        throw new Error("Failed to create fetch package data");
      }

      const responseData = await response.json();

      setPackageData(responseData.rows);
    } catch (error) {
      console.error(`Failed to fetch ${itemType} data`);
    }
  };

  useEffect(() => {
    if (data) {
      table.getRowModel().rows.forEach((row, index) => {
        setTaxInclusiveStates((taxInclusiveStates) => ({
          ...taxInclusiveStates,
          [index]: row.original.taxInclusive,
        }));

        setMasterServiceStates((masterServiceStates) => ({
          ...masterServiceStates,
          [index]: row.original.master,
        }));

        setShowInPDFStates((showInPDFStates) => ({
          ...showInPDFStates,
          [index]: row.original.showTemplate,
        }));
      });
    }
  }, [data]);

  const handleTaxInclusiveCheckedChanged = (rowIndex, isChecked, row) => {
    const value = isChecked ? "1" : "0";

    setTaxInclusiveStates((taxInclusiveStates) => ({
      ...taxInclusiveStates,
      [rowIndex]: value,
    }));

    row.original.taxInclusive = value;

    setTempRowDeliveryOrderDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if (idx === rowIndex) {
          return { ...item, taxInclusive: value };
        }
        return item;
      })
    );
  };

  const handleMasterServiceCheckedChanged = (rowIndex, isChecked, row) => {
    // Prevent unchecking master service for the first row
    if (rowIndex === 0 && !isChecked) {
      return;
    }

    const value = isChecked ? "1" : "0";

    setMasterServiceStates((masterServiceStates) => ({
      ...masterServiceStates,
      [rowIndex]: value,
    }));

    // If Master Service is checked, ensure Show in PDF is checked
    if (isChecked) {
      setShowInPDFStates((showInPDFStates) => ({
        ...showInPDFStates,
        [rowIndex]: "1",
      }));

      // Update temp data
      setTempRowDeliveryOrderDetailsList((prevList) =>
        prevList.map((item, idx) => {
          if (idx === rowIndex) {
            return { ...item, master: value, showTemplate: "1" };
          }
          return item;
        })
      );
    } else {
      // Update temp data
      setTempRowDeliveryOrderDetailsList((prevList) =>
        prevList.map((item, idx) => {
          if (idx === rowIndex) {
            return { ...item, master: value };
          }
          return item;
        })
      );
    }

    row.original.master = value;
    if (isChecked) {
      row.original.showTemplate = "1";
    }
  };

  const handleShowInPDFCheckedChanged = (rowIndex, isChecked, row) => {
    // Prevent unchecking Show in PDF for the first row
    if (rowIndex === 0 && !isChecked) {
      return;
    }

    // 'Show in PDF' can only be unchecked if 'Master Service' is unchecked
    if (masterServiceStates[rowIndex] === "1" && !isChecked) {
      return;
    }

    const value = isChecked ? "1" : "0";

    setShowInPDFStates((showInPDFStates) => ({
      ...showInPDFStates,
      [rowIndex]: value,
    }));

    // Update temp data
    setTempRowDeliveryOrderDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if (idx === rowIndex) {
          return { ...item, showTemplate: value };
        }
        return item;
      })
    );

    row.original.showTemplate = value;
  };

  const calculateTotal = (field: string) => {
    let total = 0;

    // Three Discount (Total Calculation)
    table.getPrePaginationRowModel().rows.forEach((row) => {
      if (field === "discountAmount") {
        // For discount amount, sum all three tiers
        const discount1 = Number(row.original.discountAmount) || 0;
        const discount2 = Number(row.original.discountAmount2) || 0;
        const discount3 = Number(row.original.discountAmount3) || 0;
        total += discount1 + discount2 + discount3;
      } else if (row.original[field]) {
        total += Number(row.original[field]);
      }
    });

    // If the field is "quantity", return the total as an integer
    if (field === "quantity") {
      return Math.round(total).toString();
    }

    return total.toFixed(2);
  };

  const calculateNetTotal = (convertToLocal: boolean) => {
    let total = 0;

    table.getPrePaginationRowModel().rows.forEach((row) => {
      total += Number(row.original.subtotalTax ?? 0);
    });

    total = Math.round(total * 20) / 20;

    if (convertToLocal) {
      total *= currentCurrencyRate; // Accurate Currency Rate Update
    }

    return total.toFixed(2);
  };

  // Refactor Charges Details Input Cell (Start)
  const textInputCell = ({ row, column: { id } }, className: string = "h-7.5") => {
    return (
      <TextInputCellComponent
        row={row}
        column={{ id }}
        className={className}
        setTextInputs={setTextInputs}
        setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
      />
    );
  };

  const descriptionInputCell = ({ row, column: { id } }, className: string = "h-7.5 p-0") => {
    return (
      <DescriptionInputCellComponent
        row={row}
        column={{ id }}
        className={className}
        setTextInputs={setTextInputs}
        setMoreDescriptions={setMoreDescriptions}
        setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
      />
    );
  };

  const UOMDropdownCell = ({ row, column: { id } }) => {
    return (
      <UOMDropdownInputCell
        row={row}
        column={{ id }}
        UOMInputs={UOMInputs}
        setUOMInputs={setUOMInputs}
        UOM2Inputs={UOM2Inputs}
        setUOM2Inputs={setUOM2Inputs}
        UOM3Inputs={UOM3Inputs}
        setUOM3Inputs={setUOM3Inputs}
        setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
      />
    );
  };

  const dateInputCell = ({ row, column: { id } }) => {
    return (
      <DateInputCellComponent
        row={row}
        column={{ id }}
        setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
      />
    );
  };

  const dropDownInputCell = ({ row, column: { id } }) => {
    return (
      <DropdownInputCellComponent
        row={row}
        column={{ id }}
        dropdownDatas={dropdownDatas}
        setDropdownDatas={setDropdownDatas}
        dropdownInputDatas={dropdownInputDatas}
        setDropdownInputDatas={setDropdownInputDatas}
        showTables={showTables}
        setShowTables={setShowTables}
        setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
        fetchDropdownData={fetchDropdownData}
        dropdownTableColumns={dropdownTableColumns}
        inputRef={inputRef}
        dropdownRef={dropdownRef}
      />
    );
  };

  const numberInputCell = ({ row, column: { id } }, allowDecimal: boolean) => {
    return (
      <NumberInputCellComponent
        row={row}
        column={{ id }}
        allowDecimal={allowDecimal}
        // preferenceData={preferenceData}
        setNumberInputs={setNumberInputs}
        setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
        onPriceHistoryClick={(itemId) => {
          setSelectedItemForPriceHistory(itemId);
          setPriceHistoryDialogOpen(true);
        }}
        onSerialNumberClick={(row) => {
          setSelectedRowForSerialNumber(row);
          setSerialNumberDialogOpen(true);
        }}
      />
    );
  };
  // Refactor Charges Details Input Cell (End)

  const [currentCompanyUUID, setCurrentCompanyUUID] = useState<string | null>(null);

  useEffect(() => {
    const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");

    if (currentCompany && currentCompany.UUID) {
      setCurrentCompanyUUID(currentCompany.UUID);
    } else {
      setCurrentCompanyUUID(null);
    }
  }, []);

  const fetchDropdownData = async (table: string) => {
    try {
      var form_data = new FormData();

      table == "customerCodeCode" ? form_data.append(`table[0]`, table.slice(0, -8)) : form_data.append(`table[0]`, table.slice(0, -4));

      const apiUrl = currentCompanyUUID
        ? `${ORIGIN}/universal/get-all-drop-down-table-data?byCompany=${currentCompanyUUID}`
        : `${ORIGIN}/universal/get-all-drop-down-table-data`;

      const response = await fetch(apiUrl, {
        method: "POST",
        headers,
        body: form_data,
      });

      if (!response.ok) {
        throw new Error("Failed to fetch dropdown data");
      }

      const data = await response.json();
      if (table == "customerCodeCode") {
        data.rows = data.rows.map((row) => {
          return {
            ...row,
            customerCodeCode: row.customerCode,
          }
        })
      }

      setDropdownDatas((dropdownDatas) => ({ ...dropdownDatas, [table]: data.rows }));
    } catch (error) {
      console.error("Error fetching dropdown data:", error);

      throw new Error("Failed to fetch dropdown data");
    }
  };

  const inputRef = useRef(null);
  const dropdownRef = useRef(null);

  const handleClickOutside = (event) => {
    if (
      dropdownRef.current &&
      !dropdownRef.current.contains(event.target) &&
      inputRef.current !== event.target
    ) {
      setShowTables(false);
    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);

    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);

  const updateItem = async (prop) => {
    const now = new Date();
    const startDayTs = Math.floor(now.getTime() / 1000);    // Start = now (seconds)
    const lastDayTs = Math.floor(
      new Date(
        now.getFullYear(),
        now.getMonth() + 1,
        0,
        23, 59, 59, 999
      ).getTime() / 1000
    ); // End = end of last day of current month (seconds)
    try {
      const formData = new FormData();

      let selectedRowModel = Array(0);
      if (prop.table) {
        // Selection Order (Logic)
        if (prop.selectionOrder && prop.selectionOrder.length > 0) {
          // Create a map of selected rows for quick lookup
          const selectedRowsMap = new Map(
            prop.table.getSelectedRowModel().rows.map(row => [row.id, row])
          );
          // Reorder selected rows based on selection order
          selectedRowModel = prop.selectionOrder
            .filter(rowId => selectedRowsMap.has(rowId))
            .map(rowId => selectedRowsMap.get(rowId));
        } else {
          // Fallback to default table order if no selection order is provided
          selectedRowModel = prop.table.getSelectedRowModel().rows;
        }
      } else {
        selectedRowModel.push(prop.row);
      }

      // Calculate totals from all rows in the table
      let totalAmount = table.getFilteredRowModel().rows.reduce((sum, row) => {
        return sum + (row.original.amount ? parseFloat(row.original.amount) : 0);
      }, 0);

      let totalDiscount = table.getFilteredRowModel().rows.reduce((sum, row) => {
        return sum + (row.original.discountAmount ? parseFloat(row.original.discountAmount) : 0);
      }, 0);

      let totalDiscount2 = table.getFilteredRowModel().rows.reduce((sum, row) => {
        return sum + (row.original.discountAmount2 ? parseFloat(row.original.discountAmount2) : 0);
      }, 0);

      let totalDiscount3 = table.getFilteredRowModel().rows.reduce((sum, row) => {
        return sum + (row.original.discountAmount3 ? parseFloat(row.original.discountAmount3) : 0);
      }, 0);


      let totalTax = table.getFilteredRowModel().rows.reduce((sum, row) => {
        return sum + (row.original.taxAmount ? parseFloat(row.original.taxAmount) : 0);
      }, 0);

      const finalTotalDiscount = totalDiscount + totalDiscount2 + totalDiscount3

      if (!prop.isUpdate) {
        // Add selected items
        selectedRowModel.forEach((row) => {
          totalAmount += row.original.refPrice ? parseFloat(row.original.refPrice) : 0;
        });
      }

      const subtotalTax = totalAmount - finalTotalDiscount + totalTax;
      const roundTotalPayable = Math.round(subtotalTax * 20) / 20;
      const localNetTotal = roundTotalPayable * currentCurrencyRate

      const roundingAmount = roundTotalPayable - subtotalTax;

      // Create deliveryOrder object with totals
      const deliveryOrderData = {
        totalAmount: totalAmount.toFixed(2),
        totalDiscount: finalTotalDiscount.toFixed(2),
        totalTax: totalTax.toFixed(2),
        totalSubtotal: (totalAmount - finalTotalDiscount).toFixed(2),
        totalPayable: roundTotalPayable.toFixed(2),
        outstandingAmount: roundTotalPayable.toFixed(2), // Set outstanding amount to subtotal tax
        localNetTotal: localNetTotal.toFixed(2),
        netTotal: roundTotalPayable.toFixed(2),
        roundingAmount: roundingAmount.toFixed(2)
      };

      // Get current delivery order details
      let deliveryOrderHasDetailsData = [];

      if (prop.isUpdate) {
        // For updates, use the current table data
        deliveryOrderHasDetailsData = table.getFilteredRowModel().rows.map(row => row.original);
      } else {
        // For new items, add selected items to existing data
        const existingData = table.getFilteredRowModel().rows.map(row => row.original);

        // Selection Order (Add Index and Sequence)
        const newItems = selectedRowModel.map((row, index) => {
          const item = row.original;

          // Get the maximum existing sequence number
          const existingData = table.getFilteredRowModel().rows.map(row => row.original);
          const maxSeq = existingData.length > 0
            ? Math.max(...existingData.map(item => parseInt(item.seq) || 0))
            : 0;

          return {
            UUID: "",
            seq: (maxSeq + index + 1).toString(),
            item: item.UUID,
            itemCode: prop.itemType === "service" ? item.serviceCode : item.stockCode,
            type: prop.itemType === "service" ? "Service" : "Stock",
            description: stripHtml(item.description) || "",
            "2ndDescription": stripHtml(item["2ndDescription"]) || "",
            moreDescription: stripHtml(item.moreDescription) || "",
            itemGroup: prop.itemType === "service" ? item.serviceGroupCodeCode : item.stockGroupCodeCode,
            itemCategory: prop.itemType === "service" ? item.serviceCategoryCodeCode : item.stockCategoryCodeCode,
            tariff: null,
            classification: item.classification || "",
            permitNo: null,
            project: form.getValues("project") || "",
            quantity: 1,
            quantity2: 1,
            quantity3: 1,
            UOM: item.defaultUOMSales || "",
            rate: prop.itemType === "stock" ? null : undefined,
            price: item.promotionPrice || "",
            discountRate: "",
            discountAmount: "",
            tax: null,
            deliveryDate: "",
            billingFrequency: prop.itemType === "service" ? item.billingFrequency : null,
            billingInterval: prop.itemType === "service" ? item.billingInterval : null,
            startAt: preferenceData?.data?.deliveryOrderDefaultDate == "1" ? startDayTs : "",
            endAt: preferenceData?.data?.deliveryOrderDefaultDate == "1" ? lastDayTs : "",
            remark1: "",
            remark2: "",
            amount: item.refPrice || "",
            subTotal: item.refPrice || "",
            subtotalTax: item.refPrice || "",
            taxableAmount: item.refPrice || "",
            amountExclTax: item.refPrice || "",
            amountInclTax: item.refPrice || "",
          };
        });

        deliveryOrderHasDetailsData = [...existingData, ...newItems];
      }

      // Combine deliveryOrder and deliveryOrderHasDetails into single data object
      const combinedData = {
        deliveryOrder: deliveryOrderData,
        deliveryOrderHasDetails: deliveryOrderHasDetailsData
      };

      // Add combined data as JSON string
      formData.append('data', JSON.stringify(combinedData));

      const response = await fetch(
        `${ORIGIN}/delivery_order/api/delivery-order/update-delivery-order-has-details?deliveryOrderUUID=${id}`,
        {
          method: "POST",
          headers,
          body: formData,
        },
      );

      if (!response.ok) {
        throw new Error("Failed to update user list data");
      }
      revalidateDeliveryOrderDetails();
    } catch (error) {
      console.error("Error updating service data:", error);
    }
  };

  // Mobile View (Field Configurations)
  const mobileFieldConfigs = {
    description: {
      type: 'text' as const,
      label: 'Description',
      colSpan: 2 as const
    },
    '2ndDescription': {
      type: 'text' as const,
      label: '2nd Description',
      colSpan: 2 as const
    },
    moreDescription: {
      type: 'text' as const,
      label: 'More Description',
      colSpan: 2 as const
    },
    quantity: {
      type: 'number' as const,
      label: 'Quantity[1]',
      allowDecimal: false
    },
    quantity2: {
      type: 'number' as const,
      label: 'Quantity[2]',
      allowDecimal: false
    },
    quantity3: {
      type: 'number' as const,
      label: 'Quantity[3]',
      allowDecimal: false
    },
    price: {
      type: 'number' as const,
      label: 'Price',
      allowDecimal: true,
    },
    discountRate: {
      type: 'number' as const,
      label: 'Discount %',
      allowDecimal: true
    },
    discountAmount: {
      type: 'number' as const,
      label: 'Discount Amount',
      allowDecimal: true
    },
    startAt: {
      type: 'date' as const,
      label: 'Start Date'
    },
    endAt: {
      type: 'date' as const,
      label: 'End Date'
    },
    taxInclusive: {
      type: 'checkbox' as const,
      label: 'Tax Inclusive'
    },
    master: {
      type: 'checkbox' as const,
      label: 'Master Service'
    },
    showTemplate: {
      type: 'checkbox' as const,
      label: 'Show in PDF'
    },
    UOM: {
      type: 'uom' as const,
      label: 'UOM[1]'
    },
    UOM2: {
      type: 'uom2' as const,
      label: 'UOM[2]'
    },
    UOM3: {
      type: 'uom3' as const,
      label: 'UOM[3]'
    },
    itemUOM: {
      type: 'uom' as const,
      label: 'Item UOM[1]'
    },
    itemUOM2: {
      type: 'uom2' as const,
      label: 'Item UOM[2]'
    },
    itemUOM3: {
      type: 'uom3' as const,
      label: 'Item UOM[3]'
    },
    permitNo: {
      type: 'text' as const,
      label: 'Permit No'
    },
    remark1: {
      type: 'text' as const,
      label: 'Remark 1',
      colSpan: 2 as const
    },
    remark2: {
      type: 'text' as const,
      label: 'Remark 2',
      colSpan: 2 as const
    },

    // Readonly fields
    subtotalTax: { type: 'readonly' as const, label: 'Subtotal Tax' },
    itemGroupCode: { type: 'readonly' as const, label: 'Item Group' },
    itemCategoryCode: { type: 'readonly' as const, label: 'Item Category' },
    itemRate: { type: 'readonly' as const, label: 'Item Rate' },
    amount: { type: 'readonly' as const, label: 'Amount' },
    subTotal: { type: 'readonly' as const, label: 'Subtotal' },
    taxRate: { type: 'readonly' as const, label: 'Tax Rate' },
  };

  const handleMobileFieldChange = (rowId: string, fieldId: string, value: any) => {
    const rowIndex = parseInt(rowId);
    const row = table.getRowModel().rows[rowIndex];

    if (!row) return;

    // Update the row's original data
    row.original[fieldId] = value;

    // Multi-UOM calculation logic - multiply all quantities with price
    if (fieldId === "price" || fieldId === "quantity" || fieldId === "quantity2" || fieldId === "quantity3") {
      const quantity1 = Number(row.original.quantity) || 0;
      const quantity2 = Number(row.original.quantity2) || (row.original.type === "Stock" ? 1 : row.original.quantity2 === 0 ? 0 : 1);
      const quantity3 = Number(row.original.quantity3) || (row.original.type === "Stock" ? 1 : row.original.quantity3 === 0 ? 0 : 1);
      const price = Number(row.original.price) || 0;

      // Calculate total amount: Quantity1 × Quantity2 × Quantity3 × Price
      const totalAmount = quantity1 * quantity2 * quantity3 * price;

      if (row.original.discountRate) {
        row.original.discountAmount = ((totalAmount * Number(row.original.discountRate)) / 100).toFixed(2).toString();
      }
    } else if (fieldId === "discountRate" && value) {
      const quantity1 = Number(row.original.quantity) || 0;
      const quantity2 = Number(row.original.quantity2) || (row.original.type === "Stock" ? 1 : row.original.quantity2 === 0 ? 0 : 1);
      const quantity3 = Number(row.original.quantity3) || (row.original.type === "Stock" ? 1 : row.original.quantity3 === 0 ? 0 : 1);
      const price = Number(row.original.price) || 0;
      const totalAmount = quantity1 * quantity2 * quantity3 * price;

      if (totalAmount > 0) {
        row.original.discountAmount = ((totalAmount * Number(value)) / 100).toFixed(2).toString();
      }
    } else if (fieldId === "discountAmount" && value) {
      const quantity1 = Number(row.original.quantity) || 0;
      const quantity2 = Number(row.original.quantity2) || (row.original.type === "Stock" ? 1 : row.original.quantity2 === 0 ? 0 : 1);
      const quantity3 = Number(row.original.quantity3) || (row.original.type === "Stock" ? 1 : row.original.quantity3 === 0 ? 0 : 1);
      const price = Number(row.original.price) || 0;
      const totalAmount = quantity1 * quantity2 * quantity3 * price;

      if (totalAmount > 0) {
        row.original.discountRate = ((100 * Number(value)) / totalAmount).toFixed(2).toString();
      }
    }

    // Update tempRowDeliveryOrderDetailsList
    setTempRowDeliveryOrderDetailsList((prevList) =>
      prevList.map((item, idx) => {
        if ((item.UUID && item.UUID === row.original.UUID) || idx === row.index) {
          return { ...item, [fieldId]: value };
        }
        return item;
      }),
    );
  };

  const mobileCheckboxHandlers = {
    taxInclusive: handleTaxInclusiveCheckedChanged,
    master: handleMasterServiceCheckedChanged,
    showTemplate: handleShowInPDFCheckedChanged,
  };

  // Mobile View (Totals Configuration)
  const totalsConfig = {
    title: "Total",
    sections: [
      {
        fields: [
          {
            key: "noOfRecord",
            label: "No. of Record",
            value: table.getRowModel().rows ? table.getPrePaginationRowModel().rows.length : 0,
            readOnly: true,
          },
          {
            key: "quantity",
            label: "Quantity",
            value: table.getRowModel().rows ? calculateTotal("quantity") : 0,
            readOnly: true,
          },
          {
            key: "subtotal",
            label: "Subtotal",
            value: table.getRowModel().rows ? calculateTotal("subTotal") : 0,
            readOnly: true,
          },
          {
            key: "taxAmount",
            label: "Tax Amount",
            value: table.getRowModel().rows ? calculateTotal("taxAmount") : 0,
            readOnly: true,
          },
          {
            key: "subtotalTax",
            label: "Subtotal (Tax)",
            value: table.getRowModel().rows
              ? formatNumber(
                parseFloat(calculateTotal("subTotal")) +
                parseFloat(calculateTotal("taxAmount")),
              )
              : 0,
            readOnly: true,
          },
        ],
      },
      {
        fields: [
          {
            label: "Subtotal (e-Invoice)",
            value: table.getRowModel().rows ? calculateTotal("subTotalEInvoice") : 0,
            readOnly: true,
          },
          {
            key: "localNetTotal",
            label: "Local Net Total",
            value: table.getRowModel().rows ? calculateNetTotal(true) : 0,
            readOnly: true,
          },
          {
            key: "netTotal",
            label: "Net Total (RM)",
            value: table.getRowModel().rows ? calculateNetTotal(false) : 0,
            readOnly: true,
          },
        ],
      },
    ],
  };

  // Column Drag and Drop and Resize (Unified Drag Handler for Both Rows and Columns)
  const handleUnifiedDragEnd = (event) => {
    const { active, over } = event;

    if (!over || active.id === over.id) return;

    // Check if it's a column drag (column IDs are simple strings like "docNo", "description")
    const isColumnDrag = columnOrder.includes(active.id as string);

    if (isColumnDrag) {
      // Handle column drag
      handleDndDragEnd(event, setColumnOrder);
    } else {
      // Handle row drag
      handleDragEnd(event);
    }
  };

  // Three Discount (Row Calculations)
  // Real-Time Total Calculations (Calculation Function)
  const calculateRowValues = (rowData: any, rowIndex: number) => {
    // Multi-UOM Calculation Logic - multiply all quantities with price
    const quantity1 = rowData.quantity ? Number(rowData.quantity) : 0;
    const quantity2 = rowData.quantity2 ? Number(rowData.quantity2) : rowData.type == "Stock" ? 1 : rowData.quantity2 === 0 ? 0 : 1;
    const quantity3 = rowData.quantity3 ? Number(rowData.quantity3) : rowData.type == "Stock" ? 1 : rowData.quantity3 === 0 ? 0 : 1;

    const price = rowData.price ? Number(rowData.price) : 0;

    // Calculate total amount: Quantity1 × Quantity2 × Quantity3 × Price
    const totalAmount =
      (quantity1 ?? (rowData.type === "Stock" ? 1 : rowData.quantity === 0 ? 0 : 1)) *
      (quantity2 ?? (rowData.type === "Stock" ? 1 : rowData.quantity2 === 0 ? 0 : 1)) *
      (quantity3 ?? (rowData.type === "Stock" ? 1 : rowData.quantity3 === 0 ? 0 : 1)) *
      price;

    // Helper function to calculate discount amount from rate
    const calculateDiscountAmount = (rate: number, baseAmount: number) => {
      return (baseAmount * rate) / 100;
    };

    // Helper function to calculate discount rate from amount
    const calculateDiscountRate = (amount: number, baseAmount: number) => {
      return baseAmount > 0 ? (amount * 100) / baseAmount : 0;
    };

    // 3-tier discount calculation - preserve amounts when both rate and amount exist
    let currentAmount = totalAmount;
    let totalDiscountAmount = 0;

    // First discount - preserve existing amount if it exists
    if (rowData.discountAmount && Number(rowData.discountAmount) > 0) {
      // Use existing amount, calculate rate if needed
      if (!rowData.discountRate || Number(rowData.discountRate) === 0) {
        rowData.discountRate = calculateDiscountRate(Number(rowData.discountAmount), currentAmount).toFixed(2);
      }
      if (slug == "transfer-to" || slug == "transfer-from") {
        if (!rowData.fullQuantityTransfer) {
          rowData.discountAmount = calculateDiscountAmount(Number(rowData.discountRate), currentAmount).toFixed(2);
        }

      }
    } else if (rowData.discountRate && Number(rowData.discountRate) > 0) {
      // Calculate amount from rate
      rowData.discountAmount = calculateDiscountAmount(Number(rowData.discountRate), currentAmount).toFixed(2);
    }

    const discountAmount1 = Number(rowData.discountAmount) || 0;

    currentAmount -= discountAmount1;
    totalDiscountAmount += discountAmount1;

    // Second discount - preserve existing amount if it exists
    if (rowData.discountAmount2 && Number(rowData.discountAmount2) > 0) {
      // Use existing amount, calculate rate if needed
      if (!rowData.discountRate2 || Number(rowData.discountRate2) === 0) {
        rowData.discountRate2 = calculateDiscountRate(Number(rowData.discountAmount2), currentAmount).toFixed(2);
      }
      if (slug == "transfer-to" || slug == "transfer-from") {
        if (!rowData.fullQuantityTransfer) {
          rowData.discountAmount2 = calculateDiscountAmount(Number(rowData.discountRate2), currentAmount).toFixed(2);
        }

      }
    } else if (rowData.discountRate2 && Number(rowData.discountRate2) > 0) {
      // Calculate amount from rate
      rowData.discountAmount2 = calculateDiscountAmount(Number(rowData.discountRate2), currentAmount).toFixed(2);
    }

    const discountAmount2 = Number(rowData.discountAmount2) || 0;

    currentAmount -= discountAmount2;
    totalDiscountAmount += discountAmount2;

    // Third discount - preserve existing amount if it exists
    if (rowData.discountAmount3 && Number(rowData.discountAmount3) > 0) {
      // Use existing amount, calculate rate if needed
      if (!rowData.discountRate3 || Number(rowData.discountRate3) === 0) {
        rowData.discountRate3 = calculateDiscountRate(Number(rowData.discountAmount3), currentAmount).toFixed(2);
      }
      if (slug == "transfer-to" || slug == "transfer-from") {
        if (!rowData.fullQuantityTransfer) {
          rowData.discountAmount3 = calculateDiscountAmount(Number(rowData.discountRate3), currentAmount).toFixed(2);
        }

      }
    } else if (rowData.discountRate3 && Number(rowData.discountRate3) > 0) {
      // Calculate amount from rate
      rowData.discountAmount3 = calculateDiscountAmount(Number(rowData.discountRate3), currentAmount).toFixed(2);
    }

    const discountAmount3 = Number(rowData.discountAmount3) || 0;

    currentAmount -= discountAmount3;
    totalDiscountAmount += discountAmount3;

    // Helper function to safely parse tax rate
    function safeParseTaxRate(value) {
      if (!value) return 0;

      const parsed = parseFloat(value);

      return isNaN(parsed) ? 0 : parsed;
    }

    // Update tax and totals
    if (taxInclusiveStates[rowIndex] === "1") {
      rowData.amount = totalAmount;
      rowData.subTotalEInvoice = totalAmount;
      rowData.subTotal = totalAmount - totalDiscountAmount;
      rowData.taxAmount = parseFloat((rowData.subTotal * (safeParseTaxRate(rowData.taxRate) / 100)).toFixed(2));
      rowData.subtotalTax = rowData.subTotal;
    } else {
      rowData.amount = totalAmount;
      rowData.subTotalEInvoice = totalAmount;
      rowData.subTotal = totalAmount - totalDiscountAmount;
      rowData.taxAmount = parseFloat((rowData.subTotal * (safeParseTaxRate(rowData.taxRate) / 100)).toFixed(2));
      rowData.subtotalTax = rowData.subTotal + rowData.taxAmount;
    }

    // Fix: Taxable Amount = (Quantity * Price) - Discount
    rowData.taxableAmount = totalAmount - totalDiscountAmount;

    rowData.amountExclTax =
      (rowData.subTotal ? Number(rowData.subTotal) : 0) +
      (rowData.feeAmount ? Number(rowData.feeAmount) : 0);

    rowData.amountInclTax =
      (rowData.subtotalTax ? Number(rowData.subtotalTax) : 0) +
      (rowData.feeAmount ? Number(rowData.feeAmount) : 0);

    // Add local tax amount calculation using form currency rate
    const currencyRate = form.getValues("currencyRate");

    rowData.localTaxAmount = rowData.taxAmount * (currencyRate ? Number(currencyRate) : 1);

    return rowData;
  };

  // Real-Time Total Calculations (useEffect)
  useEffect(() => {
    if (tableData && tableData.length > 0) {
      const updatedData = tableData.map((rowData, index) => {
        // Accurate Currency Rate Update
        const calculatedRow = calculateRowValues({ ...rowData }, index);

        // Use fetched currency rate for local tax amount calculation
        calculatedRow.localTaxAmount = calculatedRow.taxAmount * currentCurrencyRate;

        if (Number.isNaN(calculatedRow.subtotalTax)) {
          calculatedRow.subtotalTax = 0;
        }
        if (Number.isNaN(calculatedRow.taxAmount)) {
          calculatedRow.taxAmount = 0;
        }
        if (Number.isNaN(calculatedRow.localTaxAmount)) {
          calculatedRow.localTaxAmount = 0;
        }

        return calculatedRow;
      });

      tableData.forEach((row, index) => {
        row.subtotalTax = row.subtotalTax ? Number(row.subtotalTax) : 0
        row.taxAmount = row.taxAmount ? Number(row.taxAmount) : 0
        row.localTaxAmount = row.localTaxAmount ? Number(row.localTaxAmount) : 0
      })

      // Only update if there are actual changes to prevent infinite loops
      const hasChanges = updatedData.some((newRow, index) => {
        const oldRow = tableData[index];
        return newRow.subtotalTax !== oldRow.subtotalTax ||
          newRow.taxAmount !== oldRow.taxAmount ||
          newRow.localTaxAmount !== oldRow.localTaxAmount;
      });

      if (hasChanges) {
        setTempRowDeliveryOrderDetailsList(updatedData);
      }
    }
  }, [
    tableData,
    taxInclusiveStates,
    currentCurrencyRate, // Accurate Currency Rate Update
    tempRowDeliveryOrderDetailsList,
  ]);

  // Accurate Currency Rate Update
  const fetchCurrentCurrencyRate = async (currencyUUID?: string) => {
    try {
      const targetCurrencyUUID = currencyUUID || form.getValues("currency");
      if (!targetCurrencyUUID) {
        setCurrentCurrencyRate(1);
        return;
      }

      const formData = new FormData();
      formData.append("table[0]", "currency");

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
        method: "POST",
        headers,
        body: formData,
      });

      if (response.ok) {
        const data = await response.json();
        const currency = data.rows?.find(row => row.UUID === targetCurrencyUUID);

        if (currency && currency.exchangeRateSales) {
          setCurrentCurrencyRate(Number(currency.exchangeRateSales));
        } else {
          setCurrentCurrencyRate(1);
        }
      } else {
        setCurrentCurrencyRate(1);
      }
    } catch (error) {
      console.error('Error fetching currency rate:', error);
      setCurrentCurrencyRate(1);
    }
  };

  // Accurate Currency Rate Update2
  const fetchCurrentCurrencyRate2 = async (currencyUUID?: string) => {
    const watchedCurrencyRate = form.getValues("currencyRate")
    watchedCurrencyRate ? setCurrentCurrencyRate(watchedCurrencyRate) : setCurrentCurrencyRate(1);

  };

  // Accurate Currency Rate Update
  useEffect(() => {
    fetchCurrentCurrencyRate2();
  }, [form.watch("currencyRate")]);

  return (
    <Card
      collapsible
      defaultCollapsed={false}
      className="h-auto p-0 shadow-md"
    >
      <CardHeader>
        <CardTitle className="text-lg font-bold">Charges Details</CardTitle>
      </CardHeader>
      <CardContent className="px-2 py-0">
        <div className="h-[98cqh] p-2 md:h-[58cqh]">
          <div className="flex h-[95cqh] flex-col rounded-md bg-erp-blue-3 @container-[size] md:h-[55cqh]">
            <DeliveryOrderDetailsDataTableToolbar
              table={table}
              onAdd={handleOnAdd}
              setTempRowDeliveryOrderDetailsListData={setTempRowDeliveryOrderDetailsListData}
              tempRowDeliveryOrderDetailsList={tempRowDeliveryOrderDetailsList}
              revalidateDeliveryOrderDetails={revalidateDeliveryOrderDetails}
              handleOnPackage={handleOnPackage}
              slug={slug}
            />
            <Separator className="bg-erp-blue-11" />
            <ScrollArea className="h-[100cqh] bg-erp-gray-3">
              {/* Mobile View (Form Data Table) */}
              <MobileFormDataTable
                table={table}
                headerFields={['itemCode', 'itemName']}
                fieldConfigs={mobileFieldConfigs}
                initialVisibleFields={4}
                onFieldChange={handleMobileFieldChange}
                checkboxHandlers={mobileCheckboxHandlers}
                UOMInputs={UOMInputs}
                setUOMInputs={setUOMInputs}
                UOM2Inputs={UOM2Inputs}
                setUOM2Inputs={setUOM2Inputs}
                UOM3Inputs={UOM3Inputs}
                setUOM3Inputs={setUOM3Inputs}
                setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
              />

              {/* Web View (Data Table) */}
              <div className="hidden md:block">
                {/* Column Drag and Drop (DnD Context) */}
                <DndContext
                  collisionDetection={closestCenter}
                  onDragStart={handleDragStart}
                  onDragEnd={handleUnifiedDragEnd}
                  sensors={sensors}
                >
                  {/* Row Drag and Drop (Data Table) */}
                  <DragDropDataTable
                    items={items}
                    disabled={false}
                    hasParentDndContext={true}
                  >
                    {/* Column Drag and Drop and Resize (Table) */}
                    <Table
                      className="table-fixed border-separate border-spacing-[3px] whitespace-nowrap border bg-erp-gray-1 overflow-visible"
                      style={{ ...columnSizeVars, width: table.getTotalSize() }}
                    >
                      <TableHeader className="sticky top-0 z-10">
                        {table.getHeaderGroups().map((headerGroup) => (
                          <TableRow key={headerGroup.id}>
                            {/* Column Drag and Drop and Resize (Sortable Context) */}
                            <SortableContext
                              items={columnOrder}
                              strategy={horizontalListSortingStrategy}
                            >
                              {headerGroup.headers.map((header) => (
                                // Column Drag and Drop and Resize (Dragable Table Head)
                                <DragableTableHead
                                  key={header.id}
                                  header={header}
                                  className="bg-erp-blue-11 font-normal"
                                  style={{
                                    width: `calc(var(--header-${header?.id}-size) * 1px)`,
                                  }}
                                >
                                  {header.column.id === "valid" ? (
                                    <TableHeadValidityFilter table={table} />
                                  ) : (
                                    <TableHeadColumnTextFilter
                                      column={header.column}
                                      table={table}
                                    />
                                  )}
                                  <ColumnResizer header={header} />
                                </DragableTableHead>
                              ))}
                            </SortableContext>
                          </TableRow>
                        ))}
                      </TableHeader>
                      {/* Column Drag and Drop and Resize (Table Body) */}
                      {table.getState().columnSizingInfo.isResizingColumn ? (
                        <MemoizedTableBody
                          table={table}
                          onRowSelection={onRowSelection}
                          getRowId={getRowId}
                          refreshKey={refreshKey}
                          taxInclusiveStates={taxInclusiveStates}
                          masterServiceStates={masterServiceStates}
                          showInPDFStates={showInPDFStates}
                          handleTaxInclusiveCheckedChanged={handleTaxInclusiveCheckedChanged}
                          handleMasterServiceCheckedChanged={handleMasterServiceCheckedChanged}
                          handleShowInPDFCheckedChanged={handleShowInPDFCheckedChanged}
                          descriptionInputCell={descriptionInputCell}
                          textInputCell={textInputCell}
                          numberInputCell={numberInputCell}
                          dropDownInputCell={dropDownInputCell}
                          dateInputCell={dateInputCell}
                          UOMDropdownCell={UOMDropdownCell}
                          form={form}
                          currentCurrencyRate={currentCurrencyRate} // Accurate Currency Rate Update
                        />
                      ) : (
                        <NonMemoizedTableBody
                          table={table}
                          onRowSelection={onRowSelection}
                          getRowId={getRowId}
                          refreshKey={refreshKey}
                          taxInclusiveStates={taxInclusiveStates}
                          masterServiceStates={masterServiceStates}
                          showInPDFStates={showInPDFStates}
                          handleTaxInclusiveCheckedChanged={handleTaxInclusiveCheckedChanged}
                          handleMasterServiceCheckedChanged={handleMasterServiceCheckedChanged}
                          handleShowInPDFCheckedChanged={handleShowInPDFCheckedChanged}
                          descriptionInputCell={descriptionInputCell}
                          textInputCell={textInputCell}
                          numberInputCell={numberInputCell}
                          dropDownInputCell={dropDownInputCell}
                          dateInputCell={dateInputCell}
                          UOMDropdownCell={UOMDropdownCell}
                          form={form}
                          currentCurrencyRate={currentCurrencyRate} // Accurate Currency Rate Update
                        />
                      )}
                    </Table>
                  </DragDropDataTable>
                </DndContext>
              </div>
              <ScrollBar orientation="horizontal" />
            </ScrollArea>

            {/* Mobile View (Totals) */}
            <DataTableTotals {...totalsConfig} />

            {/* Web View (Totals) */}
            <div className="hidden flex-grow flex-row bg-white md:flex">
              <div className="flex flex-grow flex-row bg-white">
                <div className="flex flex-grow flex-row border-2 border-solid border-erp-blue-18">
                  <div className="flex w-max items-center justify-center bg-erp-blue-14 px-[1rem] text-white">
                    Total
                  </div>

                  <div className="flex flex-col justify-start px-[0.5rem]">
                    <p className="text-left text-sm">No. of Record:</p>
                    <Input
                      className="h-3 w-28 text-right text-sm"
                      readOnly
                      value={table.getRowModel().rows ? table.getPrePaginationRowModel().rows.length : 0}
                    />
                  </div>
                  <div className="flex flex-col justify-start px-[0.5rem]">
                    <p className="text-left text-sm">Quantity:</p>
                    <Input
                      className="h-3 w-28 text-right text-sm"
                      readOnly
                      value={table.getRowModel().rows ? calculateTotal("quantity") : 0}
                    />
                  </div>
                  <div className="flex flex-col justify-start px-[0.5rem]">
                    <p className="text-left text-sm">Subtotal:</p>
                    <Input
                      className="h-3 w-28 text-right text-sm"
                      readOnly
                      value={table.getRowModel().rows ? calculateTotal("subTotal") : 0}
                    />
                  </div>
                  <div className="flex flex-col justify-start px-[0.5rem]">
                    <p className="text-left text-sm">Tax Amount:</p>
                    <Input
                      className="h-3 w-28 text-right text-sm"
                      readOnly
                      value={table.getRowModel().rows ? calculateTotal("taxAmount") : 0}
                    />
                  </div>
                  <div className="flex flex-col justify-start px-[0.5rem]">
                    <p className="text-left text-sm">Subtotal (Tax):</p>
                    <Input
                      className="h-3 w-28 text-right text-sm"
                      readOnly
                      value={
                        table.getRowModel().rows
                          ? formatNumber(
                            parseFloat(calculateTotal("subTotal")) +
                            parseFloat(calculateTotal("taxAmount")),
                          )
                          : 0
                      }
                    />
                  </div>
                </div>

                <div className="flex flex-none flex-row border-2 border-solid border-erp-blue-18">
                  <div className="flex flex-col justify-start p-[0.5rem]">
                    <p className="text-left text-sm">Local Subtotal (Tax):</p>
                    <Input
                      className="h-3 w-28 text-right text-sm localNetTotal"
                      readOnly
                      value={table.getRowModel().rows ? calculateNetTotal(true) : 0}
                    />
                  </div>

                  <div className="flex flex-col justify-start p-[0.5rem]">
                    <p className="text-left text-sm">Subtotal (Tax) - Rounding:</p>
                    <Input
                      className="h-3 w-28 text-right text-sm netTotal"
                      readOnly
                      value={table.getRowModel().rows ? calculateNetTotal(false) : 0}
                    />
                  </div>
                </div>
              </div>
            </div>

            <ItemPopover
              open={dialogOpen}
              setOpen={setDialogOpen}
              columns={itemType === "service" ? ServiceColumns : StockColumns}
              setTempRowDeliveryOrderDetailsListData={setTempRowDeliveryOrderDetailsListData}
              tempRowDeliveryOrderDetailsList={tempRowDeliveryOrderDetailsList}
              revalidateDeliveryOrderDetails={revalidateDeliveryOrderDetails}
              itemTable={itemTable}
              fetchItemData={fetchItemData}
              itemType={itemType}
              form={form}
              updateItem={updateItem}
              itemData={itemData}
              slug={slug}
              preferenceData={preferenceData}

            />

            <PackagePopover
              open={packageDialogOpen}
              setOpen={setPackageDialogOpen}
              columns={PackageColumns}
              data={packageData}
              fetchPackageData={fetchPackageData}
              revalidateDeliveryOrderDetails={revalidateDeliveryOrderDetails}
              setTempRowDeliveryOrderDetailsListData={setTempRowDeliveryOrderDetailsListData}
              tempRowDeliveryOrderDetailsList={tempRowDeliveryOrderDetailsList}
              slug={slug}
              preferenceData={preferenceData}
            />

            {/* Selling Price History Popover (Popover) */}
            <SellingPriceHistoryPopover
              open={priceHistoryDialogOpen}
              setOpen={setPriceHistoryDialogOpen}
              itemId={selectedItemForPriceHistory}
            // preferenceData={preferenceData}
            />

            {/* Serial Number Popover (Popover) */}
            <SerialNumberPopover
              open={serialNumberDialogOpen}
              setOpen={setSerialNumberDialogOpen}
              selectedRow={selectedRowForSerialNumber}
              setTempRowDetailsList={setTempRowDeliveryOrderDetailsList}
            />
          </div>
        </div>
      </CardContent>
    </Card>
  );
}

// Column Drag and Drop and Resize (Table Body)
type TableBodyProps = {
  table: TableType<DeliveryOrder>;
  onRowSelection: (
    row: Row<DeliveryOrder>
  ) => (event: MouseEvent<HTMLTableRowElement>) => void;
  getRowId: (row: any, index: number) => string;
  refreshKey: number;
  taxInclusiveStates: any;
  masterServiceStates: any;
  showInPDFStates: any;
  handleTaxInclusiveCheckedChanged: (rowIndex: number, isChecked: boolean, row: any) => void;
  handleMasterServiceCheckedChanged: (rowIndex: number, isChecked: boolean, row: any) => void;
  handleShowInPDFCheckedChanged: (rowIndex: number, isChecked: boolean, row: any) => void;
  descriptionInputCell: (cell: any, className: string) => JSX.Element;
  textInputCell: (cell: any, className: string) => JSX.Element;
  numberInputCell: (cell: any, allowDecimal: boolean) => JSX.Element;
  dropDownInputCell: (cell: any) => JSX.Element;
  dateInputCell: (cell: any) => JSX.Element;
  UOMDropdownCell: (cell: any) => JSX.Element;
  form: any;
  currentCurrencyRate: number; // Accurate Currency Rate Update
};

function NonMemoizedTableBody({
  table,
  onRowSelection,
  getRowId,
  refreshKey,
  taxInclusiveStates,
  masterServiceStates,
  showInPDFStates,
  handleTaxInclusiveCheckedChanged,
  handleMasterServiceCheckedChanged,
  handleShowInPDFCheckedChanged,
  descriptionInputCell,
  textInputCell,
  numberInputCell,
  dropDownInputCell,
  dateInputCell,
  UOMDropdownCell,
  form,
  currentCurrencyRate, // Accurate Currency Rate Update
}: TableBodyProps) {
  return (
    <TableBody>
      {table.getRowModel().rows?.length ? (
        table.getRowModel().rows.map((row, index) => {
          return (
            // Row Drag and Drop (Row)
            <DraggableRow
              key={`${getRowId(row.original, index)}-${refreshKey}`}
              id={getRowId(row.original, index)}
              className="odd:bg-erp-blue-5 even:bg-erp-blue-1 hover:bg-erp-blue-7 data-[state=selected]:bg-erp-blue-17"
              onClick={onRowSelection(row)}
              data-state={row.getIsSelected() && "selected"}
              disabled={false}
            >
              {row.getVisibleCells().map((cell, cellIndex) => {
                if (cell.column.id === "taxInclusive") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      <Checkbox
                        checked={taxInclusiveStates[index] === "1"}
                        onCheckedChange={(state) =>
                          handleTaxInclusiveCheckedChanged(index, state, cell.row)
                        }
                      />
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "description" ||
                  cell.column.id === "2ndDescription" ||
                  cell.column.id === "moreDescription" ||
                  cell.column.id === "customerDescription"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {descriptionInputCell(cell, "h-7.5 p-0")}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "itemName" ||
                  cell.column.id === "permitNo" ||
                  cell.column.id === "remark1" ||
                  cell.column.id === "remark2" ||
                  cell.column.id === "customerName" ||
                  cell.column.id === "customerBRN" ||
                  cell.column.id === "customerID" ||
                  cell.column.id === "customermembershipID"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {textInputCell(cell, "h-7.5", true)}
                    </TableCell>
                  );
                } else if (
                  // Three Discount (Render)
                  cell.column.id === "price" ||
                  cell.column.id === "discountRate" ||
                  cell.column.id === "discountAmount" ||
                  cell.column.id === "discountRate2" ||
                  cell.column.id === "discountAmount2" ||
                  cell.column.id === "discountRate3" ||
                  cell.column.id === "discountAmount3"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {numberInputCell(cell, true)}
                    </TableCell>
                  );
                } else if (cell.column.id === "quantity" || cell.column.id === "quantity2" || cell.column.id === "quantity3") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {numberInputCell(cell, false)}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "classificationCode" ||
                  cell.column.id === "locationCode" ||
                  cell.column.id === "projectCode" ||
                  cell.column.id === "customerCodeCode" ||
                  cell.column.id === "taxCode" ||
                  (cell.column.id === "stockBatchCode" &&
                    row.original["type"] !== "Service")
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center overflow-visible relative"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                        overflow: 'visible',
                        position: 'relative',
                      }}
                    >
                      {dropDownInputCell(cell)}
                    </TableCell>
                  );
                } else if (cell.column.id === "localTaxAmount") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-right truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {/* Accurate Currency Rate Update */}
                      <p className="text-right">{`${(
                        row.original.taxAmount * currentCurrencyRate
                      ).toFixed(2)}`}</p>
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "deliveryDate" ||
                  cell.column.id === "startAt" ||
                  cell.column.id === "endAt"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-right truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {dateInputCell(cell)}
                    </TableCell>
                  );
                } else if (
                  cell.column.id === "itemUOM" ||
                  cell.column.id === "itemUOM2" ||
                  cell.column.id === "itemUOM3"
                ) {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-right truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {UOMDropdownCell(cell)}
                    </TableCell>
                  );
                } else if (cell.column.id === "master") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center [&:has([role=checkbox])]:pr-4 truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      <Checkbox
                        checked={masterServiceStates[index] === "1"}
                        onCheckedChange={(state) =>
                          handleMasterServiceCheckedChanged(index, state, cell.row)
                        }
                        disabled={index === 0} // Disable checkbox for the first row
                      />
                    </TableCell>
                  );
                } else if (cell.column.id === "showTemplate") {
                  return (
                    <TableCell
                      key={cell.id}
                      onClick={(e) => e.stopPropagation()}
                      className="text-center [&:has([role=checkbox])]:pr-4 truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      <Checkbox
                        checked={showInPDFStates[index] === "1"}
                        onCheckedChange={(state) =>
                          handleShowInPDFCheckedChanged(index, state, cell.row)
                        }
                        disabled={index === 0} // Disable checkbox for the first row
                      />
                    </TableCell>
                  );
                } else {
                  return (
                    <TableCell
                      key={cell.id}
                      className="truncate"
                      title={(cell.getValue() ?? "").toString()}
                      style={{
                        width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                        minWidth: cell.column.columnDef.minSize,
                      }}
                    >
                      {cellIndex === 0 ? (
                        <div className="flex items-center gap-2">
                          <DragHandle
                            id={getRowId(row.original, index)}
                            className="flex-shrink-0"
                          />
                          {flexRender(cell.column.columnDef.cell, cell.getContext())}
                        </div>
                      ) : (
                        flexRender(cell.column.columnDef.cell, cell.getContext())
                      )}
                    </TableCell>
                  );
                }
              })}
            </DraggableRow>
          );
        })
      ) : (
        <NoResultsTableRow columns={table.getVisibleLeafColumns()} />
      )}
    </TableBody>
  );
}

const MemoizedTableBody = memo(
  NonMemoizedTableBody,
  (prev, next) => prev.table.options.data === next.table.options.data
) as typeof NonMemoizedTableBody;