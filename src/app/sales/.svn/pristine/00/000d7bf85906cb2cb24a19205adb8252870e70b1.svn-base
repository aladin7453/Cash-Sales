                      render={({ field }) => (
                        <FormItem>
                          <Popover>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <PopoverTrigger asChild>
                                    <FormControl>
                                      <Button
                                        className={cn(
                                          "h-7.5 w-full rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out",
                                          !field.value && "text-muted-foreground",
                                        )}
                                        variant="outline"
                                        size="lg"
                                      >
                                        {field.value
                                          ? moment.unix(Number(field.value)).format(DATE_FORMAT)
                                          : "Posting Date"}
                                        <CalendarIcon className="ml-auto size-3.5 text-gray-400" />
                                      </Button>
                                    </FormControl>
                                  </PopoverTrigger>
                                </TooltipTrigger>

                                <TooltipContent>Posting Date</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>

                            <PopoverContent className="w-auto p-0" align="start">
                              <Calendar
                                mode="single"
                                selected={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : undefined
                                }
                                onSelect={(date) => {
                                  if (!date) {
                                    field.onChange(null);
                                    return;
                                  }

                                  const unixTimestamp = Math.floor(date.getTime() / 1000);
                                  field.onChange(unixTimestamp);
                                }}
                                initialFocus
                                defaultMonth={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : new Date()
                                }
                              />
                            </PopoverContent>
                          </Popover>

                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Tax Date */}
                    <FormField
                      control={form.control}
                      name="taxDate"
                      render={({ field }) => (
                        <FormItem>
                          <Popover>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <PopoverTrigger asChild>
                                    <FormControl>
                                      <Button
                                        className={cn(
                                          "h-7.5 w-full rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out",
                                          !field.value && "text-muted-foreground",
                                        )}
                                        variant="outline"
                                        size="lg"
                                      >
                                        {field.value
                                          ? moment.unix(Number(field.value)).format(DATE_FORMAT)
                                          : "Tax Date"}
                                        <CalendarIcon className="ml-auto size-3.5 text-gray-400" />
                                      </Button>
                                    </FormControl>
                                  </PopoverTrigger>
                                </TooltipTrigger>

                                <TooltipContent>Tax Date</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>

                            <PopoverContent className="w-auto p-0" align="start">
                              <Calendar
                                mode="single"
                                selected={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : undefined
                                }
                                onSelect={(date) => {
                                  if (!date) {
                                    field.onChange(null);
                                    return;
                                  }

                                  const unixTimestamp = Math.floor(date.getTime() / 1000);
                                  field.onChange(unixTimestamp);
                                }}
                                initialFocus
                                defaultMonth={
                                  field.value
                                    ? moment.unix(Number(field.value)).toDate()
                                    : new Date()
                                }
                              />
                            </PopoverContent>
                          </Popover>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Fifth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Location UUID */}
                    <FormField
                      control={form.control}
                      name="location"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Location UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Location */}
                    <FormField
                      control={form.control}
                      name="locationCode"
                      render={({ field }) => (
                        <FormItem className="col-span-1">
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 w-full rounded-md px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      // readOnly
                                      onChange={(e) =>
                                        handleDropdownSearchChange("location", e.target.value)
                                      }
                                      onClick={() => fetchDropdownData1("location")}
                                      ref={
                                        dropdownState.currentDropdown === "location"
                                          ? dropdownInputRef
                                          : null
                                      }
                                      autoComplete="off"
                                      placeholder="Location"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Location</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "location" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.location.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>
                </div>
              </TabPanel>

              {/* Mapping Reference */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Mapping Reference</div>
                </div>

                <div className="flex flex-col gap-y-2.5 pt-1.5">

                  {/* First Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* QT No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("quotation") && form.getValues("quotationDocNo") ? (
                          (() => {
                            const basePath = "/sales/quotation"
                            const quotationID = form.getValues("quotation");
                            const quotationDocNo = form.getValues("quotationDocNo");

                            return (
                              <Link
                                href={`${basePath}/edit?item=${quotationDocNo}&id=${quotationID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="QT No"
                              >
                                {quotationDocNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">QT No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>

                    {/* SO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("salesOrder") && form.getValues("salesOrderDocNo") ? (
                          (() => {
                            const basePath = "/sales/sales-order"
                            const salesOrderID = form.getValues("salesOrder");
                            const salesOrderDocNo = form.getValues("salesOrderDocNo");

                            return (
                              <Link
                                href={`${basePath}/edit?item=${salesOrderDocNo}&id=${salesOrderID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="SO No"
                              >
                                {salesOrderDocNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">SO No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Second Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* DO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("deliveryOrder") && form.getValues("deliveryOrderDocNo") ? (
                          (() => {
                            const basePath = "/sales/sales-delivery-order"
                            const deliveryOrderID = form.getValues("deliveryOrder");
                            const deliveryOrderDocNo = form.getValues("deliveryOrderDocNo");

                            return (
                              <Link
                                href={`${basePath}/edit?item=${deliveryOrderDocNo}&id=${deliveryOrderID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="DO No"
                              >
                                {deliveryOrderDocNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">DO No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>

                    {/* INV No */}
                    <FormField
                      control={form.control}
                      name="INVNoTransferred"
                      render={({ field }) => {
                        const basePath = "/sales/sales-invoice"

                        return (
                          <FormItem>
                            <FormControl>
                              <div className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                                {field.value && field.value.docNo && field.value.UUID ? (
                                  <Link
                                    href={`${basePath}/edit?item=${field.value.docNo}&id=${field.value.UUID}`}
                                    target="_blank"
                                    className="flex text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                    title="INV No"
                                  >
                                    {field.value.docNo}
                                  </Link>
                                ) : (
                                  <span className="text-muted-foreground">INV No</span>
                                )}
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        );
                      }}
                    />
                  </div>

                  {/* Third Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* OR No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("customerPaymentNo")?.length > 0 ? (
                          form.getValues("customerPaymentNo").split(", ").map((entry, index, array) => {
                            if (index % 2 === 0) {
                              const docNo = entry;
                              const id = array[index + 1];
                              const basePath = "/sales/customer-payment"

                              return (
                                <Link
                                  key={id}
                                  href={`${basePath}/edit?item=${docNo}&id=${id}`}
                                  target="_blank"
                                  className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                  title="OR No"
                                >
                                  {docNo}{index < array.length - 2 ? ", " : ""}
                                </Link>
                              );
                            }
                            return null;
                          })
                        ) : (
                          <span className="text-muted-foreground">OR No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>


                    {/* JO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("jobOrder") && form.getValues("jobOrderDocNo") ? (
                          (() => {
                            const basePath = "/job-management/job-order"
                            const jobOrderID = form.getValues("jobOrder");
                            const jobOrderDocNo = form.getValues("jobOrderDocNo");

                            return (
                              <Link
                                href={`${basePath}/edit?item=${jobOrderDocNo}&id=${jobOrderID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="JO No"
                              >
                                {jobOrderDocNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">JO No</span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Forth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Consolidated E-invoice No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {slug !== "clone" &&
                          form.getValues("consolidateTo") &&
                          form.getValues("consolidatedInvoiceDocNo") ? (
                          (() => {
                            const basePath = "/sales/consolidated-invoice";
                            const consolidateToID = form.getValues("consolidateTo");
                            const consolidatedInvoiceDocNo = form.getValues("consolidatedInvoiceDocNo");

                            return (
                              <Link
                                href={`${basePath}/edit?item=${consolidatedInvoiceDocNo}&id=${consolidateToID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="Consolidated E-invoice No"
                              >
                                {consolidatedInvoiceDocNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">
                            Consolidated E-Invoice No
                          </span>
                        )}
                        <ScrollBar orientation="horizontal" className="h-1.5" />
                      </ScrollArea>
                    </div>

                    {/* UUID */}
                    <div className="flex flex-col text-nowrap">
                      <FormField
                        control={form.control}
                        name="UUID"
                        render={({ field }) => (
                          <FormItem
                            className={`flex flex-col space-y-1 ${slug === "clone" ? "hidden" : ""}`}
                          >
                            <FormControl className="relative">
                              <Input
                                className="h-7.5 rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                {...field}
                                readOnly={true}
                                ref={inputRef}
                                autoComplete="off"
                                placeholder="UUID"
                                title="UUID"
                              />
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>
                  </div>
                </div>
              </TabPanel>

              {/* Import & Export Goods */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Import & Export Goods</div>
                </div>

                <ImportExportOfGoodsForm form={form} />
              </TabPanel>

              {/* Payment Details */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Payment Details</div>
                </div>

                <PaymentDetailsForm form={form} />
              </TabPanel>
            </div>

            {/* Right - Vertical TabList */}
            <TabList className="ml-1 flex flex-col gap-y-1">
              {[
                {
                  icon: <IoDocumentOutline className="size-4.5" />,
                  label: "General Details",
                },
                {
                  icon: <HiOutlineClipboardDocumentList className="size-4.5" />,
                  label: "Mapping Reference",
                },
                {
                  icon: <FaBoxes className="size-4.5" />,
                  label: "Import & Export Goods",
                },
                {
                  icon: <FaAddressCard className="size-4.5" />,
                  label: "Payment Details",
                },
              ].map((item, index) => (
                <Tab
                  key={index}
                  className="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-y-0.5 rounded-md border border-gray-200 bg-white text-[9px] text-gray-600 outline-none transition-all duration-200 ease-in-out"
                  selectedClassName="!bg-blue-300 border-blue-300 text-white"
                >
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <span className="flex h-full w-full items-center justify-center">
                          {item.icon}
                        </span>
                      </TooltipTrigger>
                      <TooltipContent side="right" align="start">
                        {item.label}
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </Tab>
              ))}
            </TabList>
          </div>
        </Tabs>
      </form>
    </Form>
  );
}