"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { useRouter, useSearchParams, useParams } from "next/navigation";
import { useEffect, useRef, useState } from "react";
import { useForm } from "react-hook-form";
import { FaCircleXmark, FaFileCirclePlus, FaMagnifyingGlass } from "react-icons/fa6";
import { z } from "zod";
import LoadingUI from "@/components/LoadingUI";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import DropdownTable from "@/components/data-table/DropdownTable";
import CancelButton from "@/components/form/ActionButton/Cancel";
import { Checkbox } from "@/components/ui/checkbox";
import { Dialog, DialogClose, DialogContent } from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Textarea } from "@/components/ui/textarea";
import { useToast } from "@/components/ui/use-toast";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { getFileToBase64 } from "@/lib/utils/commonFunction";

import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";

import type { Dispatch, SetStateAction } from "react";

import type { BillingContactDetails } from "../billing-contact-details/columns";

type Props = {
  open: boolean;
  setOpen: Dispatch<SetStateAction<boolean>>;
  setTempRowAttachments: ([]) => void;
  revalidateBillingContactDetail: () => void;
  setCustomerData: Dispatch<SetStateAction<BillingContactDetails[]>>;
};

const billingContactDetailsFormSchema = z.object({
  UUID: z.union([z.string(), z.literal("")]),
  contact: z.string().min(2, {
    message: "This field is required.",
  }),
  title: z.string().optional().nullable(),
  phoneNo: z.string().optional().nullable(),
  email: z.string().optional().nullable(),
  faxNo: z.string().optional().nullable(),
  address: z.string().optional().nullable(),
  description: z.string().optional().nullable(),
  attachment: z.any().optional().nullable(),
  valid: z.union([z.literal("0"), z.literal("1")]).default("1"),
});

export default function BillingContactDetailsFormPopover({
  open,
  setOpen,
  row,
  setTempRowAttachments,
  setTempRowBillingContactDetailData,
  revalidateBillingContactDetail,
}: Props) {
  const router = useRouter();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const data = row;
  const { toast } = useToast();
  const headers = getAuthHeaders();
  const { slug } = useParams()
  const [isSaving, setIsSaving] = useState(false);
  const [showTableContact, setShowTableContact] = useState(false);
  const [contactDropdownTableData, setContactDropdownTableData] = useState([]);
  const dropdownContactColumns = [
    { accessorKey: "fullName", header: "FullName" },
    {
      accessorKey: "description",
      header: "Description",
      cell: ({ row }) => <DescriptionCellTooltip row={row} />,
    },
  ];

  const inputRef = useRef(null);
  const dropdownRef = useRef(null);

  const handleClickOutside = (event) => {
    if (
      dropdownRef.current &&
      !dropdownRef.current.contains(event.target) &&
      inputRef.current !== event.target
    ) {
      if (event.target.tagName !== "BODY") {
        setShowTableContact(false);
      }

    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);
    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);

  const toggleTableContact = async () => {
    const formData = new FormData();
    const user = "user";
    formData.append("table[]", user);

    if (!showTableContact) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
          method: "POST",
          headers,
          body: formData,
        });
        if (!response.ok) {
          throw new Error("Failed to fetch account drop-down data");
        }
        const accountData = await response.json();
        setContactDropdownTableData(accountData.rows);
        setShowTableContact(true);
      } catch (error) {
        console.error("Error fetching account drop-down data:", error);
      }
    } else {
      setShowTableContact(false);
    }
  };

  const [billingContactFiles, setBillingContactFiles] = useState([]);
  const fileInputRef = useRef(null);

  const handleChooseFileClick = () => {
    fileInputRef.current.click();
  };

  useEffect(() => {
    if (data && data.attachmentLink) {
      setBillingContactFiles(data.attachmentLink);
    }
    if (data && data.attachmentFiles) {
      setBillingContactFiles(data.attachmentFiles);
    }

    return () => { };
  }, [data]);

  const handleFileChange = (event) => {
    const fileList = Array.from(event.target.files);
    const mergeArray: any = [...billingContactFiles, ...fileList];
    setBillingContactFiles(mergeArray);
  };

  function handleDeleteFile(index) {
    var newBillingContactFiles = [...billingContactFiles];
    newBillingContactFiles.splice(index, 1);
    setBillingContactFiles(newBillingContactFiles);
  }

  const form = useForm<z.infer<typeof billingContactDetailsFormSchema>>({
    resolver: zodResolver(billingContactDetailsFormSchema),
    defaultValues: {
      UUID: data?.UUID !== undefined ? data.UUID : "",
      contact: data?.contact !== undefined ? data.contact : "",
      title: data?.title !== undefined ? data.title : "",
      phoneNo: data?.phoneNo !== undefined ? data.phoneNo : "",
      email: data?.email !== undefined ? data.email : "",
      faxNo: data?.faxNo !== undefined ? data.faxNo : "",
      address: data?.address !== undefined ? data.address : "",
      description: data?.description !== undefined ? data.description : "",
      attachment: data?.attachment ? [new File([], data.attachment)] : null,
      valid: data?.valid ?? "1",
    },
  });

  const updateBillingContact = async (data) => {
    var counter = 0;
    try {
      const formData = new FormData();
      for (var key in data) {
        if (key !== "attachment") {
          formData.append(`customerHasBillingContact[${key}]`, data[key]);
        }
      }

      for (const fileData of billingContactFiles) {
        if (fileData.size) {
          var base64 = await getFileToBase64(fileData);
          formData.append(`customerHasBillingContact[attachment][${counter}][Name]`, fileData.name);
          formData.append(`customerHasBillingContact[attachment][${counter}][File]`, base64);
        } else {
          formData.append(`customerHasBillingContact[attachment][${counter}][Name]`, fileData.name);
          formData.append(`customerHasBillingContact[attachment][${counter}][File]`, " ");
        }

        counter++;
      }

      const response = await fetch(
        `${ORIGIN}/customer/api/customer/update-customer-has-billing-contact-data?id=${id}`,
        {
          method: "POST",
          headers,
          body: formData,
        },
      );

      if (!response.ok) {
        const errorData = await response.json();
        if (response.status === 403) {
          toast({
            title: errorData.message,
            duration: 2000,
          });
        }
        throw new Error("Failed to fetch data");
      }
      const responseData = await response.json();
      if (responseData) {
        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
      // Optionally, handle success or display a message to the user
    } catch (error) {
      console.error("Error updating billing contact data:", error);
      // Handle errors, e.g., display an error message or log the error
    }
  };

  const onClickRowContact = (row) => {
    form.setValue("contactUUID", row.UUID);
    form.setValue("contact", row.fullName);
    form.setValue("title", row.title);
    form.setValue("phoneNo", row.phoneNo);
    form.setValue("email", row.email);
    form.setValue("address", row.address);
    form.setValue("description", row.description);
    setShowTableContact(false);
  };

  const isSubmittingRef = useRef(false);

  const onSubmit = async (values) => {
    if (!values) return;

    if (isSubmittingRef.current) return;

    isSubmittingRef.current = true;
    setIsSaving(true);
    try {
      const newData: any = { ...values };

      if (id && slug == "edit") {
        await updateBillingContact(newData);
        revalidateBillingContactDetail();
      } else {
        if (!newData.UUID) {
          newData.UUID = crypto.randomUUID();
        }
        newData.attachmentFiles = billingContactFiles;

        setTempRowBillingContactDetailData(newData);
      }

      setOpen(false);
    } finally {
      setTimeout(() => {
        isSubmittingRef.current = false;
        setIsSaving(false);
      }, 300);
    }
  };
  const handleReset = () => {
    form.reset({
      UUID: "",
      contact: "",
      title: "",
      phoneNo: "",
      email: "",
      faxNo: "",
      address: "",
      description: "",
      valid: "1",
    });
  };

  useEffect(() => {
    if (open) {
      !data && handleReset()
      !data && setBillingContactFiles([])
    }
  }, [open]);

  return (
    <Dialog open={open} onOpenChange={setOpen}>
      <DialogContent className="max-w-3xl bg-erp-blue-3 p-2">
        <Form {...form}>
          <form className="space-y-2" onSubmit={form.handleSubmit(onSubmit)}>
            <div className="flex items-center justify-between pr-4">
              <div className="grid auto-cols-fr grid-flow-col gap-x-1.5">
                <SaveButton disabled={isSaving}/>
                <ResetButton onClick={handleReset} />
                <DialogClose asChild>
                  <CancelButton />
                </DialogClose>
              </div>
              <FormField
                control={form.control}
                name="valid"
                render={({ field }) => (
                  <FormItem className="flex items-center gap-x-2 space-y-0">
                    <FormControl>
                      <Checkbox
                        checked={field.value === "1"}
                        onCheckedChange={(state) => field.onChange(state ? "1" : "0")}
                      />
                    </FormControl>
                    <FormLabel>Valid</FormLabel>
                  </FormItem>
                )}
              />
            </div>
            <div className="space-y-2.5 bg-white p-3 pt-2">
              <h2 className="text-sm font-bold">Contact</h2>
              <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-3">
                <FormField
                  control={form.control}
                  name="UUID"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid hidden h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>UUID:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} readOnly={true} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="contactUUID"
                  render={({ field }) => (
                    <FormItem className="col-span-4 row-span-1 grid hidden h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>UUID:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} readOnly={true} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="contact"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>
                        Contact: <span className="text-red-500">*</span>
                      </FormLabel>
                      <FormControl className="relative">
                        <div className="relative h-7.5">
                          <Input
                            className="h-7.5 pr-8"
                            {...field}
                            ref={inputRef}
                            autoComplete="off"
                          />

                        </div>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="title"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Title:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="phoneNo"
                  render={({ field }) => (
                    <FormItem className="flex flex-col space-y-1">
                      <FormLabel>Phone No.:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>
              <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-3">
                <FormField
                  control={form.control}
                  name="email"
                  render={({ field }) => (
                    <FormItem className="col-span-1 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Email:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                <FormField
                  control={form.control}
                  name="faxNo"
                  render={({ field }) => (
                    <FormItem className="col-span-1 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Fax No.:</FormLabel>
                      <FormControl>
                        <Input className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>
              <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-3">
                <FormField
                  control={form.control}
                  name="address"
                  render={({ field }) => (
                    <FormItem className="col-span-3 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Address:</FormLabel>
                      <FormControl>
                        <Textarea className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>
              <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-3">
                <FormField
                  control={form.control}
                  name="description"
                  render={({ field }) => (
                    <FormItem className="col-span-3 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                      <FormLabel>Description:</FormLabel>
                      <FormControl>
                        <Textarea className="h-7" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </div>
              <FormField
                control={form.control}
                name="attachment"
                render={({ field }) => (
                  <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>
                      <div style={{ display: "flex", alignItems: "center" }}>
                        Attachment:{" "}
                        <button type="button" onClick={handleChooseFileClick}>
                          <FaFileCirclePlus
                            style={{ marginLeft: "5px" }}
                            className="text-erp-blue-14"
                          />
                        </button>
                      </div>
                    </FormLabel>

                    <FormControl>
                      <Input
                        id="attachments"
                        type="file"
                        multiple
                        onChange={handleFileChange}
                        ref={fileInputRef}
                        className="hidden"
                      />
                    </FormControl>

                    <FormMessage />
                  </FormItem>
                )}
              />
              {/* You can render the files here */}
              {billingContactFiles &&
                billingContactFiles.map((file, index) => (
                  <div key={index}>
                    <a
                      href={file.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      style={{ color: "blue" }}
                    >
                      {file.name}
                    </a>
                    <button
                      type="button"
                      onClick={() => handleDeleteFile(index)}
                      style={{ color: "red" }}
                    >
                      <FaCircleXmark
                        style={{ verticalAlign: "bottom", marginLeft: "2px", marginTop: "2px" }}
                        title={"Remove"}
                      />
                    </button>
                  </div>
                ))}
            </div>
          </form>
        </Form>
        {isSaving && <LoadingUI />}
      </DialogContent>
    </Dialog>
  );
}
