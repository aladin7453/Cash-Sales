"use client";

import React, { useEffect, useState, useRef } from "react";
import { FaMagnifyingGlass } from "react-icons/fa6";

import { ORIGIN, getAuthHeaders } from "@/lib/constants";

import { Textarea } from "@/components/ui/textarea";
import DropdownTable from "@/components/data-table/DropdownTable";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import { Input } from "@/components/ui/input";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";
import { toast } from "@/components/ui/use-toast";
import { Button } from "@/components/ui/button";
import { useForm, FormProvider } from "react-hook-form";
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog";


type Params = {
  form: any;
  preferenceData?: any;
};

type DropdownConfig = {
  tableName?: string;
  endpoint?: string;
  columns: { accessorKey: string; header: string; cell?: any }[];
  valueField: string;
  displayField: string;
  formValueField: string;
  formDisplayField: string;
  additionalMappings?: { sourceField: string; targetFormField: string }[];
  requiresCustomerUUID?: boolean;
}


interface ContactFormData {
  contact: string;
  phoneNo: string;
  email: string;
  description: string;
}

const contactFormSchema = z.object({
  contact: z.string().min(1, "Contact name is required").trim(),
  phoneNo: z.string().min(1, "Phone number is required").trim(),
  email: z.string().optional(),
  description: z.string().optional(),
});


export function CustomerDetailsFormOld({ form, preferenceData }: Params) {
  const headers = getAuthHeaders();

  const handleClickOutside = (event) => {
    if (dropdownTableRef.current &&
      !dropdownTableRef.current.contains(event.target) &&
      dropdownInputRef.current !== event.target) {
      setDropdownState(prev => ({ ...prev, showTable: false }));
    }
  };

  useEffect(() => {
    document.body.addEventListener('click', handleClickOutside);

    return () => {
      document.body.removeEventListener('click', handleClickOutside);
    };
  }, []);

  // Customer Filter State
  const [customerFilter, setCustomerFilter] = useState("");

  // Attention Filter State
  const [attentionFilter, setAttentionFilter] = useState("");

  // Unified Dropdown State
  const [dropdownState, setDropdownState] = useState({
    currentDropdown: null as string | null,
    data: [] as any[],
    showTable: false,
  });

  // Unified Dropdown Refs
  const dropdownInputRef = useRef(null);
  const dropdownTableRef = useRef(null);

  // Unified Dropdown Configurations
  const dropdownConfigs: Record<string, DropdownConfig> = {
    customerCode: {
      tableName: "customer",
      columns: [
        { accessorKey: "customerCode", header: "Customer Code" },
        { accessorKey: "customerGroupCode", header: "Customer Group" },
        { accessorKey: "customerName", header: "Customer Name" },
        { accessorKey: "description", header: "Description", cell: ({ row }) => <DescriptionCellTooltip row={row} /> }
      ],
      valueField: "UUID",
      displayField: "customerCode",
      formValueField: "customerCode",
      formDisplayField: "customerCodeCode",
      additionalMappings: [
        { sourceField: "customerName", targetFormField: "customerName" },
        { sourceField: "BRN", targetFormField: "BRN" },
        { sourceField: "TIN", targetFormField: "TIN" },
        { sourceField: "SSTNo", targetFormField: "SSTNo" },
        { sourceField: "address", targetFormField: "address" },
        { sourceField: "TaxExNo", targetFormField: "taxExNo" }
      ]
    },
    TIN: {
      tableName: "customer",
      columns: [
        { accessorKey: "TIN", header: "TIN", },
        { accessorKey: "customerCode", header: "Customer Code", },
        { accessorKey: "customerName", header: "Customer Name", },
        { accessorKey: "BRN", header: "BRN", },
      ],
      valueField: "UUID",
      displayField: "customerCode",
      formValueField: "customerCode",
      formDisplayField: "customerCodeCode",
      additionalMappings: [
        { sourceField: "customerName", targetFormField: "customerName" },
        { sourceField: "BRN", targetFormField: "BRN" },
        { sourceField: "TIN", targetFormField: "TIN" },
        { sourceField: "SSTNo", targetFormField: "SSTNo" },
        { sourceField: "address", targetFormField: "address" },
      ],
    },
    attention: {
      endpoint: "/universal/get-attention-by-customer",
      columns: [
        { accessorKey: "contact", header: "Contact" },
        { accessorKey: "phoneNo", header: "Phone No." },
        { accessorKey: "email", header: "Email" },
        { accessorKey: "description", header: "Description", cell: ({ row }) => <DescriptionCellTooltip row={row} /> }
      ],
      valueField: "UUID",
      displayField: "contact",
      formValueField: "attention",
      formDisplayField: "attentionName",
      additionalMappings: [
        { sourceField: "phoneNo", targetFormField: "phoneNo" },
        { sourceField: "email", targetFormField: "email" }
      ],
      requiresCustomerUUID: true
    }
  };

  // Unified Fetch Dropdown Data
  const fetchDropdownData = async (dropdownKey: string) => {
    try {
      const config = dropdownConfigs[dropdownKey];
      if (!config) return;

      let response;

      if (config.requiresCustomerUUID) {
        const customerUUID = form.getValues('customerCode');
        if (!customerUUID) {
          console.warn(`Customer must be selected first for ${dropdownKey}`);
          return;
        }

        const formData = new FormData();
        formData.append('table[]', 'user');

        response = await fetch(`${ORIGIN}${config.endpoint}?id=${customerUUID}`, {
          method: "POST",
          headers,
          body: formData,
        });
      } else if (config.tableName) {
        const formData = new FormData();
        formData.append('table[]', config.tableName);

        response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
          method: "POST",
          headers,
          body: formData,
        });
      }

      if (!response || !response.ok) {
        throw new Error(`Failed to fetch ${dropdownKey} data`);
      }

      const data = await response.json();
      setDropdownState({
        currentDropdown: dropdownKey,
        data: data.rows,
        showTable: true,
      });
    } catch (error) {
      console.error(`Error fetching ${dropdownKey} data:`, error);
    }
  };

  // Unified Dropdown Row Click Handler
  const onClickRow = (row: any) => {
    const config = dropdownConfigs[dropdownState.currentDropdown!];

    if (config) {
      form.setValue(config.formValueField, row[config.valueField]);
      form.setValue(config.formDisplayField, row[config.displayField]);

      // Apply any additional field mappings defined in the config
      if (config.additionalMappings) {
        config.additionalMappings.forEach(mapping => {
          if (row[mapping.sourceField]) {
            form.setValue(mapping.targetFormField, row[mapping.sourceField]);
          }
        });
      }

      // Reset customerFilter if the current dropdown is 'customerCode'
      if (dropdownState.currentDropdown === 'customerCode') {
        if (row.customerHasBillingContacts && row.customerHasBillingContacts.length > 0) {
          var defaultCheck = row.customerHasBillingContacts?.find(row => row.default == "1");
        }

        defaultCheck ? form.setValue("attention", defaultCheck.UUID) : form.setValue("attention", "")
        defaultCheck ? form.setValue("attentionName", defaultCheck.contact) : form.setValue("attentionName", "");
        defaultCheck ? form.setValue("phoneNo", defaultCheck.phoneNo) : form.setValue("phoneNo", "");
        defaultCheck ? form.setValue("email", defaultCheck.email) : form.setValue("email", "");

        setCustomerFilter("");
      }

      // Reset attentionFilter if the current dropdown is 'attention'
      if (dropdownState.currentDropdown === 'attention') {
        setAttentionFilter("");
      }
    }

    setDropdownState(prev => ({ ...prev, showTable: false }));
  };

  // Function for Adding a New Contact
  const [showAddAttentionDialog, setShowAddAttentionDialog] = useState(false);
  const [billingContactFiles, setBillingContactFiles] = useState<File[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const [tINFilter, setTINFilter] = useState("");


  const contactForm = useForm<ContactFormData>({
    resolver: zodResolver(contactFormSchema),
    defaultValues: {
      contact: "",
      phoneNo: "",
      email: "",
      description: "",
    },
  });

  const handleAddContact = async () => {
    const isValid = await contactForm.trigger();
    if (!isValid) return;

    const data = contactForm.getValues();
    const customerId = form.getValues("customerCode");
    const formData = new FormData();

    // Append contact data
    formData.append("customerHasBillingContact[contact]", data.contact);
    formData.append("customerHasBillingContact[phoneNo]", data.phoneNo);
    formData.append("customerHasBillingContact[email]", data.email);
    formData.append("customerHasBillingContact[description]", data.description || "");

    // Append files
    for (let i = 0; i < billingContactFiles.length; i++) {
      const file = billingContactFiles[i];

      if (file.size) {
        try {
          const base64 = await getFileToBase64(file);

          formData.append(`customerHasBillingContact[attachment][${i}][Name]`, file.name);
          formData.append(`customerHasBillingContact[attachment][${i}][File]`, base64);
        } catch (error) {
          console.error("Error converting file to base64:", error);

          toast({
            title: "Error",
            description: "Failed to process file attachment",
            variant: "destructive",
          });

          return;
        }
      } else {
        formData.append(`customerHasBillingContact[attachment][${i}][Name]`, file.name);
        formData.append(`customerHasBillingContact[attachment][${i}][File]`, "");
      }
    }

    setIsLoading(true);
    try {
      const response = await fetch(
        `${ORIGIN}/customer/api/customer/update-customer-has-billing-contact-data?id=${customerId}`,
        {
          method: "POST",
          headers,
          body: formData,
        }
      );

      if (!response.ok) {
        throw new Error("Failed to add new contact");
      }

      await fetchDropdownData('attention');

      contactForm.reset();

      setBillingContactFiles([]);
      setShowAddAttentionDialog(false);

      toast({
        title: "Success",
        description: "Contact added successfully",
      });
    } catch (error) {
      console.error("Error adding new contact:", error);

      toast({
        title: "Error",
        description: "Failed to add new contact",
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <Form {...form}>
      <form className="space-y-2">
        <Card collapsible defaultCollapsed={false} className="shadow-md">
          <CardHeader>
            <CardTitle className="text-lg font-bold">Customer Details</CardTitle>
          </CardHeader>

          <CardContent>
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-4">
              <FormField
                control={form.control}
                name="customerCode"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7" {...field} readOnly={true} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="customerCodeCode"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>
                      Customer Code: <span className="text-red-500">*</span>
                    </FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={() => fetchDropdownData('customerCode')}
                          onChange={(e) => {
                            field.onChange(e);
                            setCustomerFilter(e.target.value);
                          }}
                          ref={dropdownState.currentDropdown === 'customerCode' ? dropdownInputRef : null}
                          autoComplete="off"
                        />
                        <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {dropdownState.showTable && dropdownState.currentDropdown === 'customerCode' && (
                          <div ref={dropdownTableRef} className="dropdown-table-class absolute top-full bg-white border border-gray-200 rounded shadow-md z-50">
                            <div className="h-[50vh] max-h-[400px]">
                              <ScrollArea className="h-full bg-erp-gray-3">
                                <DropdownTable
                                  columns={dropdownConfigs.customerCode.columns}
                                  data={dropdownState.data}
                                  onClickRow={onClickRow}
                                  filterValue={customerFilter}
                                  filterColumn="customerName"
                                />
                                <ScrollBar orientation="vertical" />
                              </ScrollArea>
                            </div>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="customerName"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Customer Name:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="BRN"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>BRN:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="attention"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7" {...field} readOnly={true} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="attentionName"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Attention:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={() => fetchDropdownData('attention')}
                          onChange={(e) => {
                            field.onChange(e);
                            setAttentionFilter(e.target.value);
                          }}
                          ref={dropdownState.currentDropdown === 'attention' ? dropdownInputRef : null}
                          autoComplete="off"
                        />
                        <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {dropdownState.showTable && dropdownState.currentDropdown === 'attention' && (
                          <div ref={dropdownTableRef} className="dropdown-table-class absolute top-full bg-white border border-gray-200 rounded shadow-md z-50 right-0">
                            <div className="h-[50vh] max-h-[400px]">
                              <ScrollArea className="h-full bg-erp-gray-3">
                                <DropdownTable
                                  columns={dropdownConfigs.attention.columns}
                                  data={dropdownState.data}
                                  onClickRow={onClickRow}
                                  filterValue={attentionFilter}
                                  filterColumn="contact"
                                />
                                <ScrollBar orientation="vertical" />
                              </ScrollArea>
                              <div className="flex items-center justify-end border-t p-2 bg-white">
                                <Button
                                  type="button"
                                  variant="outline"
                                  size="sm"
                                  onClick={() => {
                                    setDropdownState(prev => ({ ...prev, showTable: false }))
                                    setShowAddAttentionDialog(true);
                                  }}
                                >
                                  +
                                  Add
                                </Button>
                              </div>
                            </div>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            <div className="grid items-start gap-x-8 gap-y-2 grid-cols-1 md:grid-cols-4 mt-4">
              <FormField
                control={form.control}
                name="address"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 md:col-span-2 md:row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Address:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7"
                        {...field}
                        moduleName="salesPurchaseContra"
                        fieldName="address"
                        columnName="Address"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="TIN"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>
                      TIN:
                    </FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={() => fetchDropdownData('TIN')}
                          onChange={(e) => {
                            field.onChange(e);
                            setTINFilter(e.target.value);
                          }}
                          ref={dropdownState.currentDropdown === 'TIN' ? dropdownInputRef : null}
                          autoComplete="off"
                        />
                        <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {dropdownState.showTable && dropdownState.currentDropdown === 'TIN' && (
                          <div ref={dropdownTableRef} className="dropdown-table-class absolute top-full bg-white border border-gray-200 rounded shadow-md z-50">
                            <div className="h-[50vh] max-h-[400px]">
                              <ScrollArea className="h-full bg-erp-gray-3">
                                <DropdownTable
                                  columns={dropdownConfigs.TIN.columns}
                                  data={dropdownState.data}
                                  onClickRow={onClickRow}
                                  filterValue={tINFilter}
                                  filterColumn="TIN"
                                />
                                <ScrollBar orientation="vertical" />
                              </ScrollArea>
                            </div>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="phoneNo"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Phone No.:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="SSTNo"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>SST.No:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="email"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Email:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="salesPurchaseContra"
                        fieldName="email"
                        columnName="Email"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </CardContent>
        </Card>
        <Dialog open={showAddAttentionDialog} onOpenChange={setShowAddAttentionDialog}>
          <DialogContent className="sm:max-w-md">
            <DialogHeader>
              <DialogTitle>Add New Contact</DialogTitle>
            </DialogHeader>
            <FormProvider {...contactForm}>
              <form>
                <div className="space-y-4">
                  <FormField
                    control={contactForm.control}
                    name="contact"
                    render={({ field }) => (
                      <FormItem>
                        <FormLabel>Contact Name:</FormLabel>
                        <FormControl>
                          <Input {...field} placeholder="Contact Name" />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                  <FormField
                    control={contactForm.control}
                    name="phoneNo"
                    render={({ field }) => (
                      <FormItem>
                        <FormLabel>Phone No.:</FormLabel>
                        <FormControl>
                          <Input {...field} placeholder="Phone No." />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                  <FormField
                    control={contactForm.control}
                    name="email"
                    render={({ field }) => (
                      <FormItem>
                        <FormLabel>Email:</FormLabel>
                        <FormControl>
                          <Input {...field} placeholder="Email" />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                  <FormField
                    control={contactForm.control}
                    name="description"
                    render={({ field }) => (
                      <FormItem>
                        <FormLabel>Description:</FormLabel>
                        <FormControl>
                          <Input {...field} placeholder="Description" />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                  <div className="flex justify-end space-x-2">
                    <Button
                      type="button"
                      variant="outline"
                      onClick={() => setShowAddAttentionDialog(false)}
                      disabled={isLoading}
                    >
                      Cancel
                    </Button>
                    <Button type="button" onClick={handleAddContact} disabled={isLoading}>
                      {isLoading ? "Saving..." : "Save"}
                    </Button>
                  </div>
                </div>
              </form>
            </FormProvider>
          </DialogContent>
        </Dialog>
      </form>
    </Form>
  );
}