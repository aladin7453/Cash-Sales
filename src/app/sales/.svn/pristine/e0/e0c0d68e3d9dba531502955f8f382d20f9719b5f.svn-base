        {/* Second Row */}
        <div className="mt-1.5 grid grid-cols-3 items-center gap-x-2">
          {/* BRN */}
          <FormField
            control={form.control}
            name="buyerBRN"
            render={({ field }) => (
              <FormItem className="flex flex-col space-y-1">
                <FormControl>
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <Input
                          className="h-7 rounded-md px-2 text-[11px] bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                          {...field}
                          readOnly
                          placeholder="BRN"
