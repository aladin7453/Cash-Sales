                      </TooltipTrigger>
                      <TooltipContent side="top" align="start">
                        BRN
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />

          {/* TIN */}
          <FormField
            control={form.control}
            name="buyerTIN"
            render={({ field }) => (
              <FormItem className="flex flex-col space-y-1">
                <FormControl>
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <Input
                          className="h-7 rounded-md px-2 text-[11px] bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                          {...field}
                          readOnly
                          moduleName="consolidatedInvoice"
                          fieldName="TIN"
                          columnName="TIN"
                          placeholder="TIN"
                        />
                      </TooltipTrigger>
                      <TooltipContent side="top" align="start">
                        TIN
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
