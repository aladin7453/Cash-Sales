                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <Input
                          className="h-7 rounded-md px-2 text-[11px] bg-erp-gray-1 border-gray-200 text-black focus-visible:ring-0 focus-visible:outline-none"
                          {...field}
                          readOnly
                          placeholder="SST No"
                        />
                      </TooltipTrigger>
                      <TooltipContent side="top" align="start">
                        SST No
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />
