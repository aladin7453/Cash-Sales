"use client";

import { endOfMonth, startOfMonth } from "date-fns";
import moment from "moment";
import React, { useState } from "react";
import { useForm } from "react-hook-form";

import { DEFAULT_DATA_TABLE_PAGE_SIZE, getAuthHeaders, ORIGIN } from "@/lib/constants";
import useLocalStorage from "@/lib/hooks/useLocalStorage";

import { CustomerPostDatedChequeListingColumns } from "./Generate/columns";
import CustomerPostDatedChequeListingDataTable from "./Generate/DataTable";
import CustomerPostDatedChequeListingForm from "./Report/CustomerPostDatedChequeListingForm";
import SummaryForm from "./Report/SummaryForm";

import type { ColumnFiltersState, SortingState } from "@tanstack/react-table";

const COLUMN_FILTERS_KEY = "customer-post-dated-cheque-listing.table.filters";
const PAGINATION_KEY = "customer-post-dated-cheque-listing.table.pagination";
const SORTING_KEY = "customer-post-dated-cheque-listing.table.sorting";

export default function CustomerPostDatedChequeListingPage() {
  const [tempGeneratedReportList, setTempGeneratedReportList] = useState<any[]>([]);
  const [showReportTable, setShowReportTable] = useState(false);
  const [previewPDF, setPreviewPDF] = useState<any>(null);
  const [salesReportData, setSalesReportData] = useState<any>(null);
  const [isPreviewLoading, setIsPreviewLoading] = useState(false);

  const [totalCounts, setTotalCounts] = useState<{ total: number }>({ total: 0 });

  const [columnFilters, setColumnFilters] = useLocalStorage<ColumnFiltersState>(
    COLUMN_FILTERS_KEY,
    [],
  );

  const [pagination, setPagination] = useLocalStorage(PAGINATION_KEY, {
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });

  const [sorting, setSorting] = useLocalStorage<SortingState>(SORTING_KEY, []);

  const headers = getAuthHeaders();

  const filterFields = [
    "docDate",
    "matureDate",
    "docNo",
    "chequeNo",
    "receivedIn",
    "customerName",
    "currencyCode",
    "amount",
    "unappliedAmount",
    "knockOffAmount",
  ];

  const form = useForm({
    defaultValues: {
      perDate: Math.floor(Date.now() / 1000).toString(),
      paymentMethod: "",
      customer: "",
      collectionAgent: "",
      collectionAgentName: "",
      currency: "",
      projectCode: "",

      docDate: "",
      matureDate: "",
      docNo: "",
      chequeNo: "",
      receivedIn: "",
      customerName: "",
      currencyCode: "",
      amount: "",
      unappliedAmount: "",
      knockOffAmount: "",

      valid: "1",

      total: "",
      totalAmountPDCheque: "",
      totalUnapplied: "",
      totalKnockOff: "",
    },
  });

  const generateReport = async (formData: any) => {
    try {
      const docType = "customerPayment";

      const allFormValues = form.getValues();

      const filterObject: Record<string, any> = {};

      filterFields.forEach((key) => {
        if ((allFormValues as any)[key]) {
          let filterKey = key;
          let filterValue = (allFormValues as any)[key];

          if (key === "docDate" || key === "matureDate") {
            // Convert Unix timestamp to YYYY-MM-DD format
            filterValue = moment.unix(filterValue).format("YYYY-MM-DD");
            filterKey = key === "docDate" ? "docDateFormat" : "matureDateFormat";
          }

          filterObject[filterKey] = filterValue;
        }
      });

      const params = new FormData();

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "docDateFormat");
      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      const validFormValues = form.getValues();

      const validfilterFields = ["valid"];

      const validfilterObject: Record<string, any> = {};

      validfilterFields.forEach((key) => {
        if ((validFormValues as any)[key]) {
          validfilterObject[key] = (validFormValues as any)[key];
        }
      });

      if (validFormValues.valid) {
        params.append("param[valid]", validFormValues.valid);
      }

      params.append("sales[perDate]", formData.perDate || "");

      Object.entries(formData).forEach(([key, value]) => {
        if (value && key !== "perDate") {
          params.append(`sales[${key}]`, value as string);
        }
      });

      const response = await fetch(
        `${ORIGIN}/sales_report/api/sales-report/generate-report?docType=${docType}&reportType=customerPostDatedCheque`,
        {
          method: "POST",
          headers,
          body: params,
        },
      );

      if (!response.ok) {
        throw new Error("Failed to generate report");
      }

      const result = await response.json();
      const rows = result.rows || [];

      setTotalCounts({ total: result.total ?? rows.length });

      form.setValue("total", result.total ?? "0");
      form.setValue("totalAmountPDCheque", result.summary?.totalAmount ?? "0.00");
      form.setValue("totalUnapplied", result.summary?.totalUnappliedAmount ?? "0.00");
      form.setValue("totalKnockOff", result.summary?.totalKnockOffAmount ?? "0.00");

      setTempGeneratedReportList(result.rows || []);
      setShowReportTable(true);
    } catch (error) {
      console.error("Error generating report:", error);
    }
  };

  const previewReport = async (formData: any) => {
    setPreviewPDF(null);
    setIsPreviewLoading(true);

    try {
      let reportName = null;

      const docType = "customerPayment";
      const reportTypeName = formData.reportTypeName;

      const levelMatch = reportTypeName.match(/lv(\d+)/i);

      if (levelMatch) {
        reportName = `level${levelMatch[1]}`;
      }

      const allFormValues = form.getValues();

      const filterObject: Record<string, any> = {};

      filterFields.forEach((key) => {
        if ((allFormValues as any)[key]) {
          let filterKey = key;
          let filterValue = (allFormValues as any)[key];

          if (key === "docDate" || key === "matureDate") {
            // Convert Unix timestamp to YYYY-MM-DD format
            filterValue = moment.unix(filterValue).format("YYYY-MM-DD");
            filterKey = key === "docDate" ? "docDateFormat" : "matureDateFormat";
          }

          filterObject[filterKey] = filterValue;
        }
      });

      const params = new FormData();

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "docDateFormat");

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      const validFormValues = form.getValues();

      const validfilterFields = ["valid"];

      const validfilterObject: Record<string, any> = {};

      validfilterFields.forEach((key) => {
        if ((validFormValues as any)[key]) {
          validfilterObject[key] = (validFormValues as any)[key];
        }
      });

      if (validFormValues.valid) {
        params.append("param[valid]", validFormValues.valid);
      }

      // params.append("sales[status]", formData.status || "");

      params.append("sales[perDate]", formData.perDate || "");

      Object.entries(formData).forEach(([key, value]) => {
        if (value && key !== "perDate") {
          params.append(`sales[${key}]`, value as string);
        }
      });

      if (reportName) {
        // const hasItemCode = /itemcode/i.test(reportTypeName);

        params.append("sales[groupBy][0]", "docDateFormat");
        params.append("sales[groupBy][1]", "docNo");
        // params.append("sales[groupBy][1]", hasItemCode ? "itemCode" : "docNo");
      }

      const baseUrl = `${ORIGIN}/sales_report/api/sales-report/preview-pdf`;

      let url = `${baseUrl}?docType=${docType}&reportType=customerPostDatedCheque`;

      if (reportName) {
        url += `&reportName=${reportName}`;
      }

      const response = await fetch(url, {
        method: "POST",
        headers,
        body: params,
      });

      // const response = await fetch(
      //   `${ORIGIN}/sales_report/api/sales-report/preview-pdf?docType=${docType}&reportType=customerPostDatedCheque`,
      //   {
      //     method: "POST",
      //     headers,
      //     body: params,
      //   }
      // );

      if (!response.ok) {
        throw new Error("Failed to preview report");
      }

      const result = await response.json();
      const rows = result.rows || [];

      setTotalCounts({ total: result.total ?? rows.length });

      form.setValue("total", result.total ?? "0");
      form.setValue("totalAmountPDCheque", result.summary?.totalAmount ?? "0.00");
      form.setValue("totalUnapplied", result.summary?.totalUnappliedAmount ?? "0.00");
      form.setValue("totalKnockOff", result.summary?.totalKnockOffAmount ?? "0.00");

      setPreviewPDF(result);
      setSalesReportData(formData);
    } catch (error) {
      console.error("Error previewing report:", error);
    } finally {
      setIsPreviewLoading(false);
    }
  };

  const onSubmit = (data: any) => {
    setTempGeneratedReportList([]);
    setShowReportTable(false);
    generateReport(data);
  };

  return (
    <>
      <CustomerPostDatedChequeListingForm
        form={form}
        onSubmit={onSubmit}
        onPreview={previewReport}
        previewPDF={previewPDF}
        salesReportData={salesReportData}
        generatedReport={tempGeneratedReportList}
        isPreviewLoading={isPreviewLoading}
        salesReportColumns={CustomerPostDatedChequeListingColumns}
        filterFields={filterFields}
        sorting={sorting}
      />
      <SummaryForm form={form} onSubmit={onSubmit} />
      {showReportTable && (
        <CustomerPostDatedChequeListingDataTable
          columns={CustomerPostDatedChequeListingColumns}
          data={tempGeneratedReportList}
          revalidateCustomerPostDatedChequeListing={() => generateReport(form.getValues())}
          columnFilters={columnFilters}
          setColumnFilters={setColumnFilters}
          pagination={pagination}
          setPagination={setPagination}
          sorting={sorting}
          setSorting={setSorting}
          formData={form.getValues()}
          totalNumOfRows={+totalCounts.total}
        />
      )}
    </>
  );
}
