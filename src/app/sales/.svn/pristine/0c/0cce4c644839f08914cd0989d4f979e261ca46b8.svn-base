"use client";

import React from "react";

import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  revalidateMonthlyComparisonByCompanyReport: () => void;
  title?: string;
  totalNumOfRows: number;
};

export default function DataTableToolbar<TData>({
  table,
  title,
  revalidateMonthlyComparisonByCompanyReport,
  totalNumOfRows,
}: Props<TData>) {
  return (
    <div className="p-2.2 flex items-center justify-between rounded-t-md">
      <div className="flex items-center gap-x-1 pl-2">
        {title && <h1 className="text-lg font-bold">{title}</h1>}
      </div>

      {/* Pagination Section */}
      <Pagination table={table} totalNumOfRows={totalNumOfRows} />

      {/* Action Buttons */}
      <div className="flex items-center gap-x-3 pr-2 text-erp-blue-14">
        <Export table={table} />
        <Refresh refreshTable={revalidateMonthlyComparisonByCompanyReport} />
        <ColumnVisibilityToggle table={table} />
      </div>
    </div>
  );
}
