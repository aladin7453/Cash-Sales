"use client";

import { endOfMonth, startOfMonth } from "date-fns";
import { useState } from "react";
import { useForm } from "react-hook-form";

import LoadingUI from "@/components/LoadingUI";
import { DEFAULT_DATA_TABLE_PAGE_SIZE, getAuthHeaders, ORIGIN } from "@/lib/constants";
import useLocalStorage from "@/lib/hooks/useLocalStorage";

import {
  CustomerAnalysisByDocumentColumns,
  CustomerAnalysisByDocumentReportColumns,
} from "./Generate/columns";
import CustomerAnalysisByDocumentDataTable from "./Generate/DataTable";
import CustomerAnalysisByDocumentForm from "./Report/CustomerAnalysisByDocumentForm";
import SummaryForm from "./Report/SummaryForm";

import type { ColumnFiltersState, PaginationState, SortingState } from "@tanstack/react-table";

const COLUMN_FILTERS_KEY = "customer-analysis-by-document.table.filters";
const PAGINATION_KEY = "customer-analysis-by-document.table.pagination";
const SORTING_KEY = "customer-analysis-by-document.table.sorting";

export default function CustomerAnalysisByDocumentPage() {
  const [tempGeneratedReportList, setTempGeneratedReportList] = useState<any[]>([]);
  const [hasGenerated, setHasGenerated] = useState("0");
  const [showReportTable, setShowReportTable] = useState(false);
  const [previewPDF, setPreviewPDF] = useState<any>(null);
  const [customerAnalysisByDocumentData, setCustomerAnalysisByDocumentData] = useState<any>(null);
  const [fullReportResult, setFullReportResult] = useState<any>(null);
  const [columnFilters, setColumnFilters] = useLocalStorage<ColumnFiltersState>(
    COLUMN_FILTERS_KEY,
    [],
  );
  const [totalCounts, setTotalCounts] = useState<{ total: number }>({ total: 0 });
  const [pagination, setPagination] = useLocalStorage<PaginationState>(PAGINATION_KEY, {
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });

  const [sorting, setSorting] = useLocalStorage<SortingState>(SORTING_KEY, []);
  const [isPreviewLoading, setIsPreviewLoading] = useState(false);
  const headers = getAuthHeaders();
  const [isGenerating, setIsGenerating] = useState(false);

  const filterFields = ["customerName", "agentName", "projectCode", "currencyCode"];

  const form = useForm({
    defaultValues: {
      startDate: Math.floor(startOfMonth(new Date()).getTime() / 1000).toString(),
      endDate: Math.floor(endOfMonth(new Date()).getTime() / 1000).toString(),
      customer: "",
      customerName: "",
      agent: "",
      agentName: "",
      project: "",
      projectCode: "",
      currency: "",
      currencyCode: "",

      totalRecords: "",
      totalBFAmt: "",
      totalBFLocalAmt: "",
      totalInvoice: "",
      totalInvoiceLocal: "",

      valid: "1",
    },
  });

  const generateReport = async (formData: any) => {
    try {
      // const columnFiltersWithoutValid = columnFilters.filter(
      //   (filter) => filter.id !== "valid"
      // );

      const allFormValues = form.getValues();

      const filterObject = {};
      filterFields.forEach((key) => {
        if (allFormValues[key]) {
          filterObject[key] = allFormValues[key];
        }
      });

      const params = new FormData();

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );
      params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "customerCode");

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      // const validFormValues = form.getValues();

      // Build filter object from the filter fields
      // const validfilterFields = [

      //   "valid",
      // ];

      // const validfilterObject = {};
      // validfilterFields.forEach((key) => {
      //   if (validFormValues[key]) {
      //     validfilterObject[key] = validFormValues[key];
      //   }
      // });
      // if (validFormValues.valid) {
      //     params.append("param[valid]", validFormValues.valid);
      //   }

      // Add valid parameter
      if (formData.valid) {
        params.append("param[valid]", formData.valid);
      }

      // Add form data to params
      Object.entries(formData).forEach(([key, value]) => {
        if (value) params.append(`sales[${key}]`, value as string);
      });

      const response = await fetch(
        `${ORIGIN}/sales_report/api/sales-report/generate-report?docType=customer&reportType=customerAnalysisByDocument`,
        {
          method: "POST",
          headers,
          body: params,
        },
      );

      if (!response.ok) {
        throw new Error("Failed to generate report");
      }

      const result = await response.json();

      setFullReportResult(result);
      setTempGeneratedReportList(result.rows || []);
      setTotalCounts({ total: result.total?.toString() ?? "0" });

      // Set summary values from backend response
      form.setValue("totalRecords", result.summary?.totalRecords ?? "0");
      form.setValue("totalBFAmt", result.summary?.totalBFAmt ?? "0.00");
      form.setValue("totalBFLocalAmt", result.summary?.totalBFLocalAmt ?? "0.00");
      form.setValue("totalInvoice", result.summary?.totalInvoice ?? "0.00");
      form.setValue("totalInvoiceLocal", result.summary?.totalInvoiceLocal ?? "0.00");

      setShowReportTable(true);
      setHasGenerated("1");
    } catch (error) {
      console.error("Error generating report:", error);
    }
  };

  const previewReport = async (formData: any) => {
    setPreviewPDF(null);
    setIsPreviewLoading(true);
    try {
      // const columnFiltersWithoutValid = columnFilters.filter(
      //   (filter) => filter.id !== "valid"
      // );

      let reportName = null;

      const reportTypeName = formData.reportTypeName;

      const levelMatch = reportTypeName.match(/lv(\d+)/i);

      if (levelMatch) {
        reportName = `level${levelMatch[1]}`;
      }

      const allFormValues = form.getValues();

      const filterObject = {};
      filterFields.forEach((key) => {
        if (allFormValues[key]) {
          filterObject[key] = allFormValues[key];
        }
      });

      const params = new FormData();

      params.append(
        "param[filter]",
        Object.keys(filterObject).length > 0 ? JSON.stringify(filterObject) : "{}",
      );

      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc",
      );

      // const validFormValues = form.getValues();

      // // Build filter object from the filter fields
      // const validfilterFields = [

      //   "valid",
      // ];

      // const validfilterObject = {};
      // validfilterFields.forEach((key) => {
      //   if (validFormValues[key]) {
      //     validfilterObject[key] = validFormValues[key];
      //   }
      // });
      // if (validFormValues.valid) {
      //     params.append("param[valid]", validFormValues.valid);
      //   }

      // Add valid parameter
      if (formData.valid) {
        params.append("param[valid]", formData.valid);
      }

      // Add form data to params
      Object.entries(formData).forEach(([key, value]) => {
        if (value) params.append(`sales[${key}]`, value as string);
      });

      if (reportName) {
        // const hasCustomerName = /customername/i.test(reportTypeName);

        params.append("sales[groupBy][0]", "code");
        params.append("sales[groupBy][1]", "companyName");
        // params.append("sales[groupBy][1]", hasCustomerName ? "docDateFormat" : "docNo");
      }

      const baseUrl = `${ORIGIN}/sales_report/api/sales-report/preview-pdf`;

      let url = `${baseUrl}?docType=customer&reportType=customerAnalysisByDocument`;

      if (reportName) {
        url += `&reportName=${reportName}`;
      }

      const response = await fetch(url, {
        method: "POST",
        headers,
        body: params,
      });

      // const response = await fetch(
      //   `${ORIGIN}/sales_report/api/sales-report/preview-pdf?docType=customer&reportType=customerAnalysisByDocument`,
      //   {
      //     method: "POST",
      //     headers,
      //     body: params,
      //   },
      // );

      if (!response.ok) {
        throw new Error("Failed to preview report");
      }

      const result = await response.json();

      setPreviewPDF(result);
      setCustomerAnalysisByDocumentData(formData);
    } catch (error) {
      console.error("Error previewing report:", error);
    } finally {
      setIsPreviewLoading(false);
    }
  };

  const onGenerate = async (data: any) => {
    try {
      setIsGenerating(true);
      await generateReport(data);
    } catch (error) {
      console.error("Error generating report:", error);
    } finally {
      setIsGenerating(false);
    }
  };

  const resetState = () => {
    form.reset({
      startDate: Math.floor(startOfMonth(new Date()).getTime() / 1000).toString(),
      endDate: Math.floor(endOfMonth(new Date()).getTime() / 1000).toString(),
      customer: "",
      customerName: "",
      agent: "",
      agentName: "",
      project: "",
      projectCode: "",
      currency: "",
      currencyCode: "",

      totalRecords: "",
      totalBFAmt: "",
      totalBFLocalAmt: "",
      totalInvoice: "",
      totalInvoiceLocal: "",

      valid: "1",
    });

    setTempGeneratedReportList([]);
    setHasGenerated("0");
    setShowReportTable(false);
    setPreviewPDF(null);
    setCustomerAnalysisByDocumentData(null);
    setFullReportResult(null);
  };

  return (
    <>
      <CustomerAnalysisByDocumentForm
        form={form}
        onGenerate={onGenerate}
        onPreview={previewReport}
        previewPDF={previewPDF}
        customerAnalysisByDocumentData={customerAnalysisByDocumentData}
        generatedReport={tempGeneratedReportList}
        customerAnalysisByDocumentColumns={CustomerAnalysisByDocumentReportColumns}
        isPreviewLoading={isPreviewLoading}
        onReset={resetState}
        filterFields={filterFields}
        sorting={sorting}
      />
      <SummaryForm form={form} onGenerate={onGenerate} data={fullReportResult} />
      {showReportTable && (
        <CustomerAnalysisByDocumentDataTable
          columns={CustomerAnalysisByDocumentColumns}
          data={tempGeneratedReportList}
          revalidateCustomerAnalysisByDocument={() => generateReport(form.getValues())}
          columnFilters={columnFilters}
          setColumnFilters={setColumnFilters}
          pagination={pagination}
          setPagination={setPagination}
          sorting={sorting}
          setSorting={setSorting}
          formData={form.getValues()}
          customerAnalysisByDocumentColumns={CustomerAnalysisByDocumentColumns} // Pass columns here
          totalNumOfRows={+totalCounts.total}
        />
      )}
      {isGenerating && <LoadingUI />}
    </>
  );
}
