"use client";

import React, { useEffect, useState } from "react";
import { Table, VisibilityState } from "@tanstack/react-table";

import CloneButton from "@/components/data-table/ActionButton/Clone";
import DeleteButton from "@/components/data-table/ActionButton/Delete";
import EditButton from "@/components/data-table/ActionButton/Edit";
import NewButton from "@/components/data-table/ActionButton/New";
import PreviewButton from "@/components/data-table/ActionButton/Preview";
import RestoreButton from "@/components/data-table/ActionButton/Restore";
import TrashButton from "@/components/data-table/ActionButton/Trash";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import Validity from "@/components/data-table/Validity";
import SubmitEInvoiceButton from "@/components/data-table/ActionButton/SubmitEInvoice";
import GetEInvoiceButton from "@/components/data-table/ActionButton/GetEinvoice";
import CancelEInvoiceButton from "@/components/data-table/ActionButton/CancelEInvoice";

// Transfer From (Imports)
import { TransferFromButton} from "@/components/features/transfer/transferFrom";
import { cashSalesTransferFromConfig } from "./transfer/transferFrom/config";

// Transfer To (Imports)./transfer/transferFrom/config
import { TransferToButton} from "@/components/features/transfer/transferTo";
import { cashSalesTransferToConfig } from "./transfer/transferTo/config";

import type { CashSales } from "./columns";

// Mobile View (Imports)
import { DropdownMenuItem } from "@/components/ui/dropdown-menu";
import MobileActionGroupStart from "@/components/data-table/MobileActionGroupStart";
import MobileActionGroupEnd from "@/components/data-table/MobileActionGroupEnd";

// Server-Side Filtering (Add totalNumOfRows)
type Props = {
  table: Table<CashSales>;
  refreshTable: any;
  totalNumOfRows?: number;
  defaultColumns?: VisibilityState;
  dataStatusBadgeDisplay?: React.ReactNode;
  onResetColumnOrdering?: () => void;
  // viewEInvoiceDetails?: (row: any) => void;
};

export default function CashSalesDataTableToolbar({
  table,
  refreshTable,
  totalNumOfRows,
  defaultColumns,
  dataStatusBadgeDisplay,
  onResetColumnOrdering,
  // viewEInvoiceDetails,
}: Props) {
  return (
    <div className="flex items-center justify-between p-1.5">
      <ActionGroupStart table={table} refreshTable={refreshTable}  />

      {/* Mobile View (Hide Pagination) */}
      <div className="hidden md:block">
        {/* Server-Side Filtering (Pass totalNumOfRows) */}
        <Pagination table={table} totalNumOfRows={totalNumOfRows} />
      </div>

      <ActionGroupEnd
        table={table}
        refreshTable={refreshTable}
        defaultColumns={defaultColumns}
        dataStatusBadgeDisplay={dataStatusBadgeDisplay}
        onResetColumnOrdering={onResetColumnOrdering}
      />
    </div>
  );
}

function ActionGroupStart({
  table,
  refreshTable,
  // viewEInvoiceDetails,
}: Omit<Props, "defaultColumns" | "dataStatusBadgeDisplay">) {
  const [selectedRow, setSelectedRow] = useState("");

  const selectedRowModel = table.getSelectedRowModel();

  useEffect(() => {
    if (selectedRowModel.rows.length === 1) {
      setSelectedRow(selectedRowModel.rows[0]);
    }
  }, [selectedRowModel]);

  // Mobile View (States)
  const [dropdownOpen, setDropdownOpen] = useState(false);

  return (
    <div className="flex flex-wrap items-center justify-start gap-x-2 p-1">
      {/* Mobile View (Start Menu) */}
      <MobileActionGroupStart
        table={table}
        refreshTable={refreshTable}
        config={{
          newDestination: "/sales/cash-sales/new",
          editDestination: (row) => `/sales/cash-sales/edit?item=${row.docNo}&id=${row.UUID}`,
          cloneDestination: (row) => `/sales/cash-sales/clone?id=${row.UUID}`,
          module: "cash_sales",
          model: "cash-sales",
        }}
      >
        {/* Additional Actions (Other than New, Edit, Clone, Trash, Restore, Delete) */}
        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <PreviewButton
              table={table}
              previewType="CASH SALES"
              module="cash_sales"
              model="cash-sales"
              doc_id={selectedRow ? selectedRow.original.UUID : ""}
              refreshTable={refreshTable}
            />
          </div>
        </DropdownMenuItem>

        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <SubmitEInvoiceButton
              table={table}
              module={"cash_sales"}
              model={"cash-sales"}
              refreshTable={refreshTable}
            />
          </div>
        </DropdownMenuItem>
        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <GetEInvoiceButton
              table={table}
              module={"cash_sales"}
              model={"cash-sales"}
              refreshTable={refreshTable}
            />
          </div>
        </DropdownMenuItem>
        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <CancelEInvoiceButton
              table={table}
              module={"cash_sales"}
              model={"cash-sales"}
              refreshTable={refreshTable}
              selectedRow={selectedRow}
            />
          </div>
        </DropdownMenuItem>

        {/* Transfer From (Mobile View Button) */}
        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <TransferFromButton
              table={table}
              id={selectedRow ? selectedRow.original.UUID : ""}
              config={cashSalesTransferFromConfig}
              onTransferComplete={refreshTable}
              refreshTable={refreshTable}
            />
          </div>
        </DropdownMenuItem>
        {/* Transfer To (Mobile View) */}
        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <TransferToButton
              table={table}
              refreshTable={refreshTable}
              id={selectedRow ? selectedRow.original.UUID : ""}
              config={cashSalesTransferToConfig}
            />
          </div>
        </DropdownMenuItem>
      </MobileActionGroupStart>

      {/* Web View (Start Menu) */}
      <div className="hidden flex-wrap items-center justify-start gap-x-2 md:flex">
        <NewButton destination="/sales/cash-sales/new" />
        <EditButton
          table={table}
          destination={`/sales/cash-sales/edit?item=${
            selectedRow ? selectedRow.original.docNo : ""
          }&id=${selectedRow ? selectedRow.original.UUID : ""}`}
        />
        <CloneButton 
          table={table} 
          destination={`/sales/cash-sales/clone?id=${selectedRow ? selectedRow.original.UUID : ""}`} 
        />
        <TrashButton
          table={table}
          module={"cash_sales"}
          model={"cash-sales"}
          refreshTable={refreshTable}
        />
        <RestoreButton
          table={table}
          module={"cash_sales"}
          model={"cash-sales"}
          refreshTable={refreshTable}
        />
        <DeleteButton
          table={table}
          module={"cash_sales"}
          model={"cash-sales"}
          refreshTable={refreshTable}
        />
        <PreviewButton
          table={table}
          previewType={"CASH SALES"}
          module={"cash_sales"}
          model={"cash-sales"}
          doc_id={selectedRow ? selectedRow.original.UUID : ""}
          refreshTable={refreshTable}
        />
        <SubmitEInvoiceButton
          table={table}
          module={"cash_sales"}
          model={"cash-sales"}
          refreshTable={refreshTable}
        />
        <GetEInvoiceButton
          table={table}
          module={"cash_sales"}
          model={"cash-sales"}
          refreshTable={refreshTable}
        />
        <CancelEInvoiceButton
          table={table}
          module={"cash_sales"}
          model={"cash-sales"}
          refreshTable={refreshTable}
          selectedRow={selectedRow}
        />
        {/* Transfer From (Web View Button) */}
        <TransferFromButton
          table={table}
          id={selectedRow ? selectedRow.original.UUID : ""}
          config={cashSalesTransferFromConfig}
          onTransferComplete={refreshTable}
          refreshTable={refreshTable}
        />
        {/* Transfer To (Web View Button) */}
        <TransferToButton
          table={table}
          refreshTable={refreshTable}
          id={selectedRow ? selectedRow.original.UUID : ""}
          config={cashSalesTransferToConfig}
        />
      </div>
    </div>
  );
}

function ActionGroupEnd({ 
  table, 
  refreshTable, 
  defaultColumns, 
  dataStatusBadgeDisplay,
  onResetColumnOrdering,
}: Props) {
  return (
    <div className="relative flex items-center gap-x-1 pr-1.5 text-erp-blue-14">
      {/* Web View (End Menu) */}
      <span className="absolute-left-32 hidden md:flex">
        {dataStatusBadgeDisplay}
      </span>
      <div className="hidden items-center gap-x-1 md:flex">
        <Export
          table={table}
          module={"cashSales"}
          mainModule={"sales"}
        />
        <Refresh
          refreshTable={refreshTable}
          resetRowSelection={() => table.resetRowSelection()}
        />
        <Validity table={table} />
        <ColumnVisibilityToggle
          table={table}
          defaultColumns={defaultColumns}
          onResetColumnOrdering={onResetColumnOrdering}
        />
      </div>

      {/* Mobile View (Search and Sort) */}
      <MobileActionGroupEnd
        table={table}
        config={{
          searchColumn: "docNo",
          searchPlaceholder: "Search Doc No.",
          sortColumn: "docNo"
        }}
      />
    </div>
  );
}