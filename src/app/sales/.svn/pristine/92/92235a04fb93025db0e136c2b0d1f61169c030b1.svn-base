"use client";

import React, { useEffect, useState, useRef } from "react";
import { useForm } from "react-hook-form";
import { FaClipboard, FaLayerGroup, FaQrcode } from "react-icons/fa6";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";

import { notFound, useRouter, useSearchParams } from "next/navigation";

import useSWR from "swr";

import { useToast } from "@/components/ui/use-toast";
import LoadingUI from "@/components/LoadingUI";
import { Form } from "@/components/ui/form";
import { ScrollArea } from "@/components/ui/scroll-area";
import { TabsNavigator } from "@/components/ui/TabsNavigator";

import { getFileToBase64 } from "@/lib/utils/commonFunction";
import {
  getAuthHeaders,
  ORIGIN,
  getGeneralPublic,
} from "@/lib/constants";

import { BuyerDetailsForm } from "./e-invoice-details/buyer-details/BuyerDetailsForm";
import { EInvoiceDetailsForm } from "./e-invoice-details/e-invoice-document-details/EInvoiceDetailsForm";
import { ImportExportOfGoodsForm } from "./e-invoice-details/import-&-export-of-goods/Import&ExportOfGoodsDetailsForm";
import { PaymentDetailsForm } from "./e-invoice-details/payment-details/PaymentDetailsForm";
import { ShippingRecipientDetailsForm } from "./e-invoice-details/shipping-recipient-details/ShippingRecipientDetailsForm";
import { SupplierDetailsForm } from "./e-invoice-details/supplier-details/SupplierDetailsForm";
import { DocumentDetailsForm } from "./main-details/document-details/DocumentDetailsForm";
import { ConsolidateEInvoiceColumns } from "./main-details/item-details/columns";
import ConsolidateEInvoiceDataTable from "./main-details/item-details/DataTable";
import OtherDetailsForm from "./more-details/OtherDetailsForm";
import TopActionBar from "./TopActionBar";
import { DateRestrictionContext } from "@/components/custom/DateRestrictionContext";

import {
  Card,
  CardContent,
  CardHeader,
  CardTitle
} from "@/components/ui/card";

type PageParams = {
  params: { slug: string };
};

const validRoutes = [
  "new",
  "edit",
  "clone",
  "transfer-to",
  "transfer-from",
] as const;

const fetcher = async (url) => {
  const headers = getAuthHeaders();

  return fetch(url, { headers }).then((res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    return res.json();
  });
};

type ValidRoute = (typeof validRoutes)[number];

const consolidateEInvoiceFormSchema = z.object({
  // docNo: z.string().min(1, {
  //   message: "Doc. No. is required",
  // }),
  // valid: z.string(),
});

function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

export default function ConsolidateEInvoiceDetailsPage({ params }: PageParams) {
  const headers = getAuthHeaders();
  const router = useRouter();

  const slug = params.slug;

  const searchParams = useSearchParams();
  const id = searchParams.get("id");

  const { toast } = useToast();

  const [isSaving, setIsSaving] = useState(false);

  const [formResetKey, setFormResetKey] = useState(0);
  const [approvalStatus, setApprovalStatus] = useState({});

  const [consolidateEInvoiceData, setConsolidateEInvoiceData] = useState({});
  const [tempRowConsolidateEInvoiceDetailsList, setTempRowConsolidateEInvoiceDetailsList] = useState([]);
  const [tempRowAttachments, setTempRowAttachments] = useState([]);
  const [UOMDetails, setUOMDetails] = useState({});
  const [allowPastRecord, setAllowPastRecord] = useState(true);

  const mainDetailsRef = useRef(null);
  const moreDetailsRef = useRef(null);
  const eInvoiceDetailsRef = useRef(null);
  const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");

  if (!isValidRoute(slug)) {
    notFound();
  }

  const {
    data: consolidateEInvoice,
    error,
    isLoading,
    isValidating,
    mutate: mutateConsolidateEInvoice,
  } = useSWR(
    id
      ? `${ORIGIN}/consolidated_invoice/api/consolidated-invoice/get-update-consolidated-invoice-data?id=${id}`
      : null,
    fetcher,
    { revalidateOnFocus: false }
  );

  
   const {
    data: defaultCurrentCompany,
  } = useSWR(
    !id
      && `${ORIGIN}/universal/get-current-company?id=${currentCompany?.UUID}`,
    fetcher,
    { revalidateOnFocus: false }
  );


  const {
    data: consolidateEInvoiceDetails,
    error: consolidateEInvoiceDetailsError,
    mutate: mutateConsolidateEInvoiceDetails,
  } = useSWR(
    id
      ? `${ORIGIN}/consolidated_invoice/api/consolidated-invoice/get-update-consolidated-invoice-has-details-data?id=${id}`
      : null,
    fetcher,
    { revalidateOnFocus: false }
  );

  const {
    data: getPermissions,
    error: getPermissionsError,
    mutate: mutateGetPermissions,
  } = useSWR(
    !id
      ? `${ORIGIN}/consolidated_invoice/api/consolidated-invoice/get-permissions`
      : null,
    fetcher,
    { revalidateOnFocus: false }
    
  );

  const viewEInvoiceDetails = [
    ...(Array.isArray(getPermissions?.data) ? getPermissions.data : []),
    ...(Array.isArray(consolidateEInvoice?.rules) ? consolidateEInvoice.rules : []),
  ].includes("view-consolidated-invoice-e-invoice-details");

  const tabs = [
    {
      id: "mainDetails",
      name: "Main Details",
      icon: FaClipboard,
      shortName: "Main",
    },
    {
      id: "moreDetails",
      name: "More Details",
      icon: FaLayerGroup,
      shortName: "More",
    },
    // {
    //   id: "eInvoiceDetails",
    //   name: "e-Invoice Details",
    //   icon: FaQrcode,
    //   shortName: "E-Inv",
    // },
    ...(viewEInvoiceDetails
      ? [
          {
            id: "eInvoiceDetails",
            name: "e-Invoice Details",
            icon: FaQrcode,
            shortName: "E-Inv",
          },
        ]
      : []),
  ];

  const isFetching = isLoading || isValidating;

  // Preference (State)
  const [preferenceData, setPreferenceData] = useState<any>(null);

 

  // Preference (Fetch Function)
  const fetchPreferenceData = async () => {
    try {
      const headers = getAuthHeaders();

      const response = await fetch(
        `${ORIGIN}/universal/get-preference?module=sales`,
        {
          method: "GET",
          headers,
        }
      );

      if (!response.ok) {
        throw new Error("Failed to fetch preference data");
      }

      const data = await response.json();
      setPreferenceData(data);
    } catch (error) {
      console.error("Error fetching preference data:", error);
    }
  };

  useEffect(() => {
    fetchPreferenceData();
  }, []);

  const form = useForm<z.infer<typeof consolidateEInvoiceFormSchema>>({
    resolver: zodResolver(consolidateEInvoiceFormSchema),
    defaultValues: {
      docNo: consolidateEInvoice?.docNo ?? "",
      // docDate: consolidateEInvoice?.docDate ?? "",
      agentName: consolidateEInvoice?.agentName ?? "",
      description: consolidateEInvoice?.description ?? "",
      valid: consolidateEInvoice?.valid ?? "1",
      currency: consolidateEInvoice?.currency ?? "",
      currencyCode: consolidateEInvoice?.currencyCode ?? "",
      currencyRate: consolidateEInvoice?.currencyRate ?? "",
    },
  });



  useEffect(() => {
    if (
      consolidateEInvoice &&
      slug !== "transfer-to" &&
      slug !== "transfer-from"
    ) {
      const consolidateEInvoiceDataCopy = { ...consolidateEInvoice.data };
   
      // Clear docNo if it's a clone page
      if (slug === "clone") {

        consolidateEInvoiceDataCopy.docNo = "";
        consolidateEInvoiceDataCopy.docDate = Math.floor(Date.now() / 1000);
        consolidateEInvoiceDataCopy.eInvoiceStatus = "";
        consolidateEInvoiceDataCopy.digitalSignature = "";
        consolidateEInvoiceDataCopy.oriRefNo = "";
        consolidateEInvoiceDataCopy.eInvoiceVersion = "";
        consolidateEInvoiceDataCopy.eInvoiceCode = "";     
        consolidateEInvoiceDataCopy.consolidateTo="";
      }

      setConsolidateEInvoiceData(consolidateEInvoiceDataCopy);
      setApprovalStatus(consolidateEInvoice.approval);
      setIsSaving(false);
      setTempRowAttachments(
        consolidateEInvoice.data.attachmentLink
          ? consolidateEInvoice.data.attachmentLink
          : []
      );

      // Repopulate form with loaded data
      form.reset(slug === "clone" ? { ...consolidateEInvoice.data, docNo: "", docDate: Math.floor(Date.now() / 1000),eInvoiceStatus:"",digitalSignature:"",oriRefNo:"",eInvoiceVersion:"",eInvoiceCode:"" } : consolidateEInvoice.data);
    }
  }, [consolidateEInvoice, slug, form]);

  useEffect(() => {
    if (
      consolidateEInvoiceDetails &&
      slug !== "transfer-to" &&
      slug !== "transfer-from"
    ) {
      // Preference (Add Preference Data to Table Details)
      const detailsWithPreferences = consolidateEInvoiceDetails.rows.map(
        (row) => ({
          ...row,
          preferenceData: preferenceData,
        })
      );

      setTempRowConsolidateEInvoiceDetailsList(detailsWithPreferences);
    }
  }, [consolidateEInvoiceDetails, preferenceData]);

  const revalidateConsolidateEInvoiceDetails = () => {
    mutateConsolidateEInvoiceDetails();
  };

  const revalidateConsolidatedInvoice = () => {
    mutateConsolidateEInvoice(undefined, { revalidate: true });
  };

  const handleSubmit = async () => {
    try {
      await form.trigger(); 
      await form.handleSubmit(onSubmit)();
    } catch (error) {
      console.error("Form submission error:", error);
    }
  };

  const onSubmit = async () => {
    setIsSaving(true);

    // Prevent save if any document has subTotal or subtotalTax = 0
    const invalidRows = tempRowConsolidateEInvoiceDetailsList.filter(
      (row) =>
        !row.subTotal ||
        parseFloat(row.subTotal) === 0 ||
        !row.subtotalTax ||
        parseFloat(row.subtotalTax) === 0
    );

    if (invalidRows.length > 0) {
      toast({
        title: "Invalid",
        description:
          "Document amount cannot be zero.",
        variant: "destructive",
        duration: 4000,
      });

      setIsSaving(false);
      return;
    }

    var form_data = new FormData();
    var formValues = form.getValues();

    const localNetTotal = document.querySelector(".localNetTotal");
    const netTotal = document.querySelector(".netTotal");


    var saveType =
      slug == "clone"
        ? `create-data?c_id=1`
        : id
        ? `update-consolidated-invoice-data?id=${id}`
        : `create-data`;

    // Preference (Get Decimal Places for Calculations)
    const decimal = preferenceData?.data?.decimal || 2;

    let totalAmount = tempRowConsolidateEInvoiceDetailsList.reduce((sum, row) => {
      return sum + (row.amount ? parseFloat(row.amount) : 0);
    }, 0);

    let totalDiscount = tempRowConsolidateEInvoiceDetailsList.reduce((sum, row) => {
      return sum + (row.discountAmount ? parseFloat(row.discountAmount) : 0);
    }, 0);

    let totalTax = tempRowConsolidateEInvoiceDetailsList.reduce((sum, row) => {
      return sum + (row.taxAmount ? parseFloat(row.taxAmount) : 0);
    }, 0);

    // Fix the calculation of totalSubtotal
    // let totalSubtotal = totalAmount - totalDiscount;

    let totalSubtotal = tempRowConsolidateEInvoiceDetailsList.reduce((sum, row) => {
      return sum + (row.subTotal ? parseFloat(row.subTotal) : 0);
    }, 0);

    let prepaymentAmount = parseFloat(formValues.prepaymentAmount) || 0;
    let totalFeeAmount = parseFloat(formValues.totalFeeAmount) || 0;

    // Use the actual rounding amount from the form instead of calculating
    let roundingAmount = parseFloat(formValues.roundingAmount) || 0;

    // Correct totalPayable Calculation using the form's rounding amount
    let totalPayable = (
      totalAmount -
      totalDiscount +
      totalTax -
      prepaymentAmount +
      totalFeeAmount +
      roundingAmount
    );

    // let totalPayableWithCurrency = totalPayable * formValues.currencyRate

    let localNetTotalValue = (
      (totalAmount -
      totalDiscount +
      totalTax -
      roundingAmount) *
      formValues.currencyRate
    );

    // Validation: Prevent save if totalPayable >= 10,000
    // if (totalPayable >= 10000 || localNetTotalValue >= 10000) {
    //   toast({
    //     title: "Error",
    //     description: "Total invoice amount cannot exceed RM10,000 for Consolidate Invoice.",
    //     variant: "destructive",
    //     duration: 4000,
    //   });
    //   setIsSaving(false);
    //   return;
    // }

     // Preference (Apply Decimal Formatting to Totals)
    formValues.totalAmount = totalAmount.toFixed(decimal);
    formValues.totalDiscount = totalDiscount.toFixed(decimal);
    formValues.totalTax = totalTax.toFixed(decimal);
    formValues.totalSubtotal = totalSubtotal.toFixed(decimal);
    formValues.totalPayable = totalPayable.toFixed(decimal);

    formValues.localNetTotal =localNetTotal?.value
    formValues.netTotal =netTotal?.value

    // Create consolidated invoice object excluding attachments
    const consolidatedInvoiceData = { ...formValues };
    delete consolidatedInvoiceData.attachmentLink;
    delete consolidatedInvoiceData.attachment;
    
    // Combine consolidated invoice and details into single data object
    const combinedData = {
      consolidatedInvoice: consolidatedInvoiceData,
      consolidatedInvoiceHasDetails: tempRowConsolidateEInvoiceDetailsList
    };

    // Add combined data as JSON string
    form_data.append("data", JSON.stringify(combinedData));

    if (saveType === "create-data") {
      if (slug === "transfer-to")
        localStorage.removeItem("transfer-to.sales-credit-note");
      else if (slug === "transfer-from")
        localStorage.removeItem("transfer-from.sales-credit-note");

      var counter = 0;

      for (const file of tempRowAttachments) {
        const base64 = await getFileToBase64(file);

        form_data.append(
          `consolidatedInvoice[attachment][${counter}][Name]`,
          file.name
        );
        form_data.append(
          `consolidatedInvoice[attachment][${counter}][File]`,
          base64
        );

        counter++;
      }
    } else {
      var counter = 0;

      for (const attachment of tempRowAttachments) {
        if (attachment.link) {
          form_data.append(
            `consolidatedInvoice[attachment][${counter}][Name]`,
            attachment.name
          );
          form_data.append(
            `consolidatedInvoice[attachment][${counter}][File]`,
            ""
          );
        } else {
          const base64 = await getFileToBase64(attachment);

          form_data.append(
            `consolidatedInvoice[attachment][${counter}][Name]`,
            attachment.name
          );
          form_data.append(
            `consolidatedInvoice[attachment][${counter}][File]`,
            base64
          );
        }

        counter++;
      }
    }

    try {
      const response = await fetch(
        `${ORIGIN}/consolidated_invoice/api/consolidated-invoice/${saveType}`,
        {
          method: "POST",
          headers,
          body: form_data,
        }
      );

      if (!response.ok) {
        const errorData = await response.json();

        setIsSaving(false);

        let errorMessage = errorData.message;

        // Error Handling for "Data too long"
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 2000,
        });
        
        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        const url = `/sales/consolidated-invoice/edit?item=${responseData.item}&id=${responseData.data}`;
        
        router.push(url);

        if (params.slug == "edit") {
          // Manually revalidate the data since router.push() won’t trigger it if same path
          mutateConsolidateEInvoice();
          mutateConsolidateEInvoiceDetails();
        }

        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        router.push(`/sales/consolidated-invoice/clone?id=${id}`);

        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error creating new consolidated invoice data:", error);

      setIsSaving(false);

      toast({
        title: "Failed",
        description: `${error.message}`,
        variant: "destructive",
        duration: 2000,
      });
    }
  };

  useEffect(() => {
    const fetchGeneralPublic = async () => {
      const result = await getGeneralPublic();
   
      if (result && slug == "new") {
        form.setValue("buyerName", result.customerName);
        form.setValue("customerName", result.customerName);
        form.setValue("customerCode", result.UUID);
        form.setValue("customerCodeCode", result.customerCode);
        form.setValue("buyerPhoneNo", result.phoneNo);
        form.setValue("buyerTIN", result.TIN);
        form.setValue("buyerBRN", result.BRN);
        form.setValue("buyerEmail", result.email);
        form.setValue("buyerSSTNo", result.SSTNo);
        form.setValue("buyerAddress", result.address);

        form.setValue("recipient", result.customerName);
        form.setValue("recipientTIN", result.TIN);
        form.setValue("recipientBRN", result.BRN);
        form.setValue("recipientSSTNo", result.SSTNo);
        form.setValue("recipientAddress", result.address);
      } else {
        form.setValue("customerName", result.customerName);
        form.setValue("customerCode", result.UUID);
        form.setValue("customerCodeCode", result.customerCode);
      }
    };

    fetchGeneralPublic();
  }, []);


  useEffect(() => {
    if (typeof window !== "undefined") {
      let transferData: any = {};

      if (slug === "transfer-to")
        transferData = JSON.parse(
          localStorage.getItem("transfer-to.sales-debit-note") || "{}"
        );
      else if (slug === "transfer-from")
        transferData = JSON.parse(
          localStorage.getItem("transfer-from.sales-debit-note") || "{}"
        );

      setConsolidateEInvoiceData(transferData?.data);

      transferData?.subData?.forEach((detail) => {
        detail["item"] = detail["itemCode"];
        detail["itemGroup"] = detail["itemGroupCode"];
        detail["itemCategory"] = detail["itemCategoryCode"];
      });

      setTempRowConsolidateEInvoiceDetailsList(transferData?.subData ?? []);

      function beforeUnload(e: BeforeUnloadEvent) {
        if (slug === "transfer-to")
          localStorage.removeItem("transfer-to.sales-debit-note");
        else if (slug === "transfer-from")
          localStorage.removeItem("transfer-from.sales-debit-note");

        e.preventDefault();
      }

      window.addEventListener("beforeunload", beforeUnload);

      return () => {
        window.removeEventListener("beforeunload", beforeUnload);
      };
    }
  }, []);

  return (
    <DateRestrictionContext.Provider value={{ allowPastRecord, setAllowPastRecord }}>
      <div className="sticky top-0 z-20">
        <TopActionBar
          ConsolidateEInvoice={consolidateEInvoiceData}
          approvalStatus={approvalStatus}
          handleSubmit={handleSubmit}
          form={form}
          consolidateEInvoiceFormSchema={consolidateEInvoiceFormSchema}
          isSaving={isSaving}          
          setIsSaving={setIsSaving}
          slug={slug}
          revalidateConsolidatedInvoice={revalidateConsolidatedInvoice}
          viewEInvoiceDetails={viewEInvoiceDetails}
        />
      </div>
      <div className="grid h-full grid-rows-[auto_1fr]">        
        <Form {...form}>
          <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
            <ScrollArea className="h-full">
              <div id="mainDetails" className="mt-2" ref={mainDetailsRef}>
                <DocumentDetailsForm form={form} slug={slug} />
              </div>

              <div className="mt-2">
                <ConsolidateEInvoiceDataTable
                  columns={ConsolidateEInvoiceColumns}
                  data={
                    id
                      ? consolidateEInvoiceDetails
                        ? consolidateEInvoiceDetails.rows
                        : []
                      : tempRowConsolidateEInvoiceDetailsList
                  }
                  tempRowConsolidateEInvoiceDetailsList={tempRowConsolidateEInvoiceDetailsList}
                  setTempRowConsolidateEInvoiceDetailsList={setTempRowConsolidateEInvoiceDetailsList}
                  revalidateConsolidateEInvoiceDetails={revalidateConsolidateEInvoiceDetails}
                  form={form}
                  consolidateEInvoiceData={consolidateEInvoiceData}
                  UOMDetails={UOMDetails}
                  preferenceData={preferenceData}
                  slug={slug}
                />
              </div>

              <div id="moreDetails" className="mt-2" ref={moreDetailsRef}>
                <OtherDetailsForm
                  tempRowAttachments={tempRowAttachments}
                  setTempRowAttachments={setTempRowAttachments}
                  form={form}
                  slug={slug}
                  preferenceData={preferenceData}
                />
              </div>
              
              <Card
                collapsible
                defaultCollapsed={false}
                // className="h-auto pb-2 shadow-md"
                className={`h-auto pb-2 shadow-md ${!viewEInvoiceDetails ? "hidden" : ""}`}
                style={{ marginTop: "10px" }}
              >
                <CardHeader>
                  <CardTitle className="text-lg font-bold">E-invoice Details</CardTitle>
                </CardHeader>
                <CardContent className="px-2 py-0">
                  <div>
                    <div id="eInvoiceDetails" ref={eInvoiceDetailsRef}>
                      <SupplierDetailsForm 
                        form={form} 
                        defaultCurrentCompany={slug=="new"?defaultCurrentCompany:""} 
                      />
                    </div>

                    <div className="mt-2">
                      <BuyerDetailsForm form={form} />
                    </div>

                    <div className="mt-2">
                      <EInvoiceDetailsForm
                        form={form}
                        consolidateEInvoiceDetails={
                          id
                            ? consolidateEInvoiceDetails
                              ? consolidateEInvoiceDetails.rows
                              : []
                            : tempRowConsolidateEInvoiceDetailsList
                        }
                        tempRowConsolidateEInvoiceDetailsList={tempRowConsolidateEInvoiceDetailsList}
                        preferenceData={preferenceData}
                        consolidateEInvoiceData={consolidateEInvoiceData}
                      />
                    </div>

                    <div className="mt-2">
                      <PaymentDetailsForm form={form} />
                    </div>

                    <div className="mt-2">
                      <ShippingRecipientDetailsForm form={form} />
                    </div>

                    <div className="mt-2">
                      <ImportExportOfGoodsForm form={form} />
                    </div>
                  </div>
                </CardContent>
              </Card>
            </ScrollArea>

            <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14"/>
          </div>
        </Form>
        
        {/* {isLoading && <LoadingUI />} */}
        {(isFetching || isSaving) && <LoadingUI />}
        {(isLoading || isSaving) && <LoadingUI />}
      </div>
    </DateRestrictionContext.Provider>
  );
}