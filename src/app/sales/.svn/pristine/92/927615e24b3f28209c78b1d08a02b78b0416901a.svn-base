"use client";

import React, { useEffect, useState } from "react";
import { useForm } from "react-hook-form";
import { FaClipboard, FaLayerGroup, FaTableList } from "react-icons/fa6";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";

import { notFound, useRouter, useSearchParams } from "next/navigation";

import useSWR from "swr";

import LoadingUI from "@/components/LoadingUI";
import { Form } from "@/components/ui/form";
import { ScrollArea } from "@/components/ui/scroll-area";
import { useToast } from "@/components/ui/use-toast";
import { TabsNavigator } from "@/components/ui/TabsNavigator";
import {
  ColumnFiltersState,
  PaginationState,
  SortingState,
} from "@tanstack/react-table";

import { getFileToBase64 } from "@/lib/utils/commonFunction";
import {
  getAuthHeaders,
  getCurrentAcc,
  getCurrentAccount,
  ORIGIN,
  DEFAULT_DATA_TABLE_PAGE_SIZE,
} from "@/lib/constants";

import { CustomerCategoryForm } from "./main-details/general-details/CustomerCategoryForm";
import TopActionBar from "./TopActionBar";
import CustomInformationDataTable from "./more-details/custom-information/DataTable";
import { customInformationColumns } from "./more-details/custom-information/columns";
import { OtherDetailForm } from "./more-details/custom-information/OtherDetailForm";
import { changelogColumns } from "./changelog/columns";
import CustomerCategoryChangelogDataTable from "./changelog/DataTable";

type PageParams = {
  params: { slug: string };
};

const validRoutes = ["new", "edit", "clone"] as const;


// Updated fetcher to handle both GET and POST requests
const fetcher = async (
  url: string,
  options: { method?: string; body?: FormData } = {}
) => {

  const headers = getAuthHeaders();

  return fetch(url, {
    method: options.method || "GET",
    headers,
    ...(options.body ? { body: options.body } : {}),
  }).then(async (res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    try {
      return await res.json();
    } catch (error) {
      throw new Error("Failed to parse response JSON");
    }
  });
};

type ValidRoute = (typeof validRoutes)[number];

const customerCategoryFormSchema = z.object({
  // companyName: z.union([z.string(), z.literal("")]),
  // port: z.string().min(2, {
  //   message: "Port must be at least 2 characters.",
  // }),
  // vessel: z.string().min(2, {
  //   message: "Vessel must be at least 2 characters.",
  // }).optional(),
  // description: z.string().optional(),
  // valid: z.union([z.literal("0"), z.literal("1")]).default("1"),
  customerCategory: z.string().min(2, {
    message: "Customer Category is required and must be at least 2 characters.",
  }),
});

// Function to check if a route is valid
function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

export default function CustomerCategoryDetailsPage({ params }: PageParams) {
  const slug = params.slug;
  const router = useRouter();
  const { toast } = useToast();
  const headers = getAuthHeaders();
  const currentAcc = getCurrentAcc();
  const currentAccount = getCurrentAccount();

  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const [formResetKey, setFormResetKey] = useState(0);
  const [isSaving, setIsSaving] = useState(false);

  const [customerCategoryData, setCustomerCategoryData] = useState({});
  const [tempRowCustomInfo, setTempRowCustomInfo] = useState([]);
  const [customerCategoryChangelogData, setCustomerCategoryChangelogData] = useState([]);

  // Add state for table parameters - these mirror what's in the DataTable
  const [columnFilters, setColumnFilters] = useState<ColumnFiltersState>([]);
  const [pagination, setPagination] = useState<PaginationState>({
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });
  const [sorting, setSorting] = useState<SortingState>([
    { id: "createdAt", desc: true },
  ]);

  const handleTableParamsChange = (
    newFilters: ColumnFiltersState,
    newPagination: PaginationState,
    newSorting: SortingState
  ) => {
    setColumnFilters(newFilters);
    setPagination(newPagination);
    setSorting(newSorting);
  };


  const tabs = [
    {
      id: "mainDetails",
      name: "Main Details",
      shortName: "Main",
      icon: FaClipboard,
    },
    {
      id: "moreDetails",
      name: "More Details",
      shortName: "More",
      icon: FaLayerGroup,
    },
    ...(slug !== "new"
      ? [
        {
          id: "changelog",
          name: "Changelog",
          shortName: "Changelog",
          icon: FaTableList,
        },
      ]
      : []),
  ];

  const resetForm = () => {
    setFormResetKey((prevKey) => prevKey + 1);
  };

  if (!isValidRoute(slug)) {
    notFound();
  }

  // const {
  //   data: changelogData,
  //   error: changelogError,
  //   mutate: mutateChangelogData,
  // } = useSWR(
  //   id && slug !== "new"
  //     ? `${ORIGIN}/customer_category/api/customer-category/get-customer-category-log?id=${id}`
  //     : null,
  //   fetcher
  // );

  const {
    data: customInformationData,
    error: customInfoError,
    mutate: mutateCustomInfo,
  } = useSWR(
    id
      ? [
        `${ORIGIN}/customer_category/api/customer-category/get-update-customer-category-has-custom-info-data?id=${id}`,
      ]
      : null,
    ([url]) => {
      const params = new FormData();

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append(
        "param[offset]",
        `${pagination.pageIndex * pagination.pageSize}`
      );

      const columnFiltersWithoutValid = columnFilters.filter(
        (filter) => filter.id !== "valid"
      );
      params.append(
        "param[filter]",
        columnFiltersWithoutValid.length > 0
          ? JSON.stringify(
            columnFiltersWithoutValid.reduce<Record<string, unknown>>(
              (acc, curr) => {
                acc[curr.id] = curr.value;
                return acc;
              },
              {}
            )
          )
          : "{}"
      );

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc"
      );
      params.append(
        "param[valid]",
        columnFilters.length > 0
          ? `${columnFilters.find((row) => row.id === "valid")?.value}`
          : ""
      );
      params.append(
        "param[sort]",
        sorting.length > 0 ? sorting[0].id : "createdAt"
      );

      return fetcher(url, { method: "POST", body: params });
    }, {
    revalidateOnMount: false, // don’t fetch immediately
    revalidateOnFocus: false, // optional, prevents refetch on tab focus
  }
  );

  const {
    data: customerCategory,
    isValidating,
    mutate: mutateCustomerCategory,
    error,
    isLoading,
  } = useSWR(
    id
      ? [
        `${ORIGIN}/customer_category/api/customer-category/get-update-customer-category-data?id=${id}`,
      ]
      : null,
    ([url]) => {
      // Create form data with the same parameters as in DataTable
      const params = new FormData();

      // Add pagination parameters
      params.append("param[limit]", `${pagination.pageSize}`);
      params.append(
        "param[offset]",
        `${pagination.pageIndex * pagination.pageSize}`
      );

      // Add filter parameters
      const columnFiltersWithoutValid = columnFilters.filter(
        (filter) => filter.id !== "valid"
      );

      params.append(
        "param[filter]",
        columnFiltersWithoutValid.length > 0
          ? JSON.stringify(
            columnFiltersWithoutValid.reduce<Record<string, unknown>>(
              (acc, curr) => {
                acc[curr.id] = curr.value;
                return acc;
              },
              {}
            )
          )
          : "{}"
      );

      // Add sorting parameters
      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc"
      );

      params.append(
        "param[valid]",
        columnFilters.length > 0
          ? `${columnFilters.find((row) => row.id === "valid")?.value}`
          : ""
      );

      params.append(
        "param[sort]",
        sorting.length > 0 ? sorting[0].id : "createdAt"
      );

      return fetcher(url, { method: "POST", body: params });
    },
    {
      revalidateOnFocus: false, // optional, prevents refetch on tab focus
    }
  );

  const isFetching = isLoading || isValidating;

  useEffect(() => {
    if (error || customInfoError) {
      toast({
        variant: "destructive",
        title: "Session Expired",
        description: "Your session has expired. Redirecting to login page.",
      });
      router.push("/login");
    }
  }, [error, router, toast, customInfoError]);


  useEffect(() => {
    if (customerCategory) {
      const customerCategoryDataCopy = { ...customerCategory.data };

      // Clear customerCategoryCode if it's a clone page
      if (slug === "clone") {
        customerCategoryDataCopy.customerCategoryCode = "";
        customerCategoryDataCopy.UUID = "";
      }

      setCustomerCategoryData(customerCategoryDataCopy);
      if (customerCategory.customerCategoryHasCustomInfo?.rows) {
        setTempRowCustomInfo(
          customerCategory.customerCategoryHasCustomInfo.rows
        );
      }
      if (customerCategory.historyData) {
        const historyData = {
          customerCategory: customerCategory.historyData.customerCategory || { rows: [] },
          customerCategoryHasCustomInfo: customerCategory.historyData.customerCategoryHasCustomInfo || { rows: [] },
        };

        setCustomerCategoryChangelogData(historyData);
      }

      setIsSaving(false)
    }
  }, [customerCategory, slug]);

  // Add separate effect for custom information data
  useEffect(() => {

    if (customInformationData?.rows) {

      setTempRowCustomInfo(customInformationData.rows);
    }
  }, [customInformationData]);

  const revalidateCustomInfoData = () => {
    mutateCustomInfo();
  };

  const handleSubmit = async () => {
    try {
      await form.trigger();
      await form.handleSubmit(onSubmit)();
    } catch (error) {
      console.error("Form submission error:", error);
    }
  };

  const form = useForm<z.infer<typeof customerCategoryFormSchema>>({
    resolver: zodResolver(customerCategoryFormSchema),
    defaultValues: {
      account: customerCategory?.account ?? currentAccount,
      accountName: customerCategory?.accountName ?? currentAcc,
      companyName: customerCategory?.companyName ?? "",
      customerCategoryCode: customerCategory?.customerCategoryCode ?? "",
      customerCategory: customerCategory?.customerCategory ?? "",
      description: customerCategory?.description ?? "",
      valid: customerCategory?.valid ?? "1",
    },
  });

  const onSubmit = async () => {
    setIsSaving(true)
    var form_data = new FormData();
    var formValues = form.getValues();
    var saveType =
      slug == "clone"
        ? `create-data?c_id=1`
        : id
          ? `update-customer-category?id=${id}`
          : `create-data`;

    for (var key in formValues) {
      form_data.append(
        `customerCategory[${key}]`,
        formValues[key] ? formValues[key] : ""
      );
    }

    if (saveType === "create-data" || saveType === "create-data?c_id=1") {
      let customInfoIndex = 0;

      for (const row of tempRowCustomInfo) {
        // Add basic custom info fields
        for (const key in row) {
          if (key !== "attachment" && key !== "attachmentFiles") {
            form_data.append(`customerCategoryHasCustomInfo[${customInfoIndex}][${key}]`, row[key]);
          }
        }

        // Handle attachment files for new records
        if (row.attachmentFiles && row.attachmentFiles.length > 0) {
          let fileCounter = 0;
          for (const fileData of row.attachmentFiles) {
            if (fileData.size) {
              // Convert file to base64 for new uploads
              const base64 = await getFileToBase64(fileData);
              form_data.append(
                `customerCategoryHasCustomInfo[${customInfoIndex}][attachment][${fileCounter}][Name]`,
                fileData.name
              );
              form_data.append(
                `customerCategoryHasCustomInfo[${customInfoIndex}][attachment][${fileCounter}][File]`,
                base64
              );
            } else {
              // Handle existing files (when cloning)
              form_data.append(
                `customerCategoryHasCustomInfo[${customInfoIndex}][attachment][${fileCounter}][Name]`,
                fileData.name
              );
              form_data.append(
                `customerCategoryHasCustomInfo[${customInfoIndex}][attachment][${fileCounter}][File]`,
                " "
              );
            }
            fileCounter++;
          }
        }

        customInfoIndex++;
      }
    }

    try {
      const response = await fetch(
        `${ORIGIN}/customer_category/api/customer-category/${saveType}`,
        {
          method: "POST",
          headers,
          body: form_data,
        }
      );

      if (response.status === 401) {
        console.error("Session expired. Redirecting to login.");
        toast({
          variant: "destructive",
          title: "Session Expired",
          description: "Your session has expired. Redirecting to login page.",
        });
        router.push("/login");
        throw new Error("Session expired");
      }

      if (!response.ok) {
        setIsSaving(false)
        const errorData = await response.json();

        let errorMessage = errorData.message;

        // Error Handling for "Data too long"
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 2000,
        });

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        const url = `/sales/customer-category/edit?item=${responseData.item}&id=${responseData.data}`;
        router.push(url);
        if (params.slug == "edit") {
          mutateCustomerCategory()
        }
        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        router.push(`/sales/customer-category/clone?id=${id}`);
        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      setIsSaving(false)
      console.error("Error creating new customer category data:", error);
    }
  };

  return (
    <>
      <div className="sticky top-0 z-20">
        <TopActionBar
          customerCategory={customerCategoryData}
          form={form}
          handleSubmit={handleSubmit}
          params={params}
          isSaving={isSaving}
          setIsSaving={setIsSaving}
        />
      </div>
      <div className="grid h-full grid-rows-[auto_1fr]">
        <Form {...form}>
          <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
            <ScrollArea className="h-full">
              <div id="mainDetails" className="mt-2">
                <CustomerCategoryForm
                  key={formResetKey}
                  form={form}
                  slug={slug}
                />
              </div>
              <div className="mt-2">
                <OtherDetailForm form={form} slug={slug} />
              </div>
              <div id="moreDetails" className="mt-2">
                <CustomInformationDataTable
                  columns={customInformationColumns}
                  data={tempRowCustomInfo}
                  tempRowCustomInfo={tempRowCustomInfo}
                  setTempRowCustomInfo={setTempRowCustomInfo}
                  revalidateCustomInfoData={revalidateCustomInfoData}
                />
              </div>
              {slug !== "new" && (
                <div id="changelog" className="mt-2">
                  <CustomerCategoryChangelogDataTable
                    columns={changelogColumns}
                    initialData={customerCategoryChangelogData}
                    onTableParamsChange={handleTableParamsChange}
                  />
                </div>
              )}
            </ScrollArea>

            <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14" />
          </div>
          {/* {isLoading && < LoadingUI />} */}
          {(isFetching || isSaving) && <LoadingUI />}
          {(isLoading || isSaving) && <LoadingUI />}
        </Form>
      </div>
    </>
  );
}