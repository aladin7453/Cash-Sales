"use client";

import { ColumnDef } from "@tanstack/react-table";

export type ChangelogItem = {
  UUID: string;
  action: string;
  agentTypeCode: string;
  agentType: string;
  createdAtFormat: string;
  createdByUsername: string;
  _version: string;
  _actionUUID: string;
  historyUUID: string;
};

export const changelogColumns: ColumnDef<ChangelogItem>[] = [
  {
    accessorKey: "createdAtFormat",
    header: "Date",
    cell: ({ row }) => {
      const date = row.getValue("createdAtFormat") as string;
      return date || "-";
    },
  },
  {
    accessorKey: "createdByUsername",
    header: "User",
  },
  {
    accessorKey: "action",
    header: "Action",
  },
  {
    accessorKey: "agentTypeCode", // Default fallback - will be overridden by tab-specific referenceField
    header: "Reference",
    cell: ({ row }) => {
      const value = row.getValue("agentTypeCode") as string;
      return value || "-";
    },
  },
  {
    accessorKey: "",
    header: "Details",
    // The cell implementation will be replaced in DataTable.tsx
  },
];
