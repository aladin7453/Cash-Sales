"use client";

import React, { useEffect, useRef, useState } from "react";
import { FaArrowRotateLeft, FaMagnifyingGlass } from "react-icons/fa6";

import { useRouter, useSearchParams } from "next/navigation";

import { Input } from "@/components/ui/input";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Textarea } from "@/components/ui/textarea";
import { useToast } from "@/components/ui/use-toast";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import DropdownTable from "@/components/data-table/DropdownTable";
import { Button } from "@/components/ui/button";
import { 
  Card, 
  CardContent, 
  CardDescription, 
  CardTitle,
  CardHeader
} from "@/components/ui/card";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { 
  Tooltip, 
  TooltipTrigger, 
  TooltipContent, 
  TooltipProvider 
} from "@/components/ui/tooltip";

import { cn } from "@/lib/utils/cn";
import { isSystemOwner } from "@/lib/utils/isSystemOwner";
import { useVerify } from "@/lib/hooks/useVerify";
import { 
  getAuthHeaders, 
  getCurrentAccount, 
  ORIGIN,
  getCurrentAcc,
  getCurrentCompanyUUID,
  getCurrentCompany
} from "@/lib/constants";

import type { Customer } from "../../../columns";

type Params = {
  customer?: Customer | null;
  customInformationData: any;
  tempRow: any;
  form: any;
  hasAssociations: boolean;
  slug?: string;
};

export function OtherDetailForm({
  customer,
  customInformationData,
  tempRow,
  form,
  hasAssociations,
  slug,
}: Params) {
  // const { verifyField } = useVerify(form, "/customer/api/customer/verify", "customer", form.watch("UUID"));

  const headers = getAuthHeaders();
  const currentAccount = getCurrentAccount();
  const currentAcc = getCurrentAcc();

  const searchParams = useSearchParams();
  const { toast } = useToast();
  const id = searchParams.get("id");
  const router = useRouter();

  const [showTableMSICCode, setShowTableMSICCode] = useState(false);
  const [showTableAccount, setShowTableAccount] = useState(false);
  const [showTableCompany, setShowTableCompany] = useState(false);
  const [showTableCustomerGroup, setShowTableCustomerGroup] = useState(false);
  const [showTableGLCode, setShowTableGLCode] = useState(false);
  const [showTableAgent, setShowTableAgent] = useState(false);

  const [MSICCodeDropdownTableData, setMSICCodeDropdownTableData] = useState([]);
  const [accountDropdownTableData, setAccountDropdownTableData] = useState([]);
  const [companyDropdownTableData, setCompanyDropdownTableData] = useState([]);
  const [customerGroupDropdownTableData, setCustomerGroupDropdownTableData] = useState([]);
  const [agentDropdownTableData, setAgentDropdownTableData] = useState([]);

  const currentCompanyName = getCurrentCompany();
  const [currentCompanyUUID, setCurrentCompanyUUID] = useState<string | null>(null);
  const [currentCompany, setCurrentCompany] = useState<string | null>(null);
 
  const toggleTableCompany = async () => {
    const formData = new FormData();
    const company = "company";

    formData.append("table[]", company);

    if (!showTableCompany) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
          method: "POST",
          headers,
          body: formData,
        });

        if (!response.ok) {
          throw new Error("Failed to fetch company drop-down data");
        }

        const companyData = await response.json();

        setCompanyDropdownTableData(companyData.rows);
        setShowTableCompany(true);
      } catch (error) {
        console.error("Error fetching company drop-down data:", error);
      }
    } else {
      setShowTableCompany(false);
    }
  };

  const dropdownRef = useRef(null);
  const inputRef = useRef(null);

  const dropdownCompanyColumns = [
    { accessorKey: "companyID", header: "Company Code" },
    { accessorKey: "company", header: "Company" },
    {
      accessorKey: "description",
      header: "Description",
      cell: ({ row }) => <DescriptionCellTooltip row={row} />,
    },
  ];

  const onClickRowCompanyCode = (row) => {
    form.setValue("company", row.UUID);
    form.setValue("companyName", row.company);

    setShowTableCompany(false);
  };

  return (
    <Card collapsible defaultCollapsed={false} className="shadow-sm">
      <CardHeader>
        <CardTitle className="text-lg font-bold">Other Details</CardTitle>
      </CardHeader>
      <CardContent>
        <Form {...form}>
          <form 
            className={cn(
              "grid h-full grid-rows-[auto_1fr] space-y-1",
            )}
          >
            { /* Mobile View CSS Class: grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-(Number of Maximum Columns)*/}
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-3">
              <FormField
                control={form.control}
                name="account"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7" {...field} value={currentAccount} readOnly={true} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="accountName"
                render={({ field }) => (
                  <FormItem
                    className={cn(
                      "col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1",
                    )}
                  >
                    <FormLabel>Sys Acc:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative h-7.5">
                        <Input
                          className="h-7.5 pr-8 bg-erp-gray-1 text-gray-500"
                          {...field}
                          value={currentAcc}
                          readOnly={true}
                          ref={inputRef}
                          autoComplete="off"
                        />
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="company"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7" {...field} defaultValue={currentCompanyUUID} readOnly={true} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="companyName"
                render={({ field }) => (
                  <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <TooltipProvider delayDuration={0}>
                      <Tooltip>
                        <TooltipTrigger asChild>
                          <FormLabel>Ownership:</FormLabel>
                        </TooltipTrigger>
                        <TooltipContent>
                          Ownership Company
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8 bg-erp-gray-1 text-gray-500"
                          {...field}
                          // onClick={toggleTableCompany}
                          ref={inputRef}
                          autoComplete="off"
                          defaultValue={currentCompanyName}
                          readOnly={true}
                        />
                        {/* <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {showTableCompany && (
                          <div ref={dropdownRef} className="absolute top-full bg-white border border-gray-200 rounded shadow-md z-50 h-[200px]">
                            <ScrollArea className="h-[100cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownCompanyColumns}
                                data={companyDropdownTableData}
                                onClickRow={onClickRowCompanyCode}
                              />
                            </ScrollArea>
                          </div>
                        )} */}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="UUID"
                render={({ field }) => (
                  <FormItem className={`col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 ${slug === "clone" ? "hidden" : ""}`}>
                    <FormLabel>UUID:</FormLabel>
                    <FormControl className="relative">
                      <Input 
                        className="h-7.5 pr-8 bg-erp-gray-1 text-gray-500"
                        {...field} 
                        readOnly={true} 
                        ref={inputRef} 
                        autoComplete="off" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}