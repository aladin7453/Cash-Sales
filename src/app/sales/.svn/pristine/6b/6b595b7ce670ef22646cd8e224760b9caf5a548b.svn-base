            </div>

            { /* Mobile View CSS Class: grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-(Number of Maximum Columns)*/}
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="remark2"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Remark 2:</FormLabel>
                    <FormControl>
                      <Input 
                        className="h-7.5" 
                        {...field} 
                        moduleName="consolidatedInvoice" 
                        fieldName="remark2" 
                        columnName="Remark 2" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="remark3"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Remark 3:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="remark4"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Remark 4:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="locationCode"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Location:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative h-7.5">
                        <Input className="h-7.5 pr-8" {...field} readOnly onClick={() => fetchDropdownData("location")} ref={locationInputRef} autoComplete="off" />
                        <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {showLocationTable && (
                          <div ref={locationDropdownRef} className="absolute right-0 top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md">
                            <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownLocationColumns}
                                data={locationDropdownData}
                                onClickRow={onClickRowLocation}
                              />
                              <ScrollBar orientation="vertical" />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                  <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="location"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>Location UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="UUID"
                render={({ field }) => (
                  <FormItem className={`flex flex-col space-y-1 ${slug === "clone" ? "hidden" : ""}`}>
                    <FormLabel>UUID:</FormLabel>
                    <FormControl className="relative">
                      <Input 
                        className="h-7.5 pr-8" 
                        {...field}  
                        readOnly={true} 
                        style={{ backgroundColor: '#f2f2f2', color: 'gray' }}
                        ref={inputRef} 
                        autoComplete="off" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
            
            { /* Mobile View CSS Class: grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-(Number of Maximum Columns)*/}
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note" 
                        columnName="Note" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note2"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 2:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note2" 
                        columnName="Note2" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note3"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 3:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note3" 
                        columnName="Note3" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note4"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 4:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note4" 
                        columnName="Note4" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note5"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 5:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note5" 
                        columnName="Note5" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note6"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 6:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note6" 
                        columnName="Note6" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note7"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 7:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note7" 
                        columnName="Note7" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

             <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="note8"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>Note 8:</FormLabel>
                    <FormControl>
                      <Textarea 
                        className="h-7.5" 
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                        moduleName="consolidatedInvoice" 
                        fieldName="note8" 
                        columnName="Note8" 
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            { /* Mobile View CSS Class: grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4*/}
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-5 mt-4">
              <FormField
                control={form.control}
                name="attachment"
                render={({ field }) => (
                  <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                    <FormLabel>
                      <div style={{ display: 'flex', alignItems: 'center' }}>
                        Attachment: <button type="button" onClick={handleChooseFileClick} ><FaFileCirclePlus style={{ marginLeft: '5px' }} className="text-erp-blue-14"/></button>
                      </div>
                    </FormLabel>
            
                    <FormControl>
                      <Input id="attachments" type="file" multiple onChange={handleFileChange} ref={fileInputRef} className="hidden" />
                    </FormControl>

                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
              
            {/* You can render the files here */}
            {tempRowAttachments && tempRowAttachments.map((file, index) => (
              <div key={index} className="mt-2">
                <a href={file.link} target="_blank" rel="noopener noreferrer"  style={{ color: 'blue' }}>
                  {file.name}
                </a>
                <button type="button" onClick={() => handleDeleteFile(index)} style={{ color: 'red' }}>
                  <FaCircleXmark  style={{verticalAlign:"bottom",marginLeft:"2px",marginTop:"2px"}} title={"Remove"}/>
                </button>
              </div>
            ))}
