export const columns: ColumnDef<CustomerPayment>[] = rawColumns.map(
  (col) => {
    if (typeof col.header === "string") {
      const sizes = autoWordSize(col.header);

      return {
        ...col,
        sizes,
        size: sizes, // 👈 applied automatically
        minSize:50
      };
    }

    return col;
  }
);