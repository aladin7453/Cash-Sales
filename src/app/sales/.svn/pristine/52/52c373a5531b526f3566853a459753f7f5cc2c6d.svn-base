    accessorKey: "description",
    header: "Description",
    cell: ({ row }) => {
      const content = row.original.description;
      return (
        <div
          style={{
            whiteSpace: "nowrap",
            overflow: "hidden",
            textOverflow: "ellipsis",
            maxWidth: "150px",
          }}
          title={content}
        >
          {content}
        </div>
