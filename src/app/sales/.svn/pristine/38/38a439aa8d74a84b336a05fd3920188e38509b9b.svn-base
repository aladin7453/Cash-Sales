"use client";

import { format, parseISO } from "date-fns";

import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import CompulsoryCellTooltip from "@/components/data-table/CompulsoryCellTooltip";
import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import type { ColumnDef } from "@tanstack/react-table";
import React from "react";

export type eInvoiceRecords = {
  id: string;
  UUID: string;
  eInvoiceVersion: string;
  generatedAt: string;
  generatedBy: string;
  updatedAt: string;
  updatedBy: string;
  submittedAt: string;
  submittedBy: string;
  validatedAt: string;
  cancelledAt: string;
  cancelledBy: string;
  cancellationReason: string;
  sharedAt: string;
  sharedBy: string;
  fileForSubmission: string;
  fileForSharing: string;
  cancellationAndRejectionTimeLeft: string;
  eInvoiceStatus: string;
  rejectionReason: string;
};

export const eInvoiceRecords: ColumnDef<eInvoiceRecords>[] = [
  {
    accessorKey: "eInvoiceVersion",
    header: "e-Invoice Version",
    filterFn: "includesString"
  },
  {
    accessorKey: "generatedAtFormat",
    header: "Generated at",
    filterFn: "includesString"
  },
  {
    accessorKey: "generatedByFullName",
    header: "Generated by",
    filterFn: "includesString"
  },
  {
    accessorKey: "updatedAtFormat",
    header: "Updated at",
    filterFn: "includesString"
  },
  {
    accessorKey: "updatedByFullName",
    header: "Updated by",
    filterFn: "includesString"
  },
  {
    accessorKey: "submittedAtFormat",
    header: "Submitted at",
    filterFn: "includesString"
  },
  {
    accessorKey: "submittedByFullName",
    header: "Submitted by",
    filterFn: "includesString"
  },
  {
    accessorKey: "validatedAtFormat",
    header: "Validated at",
    filterFn: "includesString"
  },
  {
    accessorKey: "cancelledAtFormat",
    header: "Cancelled at",
    filterFn: "includesString"
  },
  {
    accessorKey: "cancelledByFullName",
    header: "Cancelled by",
    filterFn: "includesString"
  },
  {
    accessorKey: "cancelledReason",
    header: "Cancellation Reason",
    filterFn: "includesString"
  },
  {
    accessorKey: "sharedAt",
    header: "Shared at",
    filterFn: "includesString"
  },
  {
    accessorKey: "sharedBy",
    header: "Shared by",
    filterFn: "includesString"
  },
  {
    accessorKey: "submissionFile",
    header: "File For Submission",
    cell: ({ row }) => {
      const attachments = JSON.parse(row.original.submissionFile);
      const attachmentLinks = row.original.attachmentLink;
  
      return attachments && attachments.length > 0 ? (
        attachments.map((att, index) => {
          const link = attachmentLinks.find(al => al.name === att.Name);
          return link ? (
            <a key={index} href={link.link} target="_blank" rel="noopener noreferrer" style={{ color: 'blue' }}>
              {att.Name}
            </a>
          ) : (
            <span key={index}>{att.Name}</span>
          );
        }).reduce((prev, curr) => [prev, ', ', curr])
      ) : (
        <span>No attachment</span>
      );
    },
    filterFn: "includesString"
  },
  {
    accessorKey: "fileForSharing",
    header: "File for Sharing",
    filterFn: "includesString"
  },
  {
    accessorKey: "cancelRejectTimeLeft",
    header: "Cancellation and Rejection Time Left",
    filterFn: "includesString"
  },
  {
    accessorKey: "status",
    header: "e-Invoice Status",
    filterFn: "includesString"
  },
  {
    accessorKey: "rejectedReason",
    header: "Rejection Reason",
    cell: ({ row }) => <DescriptionCellTooltip row={row} columnName="rejectedReason"/>,
    filterFn: "includesString"
  },
];