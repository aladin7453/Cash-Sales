  {
    id: "gainLoss",
    accessorKey: "gainLoss",
    header: "GainLoss",
    filterFn: "includesString"
  },
  {
    id: "knockOffTaxDate",
    accessorKey: "knockOffTaxDate",
    header: "Knock Off Tax (Date)",
    filterFn: "includesString"
  },
