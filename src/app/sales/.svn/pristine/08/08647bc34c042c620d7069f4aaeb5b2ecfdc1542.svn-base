"use client";

import React, { useState } from "react";
import { FaFileInvoiceDollar, FaCartShopping } from "react-icons/fa6";
import type { Table } from "@tanstack/react-table";

import { useToast } from "@/components/ui/use-toast";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import CancelButton from "@/components/form/ActionButton/Cancel";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import { Button } from "@/components/ui/button";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "@/components/ui/tooltip";

// Mobile View (Imports)
import MobilePopoverActionGroupStart from "@/components/form/MobilePopoverActionGroupStart";
import MobilePopoverActionGroupEnd from "@/components/form/MobilePopoverActionGroupEnd";

type Props<TData> = {
  table: Table<TData>;
  itemType: string;
  setItemType: (type: string) => void;
  fetchInvoiceData: (type: string) => void;
  onSelect: () => void;
  selectedRows: any[];
  setOpen: any;
  handleSave: (prop) => void;
  revalidateCustomerContraDetails: any;
  setSelectedRow: (row) => void;
  saveDisabled: boolean;
  setSaveDisabled: (state: boolean) => void;
  isLoading?: boolean;
  totalCount?: number;
};

export default function ItemPopoverDataTableToolbar<TData>({
  table,
  itemType,
  setItemType,
  fetchInvoiceData,
  onSelect,
  selectedRows,
  setOpen,
  handleSave,
  revalidateCustomerContraDetails,
  setSelectedRow,
  saveDisabled,
  setSaveDisabled,
  isLoading = false,
  totalCount,
}: Props<TData>) {
  const { toast } = useToast();

  const handleSelect = () => {
    if (selectedRows.length === 0) {
      toast({
        title: "No Selection",
        description: "Please select at least one invoice to add.",
        variant: "destructive",
        duration: 2000,
      });
      return;
    }
    onSelect();
  };

  const handleReset = () => {
    table.getSelectedRowModel().rows.forEach((row) => {
      row.toggleSelected();
    });
    // Reset filters and pagination
    table.setColumnFilters([]);
    table.setPagination({
      pageIndex: 0,
      pageSize: table.getState().pagination.pageSize,
    });
    revalidateCustomerContraDetails();
    setSaveDisabled(false);
    setSelectedRow(null);
  };

  // Mobile View (Determine Invoice Type Column ID)
  const invoiceCodeColumnId = itemType === "salesInvoice" ? "docNo" : "docNo";

  return (
    <>
      <div className="flex items-center justify-between p-1.5">
        {/* Mobile View (Start Action Buttons) */}
        <MobilePopoverActionGroupStart
          config={{
            save: {
              handler: () => handleSave({ table: table, itemType: itemType, isUpdate: false }),
              disabled: saveDisabled || isLoading,
            },
            reset: { handler: handleReset, disabled: isLoading },
            cancel: { handler: () => setOpen(false) },
          }}
        />

        {/* Web View (Start Action Buttons) */}
        <div className="hidden md:grid auto-cols-fr grid-flow-col gap-x-1.5">
          <SaveButton
            onClick={() => {
              handleSave({ table: table, itemType: itemType, isUpdate: false });
            }}
            disabled={saveDisabled || isLoading}
          />
          <ResetButton onClick={handleReset} disabled={isLoading} />
          <CancelButton onClick={() => setOpen(false)} />
        </div>

        {/* Mobile View (Hide Pagination) */}
        <div className="hidden md:block">
          <Pagination table={table} totalNumOfRows={totalCount} />
        </div>

        {/* Mobile View (End Action Buttons) */}
        <MobilePopoverActionGroupEnd
          table={table}
          config={{
            search: {
              column: invoiceCodeColumnId,
              placeholder: `Search ${itemType === "salesInvoice" ? "Sales" : "Purchase"} Doc No`,
            },
            sort: {
              column: invoiceCodeColumnId,
            },
          }}
        >
          {/* Sales Invoice button first */}
          <div className="flex flex-col items-center p-0">
            <TooltipProvider delayDuration={0}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    variant={itemType === "salesInvoice" ? "default" : "ghost"}
                    size="icon"
                    disabled={isLoading}
                    className="size-8"
                    onClick={() => {
                      // Only proceed if not already on salesInvoice
                      if (itemType !== "salesInvoice") {
                        setSelectedRow(null);
                        setSaveDisabled(false);
                        table.toggleAllRowsSelected(false);
                        table.setColumnFilters([]);
                        table.setPagination({
                          pageIndex: 0,
                          pageSize: table.getState().pagination.pageSize,
                        });
                        // This will trigger the fetchInvoiceData in the parent component
                        fetchInvoiceData("salesInvoice");
                      }
                    }}
                  >
                    <FaFileInvoiceDollar className="size-5.5" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent>
                  Sales Invoice
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Sales</span>
          </div>
          
          {/* Purchase Invoice button second */}
          <div className="flex flex-col items-center p-0">
            <TooltipProvider delayDuration={0}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    variant={itemType === "purchaseInvoice" ? "default" : "ghost"}
                    size="icon"
                    disabled={isLoading}
                    className="size-8"
                    onClick={() => {
                      // Only proceed if not already on purchaseInvoice
                      if (itemType !== "purchaseInvoice") {
                        setSelectedRow(null);
                        setSaveDisabled(false);
                        table.toggleAllRowsSelected(false);
                        table.setColumnFilters([]);
                        table.setPagination({
                          pageIndex: 0,
                          pageSize: table.getState().pagination.pageSize,
                        });
                        // This will trigger the fetchInvoiceData in the parent component
                        fetchInvoiceData("purchaseInvoice");
                      }
                    }}
                  >
                    <FaCartShopping className="size-5.5" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent>
                  Purchase Invoice
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Purchase</span>
          </div>

          <Export table={table} />

          {/* Mobile View (Hide Refresh and ColumnVisibilityToggle) */}
          <div className="hidden md:flex items-center gap-x-1">
            <Refresh refreshTable={() => fetchInvoiceData()} />
            <ColumnVisibilityToggle table={table} />
          </div>
        </MobilePopoverActionGroupEnd>
      </div>
    </>
  );
}
