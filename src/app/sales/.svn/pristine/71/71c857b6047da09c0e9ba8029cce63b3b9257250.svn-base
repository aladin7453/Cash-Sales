                                        </Button>
                                      </FormControl>
                                    </PopoverTrigger>
                                  </TooltipTrigger>

                                  <TooltipContent side="top" align="start">
                                    Closing Date
                                  </TooltipContent>
                                </Tooltip>
                              </TooltipProvider>

                              <PopoverContent className="w-auto p-0" align="start">
                                <Calendar
                                  mode="single"
                                  selected={
                                    field.value
                                      ? moment.unix(Number(field.value)).toDate()
                                      : undefined
                                  }
                                  onSelect={(date) => {
                                    if (!date) {
                                      field.onChange(null);
                                      return;
                                    }

                                    const unixTimestamp = Math.floor(date.getTime() / 1000);
                                    field.onChange(unixTimestamp);
                                  }}
                                  initialFocus
                                  defaultMonth={
                                    field.value
                                      ? moment.unix(Number(field.value)).toDate()
                                      : new Date()
