"use client";

import {
  flexRender,
  getCoreRowModel,
  getFilteredRowModel,
  getPaginationRowModel,
  getSortedRowModel,
  useReactTable,
} from "@tanstack/react-table";
import { useEffect, useState } from "react";
import { FaSort, FaSortDown, FaSortUp } from "react-icons/fa6";

import NoResultsTableRow from "@/components/data-table/NoResultsTableRow";
import TableHeadColumnTextFilter from "@/components/data-table/TableHeadColumnTextFilter";
import { TableHeadValidityFilter } from "@/components/data-table/TableHeadValidityFilter";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import { Separator } from "@/components/ui/separator";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { DEFAULT_DATA_TABLE_PAGE_SIZE } from "@/lib/constants";
import { useHandleRowSelect } from "@/lib/hooks/useHandleRowSelect";
import usePreventShiftTextSelect from "@/lib/hooks/usePreventShiftTextSelect";
import { cn } from "@/lib/utils/cn";

import BillingContactDetailsFormPopover from "./BillingContactForm";
import BillingContactDetailsDataTableToolbar from "./DataTableToolbar";

import type { ColumnDef, Row, SortingState } from "@tanstack/react-table";

import type { BillingContactDetails } from "./columns";

// Mobile View (Imports)
import MobileFormDataTable from "@/components/form/MobileFormDataTable";

// Column Drag and Drop and Resize (Imports)
import { memo } from "react";
import type { MouseEvent } from "react";
import { closestCenter, DndContext } from "@dnd-kit/core";
import { restrictToHorizontalAxis } from "@dnd-kit/modifiers";
import { horizontalListSortingStrategy, SortableContext } from "@dnd-kit/sortable";
import { ColumnResizer } from "@/components/data-table/ColumnResizer";
import DragableTableHead from "@/components/data-table/DragableTableHead";
import { DATA_TABLE_DEFAULT_COLUMN_SIZING } from "@/lib/constants";
import { useColumnSizeVars } from "@/lib/hooks/useColumnSizeVars";
import { useDndSensors } from "@/lib/hooks/useDndSensors";
import useLocalStorage from "@/lib/hooks/useLocalStorage";
import getExcludedColumns from "@/lib/utils/data-table/getExcludedColumns";
import handleDndDragEnd from "@/lib/utils/data-table/handleDndDragEnd";
import type {
  ColumnOrderState,
  ColumnSizingState,
  Table as TableType,
  VisibilityState,
} from "@tanstack/react-table";
import { Checkbox } from "@/components/ui/checkbox";

type BillingContactDetailsDataTableProps = {
  columns: ColumnDef<BillingContactDetails>[];
  tempRowBillingContactDetail: BillingContactDetails[];
  data: BillingContactDetails[];
  setTempRowBillingContactDetail: (data: any) => void;
  revalidateBillingContactDetail: () => void;
};

// Column Drag and Drop and Resize (Local Storage Keys)
const COLUMN_ORDERING_KEY = "customer.billing-contact.bs.table.ordering";
const COLUMN_SIZING_KEY = "customer.billing-contact.bs.table.sizing";
const COLUMN_VISIBILITY_KEY = "customer.billing-contact.bs.table.columns";

export default function BillingContactDetailsDataTable({
  columns,
  data,
  tempRowBillingContactDetail,
  setTempRowBillingContactDetail,
  revalidateBillingContactDetail,
}: BillingContactDetailsDataTableProps) {
  function setTempRowBillingContactDetailData(data: any, overwrite: boolean) {
   
    if (overwrite) {
      setTempRowBillingContactDetail([...data]);
    } else {

      setTempRowBillingContactDetail((tempRowBillingContactDetail) => {
        // Check if this is an update (item has UUID and exists in temp data)
        if (data.UUID) {
          const existingIndex = tempRowBillingContactDetail.findIndex(item => item.UUID === data.UUID);

          if (existingIndex !== -1) {
            // Update existing item
            const updatedData = [...tempRowBillingContactDetail];

            updatedData[existingIndex] = data;

            return updatedData;
          }
        }

        // Add new item
        return [...tempRowBillingContactDetail, data];
      });
    }
  }

  const [sorting, setSorting] = useState<SortingState>([]);

  // Column Drag and Drop and Resize (Constants)
  const initialColumnOrder = columns?.filter(column => column?.id).map((column) => column.id!) || [];
  const [columnOrder, setColumnOrder] = useLocalStorage<ColumnOrderState>(
    COLUMN_ORDERING_KEY,
    initialColumnOrder
  );
  const [columnSizing, setColumnSizing] = useLocalStorage<ColumnSizingState>(
    COLUMN_SIZING_KEY,
    {}
  );
  const defaultColumns: Array<keyof BillingContactDetails> = [
    "contact",
    "title",
  ];
  const defaultColumnVisibility: VisibilityState = getExcludedColumns(
    columns || [],
    defaultColumns
  );
  const [columnVisibility, setColumnVisibility] = useLocalStorage<VisibilityState>(
    COLUMN_VISIBILITY_KEY,
    defaultColumnVisibility
  );

  // Column Drag and Drop and Resize (Data Table)
  const table = useReactTable({
    columns,
    data,
    state: {
      sorting,
      columnOrder,
      columnSizing,
      columnVisibility
    },
    onSortingChange: setSorting,
    onColumnOrderChange: setColumnOrder,
    onColumnSizingChange: setColumnSizing,
    onColumnVisibilityChange: setColumnVisibility,
    autoResetPageIndex: false,
    columnResizeMode: "onChange",
    defaultColumn: DATA_TABLE_DEFAULT_COLUMN_SIZING,
    enableColumnResizing: true,
    getCoreRowModel: getCoreRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
    getSortedRowModel: getSortedRowModel(),
    initialState: {
      pagination: {
        pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
      },
    },
  });

  const sensors = useDndSensors();
  const columnSizeVars = useColumnSizeVars(table);

  useEffect(() => {
    localStorage.setItem(
      COLUMN_VISIBILITY_KEY,
      JSON.stringify(columnVisibility)
    );
  }, [columnVisibility]);

  const [dialogOpen, setDialogOpen] = useState(false);
  const [selectedRow, setSelectedRow] = useState<string>("");

  const [selectedRowUUID, setSelectedRowUUID] = useState<string | null>(null);
  
  // Prevent text selection when performing multiple row selection with "shift" + click
  usePreventShiftTextSelect();

  const openDialog = (row) => {
    setSelectedRow(row.original);
    setDialogOpen(true);
  };
  const onDoubleClick = (row: Row<BillingContactDetails>) => {
    setDialogOpen(false);
    setSelectedRow("");
    openDialog(row);
  };
  const onRowSelection = useHandleRowSelect(table, onDoubleClick);

  useEffect(() => {
    if (dialogOpen === false) {
      setSelectedRow("");
    }
  }, [dialogOpen]);

  useEffect(() => {
    if (data && data.length > 0) {
      // First, try to find a row with default === "1"
      const defaultRow = data.find(row => row.default === "1");
      if (defaultRow) {
        setSelectedRowUUID(defaultRow.UUID);
      } else {
        setSelectedRowUUID(data[0].UUID); // fallback to first row
        setTempRowBillingContactDetail(prev =>
          prev.map((item, idx) =>
            idx === 0
              ? { ...item, default: "1" } // explicitly set default
              : { ...item, default: "0" }
          )
        );
      }
    } else {
      setSelectedRowUUID(null);
    }
  }, [data]);

  // Ensure at least one default row always exists after data change or deletion
  useEffect(() => {
    if (tempRowBillingContactDetail.length === 0) return;

    const hasDefault = tempRowBillingContactDetail.some(row => row.default === "1");

    // If no default exists (e.g. after deleting the default row), set the first one as default
    if (!hasDefault) {
      setTempRowBillingContactDetail(prev =>
        prev.map((item, idx) => ({
          ...item,
          default: idx === 0 ? "1" : "0"
        }))
      );
      setSelectedRowUUID(tempRowBillingContactDetail[0].UUID);
    }
  }, [tempRowBillingContactDetail]);

  const handleCheckDefaultCheckedChanged = (row: BillingContactDetails, isChecked: boolean) => {
    if (isChecked) {
      setSelectedRowUUID(row.UUID);
      setTempRowBillingContactDetail(prevList =>
        prevList.map(item => ({
          ...item,
          default: item.UUID === row.UUID ? "1" : "0"
        }))
      );
    } else {
      setSelectedRowUUID(null);
      setTempRowBillingContactDetail(prevList =>
        prevList.map(item => ({ ...item, default: "0" }))
      );
    }
  };

  return (
    <Card
      collapsible
      defaultCollapsed={false}
      className="h-auto p-0 shadow-md"
      style={{ marginTop: "10px" }}
    >
      <CardHeader>
        <CardTitle className="text-lg font-bold">
          Billing Contact Details
        </CardTitle>
      </CardHeader>
      <CardContent className="px-2 py-0">
        <div className="h-[98cqh] p-2 md:h-[58cqh]">
          <div className="flex h-[95cqh] flex-col rounded-md bg-erp-blue-3 @container-[size] md:h-[55cqh]">
            <BillingContactDetailsDataTableToolbar
              table={table}
              onAdd={() => setDialogOpen(true)}
              setTempRowBillingContactDetailData={
                setTempRowBillingContactDetailData
              }
              tempRowBillingContactDetail={tempRowBillingContactDetail}
              revalidateBillingContactDetail={revalidateBillingContactDetail}
            />
            <Separator className="bg-erp-blue-11" />
            <ScrollArea className="h-[100cqh] bg-erp-gray-3">
              {/* Mobile View (Form Data Table) */}
              <MobileFormDataTable
                table={table}
                headerFields={["contact", "title"]}
                initialVisibleFields={4}
                setTempRowDetailsList={setTempRowBillingContactDetail}
              />

              {/* Web View (Data Table) */}
              <div className="hidden md:block">
                {/* Column Drag and Drop and Resize (DND Context) */}
                <DndContext
                  collisionDetection={closestCenter}
                  modifiers={[restrictToHorizontalAxis]}
                  onDragEnd={(event) => handleDndDragEnd(event, setColumnOrder)}
                  sensors={sensors}
                >
                  {/* Column Drag and Drop and Resize (Table) */}
                  <Table
                    className="table-fixed border-separate border-spacing-[3px] whitespace-nowrap border bg-erp-gray-1"
                    style={{ ...columnSizeVars, width: table.getTotalSize() }}
                  >
                    <TableHeader className="sticky top-0 z-10">
                      {table.getHeaderGroups().map((headerGroup) => (
                        <TableRow key={headerGroup.id}>
                          {/* Column Drag and Drop and Resize (Sortable Context) */}
                          <SortableContext
                            items={columnOrder}
                            strategy={horizontalListSortingStrategy}
                          >
                            {headerGroup.headers.map((header) => (
                              // Column Drag and Drop and Resize (Dragable Table Head)
                              <DragableTableHead
                                key={header.id}
                                header={header}
                                className="bg-erp-blue-11 font-normal"
                                style={{
                                  width: `calc(var(--header-${header?.id}-size) * 1px)`,
                                }}
                              >
                                {header.column.id === "valid" ? (
                                  <TableHeadValidityFilter table={table} />
                                ) : (
                                  <TableHeadColumnTextFilter
                                    column={header.column}
                                    table={table}
                                  />
                                )}
                                <ColumnResizer header={header} />
                              </DragableTableHead>
                            ))}
                          </SortableContext>
                        </TableRow>
                      ))}
                    </TableHeader>
                    {/* Column Drag and Drop and Resize (Table Body) */}
                    {table.getState().columnSizingInfo.isResizingColumn ? (
                      <MemoizedTableBody
                        table={table}
                        onRowSelection={onRowSelection}
                        selectedRowUUID={selectedRowUUID}
                        handleCheckDefaultCheckedChanged={handleCheckDefaultCheckedChanged}
                      />
                    ) : (
                      <NonMemoizedTableBody
                        table={table}
                        onRowSelection={onRowSelection}
                        selectedRowUUID={selectedRowUUID}
                        handleCheckDefaultCheckedChanged={handleCheckDefaultCheckedChanged}                       
                      />
                    )}
                  </Table>
                </DndContext>
              </div>
              <ScrollBar orientation="horizontal" />
            </ScrollArea>

            {selectedRow && (
              <BillingContactDetailsFormPopover
                open={dialogOpen}
                setOpen={setDialogOpen}
                row={selectedRow}
                setTempRowBillingContactDetailData={
                  setTempRowBillingContactDetailData
                }
                revalidateBillingContactDetail={revalidateBillingContactDetail}
              />
            )}
            {!selectedRow && (
              <BillingContactDetailsFormPopover
                open={dialogOpen}
                setOpen={setDialogOpen}
                row={undefined}
                setTempRowBillingContactDetailData={
                  setTempRowBillingContactDetailData
                }
                revalidateBillingContactDetail={revalidateBillingContactDetail}
              />
            )}
          </div>
        </div>
      </CardContent>
    </Card>
  );
}

// Column Drag and Drop and Resize (Table Body)
type TableBodyProps = {
  table: TableType<BillingContactDetails>;
  onRowSelection: (
    row: Row<BillingContactDetails>
  ) => (event: MouseEvent<HTMLTableRowElement>) => void;
  selectedRowUUID: string | null;
  handleCheckDefaultCheckedChanged: (row: BillingContactDetails, isChecked: boolean) => void;
};

function NonMemoizedTableBody({ table, onRowSelection, selectedRowUUID, handleCheckDefaultCheckedChanged }: TableBodyProps) {
  return (
    <TableBody>
      {table.getRowModel().rows?.length ? (
        table.getRowModel().rows.map((row) => (
          <TableRow
            className="odd:bg-erp-blue-5 even:bg-erp-blue-1 hover:bg-erp-blue-7 data-[state=selected]:bg-erp-blue-17"
            data-state={row.getIsSelected() && "selected"}
            onClick={onRowSelection(row)}
            key={row.id}
          >
            {/* {row.getVisibleCells().map((cell) => (
              <TableCell
                key={cell.id}
                className="truncate"
                title={(cell.getValue() ?? "").toString()}
                style={{
                  width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                  minWidth: cell.column.columnDef.minSize,
                }}
              >
                {flexRender(
                  cell.column.columnDef.cell,
                  cell.getContext()
                )}
              </TableCell>
            ))} */}

            {row.getVisibleCells().map((cell) => {
              if (cell.column.id === "checkDefault") {
                return (
                  <TableCell
                    key={cell.id}
                    className="text-center [&:has([role=checkbox])]:pr-4 truncate"
                    title={(cell.getValue() ?? "").toString()}
                    style={{
                      width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                      minWidth: cell.column.columnDef.minSize,
                    }}
                    // onContextMenu={(e) => rowContextMenu.handleRowRightClick(e, row)}
                  >
                    <Checkbox
                      // disabled={row.index === 0} // Disable checkbox for the first row
                      checked={selectedRowUUID === row.original.UUID}
                      onCheckedChange={(state) =>
                        handleCheckDefaultCheckedChanged(row.original, state === true)
                      }
                    />
                  </TableCell>
                );
              } else {
                return (
                  <TableCell
                    key={cell.id}
                    className="truncate"
                    title={(cell.getValue() ?? "").toString()}
                    style={{
                      width: `calc(var(--col-${cell.column.id}-size) * 1px)`,
                      minWidth: cell.column.columnDef.minSize,
                    }}
                  >
                    {flexRender(
                      cell.column.columnDef.cell,
                      cell.getContext()
                    )}
                  </TableCell>
                );
              }
            })}
          </TableRow>
        ))
      ) : (
        <NoResultsTableRow columns={table.getVisibleLeafColumns()} />
      )}
    </TableBody>
  );
}

const MemoizedTableBody = memo(
  NonMemoizedTableBody,
  (prev, next) => prev.table.options.data === next.table.options.data
) as typeof NonMemoizedTableBody;
