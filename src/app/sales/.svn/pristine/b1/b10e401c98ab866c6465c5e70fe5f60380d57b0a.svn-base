"use client";

import React, { useEffect, useState, useRef } from "react";
import { CalendarIcon } from "lucide-react";
import { FaMagnifyingGlass } from "react-icons/fa6";

import { DATE_FORMAT, ORIGIN, getAuthHeaders } from "@/lib/constants";

import moment from 'moment';

import { ScrollArea } from "@/components/ui/scroll-area";
import { Button } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import DropdownTable from "@/components/data-table/DropdownTable";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import { Input } from "@/components/ui/input";
import {
  Card,
  CardContent,
  CardTitle,
  CardHeader
} from "@/components/ui/card";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";

import { cn } from "@/lib/utils/cn";

import type { Customer } from "../../../columns";

type Params = {
  customer?: Customer | null;
  form: any;
  preferenceData?: any;
  slug?: string;
};

export function BillingDetailsForm({
  customer,
  form,
  preferenceData,
  slug
}: Params) {
  const headers = getAuthHeaders();

  const handleClickOutside = (event) => {
    if (
      currencyDropdownRef.current &&
      !currencyDropdownRef.current.contains(event.target) &&
      currencyInputRef.current !== event.target
    ) {
      setShowTableCurrency(false);
    }

    if (
      creditDropdownRef.current &&
      !creditDropdownRef.current.contains(event.target) &&
      creditInputRef.current !== event.target
    ) {
      setShowTableCreditTerm(false);
    }
  };

  useEffect(() => {
    document.body.addEventListener('click', handleClickOutside);

    return () => {
      document.body.removeEventListener('click', handleClickOutside);
    };
  }, []);

  // Default Currency Function
  const setDefaultCurrency = async () => {
    if (preferenceData?.data?.currency && !form.getValues("currency")) {
      try {
        var formData = new FormData;
        formData.append("table[0]", "currency");

        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`,
          {
            method: 'POST',
            headers,
            body: formData,
          });

        if (response.ok) {
          const data = await response.json();
          const defaultCurrency = data.rows?.find(row => row.UUID === preferenceData.data.currency);

          if (defaultCurrency) {
            form.setValue("currency", defaultCurrency.UUID);
            form.setValue("currencyCode", defaultCurrency.currencyCode);
            form.setValue("currencyRate", defaultCurrency.exchangeRateSales);
          }
        }
      } catch (error) {
        console.error('Error setting default currency:', error);
      }
    }
  };

  useEffect(() => {
    if (preferenceData?.data?.currency && slug === "new") {
      setDefaultCurrency();
    }
  }, [preferenceData, slug]);

  const [showTableCurrency, setShowTableCurrency] = useState(false);
  const [currencyDropdownTableData, setCurrencyDropdownTableData] = useState([]);
  const [currencyFilter, setCurrencyFilter] = useState("");
  const currencyInputRef = useRef<HTMLInputElement>(null);
  const currencyDropdownRef = useRef<HTMLDivElement>(null);

  const dropdownCurrencyGroupColumns = [
    { accessorKey: "currencyCode", header: "Currency" },
    { accessorKey: "currencySymbol", header: "Abbreviation" },
  ];

  const toggleTableCurrency = async () => {
    const formData = new FormData();

    formData.append("table[]", "currency");

    if (!showTableCurrency) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
          method: "POST",
          headers,
          body: formData,
        });

        if (!response.ok) throw new Error("Failed to fetch currency data");

        const { rows } = await response.json();

        setCurrencyDropdownTableData(rows);
        setShowTableCurrency(true);
      } catch (error) {
        console.error(error);
      }
    } else {
      setShowTableCurrency(false);
    }
  };

  const onClickRowCurrencyCode = (row: any) => {
    form.setValue("currency", row.UUID);
    form.setValue("currencyCode", row.currencyCode);

    setShowTableCurrency(false);
    setCurrencyFilter("");
  };

  const [showTableCreditTerm, setShowTableCreditTerm] = useState(false);
  const [creditTermDropdownTableData, setCreditTermDropdownTableData] = useState([]);
  const creditInputRef = useRef<HTMLInputElement>(null);
  const creditDropdownRef = useRef<HTMLDivElement>(null);

  const dropdownCreditTermGroupColumns = [
    { accessorKey: "creditTermCode", header: "Credit Terms" },
    { accessorKey: "noOfDay", header: "Day" },
    { accessorKey: "description", header: "Description", cell: ({ row }) => <DescriptionCellTooltip row={row} /> },
  ];

  const toggleTableCreditTerm = async () => {
    const formData = new FormData();

    formData.append("table[]", "creditTerm");

    if (!showTableCreditTerm) {
      try {
        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
          method: "POST",
          headers: getAuthHeaders(),
          body: formData,
        });

        if (!response.ok) throw new Error("Failed to fetch credit-term data");

        const { rows } = await response.json();

        setCreditTermDropdownTableData(rows);
        setShowTableCreditTerm(true);
      } catch (error) {
        console.error(error);
      }
    } else {
      setShowTableCreditTerm(false);
    }
  };

  const onClickRowCreditTermCode = (row: any) => {
    form.setValue("creditTerm", row.UUID);
    form.setValue("creditTermCode", row.creditTermCode);

    setShowTableCreditTerm(false);
  };

  // Default Credit Term Function
  const setDefaultCreditTerm = async () => {
    if (preferenceData?.data?.creditTerm) {
      form.setValue("creditTerm", preferenceData?.data?.creditTerm);
      form.setValue("creditTermCode", preferenceData?.data?.creditTermCode);
    }

  };


  useEffect(() => {
    if (preferenceData?.data?.creditTerm && slug === "new") {
      setDefaultCreditTerm();
    }
  }, [preferenceData, slug]);

  return (
    <Card collapsible defaultCollapsed={false} className="shadow-md">
      <CardHeader>
        <CardTitle className="text-lg font-bold">Billing Details</CardTitle>
      </CardHeader>
      <CardContent>
        <Form {...form}>
          <form>
            { /* Mobile View CSS Class: grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-(Number of Maximum Columns)*/}
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-6">
              <FormField
                control={form.control}
                name="currency"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7" {...field} readOnly={true} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="currencyCode"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Currency:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative h-7.5">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={toggleTableCurrency}
                          onChange={(e) => {
                            field.onChange(e);
                            setCurrencyFilter(e.target.value);
                          }}
                          ref={currencyInputRef}
                          autoComplete="off"
                        />
                        <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {showTableCurrency && (
                          <div
                            ref={currencyDropdownRef}
                            className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                          >
                            <ScrollArea className="h-[100cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownCurrencyGroupColumns}
                                data={currencyDropdownTableData}
                                onClickRow={onClickRowCurrencyCode}
                                filterValue={currencyFilter}
                                filterColumn="currencyCode"
                              />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="creditTerm"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7" {...field} readOnly={true} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="creditTermCode"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Credit Terms:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative h-7.5">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          onClick={toggleTableCreditTerm}
                          ref={creditInputRef}
                          autoComplete="off"
                        />
                        <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {showTableCreditTerm && (
                          <div
                            ref={creditDropdownRef}
                            className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                          >
                            <ScrollArea className="h-full">
                              <DropdownTable
                                columns={dropdownCreditTermGroupColumns}
                                data={creditTermDropdownTableData}
                                onClickRow={onClickRowCreditTermCode}
                              />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="creditLimit"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Credit Limit:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="customer"
                        fieldName="creditLimit"
                        columnName="Credit Limit"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="overdueLimit"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Overdue Limit:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="customer"
                        fieldName="overdueLimit"
                        columnName="Overdue Limit"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="outstandingAmount"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Outstanding:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} readOnly style={{ backgroundColor: '#f2f2f2', color: 'gray' }} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="overdue"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Overdue:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} readOnly style={{ backgroundColor: '#f2f2f2', color: 'gray' }} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            { /* Mobile View CSS Class: grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-(Number of Maximum Columns)*/}
            <div className="grid items-start gap-x-8 gap-y-1 grid-cols-1 md:grid-cols-6 mt-4">
              <FormField
                control={form.control}
                name="TaxExNo"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Tax Exemption No.:</FormLabel>
                    <FormControl>
                      <Input
                        className="h-7.5"
                        {...field}
                        moduleName="customer"
                        fieldName="TaxExNo"
                        columnName="Tax Exemption No."
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="TaxExNoExpiry"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Tax Exemption No. Expiry:</FormLabel>
                    <Popover>
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            className={cn(
                              "flex h-7.5 w-full",
                              !field.value && "text-muted-foreground",
                            )}
                            variant="outline"
                            size="sm"
                          >
                            {field.value
                              ? moment.unix(field.value).format(DATE_FORMAT)
                              : "Pick a date"}
                            <CalendarIcon className="ml-auto h-4 w-4" />
                          </Button>
                        </FormControl>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={field.value ? moment.unix(field.value).format(DATE_FORMAT) : undefined}
                          onSelect={(date) => {
                            const unixTimestamp = date ? Math.floor(date.getTime() / 1000) : null;
                            field.onChange(unixTimestamp.toString());
                          }}
                          initialFocus
                          defaultMonth={field.value ? moment.unix(field.value).format(DATE_FORMAT) : undefined}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}