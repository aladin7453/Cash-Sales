"use client";

import React, { useState } from "react";
import { FaMinus, FaPlus } from "react-icons/fa6";
import type { Table } from "@tanstack/react-table";

import { useSearchParams ,useParams} from "next/navigation";

import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import { Button } from "@/components/ui/button";
import { useToast } from "@/components/ui/use-toast";

import { getAuthHeaders, ORIGIN } from "@/lib/constants";

import ConfirmationDialog from "./ConfirmationDialog";

// Mobile View (Imports)
import MobileFormTableActionGroupStart from "@/components/form/MobileFormTableActionGroupStart";
import MobileFormTableActionGroupEnd from "@/components/form/MobileFormTableActionGroupEnd";
import { DropdownMenuItem } from "@/components/ui/dropdown-menu";

type Props<TData> = {
  table: Table<TData>;
  onAdd?: () => void;
  setTempRowCustomInfoData: (data: any, overwrite: boolean) => void;
  revalidateCustomInfoData: () => void;
  tempRowCustomInfo: any;
};

export default function CustomInformationDataTableToolbar<TData>({
  table,
  onAdd,
  tempRowCustomInfo,
  setTempRowCustomInfoData,
  revalidateCustomInfoData,
}: Props<TData>) {
  const headers = getAuthHeaders();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const { toast } = useToast();
  const { slug } = useParams()
  const [showConfirmationDialog, setShowConfirmationDialog] = useState(false);
  const [selectedRow, setSelectedRow] = useState("");

  const handleDeleteConfirmation = async () => {
    var form_data = new FormData();

    const selectedRows = table.getSelectedRowModel().rows;

    selectedRows.forEach((row, index) => {
      form_data.append(`UUIDs[]`, row["original"]["UUID"]);
    });

    if(id && slug=="edit"){
      try {
        const response = await fetch(
          `${ORIGIN}/customer/api/customer/remove-customer-has-custom-info-data`,
          {
            method: "POST",
            headers,
            body: form_data,
          },
        );

        if (!response.ok) {
          const errorData = await response.json();

          if (response.status === 403) {
            toast({
              title: errorData.message,
              duration: 2000,
            });
          }

          throw new Error("Failed to fetch data");
        }

        const responseData = await response.json();

        if (responseData) {
          toast({
            title: responseData.message,
            duration: 2000,
          });
        }
      } catch (error) {
        console.error("Error creating new customer data:", error);
      }

      revalidateCustomInfoData();
      setShowConfirmationDialog(false);
    } else {
      const deletedIndex = selectedRows.map((item) => {
        return item.index;
      });
      const remainRows = tempRowCustomInfo.filter((item, index) => !deletedIndex.includes(index));

      

      setTempRowCustomInfoData(remainRows, true);
      setShowConfirmationDialog(false);
    }
  };

  return (
    <>
      {/* Card Section (blue container) */}
      <div className="flex items-center justify-between rounded-t-md p-1.5">
        {/* Mobile View (Start Action Buttons) */}
        <MobileFormTableActionGroupStart
          table={table}
          config={{
            core: {
              add: { 
                handler: () => onAdd?.(),  
              },
              remove: { 
                handler: () => setShowConfirmationDialog(true) 
              },
            },
          }}
        >
          {/* Additional Action other than Add and Remove */}
        </MobileFormTableActionGroupStart>
        
        {/* Web View (Start Action Buttons) */}
        <div className="hidden md:flex items-center gap-x-1 pl-2 text-erp-blue-14">
          {/* Add & Remove Buttons */}
          <div className="flex items-center gap-x-1 text-erp-blue-14">
            <div className="flex flex-col items-center">
              <Button
                className="size-8"
                variant="ghost"
                size="icon"
                onClick={onAdd}
              >
                <FaPlus className="size-5.5" />
              </Button>
              <span className="text-[11px]/none font-medium text-black">Add</span>
            </div>
            <div className="flex flex-col items-center">
              <Button
                className="size-8"
                variant="ghost"
                size="icon"
                onClick={() => setShowConfirmationDialog(true)}
              >
                <FaMinus className="size-5.5" />
              </Button>
              <span className="text-[11px]/none font-medium text-black">Remove</span>
            </div>
          </div>
        </div>

        {/* Mobile View (Hide Pagination) */}
        <div className="hidden md:block">
          <Pagination table={table} />
        </div>
  
        {/* Mobile View (End Action Buttons) */}
        <MobileFormTableActionGroupEnd
          table={table}
          config={{
            search: {
              column: "fieldName",
              placeholder: "Search Field Name",
            },
            sort: {
              column: "fieldName"
            }
          }}
        >
          <Export table={table} />

          {/* Mobile View (Hide Refresh and Column Visibility Toggle) */}
          <div className="hidden md:flex items-center gap-x-3">
            <Refresh refreshTable={revalidateCustomInfoData} />
            <ColumnVisibilityToggle table={table} />
          </div>
        </MobileFormTableActionGroupEnd> 
      </div>
  
      <ConfirmationDialog
        open={showConfirmationDialog}
        setOpen={setShowConfirmationDialog}
        onConfirm={handleDeleteConfirmation}
      />
    </>
  );
}