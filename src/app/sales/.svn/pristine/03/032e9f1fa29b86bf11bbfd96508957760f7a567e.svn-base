                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>DO No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("deliveryOrder") && form.getValues("deliveryOrderNo") && (
                      (() => {
                        const basePath = "/sales/sales-delivery-order"
                        const deliveryOrderID = form.getValues("deliveryOrder");
                        const deliveryOrderNo = form.getValues("deliveryOrderNo");

                        return (
                          <Link
                            href={`${basePath}/edit?item=${deliveryOrderNo}&id=${deliveryOrderID}`}
                            target="_blank"
                            className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                          >
                            {deliveryOrderNo}
                          </Link>
                        );
                      })()
                    )
                  }
                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>CN No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("salesCreditNoteTransferred")?.map((doc, index, array) => {
                      const basePath = "/sales/sales-credit-note"
                      return (
                        <Link
                          key={doc.UUID}
                          href={`${basePath}/edit?item=${doc.docNo}&id=${doc.UUID}`}
                          target="_blank"
                          className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                        >
                          {doc.docNo}{index < array.length - 1 ? ", " : ""}
                        </Link>
                      );
                    })
                  }
                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>OR No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("customerPaymentDocNo")?.map((doc, index, array) => {
                      const basePath = "/sales/customer-payment"

                      return (
                        <Link
                          key={doc.customerPayment}
                          href={`${basePath}/edit?item=${doc.docNo}&id=${doc.customerPayment}`}
                          target="_blank"
                          className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                        >
                          {doc.docNo}{index < array.length - 1 ? ", " : ""}
                        </Link>
                      );
                    })
                  }
                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>Consolidated E-Invoice No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("consolidateTo") && form.getValues("consolidatedInvoiceDocNo") && (
                      (() => {
                        const basePath = "/sales/consolidated-invoice"
                        const consolidateToID = form.getValues("consolidateTo");
                        const consolidatedInvoiceDocNo = form.getValues("consolidatedInvoiceDocNo");

                        return (
                          <Link
                            href={`${basePath}/edit?item=${consolidatedInvoiceDocNo}&id=${consolidateToID}`}
                            target="_blank"
                            className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                          >
                            {consolidatedInvoiceDocNo}
                          </Link>
                        );
                      })()
                    )
                  }
                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <FormField
                control={form.control}
                name="UUID"
                render={({ field }) => (
                  <FormItem className={`flex flex-col space-y-1 ${slug === "clone" ? "hidden" : ""}`}>
                    <FormLabel>UUID:</FormLabel>
                    <FormControl className="relative">
                      <Input
                        className="h-7.5 pr-8 bg-erp-gray-1 text-gray-500"
                        {...field}
                        readOnly={true}
                        ref={inputRef}
                        autoComplete="off"
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            <div className="mt-4">
              <FormField
                control={form.control}
                name="note"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>Note:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value) || stripHtml(defaultNote)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            <div className="mt-4">
              <FormField
                control={form.control}
                name="note2"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
