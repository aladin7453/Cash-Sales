                          }}
                          // disabled={(date) => date > new Date() || date < new Date("1900-01-01")}
                          initialFocus
                          defaultMonth={field.value ? moment.unix(field.value).format(DATE_FORMAT) : undefined}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="taxDate"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Tax Date:</FormLabel>
                    <Popover > {/* Pass isOpen and onClose props */}
                      <PopoverTrigger asChild>
                        <FormControl>
                          <Button
                            className={cn(
                              "flex h-7.5 w-full",
                              !field.value && "text-muted-foreground",
                            )}
                            variant="outline"
                            size="sm"
                          // disabled={!!field.value}
                          >
                            {field.value
                              ? moment.unix(field.value).format(DATE_FORMAT)
                              : "Pick a date"}
                            <CalendarIcon className="ml-auto h-4 w-4" />
                          </Button>
                        </FormControl>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={field.value ? moment.unix(field.value).format(DATE_FORMAT) : undefined}
                          onSelect={(date) => {
                            const unixTimestamp = date ? Math.floor(date.getTime() / 1000) : null;
                            field.onChange(unixTimestamp.toString());
                          }}
                          // disabled={(date) => date > new Date() || date < new Date("1900-01-01")}
                          initialFocus
                          defaultMonth={field.value ? moment.unix(field.value).format(DATE_FORMAT) : undefined}
                        />
                      </PopoverContent>
                    </Popover>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="location"
                render={({ field }) => (
                  <FormItem className="hidden">
                    <FormLabel>Location UUID:</FormLabel>
                    <FormControl>
                      <Input className="h-7.5" {...field} />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="locationCode"
                render={({ field }) => (
                  <FormItem className="flex flex-col space-y-1">
                    <FormLabel>Location:</FormLabel>
                    <FormControl className="relative">
                      <div className="relative">
                        <Input
                          className="h-7.5 pr-8"
                          {...field}
                          // readOnly
                          onChange={(e) => handleDropdownSearchChange("location", e.target.value)}
                          onClick={() => fetchDropdownData1("location")}
                          ref={dropdownState.currentDropdown === "location" ? dropdownInputRef : null}
                          autoComplete="off"
                        />
                        <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                          <FaMagnifyingGlass className="text-gray-400" />
                        </div>
                        {dropdownState.showTable && dropdownState.currentDropdown === "location" && (
                          <div
                            ref={dropdownTableRef}
                            className="absolute top-full bg-white border border-gray-200 rounded shadow-md z-50 h-[200px]"
                          >
                            <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                              <DropdownTable
                                columns={dropdownConfigs.location.columns}
                                data={dropdownState.data}
                                onClickRow={onClickRow}
                              />
                              <ScrollBar orientation="vertical" />
                            </ScrollArea>
                          </div>
                        )}
                      </div>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>QT No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("quotation") && form.getValues("quotationNo") && (
                      (() => {
                        const basePath = "/sales/quotation"
                        const quotationID = form.getValues("quotation");
                        const quotationNo = form.getValues("quotationNo");

                        return (
                          <Link
                            href={`${basePath}/edit?item=${quotationNo}&id=${quotationID}`}
                            target="_blank"
                            className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                          >
                            {quotationNo}
                          </Link>
                        );
                      })()
                    )
                  }
                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>SO No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("salesOrder") && form.getValues("salesOrderNo") && (
                      (() => {
                        const basePath = "/sales/sales-order"
                        const salesOrderID = form.getValues("salesOrder");
                        const salesOrderNo = form.getValues("salesOrderNo");

                        return (
                          <Link
                            href={`${basePath}/edit?item=${salesOrderNo}&id=${salesOrderID}`}
                            target="_blank"
                            className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                          >
                            {salesOrderNo}
                          </Link>
                        );
                      })()
                    )
                  }
                  <ScrollBar
                    orientation="horizontal"
                    className="h-1.5"
                  />
                </ScrollArea>
              </div>

              <div className="flex flex-col space-y-1 text-nowrap">
                <FormLabel>JO No.:</FormLabel>
                <ScrollArea className="flex flex-col h-7.5 px-3 py-1 rounded-md text-sm font-normal border border-input bg-erp-gray-1">
                  {
                    slug !== "clone" && form.getValues("jobOrder") && form.getValues("jobOrderNo") && (
                      (() => {
                        const basePath = "/job-management/job-order"
                        const jobOrderID = form.getValues("jobOrder");
                        const jobOrderNo = form.getValues("jobOrderNo");

                        return (
                          <Link
                            href={`${basePath}/edit?item=${jobOrderNo}&id=${jobOrderID}`}
                            target="_blank"
                            className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
