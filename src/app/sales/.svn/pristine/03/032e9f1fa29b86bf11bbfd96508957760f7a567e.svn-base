                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>


            <div className="mt-4">
              <FormField
                control={form.control}
                name="note4"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>Note 4:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>


            <div className="mt-4">
              <FormField
                control={form.control}
                name="note5"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>Note 5:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>


            <div className="mt-4">
              <FormField
                control={form.control}
                name="note6"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>Note 6:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>


            <div className="mt-4">
              <FormField
                control={form.control}
                name="note7"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>Note 7:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>


            <div className="mt-4">
              <FormField
                control={form.control}
                name="note8"
                render={({ field }) => (
                  <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>Note 8:</FormLabel>
                    <FormControl>
                      <Textarea
                        className="h-7.5"
                        {...field}
                        value={stripHtml(field.value)}
                        onChange={(e) => field.onChange(e.target.value)}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>



            <div className="mt-4">
              <FormField
                control={form.control}
                name="attachment"
                render={({ field }) => (
                  <FormItem className="col-span-4 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1 mt-4">
                    <FormLabel>
                      <div style={{ display: 'flex', alignItems: 'center' }}>
                        Attachment: <button type="button" onClick={handleChooseFileClick} ><FaFileCirclePlus style={{ marginLeft: '5px' }} className="text-erp-blue-14" /></button>
                      </div></FormLabel>

                    <FormControl>
                      <Input id="attachments" type="file" multiple onChange={handleFileChange} ref={fileInputRef} className="hidden" />
                    </FormControl>

                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            {/* You can render the files here */}
            {tempRowAttachments && tempRowAttachments.map((file, index) => (
              <div className="mt-2" key={index}>
                <a href={file.link} target="_blank" rel="noopener noreferrer" style={{ color: 'blue' }}>
                  {file.name}
                </a>
                <button type="button" onClick={() => handleDeleteFile(index)} style={{ color: 'red' }}>
                  <FaCircleXmark style={{ verticalAlign: "bottom", marginLeft: "2px", marginTop: "2px" }} title={"Remove"} />
                </button>
              </div>
            ))}
          </form>
        </Form>
      </CardContent>
    </Card>
  )
}