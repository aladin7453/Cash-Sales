"use client";

import type { ColumnDef } from "@tanstack/react-table";

export type ConsolidateEInvoice = {
  seq: string;
  UUID: string;
  quotation: string;
  item: string;
  type: number;
  description: string;
  quantity: number;
  UOM: string;
  itemRate: string;
  price: number;
  discountRate: number;
  discountAmount: number;
  subTotal: number;
  tax: string;
  taxRate: number;
  taxInclusive: boolean;
  taxableAmount: number;
  taxAmount: number;
  localNetAmount: number;
  subtotalTax: number;
  billingFrequency: string;
  billingInterval: string;
  classification: string;
  remark1: string;
  remark2: string;
  master: string;
  showTemplate: string;
  docDate: string;
  approvalStatus: string;
  rejectReason: string;
  valid: "0" | "1";
}

export const ConsolidateEInvoiceColumns: ColumnDef<ConsolidateEInvoice>[] = [
  {
    id: "seq",
    accessorKey: "seq",
    header: "Seq",
    filterFn: "includesString",
  },
  {
    id: "itemName",
    accessorKey: "itemName",
    header: "Doc No",
    filterFn: "includesString"
  },
  {
    id: "docDate",
    accessorKey: "docDate",
    header: "Doc Date",
    filterFn: "includesString",
  },
  {
    id: "type",
    accessorKey: "type",
    header: "Type",
    filterFn: "includesString"
  },
  {
    id: "description",
    accessorKey: "description",
    header: "Description",
    filterFn: "includesString"
  },
  {
    id: "quantity",
    accessorKey: "quantity",
    header: "Quantity",
    filterFn: "includesString"
  },
  {
    id: "price",
    accessorKey: "price",
    header: "Price",
    filterFn: "includesString"
  },
  {
    id: "subTotal",
    accessorKey: "subTotal",
    header: "Subtotal",
    cell: ({ row }) => (
      <p className="text-right">{`${row.original.subTotal !== null && row.original.subTotal !== undefined ? row.original.subTotal : 0.00}`}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "amount",
    accessorKey: "amount",
    header: "Amount",
    cell: ({ row }) => (
      <p className="text-right">{`${row.original.amount !== null && row.original.amount !== undefined ? row.original.amount : 0.00}`}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "taxableAmount",
    accessorKey: "taxableAmount",
    header: "Taxable Amount",
    cell: ({ row }) => (
      <p className="text-right">{`${row.original.taxableAmount !== null && row.original.taxableAmount !== undefined ? row.original.taxableAmount : 0}`}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "taxAmount",
    accessorKey: "taxAmount",
    header: "Tax Amount",
    cell: ({ row }) => (
      <p className="text-right">{`${row.original.taxAmount !== null && row.original.taxAmount !== undefined ? row.original.taxAmount : 0}`}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "subtotalTax",
    accessorKey: "subtotalTax",
    header: "Subtotal (Tax)",
    cell: ({ row }) => (
      <p className="text-right">{`${row.original.subtotalTax !== null && row.original.subtotalTax !== undefined ? row.original.subtotalTax : 0}`}</p>
    ),
    filterFn: "includesString"
  },
  {
    id: "classificationCode",
    accessorKey: "classificationCode",
    header: "Classification",
    filterFn: "includesString",
  },
  {
    id: "remark1",
    accessorKey: "remark1",
    header: "Remark 1",
    filterFn: "includesString"
  },
  {
    id: "remark2",
    accessorKey: "remark2",
    header: "Remark 2",
    filterFn: "includesString"
  },
  {
    id: "valid",
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as ConsolidateEInvoice["valid"];
      return validity === "1" ? "Valid" : "Invalid";
    },
    filterFn: "includesString",
  },
];