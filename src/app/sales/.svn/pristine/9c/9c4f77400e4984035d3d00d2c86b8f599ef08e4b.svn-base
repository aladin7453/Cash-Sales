"use client";

import React, { useEffect, useRef, useState } from "react";
import { useForm } from "react-hook-form";
import { FaCircleXmark, FaFileCirclePlus, FaMagnifyingGlass } from "react-icons/fa6";
import type { Dispatch, SetStateAction } from "react";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";
import { useRouter, useSearchParams, useParams } from "next/navigation";
import DropdownTable from "@/components/data-table/DropdownTable";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import CancelButton from "@/components/form/ActionButton/Cancel";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import { Checkbox } from "@/components/ui/checkbox";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { useToast } from "@/components/ui/use-toast";
import { Dialog, DialogClose, DialogContent } from "@/components/ui/dialog";
import Map from "@/components/ui/googleMap";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { ScrollArea } from "@/components/ui/scroll-area";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { getFileToBase64 } from "@/lib/utils/commonFunction";

import type { AddressDetails } from "../address-details/columns";

type Props = {
  open: boolean;
  setOpen: Dispatch<SetStateAction<boolean>>;
  setTempRowAttachments: ([]) => void;
  revalidateAddressDetails: () => void;
  setCustomerData: Dispatch<SetStateAction<AddressDetails[]>>;
  tempRowBillingContactDetail: any
};

const addressDetailsFormSchema = z.object({
  UUID: z.union([z.string(), z.literal("")]),
  deliveryLocation: z.string(),
  contact: z.string(),
  phoneNo: z.string(),
  email: z.string(),
  deliveryAddress: z.string().nullable().optional(),
  coordinate: z.string().optional(),
  description: z.string(),
  attachment: z.any().optional(), // Make attachment optional to avoid validation issues
  valid: z.union([z.literal("0"), z.literal("1")]).default("1"),
});

export default function AddressDetailsFormPopover({
  open,
  setOpen,
  row,
  setTempRowAttachments,
  setTempRowAddressDetailsData,
  revalidateAddressDetails,
  tempRowBillingContactDetail
}: Props) {
  const headers = getAuthHeaders();
  const searchParams = useSearchParams();
  const { slug } = useParams()
  const { toast } = useToast();

  const id = searchParams.get("id");
  const [showTableContact, setShowTableContact] = useState(false);
  const [contactDropdownTableData, setContactDropdownTableData] = useState([]);
  const dropdownContactColumns = [
    { accessorKey: "contact", header: "Full Name" },
    {
      accessorKey: "description",
      header: "Description",
      cell: ({ row }) => <DescriptionCellTooltip row={row} />,
    },
  ];

  const inputRef = useRef(null);
  const dropdownRef = useRef(null);
  const data = row;

  const handleReset = () => {
    form.reset({
      UUID: "",
      deliveryLocation: "",
      contact: "",
      phoneNo: "",
      email: "",
      deliveryAddress: "",
      coordinate: "",
      description: "",
    });
    setMapKey(prev => prev + 1);
  };

  const form = useForm<z.infer<typeof addressDetailsFormSchema>>({
    resolver: zodResolver(addressDetailsFormSchema),
    defaultValues: {
      UUID: data?.UUID || "",
      deliveryLocation: data?.deliveryLocation || "",
      contact: data?.contact || "",
      phoneNo: data?.phoneNo || "",
      email: data?.email || "",
      deliveryAddress: (data?.deliveryAddress !== undefined) ? data.deliveryAddress : "",
      coordinate: data?.coordinate || "",
      description: data?.description || "",
      attachment: data?.attachment ? [new File([], data.attachment)] : null,
      valid: data?.valid ?? "1",
    },
  });

  const [addressFiles, setAddressFiles] = useState([]);
  const [mapKey, setMapKey] = useState(0);
  const fileInputRef = useRef(null);

  const handleChooseFileClick = () => {
    fileInputRef.current.click();
  };

  useEffect(() => {
    if (data && data.attachmentLink) {
      setAddressFiles(data.attachmentLink);
    }
    if (data && data.attachmentFiles) {
      setAddressFiles(data.attachmentFiles);
    }

    return () => { };
  }, [data]);

  const handleFileChange = (event) => {
    const fileList = Array.from(event.target.files);
    const mergeArray: any = [...addressFiles, ...fileList];

    setAddressFiles(mergeArray);

    // Update form field to trigger validation
    form.setValue("attachment", fileList);
  };

  function handleDeleteFile(index) {
    var newAddressFiles = [...addressFiles];

    newAddressFiles.splice(index, 1);

    setAddressFiles(newAddressFiles);
  }

  useEffect(() => {
    if (open) {
      !data && handleReset()
      !data && setAddressFiles([])
    }
  }, [open]);

  const handleMapLocationSelect = (locationData: { placeName: string; coordinates: { lat: number; lng: number } }) => {
    const coordinateString = `${locationData.coordinates.lat}, ${locationData.coordinates.lng}`;
    form.setValue("coordinate", coordinateString);

    // Optionally update the address field with the place name
    // if (locationData.placeName && !form.getValues("deliveryAddress")) {
    //   form.setValue("deliveryAddress", locationData.placeName);
    // }

    form.setValue("deliveryAddress", locationData.placeName);
  };

  const updateAddress = async (data) => {
    var counter = 0;

    try {
      const formData = new FormData();

      for (var key in data) {
        if (key !== "attachment") {
          formData.append(`customerHasDeliveryLocation[${key}]`, data[key]);
        }
      }

      for (const fileData of addressFiles) {
        if (fileData.size) {
          var base64 = await getFileToBase64(fileData);

          formData.append(
            `customerHasDeliveryLocation[attachment][${counter}][Name]`,
            fileData.name,
          );
          formData.append(`customerHasDeliveryLocation[attachment][${counter}][File]`, base64);
        } else {
          formData.append(
            `customerHasDeliveryLocation[attachment][${counter}][Name]`,
            fileData.name,
          );
          formData.append(`customerHasDeliveryLocation[attachment][${counter}][File]`, " ");
        }

        counter++;
      }

      const response = await fetch(
        `${ORIGIN}/customer/api/customer/update-customer-has-delivery-location-data?id=${id}`,
        {
          method: "POST",
          headers,
          body: formData,
        },
      );

      if (!response.ok) {
        const errorData = await response.json();

        if (response.status === 403) {
          toast({
            title: errorData.message,
            duration: 2000,
          });
        }

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData) {
        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error updating address data:", error);
    }
  };

  const onSubmit = async (values) => {
    if (!values) return;

    const newData: any = { ...values };

    if (id && slug == "edit") {
      await updateAddress(newData);

      revalidateAddressDetails();
    } else {
      if (!newData.UUID) {
        newData.UUID = crypto.randomUUID();
      }
      newData.attachmentFiles = addressFiles;

      setTempRowAddressDetailsData(newData);
    }
    setOpen(false);
  };

  const toggleTableContact = async () => {
    if (!showTableContact) {
      if (id && slug === "edit") {
        try {
          const response = await fetch(`${ORIGIN}/universal/get-attention-by-customer?id=${id}`, {
            method: "GET",
            headers,
          });
          if (!response.ok) {
            throw new Error("Failed to fetch account drop-down data");
          }
          const accountData = await response.json();
          setContactDropdownTableData(accountData.rows);
          setShowTableContact(true);
        } catch (error) {
          console.error("Error fetching account drop-down data:", error);
        }
      } else {
        const data = tempRowBillingContactDetail || []
        setContactDropdownTableData(data);
        setShowTableContact(true);
      }

    } else {
      setShowTableContact(false);
    }
  };

  const onClickRowContact = (row) => {
    form.setValue("contact", row.contact);
    form.setValue("title", row.title);
    form.setValue("phoneNo", row.phoneNo);
    form.setValue("email", row.email);
    form.setValue("address", row.address);
    form.setValue("description", row.description);
    setShowTableContact(false);
  };

  const handleClickOutside = (event) => {
    if (
      dropdownRef.current &&
      !dropdownRef.current.contains(event.target) &&
      inputRef.current !== event.target
    ) {
      if (event.target.tagName !== "BODY") {
        setShowTableContact(false);
      }

    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);
    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);


  return (
    <Dialog open={open} onOpenChange={setOpen}>
      <DialogContent className="max-w-6xl bg-erp-blue-3 p-2">
        <Form {...form}>
          <form className="space-y-2" onSubmit={form.handleSubmit(onSubmit)}>
            <div className="flex items-center justify-between pr-4">
              <div className="grid auto-cols-fr grid-flow-col gap-x-1.5">
                <SaveButton />
                <ResetButton onClick={handleReset} />
                <DialogClose asChild>
                  <CancelButton />
                </DialogClose>
              </div>

              <FormField
                control={form.control}
                name="valid"
                render={({ field }) => (
                  <FormItem className="flex items-center gap-x-2 space-y-0">
                    <FormControl>
                      <Checkbox
                        checked={field.value === "1"}
                        onCheckedChange={(state) => field.onChange(state ? "1" : "0")}
                      />
                    </FormControl>
                    <FormLabel>Valid</FormLabel>
                  </FormItem>
                )}
              />
            </div>

            <div className="p-2 bg-white">
              <h2 className="text-md font-bold">Address Details</h2>

              <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-2">
                {/* Form Fields Section */}
                <div className="lg:col-span-2 space-y-4">
                  <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-4">
                    <FormField
                      control={form.control}
                      name="UUID"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7" {...field} readOnly={true} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    <FormField
                      control={form.control}
                      name="deliveryLocation"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Designated Location:</FormLabel>
                          <FormControl>
                            <Input className="h-7" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />



                    <FormField
                      control={form.control}
                      name="contact"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>
                            Contact: <span className="text-red-500">*</span>
                          </FormLabel>
                          <FormControl className="relative">
                            <div className="relative h-7.5">
                              <Input
                                className="h-7.5 pr-8"
                                {...field}
                                ref={inputRef}
                                autoComplete="off"
                              />
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    <FormField
                      control={form.control}
                      name="phoneNo"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Phone No.:</FormLabel>
                          <FormControl>
                            <Input className="h-7" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    <FormField
                      control={form.control}
                      name="email"
                      render={({ field }) => (
                        <FormItem className="flex flex-col space-y-1">
                          <FormLabel>Email:</FormLabel>
                          <FormControl>
                            <Input className="h-7" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />


                  </div>

                  <FormField
                    control={form.control}
                    name="coordinate"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Coordinates:</FormLabel>
                        <FormControl>
                          <Input
                            className="h-7"
                            {...field}
                            onChange={(e) => {
                              field.onChange(e);
                              setMapKey(prev => prev + 1);
                            }}
                          />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-3">
                    <FormField
                      control={form.control}
                      name="deliveryAddress"
                      render={({ field }) => (
                        <FormItem className="col-span-3 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                          <FormLabel>Address:</FormLabel>
                          <FormControl>
                            <Textarea className="min-h-[80px]" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-3">
                    <FormField
                      control={form.control}
                      name="description"
                      render={({ field }) => (
                        <FormItem className="col-span-3 row-span-2 grid h-full grid-rows-[auto_1fr] space-y-1">
                          <FormLabel>Description:</FormLabel>
                          <FormControl>
                            <Textarea className="min-h-[80px]" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  <FormField
                    control={form.control}
                    name="attachment"
                    render={({ field }) => (
                      <FormItem className="space-y-1">
                        <FormLabel>
                          <div className="flex items-center">
                            Attachment:{" "}
                            <button type="button" onClick={handleChooseFileClick} className="ml-2">
                              <FaFileCirclePlus className="text-erp-blue-14" />
                            </button>
                          </div>
                        </FormLabel>

                        <FormControl>
                          <Input
                            id="attachments"
                            type="file"
                            multiple
                            onChange={handleFileChange}
                            ref={fileInputRef}
                            className="hidden"
                          />
                        </FormControl>

                        <FormMessage />

                        {/* File list display */}
                        {addressFiles && addressFiles.length > 0 && (
                          <div className="mt-2 space-y-1">
                            {addressFiles.map((file, index) => (
                              <div key={index} className="flex items-center gap-2">
                                <a
                                  href={file.link}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  className="text-blue-600 hover:text-blue-800 text-sm"
                                >
                                  {file.name}
                                </a>
                                <button
                                  type="button"
                                  onClick={() => handleDeleteFile(index)}
                                  className="text-red-500 hover:text-red-700"
                                  title="Remove"
                                >
                                  <FaCircleXmark />
                                </button>
                              </div>
                            ))}
                          </div>
                        )}
                      </FormItem>
                    )}
                  />
                </div>

                {/* Google Map Section */}
                <div className="lg:col-span-1">
                  <div className="p-2 border rounded-md bg-gray-50">
                    <Map
                      key={mapKey}
                      onLocationSelect={handleMapLocationSelect}
                      initialCoordinates={form.watch("coordinate")}
                    />
                  </div>
                </div>
              </div>
            </div>
          </form>
        </Form>
      </DialogContent>
    </Dialog>
  );
}