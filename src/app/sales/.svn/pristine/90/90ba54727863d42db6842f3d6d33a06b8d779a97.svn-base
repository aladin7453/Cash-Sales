// Preference (Format Number Function)
const formatNumber = (value: string | number, decimalPlaces: number = 2): string => {
  if (value === null || value === undefined || value === '') {
    return (0).toFixed(decimalPlaces);
  }

  const numValue = typeof value === 'string' ? parseFloat(value) : value;

  if (isNaN(numValue)) {
    return (0).toFixed(decimalPlaces);
  }

  return numValue.toFixed(decimalPlaces);
};

const isDev = process.env.NODE_ENV === "development";

const urlMap = {
  quotation: isDev ? "sales/quotation" : "view/sales/quotation",
  cashSales: isDev ? "sales/cash-sales" : "view/sales/cash-sales",
  deliveryOrder: isDev ? "sales/delivery-order" : "view/sales/delivery-order",
  jobOrder: isDev ? "job-management/job-order" : "view/job-management/job-order",
  salesInvoice: isDev ? "sales/sales-invoice" : "view/sales/sales-invoice",
  salesDebitNote: isDev ? "sales/sales-debit-note" : "view/sales/sales-debit-note",
  salesOrder: isDev ? "sales/sales-order" : "view/sales/sales-order",
};

