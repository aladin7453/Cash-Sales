"use client";

import type { ColumnDef } from "@tanstack/react-table";
import { NumberFormatter } from "@/components/ui/number-formatter";

export type CustomerDocumentListing = {
  paidAmount?: string;
  unappliedAmount?: string;
  knockoffAmount?: string;
};

export const CustomerPaymentListingColumns: ColumnDef<CustomerDocumentListing>[] = [
  {
    accessorKey: "rowNumber",
    id: "rowNumber",
    header: "No",
    cell: ({ table, row }) => {
      const { pageIndex, pageSize } = table.getState().pagination;
      return pageIndex * pageSize + row.index + 1;
    },
    enableSorting: false,
    enableColumnFilter: false,
    minSize: 60,
    maxSize: 80,
  },
  {
    accessorKey: "docDateFormat",
    id: "docDateFormat",
    header: "Doc Date",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "docNo",
    id: "docNo",
    header: "Doc No",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "customerName",
    id: "customerName",
    header: "Customer Name",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "currencyCode",
    id: "currencyCode",
    header: "Currency",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "paidAmount",
    id: "paidAmount",
    header: "Amount",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
    cell: ({ row }) => (
      <div className="text-right"><NumberFormatter value={row.original.paidAmount} /></div>
    ),
  },
  {
    accessorKey: "unappliedAmount",
    id: "unappliedAmount",
    header: "Unapplied Amount",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
    cell: ({ row }) => (
      <div className="text-right"><NumberFormatter value={row.original.unappliedAmount} /></div>
    ),
  },
  {
    accessorKey: "knockoffAmount",
    id: "knockoffAmount",
    header: "Knockoff Amount",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
    cell: ({ row }) => (
      <div className="text-right"><NumberFormatter value={row.original.knockoffAmount} /></div>
    ),
  },
  {
    accessorKey: "customerCodeCode",
    id: "customerCodeCode",
    header: "Customer Code",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "customerCategoryName",
    id: "customerCategoryName",
    header: "Customer Category",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "paymentMethodCode",
    id: "paymentMethodCode",
    header: "Payment Method",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "projectCode",
    id: "projectCode",
    header: "Project",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "salesAgentName",
    id: "salesAgentName",
    header: "Sales Agent",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
];

