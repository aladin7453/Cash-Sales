"use client";

import React, { useEffect, useState, useRef } from "react";
import { useForm } from "react-hook-form";
import { FaClipboard, FaLayerGroup, FaQrcode } from "react-icons/fa6";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";
import { useApi } from "@/lib/hooks/useAPI"
import { notFound, useRouter, useSearchParams } from "next/navigation";

import useSWR from "swr";

import LoadingUI from "@/components/LoadingUI";
import { Form } from "@/components/ui/form";
import { ScrollArea } from "@/components/ui/scroll-area";
import { TabsNavigator } from "@/components/ui/TabsNavigator";
import { useToast } from "@/components/ui/use-toast";

import { getFileToBase64 } from "@/lib/utils/commonFunction";
import {
  getAuthHeaders,
  ORIGIN,
} from "@/lib/constants";

import { BuyerDetailsForm } from "./e-invoice-details/buyer-details/BuyerDetailsFormOld";
import { EInvoiceDetailsForm } from "./e-invoice-details/e-invoice-document-details/EInvoiceDetailsFormOld";
import { ImportExportOfGoodsForm } from "./e-invoice-details/import-&-export-of-goods/Import&ExportOfGoodsDetailsFormOld";
import { PaymentDetailsForm } from "./e-invoice-details/payment-details/PaymentDetailsFormOld";
import { ShippingRecipientDetailsForm } from "./e-invoice-details/shipping-recipient-details/ShippingRecipientDetailsFormOld";
import { SupplierDetailsForm } from "./e-invoice-details/supplier-details/SupplierDetailsFormOld";
import { CustomerDetailsFormOld } from "./main-details/customer-details/CustomerDetailsFormOld";
import { DocumentDetailsFormOld } from "./main-details/document-details/DocumentDetailsFormOld";
import { CustomerDetailsForm } from "./main-details/customer-details/CustomerDetailsForm";
import { DocumentDetailsForm } from "./main-details/document-details/DocumentDetailsForm";
import { SalesDebitNoteColumns } from "./main-details/sales-debit-note-details/columns";
import SalesDebitNoteDataTable from "./main-details/sales-debit-note-details/DataTable";
import SalesDebitNoteDataTableOld from "./main-details/sales-debit-note-details/DataTableOld";
import MoreDetailsForm from "./more-details/MoreDetailsFormOld";
import TopActionBar from "./TopActionBar";
import { CustomFieldHandle } from "@/components/DisplayCustomField";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle
} from "@/components/ui/card";

type PageParams = {
  params: { slug: string };
};

const validRoutes = [
  "new",
  "edit",
  "clone",
  "transfer-to",
  "transfer-from",
] as const;

const fetcher = async (url) => {
  const headers = getAuthHeaders();

  return fetch(url, { headers }).then((res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    return res.json();
  });
};

type ValidRoute = (typeof validRoutes)[number];

const salesDebitNoteFormSchema = z.object({
  customerCodeCode: z.string().min(1, {
    message: "Required",
  }),
});

function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

export default function SalesDebitNoteDetailsPage({ params }: PageParams) {
  const headers = getAuthHeaders();
  const router = useRouter();
  const customFieldRef = useRef<CustomFieldHandle>(null);
  const { toast } = useToast();

  const slug = params.slug;
  const searchParams = useSearchParams();
  const id = searchParams.get("id");

  const [formResetKey, setFormResetKey] = useState(0);
  const [isSaving, setIsSaving] = useState(false);
  const [approvalStatus, setApprovalStatus] = useState({});

  const [salesDebitNoteData, setSalesDebitNoteData] = useState({});
  const [tempRowSalesDebitNoteDetailsList, setTempRowSalesDebitNoteDetailsList] = useState([]);
  const [tempRowAttachments, setTempRowAttachments] = useState([]);
  const [UOMDetails, setUOMDetails] = useState({});
  const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");

  if (!isValidRoute(slug)) {
    notFound();
  }

  // ─── Layout State ─────────────────────────────────────────────────────────────
  const [layout, setLayout] = useState<"new" | "old">(() => {
    if (typeof window === "undefined") return "old";
    return (localStorage.getItem("Layout") as "new" | "old") || "old";
  });

  const handleLayoutChange = (newLayout: "new" | "old") => {
    localStorage.setItem("Layout", newLayout);
    setLayout(newLayout);
  };

  const {
    data: salesDebitNote,
    error,
    isLoading,
    isValidating,
    mutate: mutateSalesDebitNote,
  } = useApi(
    id
      ? `${ORIGIN}/sales_debit_note/api/sales-debit-note/get-update-sales-debit-note-data?id=${id}`
      : null,
    { revalidateOnFocus: false }
  );


  const {
    data: defaultCurrentCompany,
  } = useApi(
    !id
    && `${ORIGIN}/universal/get-current-company?id=${currentCompany?.UUID}`,
    { revalidateOnFocus: false }
  )

  const {
    data: salesDebitNoteDetails,
    error: salesDebitNoteDetailsError,
    mutate: mutateSalesDebitNoteDetails,
  } = useApi(
    id
      ? `${ORIGIN}/sales_debit_note/api/sales-debit-note/get-update-sales-debit-note-has-details-data?id=${id}`
      : null,
    { revalidateOnFocus: false }
  );

  const revalidateSalesDebitNote = () => {

    mutateSalesDebitNote(undefined, { revalidate: true });
  };

  const {
    data: getPermissions,
    error: getPermissionsError,
    mutate: mutateGetPermissions,
  } = useApi(
    !id
      ? `${ORIGIN}/sales_debit_note/api/sales-debit-note/get-permissions`
      : null,
    { revalidateOnFocus: false }
  );

  const viewEInvoiceDetails = [
    ...(Array.isArray(getPermissions?.data) ? getPermissions.data : []),
    ...(Array.isArray(salesDebitNote?.rules) ? salesDebitNote.rules : []),
  ].includes("view-sales-debit-note-e-invoice-details");

  const tabs = [
    {
      id: "mainDetails",
      name: "Main Details",
      icon: FaClipboard,
      shortName: "Main",
    },
    {
      id: "moreDetails",
      name: "More Details",
      icon: FaLayerGroup,
      shortName: "More",
    },
    // {
    //   id: "eInvoiceDetails",
    //   name: "e-Invoice Details",
    //   icon: FaQrcode,
    //   shortName: "E-Inv",
    // },
    ...(viewEInvoiceDetails
      ? [
        {
          id: "eInvoiceDetails",
          name: "e-Invoice Details",
          icon: FaQrcode,
          shortName: "E-Inv",
        },
      ]
      : []),
  ];

  const isFetching = isLoading || isValidating;

  // Preference (State)
  const [preferenceData, setPreferenceData] = useState<any>(null);

  // Preference (Fetch Function)
  const fetchPreferenceData = async () => {
    try {
      const headers = getAuthHeaders();

      const response = await fetch(
        `${ORIGIN}/universal/get-preference?module=sales`,
        {
          method: "GET",
          headers,
        }
      );

      if (!response.ok) {
        throw new Error("Failed to fetch preference data");
      }

      const data = await response.json();

      setPreferenceData(data);
    } catch (error) {
      console.error("Error fetching preference data:", error);
    }
  };

  useEffect(() => {
    fetchPreferenceData();
  }, []);



  useEffect(() => {
    if (
      salesDebitNote &&
      slug !== "transfer-to" &&
      slug !== "transfer-from"
    ) {
      const salesDebitNoteDataCopy = { ...salesDebitNote.data };

      // Clear docNo if it's a clone page
      if (slug === "clone") {
        salesDebitNoteDataCopy.docNo = "";
        salesDebitNoteDataCopy.docDate = Math.floor(Date.now() / 1000);
        salesDebitNoteDataCopy.eInvoiceStatus = "";
        salesDebitNoteDataCopy.digitalSignature = "";
        salesDebitNoteDataCopy.oriRefNo = "";
        salesDebitNoteDataCopy.eInvoiceVersion = "";
        salesDebitNoteDataCopy.eInvoiceCode = "";
        salesDebitNoteDataCopy.consolidateTo = "";
        salesDebitNoteDataCopy.consolidatedInvoiceDocNo = "";
      }

      setSalesDebitNoteData(salesDebitNoteDataCopy);
      setApprovalStatus(salesDebitNote.approval);
      setIsSaving(false);
      setTempRowAttachments(
        salesDebitNote.data.attachmentLink
          ? salesDebitNote.data.attachmentLink
          : []
      );
    }
  }, [salesDebitNote, slug]);

  useEffect(() => {
    if (
      salesDebitNoteDetails &&
      slug !== "transfer-to" &&
      slug !== "transfer-from"
    ) {
      // Preference (Add Preference Data to Table Details)
      const detailsWithPreferences = salesDebitNoteDetails.rows.map(
        (row) => ({
          ...row,
          preferenceData: preferenceData,
        })
      );

      setTempRowSalesDebitNoteDetailsList(detailsWithPreferences);
    }
  }, [salesDebitNoteDetails, slug, preferenceData]);

  const revalidateSalesDebitNoteDetails = () => {
    mutateSalesDebitNoteDetails();
  };

  const handleSubmit = async () => {
    try {
      await form.trigger();
      await form.handleSubmit(onSubmit)();
    } catch (error) {
      console.error("Form submission error:", error);
    }
  };

  const form = useForm<z.infer<typeof salesDebitNoteFormSchema>>({
    resolver: zodResolver(salesDebitNoteFormSchema),
    defaultValues: {
      docNo: salesDebitNote?.docNo ?? "",
      agentName: salesDebitNote?.agentName ?? "",
      terms: salesDebitNote?.terms ?? "",
      creditTermCode: salesDebitNote?.creditTermCode ?? "",
      deadline: salesDebitNote?.deadline ?? "",
      description: salesDebitNote?.description ?? "",
      customerCodeCode: salesDebitNote?.customerCodeCode ?? "",
      customerName: salesDebitNote?.customerName ?? "",
      BRN: salesDebitNote?.BRN ?? "",
      attentionName: salesDebitNote?.attentionName ?? "",
      address: salesDebitNote?.address ?? "",
      TIN: salesDebitNote?.TIN ?? "",
      SSTNo: salesDebitNote?.SSTNo ?? "",
      phoneNo: salesDebitNote?.phoneNo ?? "",
      email: salesDebitNote?.email ?? "",
      valid: salesDebitNote?.valid ?? "1",
      currency: salesDebitNote?.currency ?? "",
      currencyCode: salesDebitNote?.currencyCode ?? "",
      currencyRate: salesDebitNote?.currencyRate ?? "",
    },
  });

  const onSubmit = async () => {
    setIsSaving(true);

    if (customFieldRef.current) {
      try {
        await customFieldRef.current.save();
      } catch (err) {
        console.error("Failed to save custom fields:", err);
      }
    }

    var form_data = new FormData();
    var formValues = form.getValues();

    const localNetTotal = document.querySelector(".localNetTotal");
    const netTotal = document.querySelector(".netTotal");

    var saveType =
      slug == "clone"
        ? `create-data?c_id=1`
        : id
          ? `update-sales-debit-note-data?id=${id}`
          : `create-data`;

    var transferType = "";
    var transferData = "";

    if (slug === "transfer-to") {
      transferData = JSON.parse(
        localStorage.getItem("transfer-to.sales-debit-note") || "{}"
      );
    } else if (slug === "transfer-from") {
      transferData = JSON.parse(
        localStorage.getItem("transfer-from.sales-debit-note") || "{}"
      );
    }

    var transferDocType = transferData?.data?.transferDocType;

    // Preference (Get Decimal Places for Calculations)
    const decimal = preferenceData?.data?.decimal || 2;

    transferType = slug == "transfer-to" || slug == "transfer-from" ? `?transferFrom=${transferDocType}` : "";

    // Ensure all required fields exist and default to 0 if undefined or empty
    let totalAmount = tempRowSalesDebitNoteDetailsList.reduce((sum, row) => {
      return sum + (row.amount ? parseFloat(row.amount) : 0);
    }, 0);

    let totalDiscount = tempRowSalesDebitNoteDetailsList.reduce((sum, row) => {
      const discount1 = row.discountAmount ? parseFloat(row.discountAmount) : 0;
      const discount2 = row.discountAmount2 ? parseFloat(row.discountAmount2) : 0;
      const discount3 = row.discountAmount3 ? parseFloat(row.discountAmount3) : 0;

      return sum + discount1 + discount2 + discount3;
    }, 0);

    let totalTax = tempRowSalesDebitNoteDetailsList.reduce((sum, row) => {
      return sum + (row.taxAmount ? parseFloat(row.taxAmount) : 0);
    }, 0);

    // Fix the calculation of totalSubtotal
    let totalSubtotal = totalAmount - totalDiscount;

    let prepaymentAmount = parseFloat(formValues.prepaymentAmount) || 0;
    let totalFeeAmount = parseFloat(formValues.totalFeeAmount) || 0;

    // Use the actual rounding amount from the form instead of calculating
    let roundingAmount = parseFloat(formValues.roundingAmount) || 0;

    // Correct totalPayable Calculation using the form's rounding amount
    let totalPayable = (
      totalAmount -
      totalDiscount +
      totalTax -
      prepaymentAmount +
      totalFeeAmount +
      roundingAmount
    );

    let localNetTotalValue = localNetTotal?.value

    // Validation: Prevent save if invoiceType == "Consolidate" and totalPayable >= 10,000
    if (formValues.invoiceType == "Consolidate" && (totalPayable >= 10000 || localNetTotalValue >= 10000)) {
      toast({
        title: "Error",
        description: "Total invoice amount cannot exceed RM10,000 for Consolidate Invoice.",
        variant: "destructive",
        duration: 4000,
      });
      setIsSaving(false);
      return;
    }

    // Set outstanding amount based on isPaid status
    let outstandingAmount = isPaid
      ? parseFloat(formValues.outstandingAmount)
      : totalPayable;

    // Preference (Apply Decimal Formatting to Totals)
    formValues.totalAmount = totalAmount.toFixed(decimal);
    formValues.totalDiscount = totalDiscount.toFixed(decimal);
    formValues.totalTax = totalTax.toFixed(decimal);
    formValues.totalSubtotal = totalSubtotal.toFixed(decimal);
    formValues.roundingAmount = roundingAmount.toFixed(decimal);
    formValues.totalPayable = totalPayable.toFixed(decimal);
    formValues.outstandingAmount = outstandingAmount.toFixed(decimal);

    formValues.localNetTotal = localNetTotal?.value
    formValues.netTotal = netTotal?.value

    // Create salesDebitNote object excluding attachments
    const salesDebitNoteData = { ...formValues };
    delete salesDebitNoteData.attachmentLink;
    delete salesDebitNoteData.attachment;

    // Combine salesDebitNote and salesDebitNoteHasDetails into single data object
    const combinedData = {
      salesDebitNote: salesDebitNoteData,
      salesDebitNoteHasDetails: tempRowSalesDebitNoteDetailsList
    };

    // Add combined data as JSON string
    form_data.append('data', JSON.stringify(combinedData));

    // Handle file attachments
    if (saveType === "create-data") {
      var counter = 0;

      for (const file of tempRowAttachments) {
        const base64 =
          slug === "transfer-to" || slug === "transfer-from"
            ? ""
            : await getFileToBase64(file);

        form_data.append(
          `salesDebitNote[attachment][${counter}][Name]`,
          file.name
        );

        form_data.append(
          `salesDebitNote[attachment][${counter}][File]`,
          slug === "transfer-to" || slug === "transfer-from" ? "" : base64
        );

        counter++;
      }
    } else {
      var counter = 0;

      for (const attachment of tempRowAttachments) {
        if (attachment.link) {
          form_data.append(
            `salesDebitNote[attachment][${counter}][Name]`,
            attachment.name
          );

          form_data.append(`salesDebitNote[attachment][${counter}][File]`, "");
        } else {
          const base64 = await getFileToBase64(attachment);

          form_data.append(
            `salesDebitNote[attachment][${counter}][Name]`,
            attachment.name
          );

          form_data.append(
            `salesDebitNote[attachment][${counter}][File]`,
            base64
          );
        }

        counter++;
      }
    }

    try {
      const response = await fetch(
        `${ORIGIN}/sales_debit_note/api/sales-debit-note/${saveType}${transferType}`,
        {
          method: "POST",
          headers,
          body: form_data,
        }
      );

      if (!response.ok) {
        const errorData = await response.json();

        setIsSaving(false);

        let errorMessage = errorData.message;

        // Error Handling for "Data too long"
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 2000,
        });

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        if (slug === "transfer-to")
          localStorage.removeItem("transfer-to.sales-debit-note");
        else if (slug === "transfer-from")
          localStorage.removeItem("transfer-from.sales-debit-note");

        const url = `/sales/sales-debit-note/edit?item=${responseData.item}&id=${responseData.data}`;

        router.push(url);

        if (params.slug == "edit") {
          mutateSalesDebitNote();
          mutateSalesDebitNoteDetails();
        }

        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (responseData.message) {
        if (slug === "transfer-to")
          localStorage.removeItem("transfer-to.sales-debit-note");
        else if (slug === "transfer-from")
          localStorage.removeItem("transfer-from.sales-debit-note");

        setIsSaving(false);

        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        router.push(`/sales/sales-debit-note/clone?id=${id}`);

        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error creating new sales debit note data:", error);

      setIsSaving(false);

      toast({
        title: `${error.message}`,
        variant: "destructive",
        duration: 2000,
      });
    }
  };

  useEffect(() => {
    if (
      typeof window !== "undefined" &&
      (slug === "transfer-to" || slug === "transfer-from")
    ) {
      const transferDataKey =
        slug === "transfer-to"
          ? "transfer-to.sales-debit-note"
          : "transfer-from.sales-debit-note";

      const transferData = JSON.parse(
        localStorage.getItem(transferDataKey) || "{}"
      );

      if (transferData) {
        transferData.data.eInvoiceStatus = "";
        transferData.data.digitalSignature = "";
        transferData.data.oriRefNo = "";
        transferData.data.eInvoiceVersion = "";
        transferData.data.eInvoiceCode = "";
        transferData.data.consolidateTo = "";
        transferData.data.consolidatedInvoiceDocNo = "";
      }

      // Map quotation fields to sales debit note fields
      const mappedData = {
        ...transferData?.data,
        description: "",
        note: "",
        UUID: "",
        docDate: Math.floor(Date.now() / 1000),
      };

      setSalesDebitNoteData(mappedData);

      transferData?.subData?.forEach((detail) => {
        detail["item"] = detail["item"];
        detail["itemGroup"] = detail["itemGroup"];
        detail["itemCategory"] = detail["itemCategory"];
        detail["transferredFrom"] = detail["UUID"];
      });

      // Set attachments from transfer data
      setTempRowAttachments(transferData?.data?.attachmentLink ?? []);

      setTempRowSalesDebitNoteDetailsList(transferData?.subData);

      function beforeUnload(e: BeforeUnloadEvent) {
        localStorage.removeItem(transferDataKey);

        e.preventDefault();
      }

      window.addEventListener("beforeunload", beforeUnload);

      return () => {
        window.removeEventListener("beforeunload", beforeUnload);
      };
    }
  }, [slug]);

  // ─── Shared Props ─────────────────────────────────────────────────────────────
  const documentDetailsProps = {
    key: formResetKey,
    form,
    slug,
    preferenceData,
    tempRowAttachments,
    setTempRowAttachments,
    salesDebitNoteData: salesDebitNote,
    defaultCurrentCompany,
    id,
    salesDebitNoteDetails,
    tempRowSalesDebitNoteDetailsList,
  };

  const dataTableProps = {
    columns: SalesDebitNoteColumns,
    data: id
      ? salesDebitNoteDetails
        ? salesDebitNoteDetails.rows
        : []
      : tempRowSalesDebitNoteDetailsList,
    tempRowSalesDebitNoteDetailsList,
    setTempRowSalesDebitNoteDetailsList,
    revalidateSalesDebitNoteDetails,
    form,
    salesDebitNoteData,
    UOMDetails,
    preferenceData,
    slug,
  };

  // Create refs for each section
  const mainDetailsRef = useRef(null);
  const moreDetailsRef = useRef(null);
  const eInvoiceDetailsRef = useRef(null);

  const isPaid = slug === "clone" ? false : (salesDebitNote?.isPaid || false);

  const [isExpand, setIsExpand] = useState(false);
  return (
    <>
      <div className="sticky top-0 z-20">
        <TopActionBar
          SalesDebitNote={salesDebitNoteData}
          approvalStatus={approvalStatus}
          tempRowSalesDebitNoteDetailsList={tempRowSalesDebitNoteDetailsList}
          handleSubmit={handleSubmit}
          form={form}
          salesDebitNoteFormSchema={salesDebitNoteFormSchema}
          slug={slug}
          isSaving={isSaving}
          setIsSaving={setIsSaving}
          revalidateSalesDebitNote={revalidateSalesDebitNote}
          viewEInvoiceDetails={viewEInvoiceDetails}
          // Layout switcher props
          layout={layout}
          onLayoutChange={handleLayoutChange}
        />
      </div>

      {/* New Design */}
      {layout === "new" && (
        <div className="box-border flex w-full h-full items-center justify-between gap-x-2 px-1.5 py-2.5">
          <Form {...form}>
            {/* Left Container */}
            <div className="flex h-full min-w-[440px] w-[560px] flex-col gap-y-2">
              <CustomerDetailsForm
                form={form}
                setIsExpand={setIsExpand}
                isExpand={isExpand}
                id={id}
                docNo={salesDebitNoteData?.docNo}
                customFieldRef={customFieldRef}
                preferenceData={preferenceData}
                slug={slug} 
              />
              <DocumentDetailsForm {...documentDetailsProps} isExpand={isExpand} />
            </div>

            {/* Right Container */}
            <div className="flex h-full w-full flex-1 flex-col">
              <SalesDebitNoteDataTable {...dataTableProps} />
            </div>
          </Form>

          {isLoading && <LoadingUI />}
          {(isFetching || isSaving) && <LoadingUI />}
        </div>
      )}

      {/* Old Design */}
      {layout === "old" && (
        <div className="grid h-full grid-rows-[auto_1fr]">
          <Form {...form}>
            <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
              { /* Preference (Pass preferenceData Prop) */}
              <ScrollArea className="h-full">
                <div id="mainDetails" className="mt-2" ref={mainDetailsRef}>
                  <DocumentDetailsFormOld
                    key={formResetKey}
                    form={form}
                    slug={slug}
                    preferenceData={preferenceData}
                  />
                </div>

                <div className="mt-2">
                  <CustomerDetailsFormOld form={form} />
                </div>

                <div className="mt-2">
                  <SalesDebitNoteDataTableOld
                    columns={SalesDebitNoteColumns}
                    data={
                      id
                        ? salesDebitNoteDetails
                          ? salesDebitNoteDetails.rows
                          : []
                        : tempRowSalesDebitNoteDetailsList
                    }
                    tempRowSalesDebitNoteDetailsList={tempRowSalesDebitNoteDetailsList}
                    setTempRowSalesDebitNoteDetailsList={setTempRowSalesDebitNoteDetailsList}
                    revalidateSalesDebitNoteDetails={revalidateSalesDebitNoteDetails}
                    form={form}
                    salesDebitNoteData={salesDebitNoteData}
                    UOMDetails={UOMDetails}
                    preferenceData={preferenceData}
                    slug={slug}
                  />
                </div>

                <div id="moreDetails" className="mt-2" ref={moreDetailsRef}>
                  <MoreDetailsForm
                    tempRowAttachments={tempRowAttachments}
                    setTempRowAttachments={setTempRowAttachments}
                    form={form}
                    slug={slug}
                    preferenceData={preferenceData}
                  />
                </div>

                <Card
                  collapsible
                  defaultCollapsed={false}
                  // className="h-auto pb-2 shadow-md"
                  className={`h-auto pb-2 shadow-md ${!viewEInvoiceDetails ? "hidden" : ""}`}
                  style={{ marginTop: "10px" }}
                >
                  <CardHeader>
                    <CardTitle className="text-lg font-bold">E-invoice Details</CardTitle>
                  </CardHeader>
                  <CardContent className="px-2 py-0">
                    <div id="eInvoiceDetails" ref={eInvoiceDetailsRef}>
                      <SupplierDetailsForm
                        form={form}
                        defaultCurrentCompany={slug == "new" ? defaultCurrentCompany : ""}
                      />

                      <div className="mt-2">
                        <BuyerDetailsForm form={form} />
                      </div>

                      <div className="mt-2">
                        <EInvoiceDetailsForm
                          form={form}
                          salesDebitNoteDetails={
                            id
                              ? salesDebitNoteDetails
                                ? salesDebitNoteDetails.rows
                                : []
                              : tempRowSalesDebitNoteDetailsList
                          }
                          tempRowSalesDebitNoteDetailsList={tempRowSalesDebitNoteDetailsList}
                          preferenceData={preferenceData}
                          salesDebitNoteData={salesDebitNoteData}
                        />
                      </div>

                      <div className="mt-2">
                        <PaymentDetailsForm form={form} />
                      </div>

                      <div className="mt-2">
                        <ShippingRecipientDetailsForm form={form} />
                      </div>

                      <div className="mt-2">
                        <ImportExportOfGoodsForm form={form} />
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </ScrollArea>

              <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14" />
            </div>
          </Form>

          {/* {isLoading && <LoadingUI />} */}
          {(isFetching || isSaving) && <LoadingUI />}
          {(isLoading || isSaving) && <LoadingUI />}
        </div>
      )}
    </>
  );
}