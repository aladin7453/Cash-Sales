                    <Input
                      className="h-9 rounded-lg px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                      {...field}
                      placeholder="Shipper SST No"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* BRN */}
            <FormField
              control={form.control}
              name="shipperBRN"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] text-gray-500">Shipper BRN</FormLabel>
