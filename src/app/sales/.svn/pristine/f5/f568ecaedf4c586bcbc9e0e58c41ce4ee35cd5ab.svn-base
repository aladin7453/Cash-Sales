                              <Input
                                className="h-7 rounded-xl px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                {...field}
                                placeholder="Shipper BRN"
                              />
                            </TooltipTrigger>
                            <TooltipContent side="top" align="center">
                              Shipper BRN
                            </TooltipContent>
                          </Tooltip>
                        </TooltipProvider>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                {/* TTx No */}
                <FormField
