                        <TooltipProvider delayDuration={1000}>
                          <Tooltip>
                            <TooltipTrigger asChild>
                              <Input
                                className="h-7 rounded-xl px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                {...field}
                                placeholder="Shipper TIN"
                              />
                            </TooltipTrigger>
                            <TooltipContent side="top" align="center">
                              Shipper TIN
                            </TooltipContent>
                          </Tooltip>
                        </TooltipProvider>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />

                {/* SST */}
                <FormField
                  control={form.control}
                  name="shipperSSTNo"
                  render={({ field }) => (
                    <FormItem>
                      <FormControl>
                        <TooltipProvider delayDuration={1000}>
                          <Tooltip>
                            <TooltipTrigger asChild>
                              <Input
                                className="h-7 rounded-xl px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                {...field}
                                placeholder="Shipper SST No"
                              />
                            </TooltipTrigger>
                            <TooltipContent side="top" align="center">
                              Shipper SST No
                            </TooltipContent>
                          </Tooltip>
