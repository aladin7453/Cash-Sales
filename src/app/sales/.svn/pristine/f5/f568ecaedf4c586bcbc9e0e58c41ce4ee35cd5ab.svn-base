"use client";

import React from "react";

import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { useWatch } from "react-hook-form";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "@/components/ui/tooltip";

type Params = {
  form: any;
  isMobile?: boolean;
};

export default function ShipperDetailsForm({ form, isMobile }: Params) {

  if (isMobile) {
    return (
      <>
        <div className="flex flex-col gap-y-4 px-1 py-2.5">
          <h1>Shipper Details</h1>

          {/* First Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">
            {/* Name */}
            <FormField
              control={form.control}
              name="shipperName"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] text-gray-500">Shipper Name</FormLabel>
                  <FormControl>
                    <Input
                      className="h-9 rounded-lg px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                      {...field}
                      placeholder="Shipper Name"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* TIN */}
            <FormField
              control={form.control}
              name="shipperTIN"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] text-gray-500">Shipper TIN</FormLabel>
