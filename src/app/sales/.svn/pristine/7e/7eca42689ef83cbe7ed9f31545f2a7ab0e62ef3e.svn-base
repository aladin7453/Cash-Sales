                  <div className="flex flex-col gap-y-2 pt-1.5">
                    {/* First Row */}
                    <div className="flex items-center justify-center gap-x-2">
                      {/* Estimated Working Hour */}
                      <FormField
                        control={form.control}
                        name="estimateMinute"
                        render={({ field }) => (
                          <FormItem className="flex-1">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Estimated Working Hour"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Estimated Working Hour</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      {/* Actual Working Hour */}
                      <FormField
                        control={form.control}
                        name="actualWorkingMinute"
                        render={({ field }) => (
                          <FormItem className="flex-1">
                            <FormControl>
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 rounded-xl px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      readOnly
                                      placeholder="Actual Working Hour"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Actual Working Hour</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
