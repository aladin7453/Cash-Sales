                      />
                    </div>

                    {/* Second Row */}
                    <div className="flex items-center justify-center gap-x-2">
                      {/* Assigned At */}
                      <FormField
                        control={form.control}
                        name="assignedAtFormat"
                        render={({ field }) => (
                          <FormItem className="flex-1">
                            <FormControl>
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7 rounded-xl px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      readOnly
                                      placeholder="Assigned At"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Assigned At</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      {/* Assigned By */}
                      <FormField
                        control={form.control}
                        name="assignedByFullName"
                        render={({ field }) => (
                          <FormItem className="flex-1">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 rounded-xl px-2 pr-8 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Assigned By"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Assigned By</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
