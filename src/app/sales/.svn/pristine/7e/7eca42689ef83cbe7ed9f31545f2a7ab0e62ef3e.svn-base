                      />
                    </div>

                    {/* Third Row */}
                    <div className="flex items-center justify-center gap-x-2">
                      {/* Started At */}
                      <FormField
                        control={form.control}
                        name="startedAtFormat"
                        render={({ field }) => (
                          <FormItem className="flex flex-1 flex-col">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 w-full rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Started At"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Started At</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      {/* Started By */}
                      <FormField
                        control={form.control}
                        name="startedByFullName"
                        render={({ field }) => (
                          <FormItem className="flex flex-1 flex-col">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 w-full rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Started By"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Started By</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>

                    {/* Fourth Row */}
                    <div className="flex items-center justify-center gap-x-2">
                      {/* Picked up At */}
                      <FormField
                        control={form.control}
                        name="pickedUpAtFormat"
                        render={({ field }) => (
                          <FormItem className="flex flex-1 flex-col">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 w-full rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Picked up At"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Picked up At</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      {/* Picked up By */}
                      <FormField
                        control={form.control}
                        name="pickedUpByFullName"
                        render={({ field }) => (
                          <FormItem className="flex flex-1 flex-col">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 w-full rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Picked up By"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Picked up By</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>

                    {/* Fifth Row */}
                    <div className="flex items-center justify-center gap-x-2">
                      {/* Delivered At */}
                      <FormField
                        control={form.control}
                        name="deliveredAtFormat"
                        render={({ field }) => (
                          <FormItem className="flex flex-1 flex-col">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 w-full rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Delivered At"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Delivered At</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />

                      {/* Delivered By */}
                      <FormField
                        control={form.control}
                        name="deliveredByFullName"
                        render={({ field }) => (
                          <FormItem className="flex flex-1 flex-col">
                            <FormControl className="relative">
                              <div className="relative">
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <Input
                                        className="h-7 w-full rounded-xl px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                        {...field}
                                        readOnly
                                        placeholder="Delivered By"
                                      />
                                    </TooltipTrigger>
                                    <TooltipContent>Delivered By</TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </div>
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>

                  </div>
                </TabPanel>
              </Tabs>
            </form>
          </Form>
        </CardContent>
      </Card>
    </>
  );
}
