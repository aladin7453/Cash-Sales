"use client";

import React,{ useEffect, useState } from "react";
import { FaMinus, FaPlus } from "react-icons/fa6";
import ConfirmationDialog from './ConfirmationDialog';
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { notFound, useSearchParams } from "next/navigation";
import { useToast } from "@/components/ui/use-toast";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
// import Validity from "@/components/data-table/Validity";
import { Button } from "@/components/ui/button";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  onAdd?: () => void;
  setTempRowDeliveryLocationDetailsData:(data:any,overwrite:boolean)=>void;
  revalidateDeliveryLocationDetails:()=>void;
  tempRowDeliveryLocationDetails:any;
};

export default function DeliveryLocationDetailsDataTableToolbar<TData>({ table, onAdd, tempRowDeliveryLocationDetails, setTempRowDeliveryLocationDetailsData, revalidateDeliveryLocationDetails }: Props<TData>) {
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const { toast } = useToast();
  const headers = getAuthHeaders();
  
  const [showConfirmationDialog, setShowConfirmationDialog] = useState(false);
  const [selectedRow, setSelectedRow] = useState("");

  const handleDeleteConfirmation = async() => {
    // Perform deletion logic here
    var form_data = new FormData();
    const selectedRows = table.getSelectedRowModel().rows;
    selectedRows.forEach((row, index) => {
          form_data.append(`UUIDs[]`, row["original"]["UUID"]);
       
    });
  
    if(id){
      try {
        const response = await fetch(`${ORIGIN}/customer/api/customer/remove-customer-has-delivery-location-data`, {
          method: 'POST',
          headers,
          body: form_data,
        });
        if (!response.ok) {
          throw new Error('Failed to create new stock data');
        }
        const responseData = await response.json();
        if(responseData){
          toast({
            title: responseData.message,
            duration:2000
          });
        }

      } catch (error) {
        console.error('Error creating new delivery location data:', error);
      }
      revalidateDeliveryLocationDetails()
      setShowConfirmationDialog(false);
    }else{
      const deletedIndex=selectedRows.map(item=>{
        return item.index
      })
      const remainRows = tempRowDeliveryLocationDetails.filter((item, index) => !deletedIndex.includes(index));
      setTempRowDeliveryLocationDetailsData(remainRows,true)
      setShowConfirmationDialog(false);

    }
  
  };
  return (
    <>
    <div className="flex items-center justify-between p-1.5">
        {/* ActionGroupStart */}
    <div className="flex items-center gap-x-1 pl-2">
      <span className="text-sm/none font-semibold">Delivery Location Details</span>
      <div className="flex items-center text-erp-blue-14">
        <Button className="size-8" variant="ghost" size="icon" onClick={onAdd}>
          <FaPlus className="size-5.5" />
        </Button>
        <Button className="size-8" variant="ghost" size="icon" onClick={() => setShowConfirmationDialog(true)}>
          <FaMinus className="size-5.5" />
        </Button>
      </div>
    </div>
    <Pagination table={table} /> {/* Pagination */}
    {/* ActionGroupEnd */}
    <div className="grid grid-cols-4 items-center text-erp-blue-14">
      {/* Other actions */}
      <Export table={table} />
      <Refresh />
      {/* <Validity table={table} /> */}
      <ColumnVisibilityToggle table={table} />
    </div>
  </div>
  <ConfirmationDialog
    open={showConfirmationDialog}
    setOpen={setShowConfirmationDialog}
    onConfirm={handleDeleteConfirmation}
    />
    </>
  );
}
