"use client";

import { useEffect, useState } from "react";
import { useForm } from "react-hook-form";
import { FaClipboard, FaLayerGroup, FaTableList } from "react-icons/fa6";
import { ColumnFiltersState, PaginationState, SortingState } from "@tanstack/react-table";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";

import { notFound, useRouter, useSearchParams } from "next/navigation";

import useSWR from "swr";

import { TabsNavigator } from "@/components/ui/TabsNavigator";
import { Form } from "@/components/ui/form";
import LoadingUI from "@/components/LoadingUI";
import { ScrollArea } from "@/components/ui/scroll-area";
import { useToast } from "@/components/ui/use-toast";

import { getFileToBase64 } from "@/lib/utils/commonFunction";
import {
  getAuthHeaders,
  getCurrentAcc,
  getCurrentAccount,
  ORIGIN,
  DEFAULT_DATA_TABLE_PAGE_SIZE,
  removeKeys
} from "@/lib/constants";


import { AgentTypeForm } from "./main-details/general-details/AgentTypeForm";
import { customInformationColumns } from "./more-details/custom-information/columns";
import CustomInformationDataTable from "./more-details/custom-information/DataTable";
import TopActionBar from "./TopActionBar";
import { OtherDetailForm } from "./more-details/custom-information/OtherDetailForm";
import { changelogColumns } from "./changelog/columns";
import AgentTypeChangelogDataTable from "./changelog/Datatable";

type PageParams = {
  params: { slug: string };
};

const validRoutes = ["new", "edit", "clone"] as const;

const fetcher = async (url: string, options?: RequestInit) => {

  const headers = getAuthHeaders();

  return fetch(url, { headers, ...options }).then(async (res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }

    try {
      return await res.json();
    } catch (error) {
      throw new Error("Failed to parse response JSON");
    }
  });
};



type ValidRoute = (typeof validRoutes)[number];

const agentTypeFormSchema = z.object({
  agentType: z.string().min(2, {
    message: "Agent Type must be at least 2 characters.",
  }),
});

// Function to check if a route is valid
function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

export default function AccountDetailsPage({ params }: PageParams) {
  const slug = params.slug;
  const router = useRouter();
  const [tempRowCustomInfo, setTempRowCustomInfo] = useState([]);
  const { toast } = useToast();
  const headers = getAuthHeaders();
  const currentAcc = getCurrentAcc();
  const currentAccount = getCurrentAccount();

  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const [formResetKey, setFormResetKey] = useState(0);

  const [agentTypeData, setAgentTypeData] = useState({});
  // const [customInformationData, setCustomInformationData] = useState([])

  const [isSaving, setIsSaving] = useState(false);

  const [columnFilters, setColumnFilters] = useState<ColumnFiltersState>([]);
  const [pagination, setPagination] = useState<PaginationState>({
    pageIndex: 0,
    pageSize: DEFAULT_DATA_TABLE_PAGE_SIZE,
  });
  const [sorting, setSorting] = useState<SortingState>([{ id: "createdAt", desc: true }]);
  const resetForm = () => {
    setFormResetKey((prevKey) => prevKey + 1);
  };

  if (!isValidRoute(slug)) {
    notFound();
  }


  const {
    data: agentType,
    error,
    isLoading,
  } = useSWR(
    id
      ? [`${ORIGIN}/agent_type/api/agent-type/get-update-agent-type-data?id=${id}`]
      : null,
    ([url]) => {
      const params = new FormData();

      params.append("param[limit]", `${pagination.pageSize}`);
      params.append("param[offset]", `${pagination.pageIndex * pagination.pageSize}`);

      const columnFiltersWithoutValid = columnFilters.filter((filter) => filter.id !== "valid");
      params.append(
        "param[filter]",
        columnFiltersWithoutValid.length > 0
          ? JSON.stringify(
            columnFiltersWithoutValid.reduce<Record<string, unknown>>((acc, curr) => {
              acc[curr.id] = curr.value;
              return acc;
            }, {})
          )
          : "{}"
      );

      params.append(
        "param[order]",
        sorting.length > 0 ? (sorting[0].desc ? "desc" : "asc") : "desc"
      );
      params.append(
        "param[valid]",
        columnFilters.length > 0
          ? `${columnFilters.find((row) => row.id === "valid")?.value}`
          : ""
      );
      params.append("param[sort]", sorting.length > 0 ? sorting[0].id : "createdAt");

      return fetcher(url, { method: "POST", body: params });
    }, {
    revalidateOnFocus: false
  }
  );

  const {
    data: customInformationData,
    error: customInfoError,
    mutate: mutateCustomInfo,
  } = useSWR(
    id
      ? `${ORIGIN}/agent_type/api/agent-type/get-update-agent-type-has-custom-info-data?id=${id}`
      : null,
    fetcher,
    { revalidateOnFocus: false },
  );

  useEffect(() => {
    if (agentType) {
      if (slug === "clone") {
        agentType.data.agentTypeCode = ""
      }
      setAgentTypeData(agentType.data);
      if (agentType.historyData) {
        const historyData = {
          agentType: agentType.historyData.agentTypeHistory || { rows: [] },
          agentTypeHasCustomInfo: agentType.historyData.agentTypeHasCustomInfoHistory || { rows: [] },
        };
        setChangelogData(historyData);
      }
    }

  }, [agentType]);

  useEffect(() => {
    if (customInformationData) {
      if (slug === "clone") {
        console.log(customInformationData)
        setTempRowCustomInfo(customInformationData.rows)
      }

    }
  }, [customInformationData]);





  const revalidateCustomInfoData = () => {
    mutateCustomInfo();
  };

  const handleSubmit = async () => {
    try {
      await form.trigger();
      await form.handleSubmit(onSubmit)();
    } catch (error) {
      console.error("Form submission error:", error);
    }
  };

  const form = useForm<z.infer<typeof agentTypeFormSchema>>({
    resolver: zodResolver(agentTypeFormSchema),
    defaultValues: {
      account: agentType?.account ?? currentAccount,
      accountName: agentType?.accountName ?? currentAcc,
      companyName: agentType?.companyName ?? "",
      agentTypeCode: agentType?.agentTypeCode ?? "",
      agentType: agentType?.agentType ?? "",
      description: agentType?.description ?? "",
      valid: agentType?.valid ?? "1",
    },
  });

  const onSubmit = async () => {
    setIsSaving(true);
    var form_data = new FormData();
    var formValues = form.getValues();
    var saveType =
      slug == "clone" ? `create-data?c_id=1` : id ? `update-agent-type?id=${id}` : `create-data`;

    for (var key in formValues) {
      if (key !== "attachmentLink" && key !== "attachment")
        form_data.append(`agentType[${key}]`, formValues[key] ? formValues[key] : "");
    }

    if (saveType == "create-data" || saveType === "create-data?c_id=1") {
      tempRowCustomInfo.forEach((row, index) => {
        for (const key in row) {
          if (key !== "attachment") {
            form_data.append(`agentTypeHasCustomInfo[${index}][${key}]`, row[key]);
          }
        }
      });

      for (let i = 0; i < tempRowCustomInfo.length; i++) {
        const row = tempRowCustomInfo[i];

        var counter = 0;
        if (row.attachmentFiles) {
          for (const file of row.attachmentFiles) {
            const base64 = await getFileToBase64(file);

            form_data.append(
              `agentTypeHasCustomInfo[${i}][attachment][${counter}][Name]`,
              file.name,
            );
            form_data.append(
              `agentTypeHasCustomInfo[${i}][attachment][${counter}][File]`,
              base64,
            );
            counter++;
          }
        }

      }
    }

    try {
      const response = await fetch(`${ORIGIN}/agent_type/api/agent-type/${saveType}`, {
        method: "POST",
        headers,
        body: form_data,
      });

      if (response.status === 401) {
        console.error("Session expired. Redirecting to login.");
        toast({
          variant: "destructive",
          title: "Session Expired",
          description: "Your session has expired. Redirecting to login page.",
        });
        router.push("/login");
        throw new Error("Session expired");
      }

      if (!response.ok) {
        const errorData = await response.json();

        let errorMessage = errorData.message;

        // Error Handling for "Data too long"
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 2000,
        });

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        const url = `/sales/agent-type/edit?item=${responseData.item}&id=${responseData.data}`;

        router.push(url);

        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        router.push(`/sales/agent-type/clone?id=${id}`);
        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error creating new freight term data :", error);
    } finally {
      setIsSaving(false);
    }
  };

  const [changelogData, setChangelogData] = useState(null);

  const handleTableParamsChange = (
    newFilters: ColumnFiltersState,
    newPagination: PaginationState,
    newSorting: SortingState
  ) => {
    setColumnFilters(newFilters);
    setPagination(newPagination);
    setSorting(newSorting);
  };


  const tabs = [
    {
      id: "mainDetails",
      name: "Main Details",
      shortName: "Main",
      icon: FaClipboard,
    },
    {
      id: "moreDetails",
      name: "More Details",
      shortName: "More",
      icon: FaLayerGroup,
    },
    ...(slug !== "new"
      ? [
        {
          id: "changelog",
          name: "Changelog",
          shortName: "Changelog",
          icon: FaTableList,
        },
      ]
      : []),
  ];

  return (
    <>
      <div className="sticky top-0 z-20">
        <TopActionBar
          agentType={agentTypeData}
          form={form}
          handleSubmit={handleSubmit}
          tempRowCustomInfo={tempRowCustomInfo}
          agentTypeFormSchema={agentTypeFormSchema}
          parms={params}
          params={params}
          setTempRowCustomInfo={setTempRowCustomInfo}
          isSaving={isSaving}
          setIsSaving={setIsSaving}
        />
      </div>
      <div className="grid h-full grid-rows-[auto_1fr]">
        <Form {...form}>
          <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
            <ScrollArea className="h-full">
              <div id="mainDetails" className="mt-2">
                <AgentTypeForm
                  key={formResetKey}
                  customInformationData={customInformationData}
                  tempRowCustomInfo={tempRowCustomInfo}
                  form={form}
                />
              </div>

              <div id="moreDetails" className="mt-2">
                <OtherDetailForm
                  key={formResetKey}
                  customInformationData={customInformationData}
                  tempRowCustomInfo={tempRowCustomInfo}
                  form={form}
                  pageAction={slug}
                />
              </div>

              <div className="mt-2">
                <CustomInformationDataTable
                  columns={customInformationColumns}
                  data={
                    id && slug == "edit" ? (customInformationData ? customInformationData.rows : []) : tempRowCustomInfo
                  }
                  tempRowCustomInfo={tempRowCustomInfo}
                  setTempRowCustomInfo={setTempRowCustomInfo}
                  revalidateCustomInfoData={revalidateCustomInfoData}
                />
              </div>

              {slug !== "new" && (
                <div id="changelog" className="mt-2">
                  <AgentTypeChangelogDataTable
                    columns={changelogColumns}
                    initialData={changelogData}
                    onTableParamsChange={handleTableParamsChange}
                  />
                </div>
              )}
            </ScrollArea>

            <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14" />
          </div>
          {/* {isLoading && <LoadingUI />} */}
          {(isLoading || isSaving) && <LoadingUI />}
        </Form>
      </div>
    </>
  );
}