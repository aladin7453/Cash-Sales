                                        className="h-[335px]"
                                      />
                                    </FormControl>
                                    <FormMessage />
                                  </FormItem>
                                )}
                              />
                            </CardContent>
                          </Card>
                        </TabPanel>

                        {/* Note 4 */}
                        <TabPanel
                          forceRender
                          className="hidden"
