                        >
                          <Card className="w-full border-none !shadow-none">
                            <CardContent className="p-0">
                              <FormField
                                control={form.control}
                                name="note7"
                                render={({ field }) => (
                                  <FormItem>
                                    <FormControl>
                                      <TextEditorInline
                                        value={field.value || ""}
                                        onChange={(val) => field.onChange(val)}
