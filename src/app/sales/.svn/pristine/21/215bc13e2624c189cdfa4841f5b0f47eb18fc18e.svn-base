"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { notFound, useRouter, useSearchParams } from "next/navigation";
import React, { useEffect, useRef, useState } from "react";
import { useForm } from "react-hook-form";
import { z } from "zod";
import { FaClipboard, FaLayerGroup, FaQrcode } from "react-icons/fa6";
import VerifyVoucherPopover from "./VerifyVoucherPopover";

//Hooks
import { useApi } from "@/lib/hooks/useAPI";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { getFileToBase64 } from "@/lib/utils/commonFunction";

//Components
import LoadingUI from "@/components/LoadingUI";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Form } from "@/components/ui/form";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import { TabsNavigator } from "@/components/ui/TabsNavigator";
import { useToast } from "@/components/ui/use-toast";
import { DateRestrictionContext } from "@/components/custom/DateRestrictionContext";
import { CustomFieldHandle, CustomFieldDefinition } from "@/components/DisplayCustomField";
import TopActionBar from "./TopActionBar";
import { SalesInvoiceColumns } from "./main-details/sales-invoice-details/columns";

//Mobile 
import { MobileStepperLayout } from "@/components/form/MobileStepper";

//New UI
import { CustomerDetailsForm } from "./main-details/customer-details/CustomerDetailsForm";
import ShipperDetailsForm from "./main-details/shipper-details/ShipperDetailsForm";
import { DocumentDetailsForm } from "./main-details/document-details/DocumentDetailsForm";
import SalesInvoiceDataTable from "./main-details/sales-invoice-details/DataTable";
import { ShippingRecipientDetailsForm } from "./e-invoice-details/shipping-recipient-details/ShippingRecipientDetailsForm";
import MoreDetailsForm from "./more-details/more-details/MoreDetailsForm";
import { EInvoiceDetailsForm } from "./e-invoice-details/e-invoice-details/EInvoiceDetailsForm";

//Old UI
import { BuyerDetailsForm } from "./e-invoice-details/buyer-details/BuyerDetailsFormOld";
import { EInvoiceDetailsFormOld } from "./e-invoice-details/e-invoice-details/EInvoiceDetailsFormOld";
import { ImportExportOfGoodsForm } from "./e-invoice-details/import-&-export-of-goods/Import&ExportOfGoodsDetailsFormOld";
import { PaymentDetailsForm } from "./e-invoice-details/payment-details/PaymentDetailsFormOld";
import { ShippingRecipientDetailsFormOld } from "./e-invoice-details/shipping-recipient-details/ShippingRecipientDetailsFormOld";
import { SupplierDetailsForm } from "./e-invoice-details/supplier-details/SupplierDetailsFormOld";
import { CustomerDetailsFormOld } from "./main-details/customer-details/CustomerDetailsFormOld";
import { DocumentDetailsFormOld } from "./main-details/document-details/DocumentDetailsFormOld";
import SalesInvoiceDataTableOld from "./main-details/sales-invoice-details/DataTableOld";
import MoreDetailsFormOld from "./more-details/more-details/MoreDetailsFormOld";


type PageParams = {
  params: { slug: string };
};

const validRoutes = ["new", "edit", "clone", "transfer-to", "transfer-from"] as const;
type ValidRoute = (typeof validRoutes)[number];

function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

const salesInvoiceFormSchema = z.object({
  customerCodeCode: z.string().min(1, {
    message: "Required",
  }),
});

export default function SalesInvoiceDetailsPage({ params }: PageParams) {
  const slug = params.slug;
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const router = useRouter();
  const headers = getAuthHeaders();
  const { toast } = useToast();
  const customFieldRef = useRef<CustomFieldHandle>(null);

  if (!isValidRoute(slug)) {
    notFound();
  }

  //Layout State
  const [layout, setLayout] = useState<"new" | "old">(() => {
    if (typeof window === "undefined") return "old";
    return (localStorage.getItem("Layout") as "new" | "old") || "old";
  });

  const handleLayoutChange = (newLayout: "new" | "old") => {
    localStorage.setItem("Layout", newLayout);
    setLayout(newLayout);
  };

  //States
  const [formResetKey, setFormResetKey] = useState(0);
  const [isSaving, setIsSaving] = useState(false);
  const [salesInvoiceData, setSalesInvoiceData] = useState({});
  const [approvalStatus, setApprovalStatus] = useState({});
  const [tempRowSalesInvoiceDetailsList, setTempRowSalesInvoiceDetailsList] = useState([]);
  const [tempRowAttachments, setTempRowAttachments] = useState([]);
  const [UOMDetails, setUOMDetails] = useState({});
  const [preferenceData, setPreferenceData] = useState<any>(null);
  const [isExpand, setIsExpand] = useState(false);
  const [allowPastRecord, setAllowPastRecord] = useState(false);
  const currentCompany = JSON.parse(localStorage.getItem("currentCompany") || "null");

  //Mobile state
  const [isMobile, setIsMobile] = useState(false);

  //Customise steps
  const [currentStep, setCurrentStep] = useState(0);
  const steps = ["Customer", "Shipper", "Recipient", "Document", "Others", "E-Invoice", "Charges"];

  //Voucher logic
  const [voucherOpen, setVoucherOpen] = useState(false)
  const [verifyVoucherData, setVerifyVoucherData] = useState([])

  //API
  const {
    data: salesInvoice,
    error,
    isLoading,
    isValidating,
    mutate: mutateSalesInvoice,
  } = useApi(
    id ? `${ORIGIN}/sales_invoice/api/sales-invoice/get-update-sales-invoice-data?id=${id}` : null,
    { revalidateOnFocus: false },
  );

  const { data: defaultCurrentCompany } = useApi(
    !id && `${ORIGIN}/universal/get-current-company?id=${currentCompany?.UUID}`,
    { revalidateOnFocus: false },
  );

  const {
    data: salesInvoiceDetails,
    mutate: mutateSalesInvoiceDetails,
  } = useApi(
    id
      ? `${ORIGIN}/sales_invoice/api/sales-invoice/get-sales-invoice-has-details?salesInvoiceUUID=${id}`
      : null,
    { revalidateOnFocus: false },
  );

  const {
    data: attachmentData,
    mutate: mutateAttachmentData,
  } = useApi(id ? `${ORIGIN}/sales_invoice/api/sales-invoice/load-files?id=${id}` : null, {
    revalidateOnFocus: false,
  });

  const { data: getPermissions } = useApi(
    !id ? `${ORIGIN}/sales_invoice/api/sales-invoice/get-permissions` : null,
    { revalidateOnFocus: false },
  );

  //Computed
  const viewEInvoiceDetails = [
    ...(Array.isArray(getPermissions?.data) ? getPermissions.data : []),
    ...(Array.isArray(salesInvoice?.rules) ? salesInvoice.rules : []),
  ].includes("view-sales-invoice-e-invoice-details");

  const isPaid = slug === "clone" ? false : salesInvoice?.isPaid || false;

  //Form
  const form = useForm<z.infer<typeof salesInvoiceFormSchema>>({
    resolver: zodResolver(salesInvoiceFormSchema),
    defaultValues: {
      account: salesInvoiceData?.account ?? "",
      company: salesInvoiceData?.company ?? "",
      serviceCategoryCode: salesInvoiceData?.serviceCategoryCode ?? "",
      description: salesInvoiceData?.description ?? "",
      moreDescription: salesInvoiceData?.moreDescription ?? "",
      attachment: salesInvoiceData?.attachment ?? "",
      eInvoiceTypeDescription: salesInvoiceData?.eInvoiceTypeDescription ?? "Invoice",
      valid: salesInvoiceData?.valid ?? "1",
      currency: salesInvoiceData?.currency ?? "",
      currencyCode: salesInvoiceData?.currencyCode ?? "",
      currencyRate: salesInvoiceData?.currencyRate ?? "",
    },
  });

  //Preference
  const [customFieldDefs, setCustomFieldDefs] = useState<CustomFieldDefinition[]>([]);
  const [customFieldSavedData, setCustomFieldSavedData] = useState<Record<string, unknown>>({});

  const fetchPreferenceData = async () => {
    try {
      const headers = getAuthHeaders();

      const response = await fetch(`${ORIGIN}/universal/get-preference?module=sales`, {
        method: "GET",
        headers,
      });
      if (!response.ok) throw new Error("Failed to fetch preference data");
      const data = await response.json();
      setPreferenceData(data);

      // Fetch custom field definitions
      const prefRes = await fetch(
        `${ORIGIN}/sales_preference/api/sales-preference/get-index-sales-preference`,
        { method: "GET", headers }
      );
      if (!prefRes.ok) throw new Error("Failed to fetch custom field preference");
      const prefData = await prefRes.json();
      const raw = prefData?.data?.customDIYFields ?? prefData?.customDIYFields ?? [];
      const rawFields: CustomFieldDefinition[] = (() => {
        try {
          const parsed = typeof raw === "string" ? JSON.parse(raw) : raw;
          return Array.isArray(parsed) ? parsed : [];
        } catch { return []; }
      })();
      setCustomFieldDefs(rawFields);

    } catch (error) {
      console.error("Error fetching preference data:", error);
    }
  };

  useEffect(() => {
    fetchPreferenceData();
  }, []);

  //Sales Invoice Data Effects
  useEffect(() => {
    if (salesInvoice && slug !== "transfer-to" && slug !== "transfer-from") {
      const salesInvoiceDataCopy = { ...salesInvoice.data };
      salesInvoiceDataCopy.voucherCode = salesInvoiceDataCopy.voucherDetails?.number //Voucher logic
      if (slug === "clone") {
        salesInvoiceDataCopy.docNo = "";
        salesInvoiceDataCopy.eInvoiceStatus = "";
        salesInvoiceDataCopy.customerPaymentDocNo = "";
        salesInvoiceDataCopy.digitalSignature = "";
        salesInvoiceDataCopy.oriRefNo = "";
        salesInvoiceDataCopy.eInvoiceVersion = "";
        salesInvoiceDataCopy.eInvoiceCode = "";
        salesInvoiceDataCopy.consolidateTo = "";
        salesInvoiceDataCopy.consolidatedInvoiceDocNo = "";
        salesInvoiceDataCopy.docDate = Math.floor(Date.now() / 1000);
        salesInvoiceDataCopy.voucher = "" //Voucher logic
        salesInvoiceDataCopy.voucherCode = "" //Voucher logic
      }

      const qrLink = salesInvoiceDataCopy.QRAttachmentLink;
      salesInvoiceDataCopy.QRAttachmentLink = Array.isArray(qrLink)
        ? qrLink[0] ?? null
        : qrLink ?? null;

      setSalesInvoiceData(salesInvoiceDataCopy);
      setApprovalStatus(salesInvoice.approval);
      setAllowPastRecord(salesInvoice.data.allowPastDates === "1");
      setIsSaving(false);

      const rawSaved = salesInvoice?.customDIYFieldData;
      if (rawSaved) {
        setCustomFieldSavedData(
          typeof rawSaved === "string" ? JSON.parse(rawSaved) : rawSaved
        );
      } else {
        setCustomFieldSavedData({});
      }
    }
  }, [salesInvoice, slug]);

  useEffect(() => {
    if (salesInvoiceDetails && slug !== "transfer-to" && slug !== "transfer-from") {
      const detailsWithPreferences = salesInvoiceDetails.rows.map((row) => ({
        ...row,
        voucher: slug == "clone" ? null : row.voucher, //Voucher logic
        voucherCode: slug == "clone" ? null : row.voucherCode,
        discountRate: slug == "clone" ? "0.00" : row.discountRate,
        discountAmount: slug == "clone" ? "0.00" : row.discountAmount,
        voucherOption: slug == "clone" ? "" : row.voucherOption,
        preferenceData: preferenceData,
      }));

      setTempRowSalesInvoiceDetailsList(detailsWithPreferences);
    }
  }, [salesInvoiceDetails, preferenceData]);

  useEffect(() => {
    if (attachmentData) {
      setTempRowAttachments(attachmentData);
    }
  }, [attachmentData]);

  //Transfer Effects
  useEffect(() => {
    if (typeof window !== "undefined" && (slug === "transfer-to" || slug === "transfer-from")) {
      const transferDataKey =
        slug === "transfer-to" ? "transfer-to.sales-invoice" : "transfer-from.sales-invoice";

      const transferData = JSON.parse(localStorage.getItem(transferDataKey) || "{}");

      if (transferData && transferData.transferDocType == "salesOrder") {
        var mappedData = {
          ...transferData?.data,
          attentionName: transferData?.data?.customerAttentionNameName,
          address: transferData?.data?.address,
          phoneNo: transferData?.data?.customerAttentionTel,
          email: transferData?.data?.customerAttentionEmail,
          quotationNo: transferData?.data?.quotationDocNo ?? transferData?.data?.quotationNo ?? "",
          description: "",
          note: "",
          UUID: "",
          docDate: Math.floor(Date.now() / 1000),
        };
      } else {
        var mappedData = {
          ...transferData?.data,
          attentionName: transferData?.data?.attentionName,
          address: transferData?.data?.address,
          phoneNo: transferData?.data?.phoneNo,
          email: transferData?.data?.email,
          quotationNo: transferData?.data?.quotationDocNo ?? transferData?.data?.quotationNo ?? "",
          description: "",
          note: "",
          UUID: "",
          docDate: Math.floor(Date.now() / 1000),
        };
      }

      setSalesInvoiceData(mappedData);

      transferData?.subData?.forEach((detail) => {
        detail["item"] = detail["item"];
        detail["itemGroup"] = detail["itemGroupCode"];
        detail["itemCategory"] = detail["itemCategoryCode"];
      });

      setTempRowAttachments(transferData?.data?.attachmentLink ?? []);
      setTempRowSalesInvoiceDetailsList(transferData?.subData);

      function beforeUnload(e: BeforeUnloadEvent) {
        localStorage.removeItem(transferDataKey);
        e.preventDefault();
      }

      window.addEventListener("beforeunload", beforeUnload);
      return () => {
        window.removeEventListener("beforeunload", beforeUnload);
      };
    }
  }, [slug]);

  //Revalidate Helpers 
  const revalidateSalesInvoiceDetails = () => {
    mutateSalesInvoiceDetails(undefined, { revalidate: true });
  };

  const revalidateSalesInvoice = () => {
    mutateSalesInvoice(undefined, { revalidate: true });
  };

  //OnSubmit
  const onSubmit = async () => {
    setIsSaving(true);

    var form_data = new FormData();
    var formValues = form.getValues();

    const localNetTotal = document.querySelector(".localNetTotal");
    const netTotal = document.querySelector(".netTotal");

    var saveType = id
      ? `${slug === "clone" ? "create-data?c_id=1" : `update-sales-invoice-data?id=${id}`}`
      : `create-data`;

    const decimal = preferenceData?.data?.decimal || 2;

    let totalAmount = tempRowSalesInvoiceDetailsList.reduce((sum, row) => {
      return sum + (row.amount ? parseFloat(row.amount) : 0);
    }, 0);

    let totalDiscount = tempRowSalesInvoiceDetailsList.reduce((sum, row) => {
      const discount1 = row.discountAmount ? parseFloat(row.discountAmount) : 0;
      const discount2 = row.discountAmount2 ? parseFloat(row.discountAmount2) : 0;
      const discount3 = row.discountAmount3 ? parseFloat(row.discountAmount3) : 0;
      return sum + discount1 + discount2 + discount3;
    }, 0);

    let totalTax = tempRowSalesInvoiceDetailsList.reduce((sum, row) => {
      return sum + (row.taxAmount ? parseFloat(row.taxAmount) : 0);
    }, 0);

    let totalSubtotal = totalAmount - totalDiscount;
    let prepaymentAmount = parseFloat(formValues.prepaymentAmount) || 0;
    let totalFeeAmount = parseFloat(formValues.totalFeeAmount) || 0;
    let subtotalTax = totalAmount - totalDiscount + totalTax;
    let roundingAmount = parseFloat(formValues.roundingAmount) || 0;
    let totalPayable =
      totalAmount - totalDiscount + totalTax - prepaymentAmount + totalFeeAmount + roundingAmount;

    let localNetTotalValue = localNetTotal?.value;

    if (
      formValues.invoiceType == "Consolidate" &&
      (totalPayable >= 10000 || localNetTotalValue >= 10000)
    ) {
      toast({
        title: "Error",
        description: "Total invoice amount cannot exceed RM10,000 for Consolidate Invoice.",
        variant: "destructive",
        duration: 4000,
      });
      setIsSaving(false);
      return;
    }

    let outstandingAmount = isPaid ? parseFloat(formValues.outstandingAmount) || 0 : totalPayable;

    formValues.totalAmount = totalAmount.toFixed(decimal);
    formValues.totalDiscount = totalDiscount.toFixed(decimal);
    formValues.totalTax = totalTax.toFixed(decimal);
    formValues.totalSubtotal = totalSubtotal.toFixed(decimal);
    formValues.roundingAmount = roundingAmount.toFixed(decimal);
    formValues.totalPayable = totalPayable.toFixed(decimal);
    formValues.outstandingAmount = outstandingAmount.toFixed(decimal);
    formValues.localNetTotal = localNetTotal?.value;
    formValues.netTotal = netTotal?.value;

    if (slug == "clone") {
      formValues.consolidateTo = "";
    }

    const salesInvoiceDataToSend = { ...formValues };
    delete salesInvoiceDataToSend.attachmentLink;
    delete salesInvoiceDataToSend.attachment;

    const tempRowSalesInvoiceDetailsListToSend = tempRowSalesInvoiceDetailsList.map(
      (item: any) => ({
        ...item,
        transferableQuantity: item.quantity,
      }),
    );

    const combinedData = {
      salesInvoice: salesInvoiceDataToSend,
      salesInvoiceHasDetails: tempRowSalesInvoiceDetailsListToSend,
    };

    form_data.append("data", JSON.stringify(combinedData));

    var transferType = "";
    var transferData: any = "";

    if (saveType === "create-data") {
      if (slug === "transfer-to") {
        transferData = JSON.parse(localStorage.getItem("transfer-to.sales-invoice") || "{}");
      } else if (slug === "transfer-from") {
        transferData = JSON.parse(localStorage.getItem("transfer-from.sales-invoice") || "{}");
      }

      var transferDocType = transferData?.data?.transferDocType;
      var counter = 0;

      for (const file of tempRowAttachments) {
        const base64 =
          slug === "transfer-to" || slug === "transfer-from" ? "" : await getFileToBase64(file);
        form_data.append(`salesInvoice[attachment][${counter}][Name]`, file.name);
        form_data.append(
          `salesInvoice[attachment][${counter}][File]`,
          slug === "transfer-to" || slug === "transfer-from" ? "" : base64,
        );
        counter++;
      }
    } else {
      var counter = 0;
      for (const attachment of tempRowAttachments) {
        if (attachment.link) {
          form_data.append(`salesInvoice[attachment][${counter}][Name]`, attachment.name);
          form_data.append(`salesInvoice[attachment][${counter}][File]`, "");
        } else {
          const base64 = await getFileToBase64(attachment);
          form_data.append(`salesInvoice[attachment][${counter}][Name]`, attachment.name);
          form_data.append(`salesInvoice[attachment][${counter}][File]`, base64);
        }
        counter++;
      }
    }

    transferType =
      slug == "transfer-to" || slug == "transfer-from" ? `?transferFrom=${transferDocType}` : "";

    try {
      const response = await fetch(
        `${ORIGIN}/sales_invoice/api/sales-invoice/${saveType}${transferType}`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      if (!response.ok) {
        const errorData = await response.json();
        setIsSaving(false);

        let errorMessage = errorData.message;
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 4000,
        });

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        if (slug === "transfer-to") localStorage.removeItem("transfer-to.sales-invoice");
        else if (slug === "transfer-from") localStorage.removeItem("transfer-from.sales-invoice");

        if (customFieldRef.current) {
          try {
            await customFieldRef.current.save(
              responseData.data,
              responseData.item,
            );
          } catch (err) {
            console.error("Failed to save custom fields:", err);
          }
        }

        const url = `/sales/sales-invoice/edit?item=${responseData.item}&id=${responseData.data}`;
        router.push(url);

        if (params.slug == "edit") {
          mutateSalesInvoice();
          mutateSalesInvoiceDetails();
          mutateAttachmentData();
        }

        toast({ title: responseData.message, duration: 2000 });
      } else if (responseData.message) {
        if (slug === "transfer-to") localStorage.removeItem("transfer-to.sales-invoice");
        else if (slug === "transfer-from") localStorage.removeItem("transfer-from.sales-invoice");

        setIsSaving(false);
        toast({ title: responseData.message, duration: 2000 });
      } else if (slug === "clone" && id) {
        router.push(`/sales/sales-invoice/clone?id=${id}`);
        toast({ title: responseData.message, duration: 2000 });
      }
    } catch (error) {
      console.error("Error creating new sales data:", error.message);
      setIsSaving(false);
      toast({ title: `${error.message}`, duration: 2000 });
    }
  };

  const handleSubmit = async () => {
    const isFormValid = await form.trigger();

    if (!isFormValid) {
      const errors = form.formState.errors;

      if (errors.customerCodeCode) {
        toast({
          title: "Customer Required",
          description: "Please select a customer before saving.",
          variant: "destructive",
          duration: 3000,
        });
      }
      return;
    }

    try {
      await onSubmit();
    } catch (error) {
      console.error("Form submission error:", error);
    }
  };

  const moreDetailsRef = useRef(null);
  const eInvoiceDetailsRef = useRef(null);
  const mainDetailsRef = useRef(null);

  const tabs = [
    { id: "mainDetails", name: "Main Details", icon: FaClipboard, shortName: "Main" },
    { id: "moreDetails", name: "More Details", icon: FaLayerGroup, shortName: "More" },
    ...(viewEInvoiceDetails
      ? [{ id: "eInvoiceDetails", name: "e-Invoice Details", icon: FaQrcode, shortName: "E-Inv" }]
      : []),
  ];

  //If less than 500px, enter mobile view
  useEffect(() => {
    const checkMobile = () => setIsMobile(window.innerWidth < 500);
    checkMobile();
    window.addEventListener("resize", checkMobile);
    return () => window.removeEventListener("resize", checkMobile);
  }, []);

  //Voucher logic
  const [isVoucherLoading, setIsVoucherLoading] = useState(false);

  //Verify voucher function
  const verifyVoucher = async (value) => {
    if (!value) {
      clearVoucherData()
      return false
    }
    const verifyVoucherForm = new FormData();
    const docId = slug == "clone" ? "" : id || ""
    verifyVoucherForm.append("voucherNumber", value)
    verifyVoucherForm.append("docDate", form.getValues("docDate"))
    verifyVoucherForm.append("doc_id", docId)
    const itemUUIDs = tempRowSalesInvoiceDetailsList.map(row => row.item);

    itemUUIDs.forEach((uuid, index) => {
      verifyVoucherForm.append(`itemUUIDs[${index}]`, uuid);
    });

    if (itemUUIDs.length == 0) {
      return false
    }

    setIsVoucherLoading(true);

    try {
      clearVoucherData();
      const response = await fetch(
        `${ORIGIN}/promotion_voucher/api/promotion-voucher/verify-voucher`,
        {
          method: "POST",
          headers,
          body: verifyVoucherForm,
        }
      );

      const data = await response.json();

      if (data && data.data.length == 0) {
        form.setValue("voucher", "");
        form.setValue("voucherCode", "");
        setVerifyVoucherData([]);
        if (data.used) {
          toast({
            title: "Voucher Used",
            description: "This voucher has already been used",
            variant: "destructive",
            duration: 3000,
          });
        } else {
          toast({
            title: "Invalid Voucher",
            description: "Voucher not available.",
            variant: "destructive",
            duration: 3000,
          });
        }


        clearVoucherData();

      } else if (data && data.data) {

        form.setValue("voucher", data.data.UUID);

        const availableItems = data.data.availableItems;
        const discountRate = data.data.discountRate;
        const decimal = preferenceData?.data?.decimal || 2;
        const voucherCode = data.data.number;
        const voucherUUID = data.data.UUID;

        let rate = "";

        if (discountRate && discountRate.includes("%")) {
          rate = parseFloat(discountRate.replace("%", ""));
        }

        const itemMap = new Map();
        availableItems.forEach(item => {
          itemMap.set(item.item, {
            voucher: voucherUUID,
            discountRate: rate,
            minQuantity: item.minQuantity,
            voucherCode: voucherCode
          });
        });

        if (data.data.option == "Apply to all item") {

          tempRowSalesInvoiceDetailsList.forEach(row => {
            if (
              itemMap.has(row.item) &&
              Number(row.quantity) >= Number(itemMap.get(row.item).minQuantity)
            ) {
              const data = itemMap.get(row.item);
              const price = row.price || 0;
              const quantity = row.quantity || 0;
              const minQty = itemMap.get(row.item).minQuantity
              const discountAmount = rate
                ? ((price * quantity) * rate) / 100
                : 0;



              row.voucher = data.voucher;
              row.voucherCode = data.voucherCode;
              row.discountRate = parseFloat(data.discountRate).toFixed(decimal);
              row.discountAmount = parseFloat(discountAmount).toFixed(decimal);
              row.voucherMinQuantity = minQty;
              row.voucherOption = "Apply to all item"
            }
          });

          setTempRowSalesInvoiceDetailsList([...tempRowSalesInvoiceDetailsList]);

          toast({
            title: "Voucher Applied",
            description: "Voucher has been applied successfully.",
            variant: "success",
            duration: 3000,
          });

        } else {//Apply to single item

          let matchedArray = [];

          tempRowSalesInvoiceDetailsList.forEach(row => {
            if (
              itemMap.has(row.item) &&
              Number(row.quantity) >= Number(itemMap.get(row.item).minQuantity)
            ) {
              const data = itemMap.get(row.item);
              const price = row.price || 0;
              const quantity = row.quantity || 0;
              const minQty = itemMap.get(row.item).minQuantity

              const newRow = { ...row };

              const discountAmount = rate
                ? ((price * quantity) * rate) / 100
                : 0;
              newRow.voucher = data.voucher;
              newRow.voucherCode = data.voucherCode;
              newRow.discountRate = parseFloat(data.discountRate).toFixed(decimal);
              newRow.discountAmount = parseFloat(discountAmount).toFixed(decimal);
              newRow.voucherMinQuantity = minQty;
              newRow.voucherOption = "Apply to single item";
              matchedArray.push(newRow);


            }
          });
          setVerifyVoucherData(matchedArray);

          if (matchedArray.length > 0) {
            setVoucherOpen(true);
          } else {
            toast({
              title: "Invalid Voucher",
              description:
                "This voucher can't be used with the selected item. Please check the voucher conditions.",
              variant: "destructive",
              duration: 3000,
            });
          }
        }
      }

    } catch (err) {
      console.error(err);
      toast({
        title: "Error",
        description: "Failed to verify voucher. Please try again.",
        variant: "destructive",
        duration: 3000,
      });

    } finally {
      setIsVoucherLoading(false);
    }

  };

  //Voucher logic
  const updateSelectedVoucherData = (data, overwrite) => {
    const updatedList = tempRowSalesInvoiceDetailsList.map(item => ({
      ...item,
      voucher: null,
      voucherCode: null,
      discountRate: "0.00",
      discountAmount: "0.00"
    }));
    const updatedArray = updatedList.map((row) => {
      if (row.seq === data.seq && row.item === data.item) {
        return data;
      }
      return row;
    });
    setTempRowSalesInvoiceDetailsList(updatedArray)
    toast({
      title: "Voucher Applied",
      description: "Voucher has been applied successfully.",
      variant: "success",
      duration: 3000,
    });
  }

  //Voucher logic
  const clearVoucherData = () => {
    const updatedArray = tempRowSalesInvoiceDetailsList.map((row) => {
      row.voucher = null;
      row.voucherCode = null;
      row.discountRate = "0.00";
      row.discountAmount = "0.00";
      return row;
    });
    setTempRowSalesInvoiceDetailsList(updatedArray)
  }

  //Loading State
  const isFetching = isLoading || isValidating || isVoucherLoading || isSaving;

  // Shared Props
  const documentDetailsProps = {
    key: formResetKey,
    form,
    slug,
    preferenceData,
    tempRowAttachments,
    setTempRowAttachments,
    salesInvoiceData: salesInvoice,
    defaultCurrentCompany,
    id,
    salesInvoiceDetails,
    tempRowSalesInvoiceDetailsList,
    isExpand,
    isMobile,
    verifyVoucher,
    clearVoucherData
  };

  const dataTableProps = {
    columns: SalesInvoiceColumns,
    data: id
      ? salesInvoiceDetails
        ? salesInvoiceDetails.rows
        : []
      : tempRowSalesInvoiceDetailsList,
    tempRowSalesInvoiceDetailsList,
    setTempRowSalesInvoiceDetailsList,
    revalidateSalesInvoiceDetails,
    form,
    salesInvoiceData,
    UOMDetails,
    isPaid,
    preferenceData,
    slug,
  };

  return (
    <DateRestrictionContext.Provider value={{ allowPastRecord, setAllowPastRecord }}>
      <div className="sticky top-0 z-20">
        <TopActionBar
          handleSubmit={handleSubmit}
          salesInvoice={salesInvoiceData}
          approvalStatus={approvalStatus}
          tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
          form={form}
          revalidateSalesInvoiceDetails={revalidateSalesInvoiceDetails}
          slug={slug}
          revalidateSalesInvoice={revalidateSalesInvoice}
          viewEInvoiceDetails={viewEInvoiceDetails}
          salesInvoiceData={salesInvoice}
          layout={layout}
          onLayoutChange={handleLayoutChange}
          isMobile={isMobile}
        />
      </div>

      {/* New Design */}
      {layout === "new" && (
        <Form {...form}>
          <div
            data-layout="new"
            className={
              isMobile
                ? "flex flex-col w-full h-full"
                : "box-border flex flex-row w-full h-full items-center justify-between gap-x-2 p-1.5"
            }
          >
            {/* Mobile View */}
            {isMobile ? (
              <MobileStepperLayout
                steps={steps}
                currentStep={currentStep}
                onStepChange={setCurrentStep}
                onSave={handleSubmit}
                preventdoublescroll={[6]}
              >
                {/* Customer Details */}
                <CustomerDetailsForm form={form} setIsExpand={setIsExpand} isExpand={isExpand} isMobile={isMobile} preferenceData={preferenceData} slug={slug} customFieldRef={customFieldRef} customFieldDefs={customFieldDefs} customFieldSavedData={customFieldSavedData} />

                {/* Shipper Details */}
                <ShipperDetailsForm form={form} isMobile={isMobile} />

                {/* Recipient Details */}
                <ShippingRecipientDetailsForm form={form} isMobile={isMobile} />

                {/* Document Details */}
                <DocumentDetailsForm {...documentDetailsProps} />

                {/* More Details */}
                <MoreDetailsForm
                  tempRowAttachments={tempRowAttachments}
                  setTempRowAttachments={setTempRowAttachments}
                  form={form}
                  salesInvoiceData={salesInvoiceData}
                  slug={slug}
                  isPaid={isPaid}
                  preferenceData={preferenceData}
                  isMobile={isMobile}
                />

                {/* E-Invoice Details */}
                <EInvoiceDetailsForm
                  form={form}
                  salesInvoiceDetails={id ? salesInvoiceDetails ? salesInvoiceDetails.rows : [] : tempRowSalesInvoiceDetailsList}
                  tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
                  preferenceData={preferenceData}
                  salesInvoiceData={salesInvoiceData}
                  isMobile={isMobile}
                />

                {/* Charges Details */}
                <SalesInvoiceDataTable {...dataTableProps} isMobile={isMobile} />
              </MobileStepperLayout>
            ) : (
              /* Web View */
              <div className="box-border flex flex-col md:flex-row w-full h-full items-center justify-between gap-x-2">
                {/* Left */}
                <div className="flex h-full w-full md:min-w-[380px] md:w-[480px] flex-col gap-y-2">
                  <CustomerDetailsForm
                    form={form}
                    setIsExpand={setIsExpand}
                    isExpand={isExpand}
                    isMobile={false}
                    id={id}
                    docNo={salesInvoiceData?.docNo}
                    customFieldRef={customFieldRef}
                    preferenceData={preferenceData}
                    slug={slug}
                    customFieldDefs={customFieldDefs}
                    customFieldSavedData={customFieldSavedData}
                  />
                  <DocumentDetailsForm {...documentDetailsProps} />
                </div>

                {/* Right */}
                <div className="w-full flex flex-1 flex-col h-full mt-3.5 md:mt-0">
                  <SalesInvoiceDataTable {...dataTableProps} />
                </div>
              </div>
            )}
          </div>

          {/* Loading */}
          <VerifyVoucherPopover open={voucherOpen} setOpen={setVoucherOpen} data={verifyVoucherData} tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList} updateSelectedVoucherData={updateSelectedVoucherData} form={form} />
          {isFetching && <LoadingUI />}
        </Form>
      )}

      {/* Old Design */}
      {layout === "old" && (
        <div data-layout="old" className="grid h-full grid-rows-[auto_1fr]">
          <Form {...form}>
            <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
              <ScrollArea className="h-full">
                <div id="mainDetails" className="mt-2" ref={mainDetailsRef}>
                  {/* Voucher logic */}
                  <DocumentDetailsFormOld key={formResetKey} form={form} slug={slug} preferenceData={preferenceData} verifyVoucher={verifyVoucher} tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList} clearVoucherData={clearVoucherData} />
                </div>
                <div className="mt-2">
                  <CustomerDetailsFormOld form={form} />
                </div>
                <div className="mt-2">
                  <SalesInvoiceDataTableOld
                    columns={SalesInvoiceColumns}
                    data={id ? salesInvoiceDetails ? salesInvoiceDetails.rows : [] : tempRowSalesInvoiceDetailsList}
                    tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
                    setTempRowSalesInvoiceDetailsList={setTempRowSalesInvoiceDetailsList}
                    revalidateSalesInvoiceDetails={revalidateSalesInvoiceDetails}
                    form={form}
                    salesInvoiceData={salesInvoiceData}
                    UOMDetails={UOMDetails}
                    isPaid={isPaid}
                    preferenceData={preferenceData}
                    slug={slug}
                  />
                </div>
                <div id="moreDetails" className="mt-2" ref={moreDetailsRef}>
                  <MoreDetailsFormOld
                    tempRowAttachments={tempRowAttachments}
                    setTempRowAttachments={setTempRowAttachments}
                    form={form}
                    salesInvoiceData={salesInvoiceData}
                    slug={slug}
                    isPaid={isPaid}
                    preferenceData={preferenceData}
                    verifyVoucher={verifyVoucher}
                  />
                </div>
                <Card
                  collapsible
                  defaultCollapsed={false}
                  className={`h-auto pb-2 shadow-md ${!viewEInvoiceDetails ? "hidden" : ""}`}
                  style={{ marginTop: "10px" }}
                >
                  <CardHeader>
                    <CardTitle className="text-lg font-bold">E-invoice Details</CardTitle>
                  </CardHeader>
                  <CardContent className="px-2 py-0">
                    <div id="eInvoiceDetails" ref={eInvoiceDetailsRef}>
                      <SupplierDetailsForm form={form} supplierCode={form.getValues("supplierCode")} defaultCurrentCompany={slug == "new" ? defaultCurrentCompany : ""} />
                      <div className="mt-2"><BuyerDetailsForm form={form} /></div>
                      <div className="mt-2">
                        <EInvoiceDetailsFormOld
                          form={form}
                          salesInvoiceDetails={id ? salesInvoiceDetails ? salesInvoiceDetails.rows : [] : tempRowSalesInvoiceDetailsList}
                          tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList}
                          preferenceData={preferenceData}
                          salesInvoiceData={salesInvoiceData}
                        />
                      </div>
                      <div className="mt-2"><PaymentDetailsForm form={form} /></div>
                      <div className="mt-2"><ShippingRecipientDetailsFormOld form={form} /></div>
                      <div className="mt-2"><ImportExportOfGoodsForm form={form} /></div>
                    </div>
                  </CardContent>
                </Card>
              </ScrollArea>
              <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14" />
            </div>
          </Form>
          <VerifyVoucherPopover open={voucherOpen} setOpen={setVoucherOpen} data={verifyVoucherData} tempRowSalesInvoiceDetailsList={tempRowSalesInvoiceDetailsList} updateSelectedVoucherData={updateSelectedVoucherData} form={form} />
          {isFetching && <LoadingUI />}
        </div>
      )}
    </DateRestrictionContext.Provider>
  );
}