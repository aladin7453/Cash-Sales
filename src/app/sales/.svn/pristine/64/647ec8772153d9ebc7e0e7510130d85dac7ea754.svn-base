export type Customer = {
  UUID: string;
  account: string;
  company: string;
  customerGroup: string;
  GLCode: string;
  location: string;
  agent: string;
  currency: string;
  creditTerm: string;
  customerName: string;
  description: string;
  customerCode: string;
  BRN: string;
  businessNature: string;
  address: string;
  TIN: string;
  SSTNo: string;
  creditLimit: string;
  overdueLimit: string;
  billingAddress: string;
  TaxExNo: string;
  TaxExNoExpiry: string;
  approvalStatus: string;
  rejectReason: string;
  createdAt: string;
  createdBy: string;
  updatedAt: string;
  updatedBy: string;
  valid: "0" | "1";
  deliveryAddress: string;
  postcode: string;
  city: string;
  state: string;
  country: string;
  companyName: string;
  accountName: string;
  customerGroupName: string;
  GLCodeCode: string;
  locationName: string;
  salesAgent: string;
  currencyCode: string;
  creditTermCode: string;
  stateCode: string;
  countryOfOriginCode: string;
  CreatedByUsername: string;
  createdAtFormat: string;
  UpdatedByUsername: string;
  updatedAtFormat: string;
  outstandingAmountAmount: number;
  preferenceData?: any;
};

// Preference (Format Number Function)
const formatNumber = (value: string | number, decimalPlaces: number = 2): string => {
  if (value === null || value === undefined || value === '') {
    return (0).toFixed(decimalPlaces);
  }
  
  const numValue = typeof value === 'string' ? parseFloat(value) : value;
  
  if (isNaN(numValue)) {
    return (0).toFixed(decimalPlaces);
  }
  
  return numValue.toFixed(decimalPlaces);
};


