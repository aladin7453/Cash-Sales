import { FaObjectUngroup } from "react-icons/fa6";

import { cn } from "@/lib/utils/cn";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  isDisabled: boolean;
  onClick: () => void; // Pass the onClick handler
};

const AuthorizedLocationButton = <TData,>({ table, isDisabled, onClick }: Props<TData>) => {
  return (
    <button
      onClick={onClick} // Call the onClick handler passed from the parent
      disabled={isDisabled}
      className="group flex flex-col items-center gap-y-1 disabled:cursor-not-allowed"
      aria-label="Authorized Location"
    >
      <FaObjectUngroup
        className={cn("size-5.5", isDisabled ? "text-erp-gray-5" : "text-erp-blue-11")}
      />
      <span
        className={cn(
          "text-[11px]/none font-medium",
          isDisabled ? "text-erp-gray-5" : "text-black",
        )}
      >
        Auth
      </span>
    </button>
  );
};

export default AuthorizedLocationButton;
