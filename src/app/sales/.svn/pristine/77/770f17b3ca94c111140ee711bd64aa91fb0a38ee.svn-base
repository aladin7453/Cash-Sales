  {
    id: "createdAtFormat",
    accessorKey: "createdAtFormat",
    header: "Created at",
    filterFn: "includesString",
  },
  {
    id: "createdByUsername",
    accessorKey: "createdByUsername",
    header: "Created by",
    filterFn: "includesString",
  },
  {
    id: "updatedAtFormat",
    accessorKey: "updatedAtFormat",
    header: "Updated at",
    filterFn: "includesString",
  },
  {
    id: "updatedByUsername",
    accessorKey: "updatedByUsername",
    header: "Updated by",
    filterFn: "includesString",
  },
  {
    id: "description",
    accessorKey: "description",
    header: "Description",
    cell: ({ row }) => <DescriptionCellTooltip row={row} />,
    filterFn: "includesString",
  },
   {
    id: "avatar",
    accessorKey: "avatar", // 👈 change this to your actual field name (e.g. "photoUrl")
    header: "Avatar",
    cell: ({ row }) => {
      const imageLinkArray =row.original.profileImageLink.length>0?row.original.profileImageLink[0].link:"";
      const imageUrl =imageLinkArray
      return (
      <div className="flex justify-center items-center">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt="Agent"
            className="w-16 h-16 object-cover border"
            onError={(e) => {
              (e.currentTarget as HTMLImageElement).src = "/no-image.png";
            }}
          />
        ) : (
          <span className="text-gray-400">No Image</span>
        )}
      </div>
    );
    },
    enableSorting: false,
    enableColumnFilter: false,
  },

  {
    id: "valid",
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as Agent["valid"];
      return validity === "1" ? "Valid" : "Invalid";
    },
    filterFn: filterWithStringConversion,
  },
];

export const columns: ColumnDef<Agent>[] = rawColumns.map(
  (col) => {
    if (typeof col.header === "string") {
      const sizes = autoWordSize(col.header);

      return {
        ...col,
        sizes,
        size: sizes, // 👈 applied automatically
        minSize:50
      };
    }

    return col;
  }
);