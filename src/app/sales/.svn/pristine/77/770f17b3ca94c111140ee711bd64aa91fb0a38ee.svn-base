"use client";

import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";
import type { ColumnDef } from "@tanstack/react-table";
import toStringAccessorFn from "@/lib/utils/data-table/toStringAccessorFn";
import {autoWordSize} from "@/lib/constants";
// Updated Agent type based on both AgentForm and OtherDetailForm fields
export type Agent = {
  UUID: string;
  account: string;
  accountName: string;
  company: string;
  companyName: string;
  agentCode: string;
  agentName: string;
  agentTypeCode: string;
  commission: string;
  gender: string;
  title: string;
  phoneNo: string;
  email: string;
  address: string;
  description: string;
  valid: "0" | "1";
  createdAt: string;
  createdAtFormat: string;
  createdBy: string;
  createdByUsername: string;
  updatedAt: string;
  updatedAtFormat: string;
  updatedBy: string;
  updatedByUsername: string;
  nationality: string;
  race: string;
  religion: string;
  maritalStatus: string;
  DOB: string;
  DOBFormat: string;
  NRIC: string;
  preferenceData?: any;
  avatar?:any;
};

// Preference (Format Number Function)
const formatNumber = (value: string | number, decimalPlaces: number = 2): string => {
  if (value === null || value === undefined || value === '') {
    return (0).toFixed(decimalPlaces);
  }
  
  const numValue = typeof value === 'string' ? parseFloat(value) : value;
  
  if (isNaN(numValue)) {
    return (0).toFixed(decimalPlaces);
  }
  
  return numValue.toFixed(decimalPlaces);
};

export const rawColumns: ColumnDef<Agent>[] = [
  {
    id: "agentCode",
    accessorKey: "agentCode",
    header: "Agent Code",
    filterFn: "includesString",
  },
  {
    id: "agentName",
    accessorKey: "agentName",
    header: "Agent Name",
    filterFn: "includesString",
  },
   {
    id: "agentTypeCode",
    accessorKey: "agentTypeCode",
    header: "Agent Type",
    filterFn: "includesString",
  },
  {
    id: "commission",
    accessorKey: "commission",
    header: "Commission %",
    filterFn: "includesString",
  },
  {
    id: "gender",
    accessorKey: "gender",
    header: "Gender",
    filterFn: "includesString",
  },
  {
    id: "title",
    accessorKey: "title",
    header: "Title",
    filterFn: "includesString",
  },
  {
    id: "phoneNo",
    accessorKey: "phoneNo",
    header: "Phone No.",
    filterFn: "includesString",
  },
  {
    id: "email",
    accessorKey: "email",
    header: "Email",
    filterFn: "includesString",
  },
  {
    id: "address",
    accessorKey: "address",
    header: "Address",
    filterFn: "includesString",
  },
  {
    id: "nationality",
    accessorKey: "nationality",
    header: "Nationality",
    filterFn: "includesString",
  },
  {
    id: "race",
    accessorKey: "race",
    header: "Race",
    filterFn: "includesString",
  },
  {
    id: "religion",
    accessorKey: "religion",
    header: "Religion",
    filterFn: "includesString",
  },
  {
    id: "maritalStatus",
