"use client";

import React, { useState, useEffect } from 'react';
import { FaMinus, FaPlus, FaCube } from "react-icons/fa6";
import type { Table } from "@tanstack/react-table";

import ConfirmationDialog from './ConfirmationDialog';
import { notFound, useSearchParams } from "next/navigation";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";

import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import Validity from "@/components/data-table/Validity";
import { Button } from "@/components/ui/button";
import { Tooltip, TooltipTrigger, TooltipContent, TooltipProvider } from "@/components/ui/tooltip";
import { TOOLTIP_DELAY_DURATION } from "@/lib/constants";

// Mobile View (Imports)
import MobileFormTableActionGroupStart from "@/components/form/MobileFormTableActionGroupStart";
import MobileFormTableActionGroupEnd from "@/components/form/MobileFormTableActionGroupEnd";
import { DropdownMenuItem } from "@/components/ui/dropdown-menu";

type Props<TData> = {
  table: Table<TData>;
  onAdd?: () => void;
  setTempRowConsolidateEInvoiceDetailsListData: (data, overwrite) => void;
  tempRowConsolidateEInvoiceDetailsList: [];
  revalidateConsolidateEInvoiceDetails: any;
  form: any
  slug: string;
};

export default function DataTableToolbar<TData>({
  table,
  onAdd,
  setTempRowConsolidateEInvoiceDetailsListData,
  tempRowConsolidateEInvoiceDetailsList,
  revalidateConsolidateEInvoiceDetails,
  form,
  slug,
}: Props<TData>) {
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const headers = getAuthHeaders();

  const [showConfirmationDialog, setShowConfirmationDialog] = useState(false);
  const [selectedRow, setSelectedRow] = useState<any[]>([]);
  const eInvoiceStat = form.getValues("eInvoiceStatus")
  const handleDeleteConfirmation = async () => {
    // Perform deletion logic here
    var form_data = new FormData();

    const selectedRows = table.getSelectedRowModel().rows;

    selectedRows.forEach((row, index) => {
      form_data.append(`UUIDs[${index}]`, row.original.UUID);
    });
    // Calculate totals from the remaining rows (after deletion)
    const remainingRows = table.getFilteredRowModel().rows.filter(
      row => !selectedRows.some(selectedRow => selectedRow.id === row.id)
    );

    // Calculate total values
    let totalAmount = remainingRows.reduce((sum, row) => {
      return sum + (row.original.amount ? parseFloat(row.original.amount) : 0);
    }, 0);

    let totalDiscount = remainingRows.reduce((sum, row) => {
      return sum + (row.original.discountAmount ? parseFloat(row.original.discountAmount) : 0);
    }, 0);

    let totalTax = remainingRows.reduce((sum, row) => {
      return sum + (row.original.taxAmount ? parseFloat(row.original.taxAmount) : 0);
    }, 0);

    // Calculate subtotal tax (this is what should be used for outstanding amount)
    const subtotalTax = totalAmount - totalDiscount + totalTax;
    const roundTotalPayable = Math.round(subtotalTax * 20) / 20;

    const prepaymentAmount = form.getValues("prepaymentAmount")
    const currentCurrencyRate = form.getValues("currencyRate")

    const roundTotalPayableAfterPrepayment = roundTotalPayable - (prepaymentAmount ? prepaymentAmount : 0)
    const roundingAmount = roundTotalPayable - subtotalTax;

    const localNetTotal = roundTotalPayable * (currentCurrencyRate)
    const totalExclTax = totalAmount - totalDiscount

    // Add the calculated totals to form data
    form_data.append('consolidatedInvoice[totalAmount]', totalAmount.toFixed(2));
    form_data.append('consolidatedInvoice[totalDiscount]', totalDiscount.toFixed(2));
    form_data.append('consolidatedInvoice[totalTax]', totalTax.toFixed(2));
    form_data.append('consolidatedInvoice[totalSubtotal]', (totalAmount - totalDiscount).toFixed(2));
    form_data.append('consolidatedInvoice[totalPayable]', roundTotalPayableAfterPrepayment.toFixed(2));


    form_data.append('consolidatedInvoice[localNetTotal]', localNetTotal.toFixed(2));
    form_data.append('consolidatedInvoice[netTotal]', roundTotalPayable.toFixed(2));
    form_data.append('consolidatedInvoice[roundingAmount]', roundingAmount.toFixed(2));

    form_data.append('consolidatedInvoice[totalNetAmount]', totalExclTax.toFixed(2));
    form_data.append('consolidatedInvoice[totalExclTax]', totalExclTax.toFixed(2));
    form_data.append('consolidatedInvoice[totalInclTax]', subtotalTax.toFixed(2));
    form_data.append('consolidatedInvoice[prepaymentAmount]', prepaymentAmount ? prepaymentAmount : "0.00")

    // if (id && slug !== "clone") {
    //   try {
    //     const response = await fetch(`${ORIGIN}/consolidated_invoice/api/consolidated-invoice/remove-consolidated-invoice-has-details-data`, {
    //       method: 'POST',
    //       headers,
    //       body: form_data,
    //     });

    //     if (!response.ok) {
    //       throw new Error('Failed to delete sales debit note has details data');
    //     }

    //     const responseData = await response.json();

    //     if (responseData.RemoveSuccess && responseData.RemoveSuccess.length > 0) {
    //       revalidateConsolidateEInvoiceDetails()
    //     }
    //   } catch (error) {
    //     console.error('Error deleting sales debit note has details data:', error);
    //   }

    //   revalidateConsolidateEInvoiceDetails();

    //   setShowConfirmationDialog(false);
    // } else {
    const deletedIndex = selectedRows.map(item => {
      return item.index
    });
    const remainRows = tempRowConsolidateEInvoiceDetailsList.filter((item, index) => !deletedIndex.includes(index));

    const resequencedRows = remainRows.map((row, index) => ({
      ...row,
      seq: index + 1
    }));

    setTempRowConsolidateEInvoiceDetailsListData(resequencedRows, true);
    setShowConfirmationDialog(false);
    //}
  };

  //Update total selected rows
  useEffect(() => {
    const selected = table.getSelectedRowModel().rows;
    setSelectedRow(selected);
  }, [table.getState().rowSelection, table.getRowModel().rows.length]);

  return (
    <>
      <div className="flex items-center justify-center px-2">
        {/* Web View Action Buttons */}

        {/* Add Buttons */}
        <div className="flex items-center justify-center gap-x-4 text-erp-blue-14">
          <div className="flex flex-col items-center">
            <TooltipProvider delayDuration={TOOLTIP_DELAY_DURATION}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    className="size-6 hover:text-erp-blue-14 active:bg-erp-blue-14 active:text-white disabled:text-gray-300 disabled:hover:bg-transparent"
                    variant="ghost"
                    size="icon"
                    onClick={onAdd}
                    disabled={eInvoiceStat == "Valid" || eInvoiceStat == "Submitted"}
                  >
                    <FaPlus className="size-4" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent>
                  Add
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Add</span>
          </div>

          {/* Remove */}
          <div className="flex flex-col items-center">
            <TooltipProvider delayDuration={TOOLTIP_DELAY_DURATION}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    className="size-6 hover:text-erp-blue-14 active:bg-erp-blue-14 active:text-white disabled:text-gray-300 disabled:hover:bg-transparent"
                    variant="ghost"
                    size="icon"
                    onClick={() => setShowConfirmationDialog(true)}
                    disabled={selectedRow?.length === 0 || eInvoiceStat == "Valid" || eInvoiceStat == "Submitted"}
                  >
                    <FaMinus className="size-4" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent>
                  Remove
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Remove</span>
          </div>

          {/* Refresh */}
          <div className="[&_button]:!size-6 [&_svg]:!size-4">
            <Refresh refreshTable={revalidateConsolidateEInvoiceDetails} />
          </div>

          {/* Validity */}
          <div className="[&_button]:!size-6 [&_svg]:!size-4">
            <Validity table={table} />
          </div>

          {/* Column */}
          <div className="[&_button]:!size-6 [&_svg]:!size-4">
            <ColumnVisibilityToggle table={table} />
          </div>
        </div>
      </div>

      {/* Confirmation Dialog */}
      <ConfirmationDialog
        open={showConfirmationDialog}
        setOpen={setShowConfirmationDialog}
        onConfirm={handleDeleteConfirmation}
        selectedRows={selectedRow}
      />
    </>
  );
}
