"use client";

import type { ColumnDef } from "@tanstack/react-table";

import filterWithStringConversion from "@/lib/utils/data-table/filterWithStringConversion";

import { NumberFormatter } from "@/components/ui/number-formatter";

export type CustomerPostDatedChequeListing = {
  docDate?: string;
  matureDate?: string;
  docNo?: string;
  chequeNo?: string;
  receivedIn?: string;
  customerName?: string;
  currencyCode?: string;
  paidAmount?: string;
  unappliedAmount?: string;
  knockoffAmount?: string;
};

export const CustomerPostDatedChequeListingColumns: ColumnDef<CustomerPostDatedChequeListing>[] = [
  {
    accessorKey: "rowNumber",
    id: "rowNumber",
    header: "No",
    cell: ({ table, row }) => {
      const { pageIndex, pageSize } = table.getState().pagination;

      return (
        <div className="text-right">
          {pageIndex * pageSize + row.index + 1}
        </div>
      );
    },
    enableSorting: false,
    enableColumnFilter: false,
    minSize: 60,
    maxSize: 80,
  },
  {
    accessorKey: "docDateFormat",
    id: "docDateFormat",
    header: "Received Date",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "matureDateFormat",
    id: "matureDateFormat",
    header: "Mature Date",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "docNo",
    id: "docNo",
    header: "Doc No",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
  },
  {
    accessorKey: "chequeNo",
    id: "chequeNo",
    header: "Cheque No",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "bank",
    id: "bank",
    header: "Received In",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "customerName",
    id: "customerName",
    header: "Customer Name",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "currencyCode",
    id: "currencyCode",
    header: "Currency Code",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 120,
    maxSize: 200,
  },
  {
    accessorKey: "paidAmount",
    id: "paidAmount",
    header: "Amount",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
    cell: ({ row }) => (
      <div className="text-right"><NumberFormatter value={row.original.paidAmount} /></div>
    ),
  },
  {
    accessorKey: "unappliedAmount",
    id: "unappliedAmount",
    header: "Unapplied",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
    cell: ({ row }) => (
      <div className="text-right"><NumberFormatter value={row.original.unappliedAmount} /></div>
    ),
  },
  {
    accessorKey: "knockoffAmount",
    id: "knockoffAmount",
    header: "Knock Off Amount",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
    cell: ({ row }) => (
      <div className="text-right"><NumberFormatter value={row.original.knockoffAmount} /></div>
    ),
  },
];