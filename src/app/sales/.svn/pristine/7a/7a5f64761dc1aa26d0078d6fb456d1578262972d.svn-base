  UOM2?: string;
  UOM3?: string;
  UOMDropdown2?: any[];
  UOMDropdown3?: any[];
  itemRate: string;
  price: number;
  discountRate: number;
  discountAmount: number;
  discountRate2?: number;
  discountAmount2?: number;
  discountRate3?: number;
  discountAmount3?: number;
  subtotal: number;
  tax: string;
  taxRate: number;
  taxInclusive: string;
  taxableAmount: number;
  taxAmount: number;
  localNetAmount: number;
  subtotalTax: number;
  deliveryDate: string;
  billingFrequency: number;
  billingInterval: string;
  startDate: string;
  endDate: string;
  remark1: string;
  remark2: string;
  transferredFrom: string;
  transferredTo: string;
  stockBatch: string;
  valid: string;
  master: string;
  showTemplate: string;
  customerCodeCode: string;
  customerName: string;
  customerBRN: string;
  customerID: string;
  customermembershipID: string;
  customerDescription: string;
};

const isDev = process.env.NODE_ENV === "development";

const urlMap = {
  quotation: isDev ? "sales/quotation" : "view/sales/quotation",
  salesOrder: isDev ? "sales/sales-order" : "view/sales/sales-order",
  jobOrder: isDev ? "sales/job-order" : "view/sales/job-order",
  salesInvoice: isDev ? "sales/sales-invoice" : "view/sales/sales-invoice",
  cashSales: isDev ? "sales/cash-sales" : "view/sales/cash-sales",
  salesDebitNote: isDev ? "sales/sales-debit-note" : "view/sales/sales-debit-note",
};

