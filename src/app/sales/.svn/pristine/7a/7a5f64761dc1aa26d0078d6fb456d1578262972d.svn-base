export type DeliveryOrder = {
  seq: string;
  UUID: string;
  item: string;
  itemName: string;
  type: number;
  description: string;
  "2ndDescription": string;
  moreDescription: string;
  itemGroup: string;
  itemCategory: string;
  masterItem: string;
  tariff: string;
  classification: string;
  permitNo: string;
  locationCode: string;
  project: string;
  quantity: number;
  quantity2?: number;
  quantity3?: number;
