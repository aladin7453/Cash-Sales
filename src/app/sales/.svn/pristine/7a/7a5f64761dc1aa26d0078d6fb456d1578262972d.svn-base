    accessorKey: "remark2",
    header: "Remark 2",
    filterFn: "includesString",
  },
  {
    id: "transferFrom",
    accessorKey: "transferFrom",
    header: "Transfer From Doc No",
    cell: ({ row }) => {
      const transferFromDocuments = row.original.transferFromDocuments;

      if (!transferFromDocuments || typeof transferFromDocuments !== "object") {
        return <span className="text-gray-400">-</span>;
      }

      const docNo = transferFromDocuments.docNo || "";
      const docType = transferFromDocuments.docType || "";

      const url = `/${urlMap[docType as keyof typeof urlMap]}/edit?item=${docNo}&id=${transferFromDocuments.UUID}`;

      return (
        <a
          href={url}
          className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          {transferFromDocuments.docNo}
        </a>
      );
    },
    filterFn: "includesString",
  },
  {
    id: "transferFromDocType",
    accessorKey: "transferFromDocType",
    header: "Transfer From Doc Type",
    cell: ({ row }) => {
      const transferFromDocuments = row.original.transferFromDocuments;

      if (!transferFromDocuments || typeof transferFromDocuments !== "object") {
        return <span className="text-gray-400">-</span>;
      }

      return <span className="text-sm">{transferFromDocuments.docType || "-"}</span>;
    },
    filterFn: "includesString",
  },
  {
    id: "transferTo",
    accessorKey: "transferTo",
    header: "Transfer To",
    cell: ({ row }) => {
      const transferToDocuments = row.original.transferToDocuments;

      if (!transferToDocuments || transferToDocuments.length === 0) {
        return <span className="text-gray-400">-</span>;
      }

      return (
        <div className="flex flex-wrap">
          {transferToDocuments.map((doc, index) => {
            const docNo = doc.docNo || "";
            const docType = doc.docType || "";
            const url = `/${urlMap[docType as keyof typeof urlMap]}/edit?item=${docNo}&id=${doc.UUID}`;

            return (
              <span key={index}>
                <a
                  href={url}
                  className="text-blue-600 hover:text-blue-800 hover:underline text-sm"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {doc.docNo}
                </a>
                {index < transferToDocuments.length - 1 && ", "}
              </span>
            );
          })}
        </div>
      );
    },
    filterFn: "includesString",
  },
  {
    id: "stockBatchCode",
    accessorKey: "stockBatchCode",
    header: "Stock Batch",
    filterFn: "includesString",
  },
  {
    id: "valid",
    accessorKey: "valid",
    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as UOMList["valid"];
      return validity ? "Valid" : "Invalid";
    },
    // Custom filter function that first convert the row's numeric boolean
    // value to string, then check if the string contains the filterValue
    filterFn: filterWithStringConversion,
  },
  {
    id: "master",
    accessorKey: "master",
    header: "Master Service",
    filterFn: "includesString",
  },
  {
    id: "showTemplate",
    accessorKey: "showTemplate",
    header: "Show in PDF",
    filterFn: "includesString",
  },
];
