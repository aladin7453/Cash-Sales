"use client";

import React from "react";
import { useEffect, useState, useRef } from "react";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Card, CardHeader, CardContent, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import {
  TooltipProvider,
  Tooltip,
  TooltipContent,
  TooltipTrigger,
} from "@/components/ui/tooltip";
import { Textarea } from "@/components/ui/textarea";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import DropdownTable from "@/components/data-table/DropdownTable";
import { FaMagnifyingGlass } from "react-icons/fa6";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import { ORIGIN, getAuthHeaders } from "@/lib/constants";

type Params = {
  form: any;
  isMobile?: boolean;
};

export function ImportExportOfGoodsForm({ form, isMobile }: Params) {
  const headers = getAuthHeaders();
  const [showTableCountry, setShowTableCountry] = useState(false);

  const [countryDropdownTableData, setCountryDropdownTableData] = useState([]);
  const [countrySearchTerm, setCountrySearchTerm] = useState("");

  const dropdownCountryColumns = [
    { accessorKey: "code", header: "Country" },
    {
      accessorKey: "description",
      header: "Description",
      cell: ({ row }) => <DescriptionCellTooltip row={row} />,
    },
  ];

  const inputRef = useRef(null);
  const dropdownRef = useRef(null);

  const handleClickOutside = (event) => {
    if (
      dropdownRef.current &&
      !dropdownRef.current.contains(event.target) &&
      inputRef.current !== event.target
    ) {
      setShowTableCountry(false);
    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);

    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);

  const toggleTableCountry = async () => {
    const formData = new FormData();
    const country = "countryOfOrigin";
    formData.append("table[]", country);

    if (!showTableCountry) {
      try {
        const response = await fetch(
          `${ORIGIN}/universal/get-all-drop-down-table-data`,
          {
            method: "POST",
            headers,
            body: formData,
          },
        );
        if (!response.ok) {
          throw new Error("Failed to fetch agent drop-down data");
        }

        const CountryData = await response.json();

        setCountryDropdownTableData(CountryData.rows);
        setShowTableCountry(true);
      } catch (error) {
        console.error("Error fetching country drop-down data:", error);
      }
    } else {
      setShowTableCountry(false);
    }
  };

  const onClickRowCountry = (row) => {
    form.setValue("country", row.UUID);
    form.setValue("countryOfOriginCode", `${row.description}(${row.code})`);

    setCountrySearchTerm("");
    setShowTableCountry(false);
  };

  const filteredCountryData = countryDropdownTableData.filter((item) => {
    const term = countrySearchTerm.toLowerCase();
    return (
      item.code.toLowerCase().includes(term) ||
      item.description.toLowerCase().includes(term)
    );
  });

  if (isMobile) {
    return (
      <>
        <div className="flex flex-col gap-y-4 px-1 py-2.5">
          <h1 className="mt-3 font-bold uppercase text-black">Import & Export Goods</h1>

          {/* First Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">
            {/* Custom Form No 1 */}
            <FormField
              control={form.control}
              name="customFormRefNo1"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Custom Form Ref No.1</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      moduleName="salesInvoice"
                      fieldName="customFormRefNo1"
                      columnName="Custom Form Ref No. 1"
                      placeholder="Custom Form Ref No.1"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Incoterms */}
            <FormField
              control={form.control}
              name="interTradeRule"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Incoterms</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      placeholder="Incoterms"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Second Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">

            {/* Tariff Code */}
            <FormField
              control={form.control}
              name="tariffCode"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Tariff Code</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      placeholder="Tariff Code"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Exporter No */}
            <FormField
              control={form.control}
              name="exporterNo"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Exporter No</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      placeholder="Exporter No"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Third Row */}

          {/* FTA */}
          <FormField
            control={form.control}
            name="FTA"
            render={({ field }) => (
              <FormItem className="flex flex-col">
                <FormLabel className="text-[11px] font-semibold tracking-wider text-black">FTA</FormLabel>
                <FormControl>
                  <Textarea
                    className="!min-h-[80px] px-2 bg-white border border-gray-200 resize-none text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                    {...field}
                    moduleName="salesInvoice"
                    fieldName="FTA"
                    columnName="FTA"
                    placeholder="FTA"
                  />
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />

          {/* Forth Row */}
          <div className="grid grid-cols-2 items-center gap-x-3">
            {/* Custom Form No 2 */}
            <FormField
              control={form.control}
              name="customFormRefNo2"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Custom Form Ref No.2</FormLabel>
                  <FormControl>
                    <Input
                      className="h-10 bg-white border border-gray-200 px-2 text-[11px] rounded-md outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                      {...field}
                      placeholder="Custom Form Ref No.2"
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Country UUID */}
            <FormField
              control={form.control}
              name="country"
              render={({ field }) => (
                <FormItem className="hidden">
                  <FormLabel>UUID:</FormLabel>
                  <FormControl>
                    <Input className="h-7" {...field} readOnly={true} />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Country */}
            <FormField
              control={form.control}
              name="countryOfOriginCode"
              render={({ field }) => (
                <FormItem className="flex flex-col">
                  <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Country</FormLabel>
                  <FormControl>
                    <div className="relative">
                      <Input
                        className="h-10 rounded-md px-2 pr-9 bg-white border border-gray text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                        {...field}
                        onClick={toggleTableCountry}
                        onChange={(e) => {
                          field.onChange(e);
                          setCountrySearchTerm(e.target.value);
                          setShowTableCountry(true);
                        }}
                        // readOnly={true}
                        ref={inputRef}
                        autoComplete="off"
                        placeholder="Country"
                      />
                      <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <FaMagnifyingGlass className="size-3 text-gray-400" />
                      </div>
                      {showTableCountry && (
                        <div
                          ref={dropdownRef}
                          className="absolute bottom-[170px] bg-white border border-gray-200 rounded shadow-md z-50 h-[200px]"
                        >
                          <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                            <DropdownTable
                              columns={dropdownCountryColumns}
                              data={filteredCountryData}
                              onClickRow={onClickRowCountry}
                            />
                          </ScrollArea>
                        </div>
                      )}
                    </div>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Fifth Row */}
          <FormField
            control={form.control}
            name="otherCharges"
            render={({ field }) => (
              <FormItem className="flex flex-col">
                <FormLabel className="text-[11px] font-semibold tracking-wider text-black">Details of other charges</FormLabel>
                <FormControl>
                  <Textarea
                    className="!min-h-[80px] px-2 bg-white border border-gray-200 resize-none text-[11px] outline-none transition-all duration-300 ease-in-out shadow-sm focus-visible:ring-blue-300"
                    {...field}
                    placeholder="Details of other Charges"
                  />
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />
        </div>
      </>)
  }

  return (
    <Form {...form}>
      <form>
        <div className="flex flex-col gap-y-2 pt-1.5">

          {/* First Row */}
          <div className="grid grid-cols-5 items-center gap-x-2">
            {/* Custom Form No 1 */}
            <FormField
              control={form.control}
              name="customFormRefNo1"
              render={({ field }) => (
                <FormItem className="col-span-2">
                  <FormControl>
                    <TooltipProvider delayDuration={1000}>
                      <Tooltip>
                        <TooltipTrigger asChild>
                          <Input
                            className="text-[11px] h-7 px-2 rounded-md transition-all duration-300 ease-in-out outline-none"
                            {...field}
                            moduleName="salesInvoice"
                            fieldName="customFormRefNo1"
                            columnName="Custom Form Ref No. 1"
                            placeholder="Custom Form Ref No. 1"
                          />
                        </TooltipTrigger>
                        <TooltipContent side="top" align="center">
                          Custom Form Ref No. 1
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Incoterms */}
            <FormField
              control={form.control}
              name="interTradeRule"
              render={({ field }) => (
                <FormItem>
                  <FormControl>
                    <TooltipProvider delayDuration={1000}>
                      <Tooltip>
                        <TooltipTrigger asChild>
                          <Input
                            className="text-[11px] h-7 px-2 rounded-md transition-all duration-300 ease-in-out outline-none"
                            {...field}
                            placeholder="Incoterms"
                          />
                        </TooltipTrigger>
                        <TooltipContent side="top" align="center">
                          Incoterms
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Tariff Code */}
            <FormField
              control={form.control}
              name="tariffCode"
              render={({ field }) => (
                <FormItem>
                  <FormControl>
                    <TooltipProvider delayDuration={1000}>
                      <Tooltip>
                        <TooltipTrigger asChild>
                          <Input
                            className="text-[11px] h-7 px-2 rounded-md transition-all duration-300 ease-in-out outline-none"
                            {...field}
                            placeholder="Tariff Code"
                          />
                        </TooltipTrigger>
                        <TooltipContent side="top" align="center">
                          Tariff Code
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Exporter No */}
            <FormField
              control={form.control}
              name="exporterNo"
              render={({ field }) => (
                <FormItem>
                  <FormControl>
                    <TooltipProvider delayDuration={1000}>
                      <Tooltip>
                        <TooltipTrigger asChild>
                          <Input
                            className="text-[11px] h-7 px-2 rounded-md transition-all duration-300 ease-in-out outline-none"
                            {...field}
                            placeholder="Exporter No"
                          />
                        </TooltipTrigger>
                        <TooltipContent side="top" align="center">
                          Exporter No
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Second Row */}
          {/* FTA */}
          <FormField
            control={form.control}
            name="FTA"
            render={({ field }) => (
              <FormItem className="flex flex-col">
                <FormControl>
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <Textarea
                          className="!min-h-[58px] px-2 resize-none text-[11px] transition-all duration-300 ease-in-out outline-none"
                          {...field}
                          moduleName="salesInvoice"
                          fieldName="FTA"
                          columnName="FTA"
                          placeholder="FTA"
                        />
                      </TooltipTrigger>
                      <TooltipContent side="top" align="start">
                        FTA
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />

          <hr></hr>

          {/* Third Row */}
          <div className="grid grid-cols-3 items-center gap-x-2">
            {/* Custom Form No 2 */}
            <FormField
              control={form.control}
              name="customFormRefNo2"
              render={({ field }) => (
                <FormItem className="col-span-2">
                  <FormControl>
                    <TooltipProvider delayDuration={1000}>
                      <Tooltip>
                        <TooltipTrigger asChild>
                          <Input
                            className="text-[11px] h-7 px-2 rounded-md transition-all duration-300 ease-in-out outline-none"
                            {...field}
                            placeholder="Custom Form Ref No. 2"
                          />
                        </TooltipTrigger>
                        <TooltipContent side="top" align="center">
                          Supplier Name
                        </TooltipContent>
                      </Tooltip>
                    </TooltipProvider>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Country UUID */}
            <FormField
              control={form.control}
              name="country"
              render={({ field }) => (
                <FormItem className="hidden">
                  <FormLabel>UUID:</FormLabel>
                  <FormControl>
                    <Input className="h-7" {...field} readOnly={true} />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Country */}
            <FormField
              control={form.control}
              name="countryOfOriginCode"
              render={({ field }) => (
                <FormItem>
                  <FormControl className="relative">
                    <div className="relative">
                      <TooltipProvider delayDuration={1000}>
                        <Tooltip>
                          <TooltipTrigger asChild>
                            <Input
                              className="text-[11px] h-7 px-2 pr-8 rounded-md transition-all duration-300 ease-in-out outline-none"
                              {...field}
                              onClick={toggleTableCountry}
                              onChange={(e) => {
                                field.onChange(e);
                                setCountrySearchTerm(e.target.value);
                                setShowTableCountry(true);
                              }}
                              // readOnly={true}
                              ref={inputRef}
                              autoComplete="off"
                              placeholder="Country"
                            />
                          </TooltipTrigger>
                          <TooltipContent side="top" align="center">
                            Country
                          </TooltipContent>
                        </Tooltip>
                      </TooltipProvider>
                      <div className="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <FaMagnifyingGlass className="size-3 text-gray-400" />
                      </div>
                      {showTableCountry && (
                        <div
                          ref={dropdownRef}
                          className="absolute bottom-[170px] bg-white border border-gray-200 rounded shadow-md z-50 h-[200px]"
                        >
                          <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                            <DropdownTable
                              columns={dropdownCountryColumns}
                              data={filteredCountryData}
                              onClickRow={onClickRowCountry}
                            />
                          </ScrollArea>
                        </div>
                      )}
                    </div>
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />
          </div>

          {/* Forth Row */}
          <FormField
            control={form.control}
            name="otherCharges"
            render={({ field }) => (
              <FormItem className="col-span-5 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                <FormControl>
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <Textarea
                          className="!min-h-[60px] px-2 resize-none text-[11px] transition-all duration-300 ease-in-out outline-none"
                          {...field}
                          placeholder="Details of other Charges"
                        />
                      </TooltipTrigger>
                      <TooltipContent side="top" align="start">
                        Details of other Charges
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
          />
        </div>
      </form>
    </Form>
  );
}