"use client";

import { notFound, useSearchParams } from "next/navigation";
import React, { useEffect, useState } from "react";
import { FaCube, FaMinus, FaPlus } from "react-icons/fa6";

import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import Validity from "@/components/data-table/Validity";
import MobileFormTableActionGroupEnd from "@/components/form/MobileFormTableActionGroupEnd";
// Mobile View (Imports)
import MobileFormTableActionGroupStart from "@/components/form/MobileFormTableActionGroupStart";
import { Button } from "@/components/ui/button";
import { DropdownMenuItem } from "@/components/ui/dropdown-menu";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "@/components/ui/tooltip";
import { TOOLTIP_DELAY_DURATION } from "@/lib/constants";
import { useToast } from "@/components/ui/use-toast";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { IoCloseSharp } from "react-icons/io5";

import ConfirmationDialog from "./ConfirmationDialog";

import type { Table } from "@tanstack/react-table";

type Props<TData> = {
  table: Table<TData>;
  onAdd?: () => void;
  setTempRowSalesInvoiceDetailsListData: (data, overwrite) => void;
  tempRowSalesInvoiceDetailsList: [];
  revalidateSalesInvoiceDetails: any;
  handleOnPackage: () => void;
  isPaid?: boolean;
  slug: string;
  form: any;
  isMobile?: boolean;
  isSelectionMode?: boolean;
  onExitSelectionMode?: () => void;
};

export default function DataTableToolbar<TData>({
  table,
  onAdd,
  setTempRowSalesInvoiceDetailsListData,
  tempRowSalesInvoiceDetailsList,
  revalidateSalesInvoiceDetails,
  handleOnPackage,
  isPaid,
  slug,
  form,
  isMobile,
  isSelectionMode,
  onExitSelectionMode
}: Props<TData>) {
  const searchParams = useSearchParams();
  const id = searchParams.get("id");
  const headers = getAuthHeaders();
  const { toast } = useToast();

  const [showConfirmationDialog, setShowConfirmationDialog] = useState(false);
  const [selectedRow, setSelectedRow] = useState<any[]>([]);

  const eInvoiceStat = form.getValues("eInvoiceStatus");

  const handleDeleteConfirmation = async () => {
    // Perform deletion logic here
    var form_data = new FormData();

    const selectedRows = table.getSelectedRowModel().rows;
    selectedRows.forEach((row, index) => {
      form_data.append(`UUIDs[${index}]`, row.original.UUID);
    });

    const deletedIndex = selectedRows.map((item) => {
      return item.index;
    });

    // Calculate totals from the remaining rows (after deletion)
    const remainingRows = table
      .getRowModel()
      .rows.filter((item, index) => !deletedIndex.includes(index));

    // Calculate total values
    let totalAmount = remainingRows.reduce((sum, row) => {
      return sum + (row.original.amount ? parseFloat(row.original.amount) : 0);
    }, 0);

    let totalDiscount = remainingRows.reduce((sum, row) => {
      return sum + (row.original.discountAmount ? parseFloat(row.original.discountAmount) : 0);
    }, 0);

    let totalDiscount2 = remainingRows.reduce((sum, row) => {
      return sum + (row.original.discountAmount2 ? parseFloat(row.original.discountAmount2) : 0);
    }, 0);

    let totalDiscount3 = remainingRows.reduce((sum, row) => {
      return sum + (row.original.discountAmount3 ? parseFloat(row.original.discountAmount3) : 0);
    }, 0);

    let totalTax = remainingRows.reduce((sum, row) => {
      return sum + (row.original.taxAmount ? parseFloat(row.original.taxAmount) : 0);
    }, 0);

    const finalTotalDiscount = totalDiscount + totalDiscount2 + totalDiscount3;

    const prepaymentAmount = form.getValues("prepaymentAmount");

    // Calculate subtotal tax (this is what should be used for outstanding amount)
    const subtotalTax = totalAmount - finalTotalDiscount + totalTax;
    const roundTotalPayable = Math.round(subtotalTax * 20) / 20;
    const roundTotalPayableAfterPrepayment =
      roundTotalPayable - (prepaymentAmount ? prepaymentAmount : 0);
    const roundingAmount = roundTotalPayable - subtotalTax;

    const totalExclTax = totalAmount - finalTotalDiscount;

    const currentCurrencyRate = form.getValues("currencyRate");

    const localNetTotal = roundTotalPayable * currentCurrencyRate;

    // Add the calculated totals to form data
    form_data.append("salesInvoice[totalAmount]", totalAmount.toFixed(2));
    form_data.append("salesInvoice[totalDiscount]", finalTotalDiscount.toFixed(2));
    form_data.append("salesInvoice[totalTax]", totalTax.toFixed(2));
    form_data.append("salesInvoice[totalSubtotal]", (totalAmount - finalTotalDiscount).toFixed(2));
    form_data.append("salesInvoice[totalPayable]", roundTotalPayableAfterPrepayment.toFixed(2));
    form_data.append(
      "salesInvoice[outstandingAmount]",
      roundTotalPayableAfterPrepayment.toFixed(2),
    );

    form_data.append("salesInvoice[localNetTotal]", localNetTotal.toFixed(2));
    form_data.append("salesInvoice[netTotal]", roundTotalPayable.toFixed(2));
    form_data.append("salesInvoice[roundingAmount]", roundingAmount.toFixed(2));

    form_data.append("salesInvoice[totalNetAmount]", totalExclTax.toFixed(2));
    form_data.append("salesInvoice[totalExclTax]", totalExclTax.toFixed(2));
    form_data.append("salesInvoice[totalInclTax]", subtotalTax.toFixed(2));
    form_data.append(
      "salesInvoice[prepaymentAmount]",
      prepaymentAmount ? prepaymentAmount : "0.00",
    );

    const existingData = table.getFilteredRowModel().rows.map((row) => row.original);
    const maxSeq =
      existingData.length > 0
        ? Math.max(...existingData.map((item) => parseInt(item.seq) || 0))
        : 0;

    const existingDataWithoutUUID = existingData.filter((item) => {
      return item.UUID == "";
    });
    // return false
    // if (id && slug !== "clone") {
    //   try {
    //     const response = await fetch(
    //       `${ORIGIN}/sales_invoice/api/sales-invoice/remove-sales-invoice-has-details?salesInvoiceUUID=${id}`,
    //       {
    //         method: "POST",
    //         headers,
    //         body: form_data,
    //       },
    //     );

    //     if (!response.ok) {
    //       const errorData = await response.json();

    //       if (response.status === 403) {
    //         toast({
    //           title: errorData.message,
    //           duration: 2000,
    //         });
    //       }

    //       throw new Error("Failed to fetch data");
    //     }

    //     const responseData = await response.json();

    //     // if (responseData.RemoveSuccess && responseData.RemoveSuccess.length > 0) {
    //     //   revalidateSalesInvoiceDetails();
    //     // }
    //   } catch (error) {
    //     console.error("Error deleting sales invoice has details data:", error);
    //     // Handle error as needed, display error message to user
    //   }

    //   if (existingDataWithoutUUID.length > 0) {
    //     const deletedIndex = selectedRows.map((item) => {
    //       return item.index;
    //     });
    //     const remainRows = tempRowSalesInvoiceDetailsList.filter(
    //       (item, index) => !deletedIndex.includes(index),
    //     );
    //     if (remainRows.length > 0) {
    //       setTempRowSalesInvoiceDetailsListData(remainRows, true);
    //     } else {
    //       revalidateSalesInvoiceDetails();
    //     }
    //   } else {
    //     revalidateSalesInvoiceDetails();
    //   }

    //   // After deletion, close the confirmation dialog
    //   setShowConfirmationDialog(false);
    // } else {
    // const deletedIndex = selectedRows.map((item) => {
    //   return item.index;
    // });
    const remainRows = tempRowSalesInvoiceDetailsList.filter(
      (item, index) => !deletedIndex.includes(index),
    );



    const resequencedRows = remainRows.map((row, index) => ({
      ...row,
      seq: index + 1,
    }));
    //Voucher logic
    const checkVoucherUsedInRows = resequencedRows.some(row => row.voucher)
    if (!checkVoucherUsedInRows) {
      form.setValue("voucher", "")
      form.setValue("voucherCode", "")
    }


    setTempRowSalesInvoiceDetailsListData(resequencedRows, true);
    setShowConfirmationDialog(false);
    //}
  };

  //Update total selected rows
  useEffect(() => {
    const selected = table.getSelectedRowModel().rows;
    setSelectedRow(selected);
  }, [table.getState().rowSelection, table.getRowModel().rows.length]);

  return (
    <>
      <div className="flex items-center justify-center px-2">
        {/* Web View Action Buttons */}

        {/* Add Button */}
        <div className="flex items-center justify-center gap-x-4 text-erp-blue-14">
          <div className="flex flex-col items-center">
            <TooltipProvider delayDuration={TOOLTIP_DELAY_DURATION}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    className="size-6 hover:text-erp-blue-14 active:bg-erp-blue-14 active:text-white disabled:text-gray-300 disabled:hover:bg-transparent"
                    variant="ghost"
                    size="icon"
                    onClick={onAdd}
                    disabled={isPaid || eInvoiceStat == "Valid" || eInvoiceStat == "Submitted"}
                  >
                    <FaPlus className="size-4" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent className={isPaid || eInvoiceStat == "Submitted" || eInvoiceStat == "Valid" ? "hidden" : "block"}>
                  Add
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Add</span>
          </div>

          {/* Remove */}
          <div className="flex flex-col items-center">
            <TooltipProvider delayDuration={TOOLTIP_DELAY_DURATION}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    className="size-6 hover:text-erp-blue-14 active:bg-erp-blue-14 active:text-white disabled:text-gray-300 disabled:hover:bg-transparent"
                    variant="ghost"
                    size="icon"
                    onClick={() => setShowConfirmationDialog(true)}
                    disabled={isPaid || eInvoiceStat == "Valid" || eInvoiceStat == "Submitted"}
                  >
                    <FaMinus className="size-4" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent className={isPaid || eInvoiceStat == "Submitted" || eInvoiceStat == "Valid" ? "hidden" : "block"}>
                  Remove
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Remove</span>
          </div>

          {/* Package */}
          <div className="flex flex-col items-center">
            <TooltipProvider delayDuration={TOOLTIP_DELAY_DURATION}>
              <Tooltip>
                <TooltipTrigger asChild>
                  <Button
                    className="size-6 hover:text-erp-blue-14 active:bg-erp-blue-14 active:text-white disabled:text-gray-300 disabled:hover:bg-transparent"
                    variant="ghost"
                    size="icon"
                    onClick={handleOnPackage}
                    disabled={isPaid || eInvoiceStat == "Valid" || eInvoiceStat == "Submitted"}
                  >
                    <FaCube className="size-4" />
                  </Button>
                </TooltipTrigger>
                <TooltipContent className={isPaid || eInvoiceStat == "Submitted" || eInvoiceStat == "Valid" ? "hidden" : "block"}>
                  Package
                </TooltipContent>
              </Tooltip>
            </TooltipProvider>
            <span className="text-[11px]/none font-medium text-black">Package</span>
          </div>

          {/* Refresh */}
          <div className="[&_button]:!size-6 [&_svg]:!size-4">
            <Refresh refreshTable={revalidateSalesInvoiceDetails} />
          </div>

          {/* Validity */}
          <div className="[&_button]:!size-6 [&_svg]:!size-4">
            <Validity table={table} />
          </div>

          {/* Column */}
          <div className={isMobile ? "hidden" : "[&_button]:!size-6 [&_svg]:!size-4"}>
            <ColumnVisibilityToggle table={table} />
          </div>

          {/* Selection Mode */}
          {isSelectionMode && (
            <div className="flex flex-col items-center">
              <Button
                variant="ghost"
                size="icon"
                className="size-6 hover:text-erp-blue-14 active:bg-erp-blue-14 active:text-white"
                onClick={onExitSelectionMode}
              >
                <IoCloseSharp className="size-5.5 text-erp-blue-11" />
              </Button>
              <span className="text-[11px]/none font-medium text-black">Cancel</span>
            </div>
          )}
        </div>
      </div>

      <ConfirmationDialog
        open={showConfirmationDialog}
        setOpen={setShowConfirmationDialog}
        onConfirm={handleDeleteConfirmation}
        selectedRows={selectedRow}
      />
    </>
  );
}
