"use client";

import React, { useRef, useEffect, useState } from "react";
import { FaFileCirclePlus, FaCircleXmark, FaMagnifyingGlass } from "react-icons/fa6";

import Link from 'next/link'

import { DATE_FORMAT, getAuthHeaders, ORIGIN } from "@/lib/constants";

import { Textarea } from "@/components/ui/textarea";
import { Input, NumberInputField } from "@/components/ui/input";
import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import { Tab, TabList, TabPanel, Tabs } from "react-tabs";
import { Button } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import { CalendarIcon } from "lucide-react";
import DropdownTable from "@/components/data-table/DropdownTable";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "@/components/ui/tooltip";
import { cn } from "@/lib/utils/cn";
import { HiOutlineClipboardDocumentList } from "react-icons/hi2";
import { IoDocumentOutline } from "react-icons/io5";
import {
  Card,
  CardHeader,
  CardContent,
  CardTitle
} from "@/components/ui/card";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";

// Preference (Define Param)
type Params = {
  tempRowAttachments: any;
  setTempRowAttachments: ([]) => void;
  form: any;
  salesOrderData?: any;
  slug?: string;
  preferenceData?: any;
  onCurrencyChange?: (currencyUUID: string) => void; // Accurate Currency Rate Update
};

type DropdownConfig = {
  tableName: string;
  columns: { accessorKey: string; header: string }[];
  valueField: string;
  displayField: string;
  formValueField: string;
  formDisplayField: string;
  additionalMappings?: { sourceField: string; targetFormField: string }[];
};

// HTML Utility Function
function stripHtml(html) {
  if (!html) return "";
  // Replace <br> and <br/> with newlines
  let text = html.replace(/<br\s*\/?>/gi, '\n');
  // Replace <p> with nothing, </p> with newline
  text = text.replace(/<p[^>]*>/gi, '').replace(/<\/p>/gi, '\n');
  // Remove all other HTML tags
  text = text.replace(/<[^>]+>/g, '');
  // Replace HTML entities
  text = text.replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&');

  return text;
}

export default function MoreDetailsForm({
  tempRowAttachments,
  form,
  setTempRowAttachments,
  salesOrderData,
  slug,
  preferenceData,
  onCurrencyChange // Accurate Currency Rate Update
}: Params) {
  const headers = getAuthHeaders();

  const [dropdownState, setDropdownState] = useState({
    currentDropdown: null as string | null,
    data: [] as any[],
    originalData: [] as any[],
    showTable: false,
  });

  const dropdownInputRef = useRef(null);
  const dropdownTableRef = useRef(null);

  const dropdownConfigs: Record<string, DropdownConfig> = {
    shipper: {
      tableName: "shipper",
      columns: [
        // { accessorKey: "shipperName", header: "shipper" },
        { accessorKey: "shipperCode", header: "Shipper Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "shipperCode",
      formValueField: "shipper",
      formDisplayField: "shipperCode",
    },
  };

  const fetchDropdownData1 = async (dropdownKey: string) => {
    try {
      const config = dropdownConfigs[dropdownKey];

      if (!config) return;

      var form_data = new FormData();

      form_data.append(`table[0]`, config.tableName);

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
        method: "POST",
        headers,
        body: form_data,
      });

      if (!response.ok) {
        throw new Error(`Failed to fetch ${dropdownKey} data`);
      }

      const data = await response.json();

      setDropdownState({
        currentDropdown: dropdownKey,
        data: data.rows,
        originalData: data.rows,
        showTable: true,
      });
    } catch (error) {
      console.error(`Error fetching ${dropdownKey} data:`, error);

      throw new Error(`Failed to fetch ${dropdownKey} data`);
    }
  };

  const onClickRow = (row: any) => {
    const config = dropdownConfigs[dropdownState.currentDropdown!];

    if (config) {
      form.setValue(config.formValueField, row[config.valueField]);
      form.setValue(config.formDisplayField, row[config.displayField]);

      if (config.additionalMappings) {
        config.additionalMappings.forEach((mapping) => {
          if (row[mapping.sourceField]) {
            form.setValue(mapping.targetFormField, row[mapping.sourceField]);
          }
        });
      }
    }

    setDropdownState((prev) => ({ ...prev, showTable: false }));
  };

  const inputRef = useRef(null);

  // Preference (Define Decimal)
  const decimal = preferenceData?.data?.decimal || 2;

  const handleClickOutside = (event) => {
    if (
      dropdownTableRef.current &&
      !dropdownTableRef.current.contains(event.target) &&
      dropdownInputRef.current !== event.target
    ) {
      setDropdownState((prev) => ({ ...prev, showTable: false }));
    }

    if (currencyDropdownRef.current && !currencyDropdownRef.current.contains(event.target) && currencyInputRef.current !== event.target) {
      setShowCurrencyTable(false);
    }

    if (projectDropdownRef.current && !projectDropdownRef.current.contains(event.target) && projectInputRef.current !== event.target) {
      setShowProjectTable(false);
    }

    if (deliveryAddressDropdownRef.current && !deliveryAddressDropdownRef.current.contains(event.target) && deliveryAddressInputRef.current !== event.target) {
      setShowTableDeliveryAddress(false);
    }
  };

  useEffect(() => {
    document.body.addEventListener('click', handleClickOutside);

    return () => {
      document.body.removeEventListener('click', handleClickOutside);
    };
  }, []);

  // Fetch Dropdown Data
  const fetchDropdownData = async (table: string) => {
    try {
      var formData = new FormData;

      formData.append("table[0]", table);

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`,
        {
          method: 'POST',
          headers,
          body: formData,
        });

      if (!response.ok) {
        throw new Error('Failed to fetch dropdown data');
      }

      const data = await response.json();

      if (table == "currency") {
        setCurrencyDropdownData(data.rows);
        setShowCurrencyTable(true);
      } else if (table == "project") {
        setProjectDropdownData(data.rows);
        setShowProjectTable(true);
      }
    } catch (error) {
      console.error('Error fetching dropdown data:', error);

      throw new Error('Failed to fetch dropdown data');
    }
  };

  // Default Currency Function
  const setDefaultCurrency = async () => {
    if (preferenceData?.data?.currency && !form.getValues("currency")) {
      try {
        var formData = new FormData;

        formData.append("table[0]", "currency");

        const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`,
          {
            method: 'POST',
            headers,
            body: formData,
          });

        if (response.ok) {
          const data = await response.json();
          const defaultCurrency = data.rows?.find(row => row.UUID === preferenceData.data.currency);

          if (defaultCurrency) {
            form.setValue("currency", defaultCurrency.UUID);
            form.setValue("currencyCode", defaultCurrency.currencyCode);
            form.setValue("currencyRate", defaultCurrency.exchangeRateSales);
          }
        }
      } catch (error) {
        console.error('Error setting default currency:', error);
      }
    }
  };

  const fillDefaultNote = async () => {
    if (preferenceData?.data?.salesOrderNote && !form.getValues("note")) {
      form.setValue("note", preferenceData.data.salesOrderNote);
    }
  };

  useEffect(() => {
    if (preferenceData?.data?.currency && slug === "new") {
      setDefaultCurrency();
    }

    if (preferenceData?.data?.salesOrderNote && slug === "new") {
      fillDefaultNote();
    }

  }, [preferenceData, slug]);

  // Currency Dropdown
  const [currencyDropdownData, setCurrencyDropdownData] = useState<[]>([]);
  const [showCurrencyTable, setShowCurrencyTable] = useState(false);
  const [currencyFilter, setCurrencyFilter] = useState("");
  const currencyInputRef = useRef(null);
  const currencyDropdownRef = useRef(null);

  const dropdownCurrencyColumns = [
    { accessorKey: "currencyCode", header: "Currency Code" },
    { accessorKey: "description", header: "Description" },
  ];

  const onClickRowCurrency = (row) => {
    form.setValue("currency", row.UUID);
    form.setValue("currencyCode", row.currencyCode);
    form.setValue("currencyRate", row.exchangeRateSales);

    // Accurate Currency Rate Update
    if (onCurrencyChange) {
      onCurrencyChange(row.UUID);
    }

    setShowCurrencyTable(false);
    setCurrencyFilter("");
  };

  // Project Dropdown
  const [projectDropdownData, setProjectDropdownData] = useState<[]>([]);
  const [showProjectTable, setShowProjectTable] = useState(false);
  const [projectFilter, setProjectFilter] = useState("");

  const projectInputRef = useRef(null);
  const projectDropdownRef = useRef(null);

  const dropdownProjectColumns = [
    { accessorKey: "projectCode", header: "Project Code" },
    { accessorKey: "description", header: "Description" },
  ];

  const onClickRowProject = (row) => {
    form.setValue("project", row.UUID);
    form.setValue("projectCode", row.projectCode);

    setProjectFilter("");
    setShowProjectTable(false);
  };

  // Fetch Delivery Address Dropdown Data
  const fetchDropdownDeliveryAddress = async () => {
    const formData = new FormData();
    const customerUUID = form.getValues('customerCode');

    if (!showTableDeliveryAddress) {
      try {
        const response = await fetch(
          `${ORIGIN}/universal/get-customer-has-delivery-location-by-customer?id=${customerUUID}`,
          {
            method: "POST",
            headers,
            body: formData,
          }
        );

        if (!response.ok) {
          throw new Error("Failed to fetch attention drop-down data");
        }

        const deliveryAddressData = await response.json();

        setDeliveryAddressDropdownTableData(deliveryAddressData.rows);
        setShowTableDeliveryAddress(true);
      } catch (error) {
        console.error("Error fetching attention drop-down data:", error);
      }
    } else {
      setShowTableDeliveryAddress(false);
    }
  };

  // Delivery Address Dropdown
  const [showTableDeliveryAddress, setShowTableDeliveryAddress] = useState(false);
  const [deliveryAddressDropdownTableData, setDeliveryAddressDropdownTableData] = useState([]);
  const deliveryAddressInputRef = useRef(null);
  const deliveryAddressDropdownRef = useRef(null);

  const dropdownDeliveryAddressColumns = [
    { accessorKey: "deliveryLocation", header: "Delivery Location", },
    {
      accessorKey: "deliveryAddress", header: "Delivery Address",
      cell: ({ row }) => {
        const address = row.original.deliveryAddress || "";
        const addressStyle = {
          whiteSpace: "pre-wrap",
          wordWrap: "break-word",
        };

        return (
          <span style={addressStyle}>
            {address.length > 50 ? `${address}` : address}
          </span>
        );
      },
    },
    { accessorKey: "description", header: "Remark", cell: ({ row }) => <DescriptionCellTooltip row={row} />, },
  ];

  const onClickRowDeliveryAddress = (row) => {
    form.setValue('deliveryAddress', row.deliveryAddress);

    setShowTableDeliveryAddress(false);
  };

  // File Attachment
  const fileInputRef = useRef(null);

  const handleChooseFileClick = () => {
    fileInputRef.current.click();
  };

  const handleFileChange = (event) => {
    const fileList = Array.from(event.target.files);
    const mergeArray: any = [...tempRowAttachments, ...fileList];

    setTempRowAttachments(mergeArray);
  };

  function handleDeleteFile(index) {
    var newCustomInfoFiles = [...tempRowAttachments];

    newCustomInfoFiles.splice(index, 1);

    setTempRowAttachments(newCustomInfoFiles);
  }

  const handleDropdownSearchChange = (dropdownKey: string, searchTerm: string) => {
    const config = dropdownConfigs[dropdownKey];
    if (!config) return;

    form.setValue(config.formDisplayField, searchTerm);

    if (!dropdownState.originalData || dropdownState.currentDropdown !== dropdownKey) {
      fetchDropdownData1(dropdownKey);
      return;
    }

    const filtered = dropdownState.originalData.filter((row: any) =>
      row[config.displayField]
        ?.toString()
        .toLowerCase()
        .includes(searchTerm.toLowerCase())
    );

    setDropdownState((prev) => ({
      ...prev,
      data: filtered,
      showTable: true,
      currentDropdown: dropdownKey,
    }));
  };

  return (
    <Form {...form}>
      <form>
        <Tabs>
          <div className="flex">
            {/* Left Container*/}
            <div className="min-w-0 flex-1">
              {/* General Details*/}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">General Details</div>
                </div>

                <div className="flex flex-col gap-y-2.5 pt-1.5">

                  {/* First Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Currency UUID */}
                    <FormField
                      control={form.control}
                      name="currency"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Currency UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Currency Code */}
                    <FormField
                      control={form.control}
                      name="currencyCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 rounded-md px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      onClick={() => fetchDropdownData("currency")}
                                      onChange={(e) => {
                                        field.onChange(e);
                                        setCurrencyFilter(e.target.value);
                                      }}
                                      ref={currencyInputRef}
                                      autoComplete="off"
                                      moduleName="quotation"
                                      fieldName="currencyCode"
                                      columnName="Currency Code"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Currency Code</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                              </div>
                              {showCurrencyTable && (
                                <div
                                  ref={currencyDropdownRef}
                                  className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownCurrencyColumns}
                                      data={currencyDropdownData}
                                      onClickRow={onClickRowCurrency}
                                      filterValue={currencyFilter}
                                      filterColumn="currencyCode"
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Currency rate */}
                    <FormField
                      control={form.control}
                      name="currencyRate"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <NumberInputField
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    form={form}
                                    fieldName="currencyRate"
                                    value={field.value || ""}
                                    decimalPlaces={decimal}
                                    constUpdate={true}
                                    placeholder="Currency Rate"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Currency Rate</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Second Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* Project UUID */}
                    <FormField
                      control={form.control}
                      name="project"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Project UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Project */}
                    <FormField
                      control={form.control}
                      name="projectCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 rounded-md px-2 pr-8 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      onClick={() => fetchDropdownData("project")}
                                      onChange={(e) => {
                                        field.onChange(e);
                                        setProjectFilter(e.target.value);
                                      }}
                                      ref={projectInputRef}
                                      autoComplete="off"
                                      moduleName="quotation"
                                      fieldName="projectCode"
                                      columnName="Project"
                                      placeholder="Project"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Project</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                                {/* Using the search icon */}
                              </div>
                              {showProjectTable && (
                                <div
                                  ref={projectDropdownRef}
                                  className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownProjectColumns}
                                      data={projectDropdownData}
                                      onClickRow={onClickRowProject}
                                      filterValue={projectFilter}
                                      filterColumn="projectCode"
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Validity Days */}
                    <FormField
                      control={form.control}
                      name="docValidity"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    {...field}
                                    onChange={(e) => {
                                      form.setValue(
                                        "docValidity",
                                        e.target.value.replace(/[^0-9]/g, ""),
                                      );
                                    }}
                                    moduleName="quotation"
                                    fieldName="docValidity"
                                    columnName="Doc. Validity Days"
                                    placeholder="Doc Validity Days"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Doc Validity Days</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                  {/* Third Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* Shipper UUID */}
                    <FormField
                      control={form.control}
                      name="shipper"
                      render={({ field }) => (
                        <FormItem className="hidden">
                          <FormLabel>Shipper UUID:</FormLabel>
                          <FormControl>
                            <Input className="h-7.5" {...field} />
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Shipper */}
                    <FormField
                      control={form.control}
                      name="shipperCode"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <div className="relative">
                              <TooltipProvider delayDuration={1000}>
                                <Tooltip>
                                  <TooltipTrigger asChild>
                                    <Input
                                      className="h-7.5 rounded-md px-2 pr-8 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                      {...field}
                                      // readOnly
                                      onChange={(e) =>
                                        handleDropdownSearchChange("shipper", e.target.value)
                                      }
                                      onClick={() => fetchDropdownData1("shipper")}
                                      ref={
                                        dropdownState.currentDropdown === "shipper"
                                          ? dropdownInputRef
                                          : null
                                      }
                                      autoComplete="off"
                                      placeholder="Shipper"
                                    />
                                  </TooltipTrigger>
                                  <TooltipContent>Shipper</TooltipContent>
                                </Tooltip>
                              </TooltipProvider>
                              <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <FaMagnifyingGlass className="size-3 text-gray-400" />
                              </div>
                              {dropdownState.showTable &&
                                dropdownState.currentDropdown === "shipper" && (
                                  <div
                                    ref={dropdownTableRef}
                                    className="absolute bottom-[170px] z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                  >
                                    <ScrollArea className="h-[50cqh] bg-erp-gray-3">
                                      <DropdownTable
                                        columns={dropdownConfigs.shipper.columns}
                                        data={dropdownState.data}
                                        onClickRow={onClickRow}
                                      />
                                      <ScrollBar orientation="vertical" />
                                    </ScrollArea>
                                  </div>
                                )}
                            </div>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />

                    {/* Delivery Terms */}
                    <FormField
                      control={form.control}
                      name="deliveryTerm"
                      render={({ field }) => (
                        <FormItem>
                          <FormControl>
                            <TooltipProvider delayDuration={1000}>
                              <Tooltip>
                                <TooltipTrigger asChild>
                                  <Input
                                    className="h-7.5 rounded-md px-2 text-left text-[11px] outline-none transition-all duration-300 ease-in-out"
                                    {...field}
                                    moduleName="quotation"
                                    fieldName="deliveryTerm"
                                    columnName="Delivery Terms"
                                    placeholder="Delivery Terms"
                                  />
                                </TooltipTrigger>
                                <TooltipContent>Delivery Terms</TooltipContent>
                              </Tooltip>
                            </TooltipProvider>
                          </FormControl>
                          <FormMessage />
                        </FormItem>
                      )}
                    />
                  </div>

                </div>
              </TabPanel>

              {/* Mapping Reference */}
              <TabPanel
                forceRender
                className="hidden"
                selectedClassName="react-tabs__tab-panel--selected"
              >
                <div className="flex w-full items-center justify-between px-0.5 pt-1.5">
                  <div className="text-sm font-bold">Mapping Reference</div>
                </div>

                <div className="flex flex-col gap-y-2.5 pt-1.5">

                  {/* First Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* QT No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("quotation") && form.getValues("quotationNo") ? (
                          (() => {
                            const basePath = "/sales/quotation"
                            const quotationID = form.getValues("quotation");
                            const quotationNo = form.getValues("quotationNo");

                            return (
                              <Link
                                href={`${basePath}/edit?item=${quotationNo}&id=${quotationID}`}
                                target="_blank"
                                className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                title="QT No"
                              >
                                {quotationNo}
                              </Link>
                            );
                          })()
                        ) : (
                          <span className="text-muted-foreground">QT No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>

                    {/* JO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("jobOrderNo")?.length > 0 ? (
                          form.getValues("jobOrderNo")?.map((doc, index, array) => (
                            <Link
                              key={doc.UUID}
                              href={`/job-management/job-order/edit?item=${doc.docNo}&id=${doc.UUID}`}
                              target="_blank"
                              className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                              title="JO No"
                            >
                              {doc.docNo}{index < array.length - 1 ? ", " : ""}
                            </Link>)
                          )) : (
                          <span className="text-muted-foreground">JO No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Second Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* DO No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("deliveryOrderNo")?.length > 0 ? (
                          form.getValues("deliveryOrderNo").split(", ").map((entry, index, array) => {
                            if (index % 2 === 0) {
                              const docNo = entry;
                              const id = array[index + 1];
                              const basePath = "/sales/sales-delivery-order";

                              return (
                                <Link
                                  key={id}
                                  href={`${basePath}/edit?item=${docNo}&id=${id}`}
                                  target="_blank"
                                  className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                  title="DO No"
                                >
                                  {docNo}{index < array.length - 2 ? ", " : ""}
                                </Link>
                              );
                            }
                            return null;
                          })
                        ) : (
                          <span className="text-muted-foreground">DO No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>

                    {/* INV No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("salesInvoiceNo")?.length > 0 ? (
                          form.getValues("salesInvoiceNo")?.map((doc, index, array) => (
                            <Link
                              key={doc.UUID}
                              href={`/sales/sales-invoice/edit?item=${doc.docNo}&id=${doc.UUID}`}
                              target="_blank"
                              className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                              title="INV No"
                            >
                              {doc.docNo}{index < array.length - 1 ? ", " : ""}
                            </Link>)
                          )) : (
                          <span className="text-muted-foreground">INV No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Third Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">

                    {/* CS No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("cashSalesNo")?.length > 0 ? (
                          form.getValues("cashSalesNo").split(", ").map((entry, index, array) => {
                            if (index % 2 === 0) {
                              const docNo = entry;
                              const id = array[index + 1];
                              const basePath = "/sales/cash-sales"

                              return (
                                <Link
                                  key={id}
                                  href={`${basePath}/edit?item=${docNo}&id=${id}`}
                                  target="_blank"
                                  className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                  title="CS No"
                                >
                                  {docNo}{index < array.length - 2 ? ", " : ""}
                                </Link>
                              );
                            }
                            return null;
                          })
                        ) : (
                          <span className="text-muted-foreground">CS No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>

                    {/* DN No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("salesDebitNoteNo")?.length > 0 ? (
                          form.getValues("salesDebitNoteNo")?.map((doc, index, array) => (
                            <Link
                              key={doc.UUID}
                              href={`/sales/sales-debit-note/edit?item=${doc.docNo}&id=${doc.UUID}`}
                              target="_blank"
                              className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                              title="DN No"
                            >
                              {doc.docNo}{index < array.length - 1 ? ", " : ""}
                            </Link>)
                          )) : (
                          <span className="text-muted-foreground">DN No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>
                  </div>

                  {/* Forth Row */}
                  <div className="grid grid-cols-2 items-center gap-x-2">
                    {/* OR No */}
                    <div className="flex flex-col text-nowrap">
                      <ScrollArea className="flex h-7.5 flex-col rounded-md border border-input bg-erp-blue-4 px-2 pt-[6px] text-[11px] font-normal">
                        {form.getValues("customerPaymentNo")?.length > 0 ? (
                          form.getValues("customerPaymentNo").split(", ").map((entry, index, array) => {
                            if (index % 2 === 0) {
                              const docNo = entry;
                              const id = array[index + 1];
                              const basePath = "/sales/customer-payment"

                              return (
                                <Link
                                  key={id}
                                  href={`${basePath}/edit?item=${docNo}&id=${id}`}
                                  target="_blank"
                                  className="text-[11px] text-blue-600 hover:text-blue-800 hover:underline"
                                  title="OR No"
                                >
                                  {docNo}{index < array.length - 2 ? ", " : ""}
                                </Link>
                              );
                            }
                            return null;
                          })
                        ) : (
                          <span className="text-muted-foreground">OR No</span>
                        )}
                        <ScrollBar
                          orientation="horizontal"
                          className="h-1.5"
                        />
                      </ScrollArea>
                    </div>

                    {/* UUID */}
                    <div className="flex flex-1 flex-col text-nowrap">
                      <FormField
                        control={form.control}
                        name="UUID"
                        render={({ field }) => (
                          <FormItem
                            className={`flex flex-col space-y-1 ${slug === "clone" ? "hidden" : ""}`}
                          >
                            <FormControl className="relative">
                              <Input
                                className="h-7.5 rounded-md px-2 text-[11px] outline-none transition-all duration-300 ease-in-out"
                                {...field}
                                readOnly={true}
                                ref={inputRef}
                                autoComplete="off"
                                placeholder="UUID"
                                title="UUID"
                              />
                            </FormControl>
                            <FormMessage />
                          </FormItem>
                        )}
                      />
                    </div>
                  </div>
                </div>
              </TabPanel>
            </div>

            {/* Right - Vertical TabList */}
            <TabList className="ml-1 flex flex-col gap-y-1">
              {[
                {
                  icon: <IoDocumentOutline className="size-4.5" />,
                  label: "General Details",
                },
                {
                  icon: <HiOutlineClipboardDocumentList className="size-4.5" />,
                  label: "Mapping Reference",
                }
              ].map((item, index) => (
                <Tab
                  key={index}
                  className="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-y-0.5 rounded-md border border-gray-200 bg-white text-[9px] text-gray-600 outline-none transition-all duration-200 ease-in-out"
                  selectedClassName="!bg-blue-300 border-blue-300 text-white"
                >
                  <TooltipProvider delayDuration={1000}>
                    <Tooltip>
                      <TooltipTrigger asChild>
                        <span className="flex h-full w-full items-center justify-center">
                          {item.icon}
                        </span>
                      </TooltipTrigger>
                      <TooltipContent side="right" align="start">
                        {item.label}
                      </TooltipContent>
                    </Tooltip>
                  </TooltipProvider>
                </Tab>
              ))}
            </TabList>
          </div>
        </Tabs>
      </form >
    </Form >
  );
}