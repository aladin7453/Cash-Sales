"use client";

import type { ColumnDef } from "@tanstack/react-table";

export type SalesPriceHistoryReport = {
  UUID?: string;
  docDateFormat?: string;
  docNo?: string;
  itemCode?: string;
  itemType?: string;
  customerName?: string;
  quantity?: string;
  itemUOM?: string;
  price?: string;
  totalDiscountAmount?: string;
  subtotalTax?: string;
};

// Helper to format decimals
const formatDecimal = (value: any) => {
  if (value === undefined || value === null || value === "") return "0.00";

  const num = parseFloat(value);

  return isNaN(num) ? "0.00" : num.toFixed(2);
};

export const salesPriceHistoryColumns: ColumnDef<SalesPriceHistoryReport>[] = [
  {
    accessorKey: "rowNumber",
    id: "rowNumber",
    header: "No",
    cell: ({ table, row }) => {
      const { pageIndex, pageSize } = table.getState().pagination;
      return pageIndex * pageSize + row.index + 1;
    },
    enableSorting: false,
    enableColumnFilter: false,
    minSize: 60,
    maxSize: 80,
  },
  {
    accessorKey: "docDateFormat",
    id: "docDateFormat",
    header: "Date",
    filterFn: "includesString",
    enableColumnFilter: false,
    minSize: 100,
    maxSize: 150,
  },
  {
    accessorKey: "docNo",
    id: "docNo",
    header: "Doc No",
