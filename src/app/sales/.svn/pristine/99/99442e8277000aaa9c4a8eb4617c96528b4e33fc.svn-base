"use client";

import { useState } from "react";
import { ColumnDef } from "@tanstack/react-table";
import { FaListUl } from "react-icons/fa";
import { Button } from "@/components/ui/button";
import DetailsPopover from "./detailsPopover";
import { format } from "date-fns";

export type ChangelogItem = {
  UUID: string;
  action: string;
  customerCategory: string;
  createdAtFormat: string;
  createdByUsername: string;
  _version: string;
  _actionUUID: string;
  historyUUID: string;
};

export const changelogColumns: ColumnDef<ChangelogItem>[] = [
  {
    accessorKey: "createdAtFormat",
    header: "Date",
    cell: ({ row }) => {
      const date = row.getValue("createdAtFormat") as string;
      return date || "-";
    },
  },
  {
    accessorKey: "createdByUsername",
    header: "User",
  },
  {
    accessorKey: "action",
    header: "Action",
  },
  {
    accessorKey: "customerCategoryCode", // Default fallback - will be overridden by tab-specific referenceField
    header: "Reference",
    cell: ({ row }) => {
      const value = row.getValue("customerCategoryCode") as string;
      return value || "-";
    },
  },
  {
    accessorKey: "",
    header: "Details",
    // The cell implementation will be replaced in DataTable.tsx
  },
];
