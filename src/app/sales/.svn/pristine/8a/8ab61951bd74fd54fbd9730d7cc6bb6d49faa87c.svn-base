import React from 'react';
import { Separator } from "@/components/ui/separator";

type PODTabProps = {
  jobAssignmentData?: any;
  selectedPoint: string | null;
  handleSelectPoint: (item: string) => void;
};

const PODTab = ({ jobAssignmentData, selectedPoint, handleSelectPoint }: PODTabProps) => {
  return (
    <div>
      <div className="p-2 text-left flex flex-col md:grid md:grid-cols-4 gap-0.5 ml-4">
        <div>
          <span className="font-bold text-erp-blue-11">{jobAssignmentData.parentJobID}</span>
          {jobAssignmentData.jobID && (
            <>
              {' : '}
              <span className="text-blue-500">{jobAssignmentData.jobID}</span>
            </>
          )}
        </div>
        <div
          className={`inline-block cursor-pointer ${
            selectedPoint === 'Starting Point' ? 'text-blue-500 border-b-2 border-blue-500' : 'text-gray-500'
          } text-center`}
          onClick={() => handleSelectPoint('Starting Point')}
        >
          Starting Point
        </div>
        <div
          className={`inline-block cursor-pointer ${
            selectedPoint === 'Pickup Point' ? 'text-blue-500 border-b-2 border-blue-500' : 'text-gray-500'
          } text-center`}
          onClick={() => handleSelectPoint('Pickup Point')}
        >
          Pickup Point
        </div>
        <div
          className={`inline-block cursor-pointer ${
            selectedPoint === 'Delivery Point' ? 'text-blue-500 border-b-2 border-blue-500' : 'text-gray-500'
          } text-center`}
          onClick={() => handleSelectPoint('Delivery Point')}
        >
          Delivery Point
        </div>
      </div>
      <Separator className="bg-erp-gray-3" style={{ height: '2px' }} />
    </div>
  );
};

export default PODTab;
