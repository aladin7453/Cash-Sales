"use client";

import { Table } from "@tanstack/react-table";
import React, { useEffect, useState } from "react";

import CloneButton from "@/components/data-table/ActionButton/Clone";
import DeleteButton from "@/components/data-table/ActionButton/Delete";
import EditButton from "@/components/data-table/ActionButton/Edit";
import NewButton from "@/components/data-table/ActionButton/New";
import PreviewButton from "@/components/data-table/ActionButton/Preview";
import RestoreButton from "@/components/data-table/ActionButton/Restore";
import TrashButton from "@/components/data-table/ActionButton/Trash";
import ColumnVisibilityToggle from "@/components/data-table/ColumnVisibilityToggle";
import Export from "@/components/data-table/Export";
import MobileActionGroupEnd from "@/components/data-table/MobileActionGroupEnd";
import MobileActionGroupStart from "@/components/data-table/MobileActionGroupStart";
import { Pagination } from "@/components/data-table/Pagination";
import Refresh from "@/components/data-table/Refresh";
import Validity from "@/components/data-table/Validity";
// Mobile View (Imports)
import { DropdownMenuItem } from "@/components/ui/dropdown-menu";

import { CustomerPayment } from "./columns";

import type { VisibilityState } from "@tanstack/react-table";

// Server-Side Filtering (Add totalNumOfRows)
type Props = {
  table: Table<CustomerPayment>;
  refreshTable: any;
  totalNumOfRows?: number;
  defaultColumns?: VisibilityState;
  dataStatusBadgeDisplay?: React.ReactNode;
  onResetColumnOrdering?: () => void;
};

export default function CustomerPaymentDataTableToolbar({
  table,
  refreshTable,
  totalNumOfRows,
  defaultColumns,
  dataStatusBadgeDisplay,
  onResetColumnOrdering,
}: Props) {
  return (
    <div className="flex items-center justify-between p-1.5">
      <ActionGroupStart table={table} refreshTable={refreshTable} />

      {/* Mobile View (Hide Pagination) */}
      <div className="hidden md:block">
        {/* Server-Side Filtering (Pass totalNumOfRows) */}
        <Pagination table={table} totalNumOfRows={totalNumOfRows} />
      </div>

      <ActionGroupEnd
        table={table}
        refreshTable={refreshTable}
        defaultColumns={defaultColumns}
        dataStatusBadgeDisplay={dataStatusBadgeDisplay}
        onResetColumnOrdering={onResetColumnOrdering}
      />
    </div>
  );
}

function ActionGroupStart({ table, refreshTable }: Props) {
  const [selectedRow, setSelectedRow] = useState<any>(null);

  const selectedRowModel = table.getSelectedRowModel();

  useEffect(() => {
    if (selectedRowModel.rows.length === 1) {
      setSelectedRow(selectedRowModel.rows[0]);
    } else {
      setSelectedRow(null);
    }
  }, [selectedRowModel]);

  // Mobile View (States)
  const [dropdownOpen, setDropdownOpen] = useState(false);

  return (
    <div className="flex flex-wrap items-center justify-start gap-x-2 p-1">
      {/* Mobile View (Start Menu) */}
      <MobileActionGroupStart
        table={table}
        refreshTable={refreshTable}
        config={{
          newDestination: "/sales/customer-payment/new",
          editDestination: (row) => `/sales/customer-payment/edit?item=${row.docNo}&id=${row.UUID}`,
          cloneDestination: (row) => `/sales/customer-payment/clone?id=${row.UUID}`,
          module: "customer_payment",
          model: "customer-payment",
        }}
      >
        {/* Additional Actions (Other than New, Edit, Clone, Trash, Restore, Delete) */}
        <DropdownMenuItem onSelect={(e) => e.preventDefault()}>
          <div onClick={() => setDropdownOpen(false)}>
            <PreviewButton
              table={table}
              previewType={"CUSTOMER PAYMENT"}
              module={"customer_payment"}
              model={"customer-payment"}
              doc_id={selectedRow ? selectedRow.original.UUID : ""}
              refreshTable={refreshTable}
            />
          </div>
        </DropdownMenuItem>
      </MobileActionGroupStart>

      {/* Web View (Menu) */}
      <div className="hidden flex-wrap items-center justify-start gap-x-2 md:flex">
        <NewButton destination="/sales/customer-payment/new" />
        <EditButton
          table={table}
          destination={`/sales/customer-payment/edit?item=${
            selectedRow ? selectedRow.original.docNo : ""
          }&id=${selectedRow ? selectedRow.original.UUID : ""}`}
        />
        <CloneButton
          table={table}
          destination={`/sales/customer-payment/clone?id=${
            selectedRow ? selectedRow.original.UUID : ""
          }`}
        />
        <TrashButton
          table={table}
          module={"customer_payment"}
          model={"customer-payment"}
          refreshTable={refreshTable}
        />
        <RestoreButton
          table={table}
          module={"customer_payment"}
          model={"customer-payment"}
          refreshTable={refreshTable}
        />
        <DeleteButton
          table={table}
          module={"customer_payment"}
          model={"customer-payment"}
          refreshTable={refreshTable}
        />
        <PreviewButton
          table={table}
          previewType={"CUSTOMER PAYMENT"}
          module={"customer_payment"}
          model={"customer-payment"}
          doc_id={selectedRow ? selectedRow.original.UUID : ""}
          refreshTable={refreshTable}
        />
      </div>
    </div>
  );
}

function ActionGroupEnd({
  table,
  refreshTable,
  defaultColumns,
  dataStatusBadgeDisplay,
  onResetColumnOrdering,
}: Props) {
  return (
    <div className="relative flex items-center gap-x-1 pr-1.5 text-erp-blue-14">
      {/* Web View (End Menu) */}
      <span className="absolute-left-32 hidden md:flex">{dataStatusBadgeDisplay}</span>
      <div className="hidden items-center gap-x-1 md:flex">
        <Export table={table} module={"customerPayment"} mainModule={"sales"} />
        <Refresh refreshTable={refreshTable} resetRowSelection={() => table.resetRowSelection()} />
        <Validity table={table} />
        <ColumnVisibilityToggle
          table={table}
          defaultColumns={defaultColumns}
          onResetColumnOrdering={onResetColumnOrdering}
        />
      </div>

      {/* Mobile View (Search and Sort) */}
      <MobileActionGroupEnd
        table={table}
        config={{
          searchColumn: "docNo",
          searchPlaceholder: "Search Doc No.",
          sortColumn: "docNo",
        }}
      />
    </div>
  );
}
