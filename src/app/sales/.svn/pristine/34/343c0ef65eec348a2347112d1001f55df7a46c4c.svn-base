import { useRouter, useSearchParams } from "next/navigation";
import { useEffect } from "react";

import CancelButton from "@/components/form/ActionButton/Cancel";
import CloneButton from "@/components/form/ActionButton/Clone";
import DeleteButton from "@/components/form/ActionButton/Delete";
import NewButton from "@/components/form/ActionButton/New";
import ResetButton from "@/components/form/ActionButton/Reset";
import SaveButton from "@/components/form/ActionButton/Save";
import { Checkbox } from "@/components/ui/checkbox";
import { Form, FormControl, FormField, FormItem, FormLabel } from "@/components/ui/form";

// Mobile View (Imports)
import MobileFormActionGroup from "@/components/form/MobileFormActionGroup";
import { DropdownMenuItem } from "@/components/ui/dropdown-menu";

import type { AutoBillingConfig } from "../columns";

type TopActionBarProps = {
  autoBillingConfig?: AutoBillingConfig | null;
  form: any;
  handleSubmit: () => void;
  // resetForm: () => void;
  // onSubmit: (values: any) => void;
  // tempRowCustomInfo: [];
  action: string;
  params: any;
};

export default function TopActionBar({
  autoBillingConfig,
  form,
  handleSubmit,
  action,
  params
}: TopActionBarProps) {
  const router = useRouter();
  const searchParams = useSearchParams();
  const id = searchParams.get("id");

  useEffect(() => {
    form.reset(autoBillingConfig || {});
  }, [autoBillingConfig, form]);

  const handleReset = () => {
    const excludedKeys = ['account', 'accountName', '_actionUUID', '_version', 'UUID', 'company', 'companyName'];
    if(params.slug=="new"){//new reset all to empty
      const defaultValues = Object.keys(form.getValues()).reduce((acc, key) => {
        const originalValue = form.getValues(key); // Get the original value
        
        if (!excludedKeys.includes(key)) {
          acc[key] = ''; // Reset to an empty string
        } else {
          acc[key] = originalValue; // Keep the original value
        }
        return acc;
      }, {});
      defaultValues.valid='1'
      form.reset(defaultValues)
    }else{//reset back to previous data
        form.reset();
  
    }
  
  };

  const handleSave = async () => {
    handleSubmit();
  };

  return (
    <div className="-mx-2 -mt-1 flex items-center justify-between bg-erp-gray-3 px-4 py-2">
      <div className="flex space-x-3">
        {/* Mobile View (Action Buttons) */}
        <MobileFormActionGroup
          config={{
            onSave: handleSave,
            onReset: handleReset,
            onCancel: () => router.push(`/sales/auto-billing-config/`),
            newDestination: "/sales/auto-billing-config/new",
            cloneDestination: `/sales/auto-billing-config/clone?id=${id}`,
            deleteConfig: id && action !== "clone" ? {
              module: "auto_billing_config",
              model: "auto-billing-config", 
              id: `${id}`,
              indexPath: `/sales/auto-billing-config/`
            } : undefined,
            showNew: !!(id && action !== "clone"),
            showClone: !!(id && action !== "clone"),
            showDelete: !!(id && action !== "clone"),
          }}
        >
          {/* Additional Actions (Other than Save, New, Clone, Reset, Delete, and Cancel) */}
        </MobileFormActionGroup>

        {/* Web View (Action Buttons) */}
        <div className="hidden md:flex space-x-3">
          <SaveButton onSubmit={handleSave} />
          {id && action !== "clone" && <NewButton destination="/sales/auto-billing-config/new" />}
          {id && action !== "clone" && (
            <CloneButton destination={`/sales/auto-billing-config/clone?id=${id}`} />
          )}
          <ResetButton onClick={handleReset} />
          {id && action !== "clone" && (
            <DeleteButton
              module={"auto_billing_config"}
              model={"auto-billing-config"}
              id={`${id}`}
              indexPath={`/sales/auto-billing-config/`}
            />
          )}
          <CancelButton onClick={() => router.push(`/sales/auto-billing-config/`)} />
        </div>
      </div>
      <Form id="topActionBarForm" {...form}>
        <FormField
          control={form.control}
          name="valid"
          render={({ field }) => (
            <FormItem className="flex items-center gap-x-2 space-y-0">
              <FormControl>
                <Checkbox
                  checked={field.value === "1"}
                  onCheckedChange={(state) => field.onChange(state ? "1" : "0")}
                />
              </FormControl>
              <FormLabel>Valid</FormLabel>
            </FormItem>
          )}
        />
      </Form>
    </div>
  );
}
