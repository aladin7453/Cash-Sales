    header: "Validity",
    cell: ({ row }) => {
      const validity = row.getValue("valid") as SalesInvoice["valid"];
      return validity === "1" ? "Valid" : "Invalid";
    },
    filterFn: "includesString",
  },
];

export const columns: ColumnDef<SalesInvoice>[] = rawColumns.map(
  (col) => {
    if (typeof col.header === "string") {
      const sizes = autoWordSize(col.header);

      return {
        ...col,
        sizes,
        size: sizes, // 👈 applied automatically
        minSize: 50
      };
    }

    return col;
  }
);