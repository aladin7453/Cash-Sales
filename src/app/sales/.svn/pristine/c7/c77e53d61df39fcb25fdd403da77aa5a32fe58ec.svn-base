"use client";

import React, { useState, useEffect } from 'react'
import { Input } from "@/components/ui/input";
import { cn } from "@/lib/utils/cn";

export default function AutoBillingYearFilter({ yearFilterValues, setYearFilterValues }) {
  const [inputValue, setInputValue] = useState(yearFilterValues.join(","))

  const changeHandler = (e) => {
    setInputValue(e.target.value.replace(/[^0-9,]/g, ""))
  }

  useEffect(() => {
    let tempArray = new Array(0)
    inputValue.split(",").forEach((year) => {
      if (year.length > 0) tempArray.push(year)
    })
    setYearFilterValues(tempArray)
  }, [inputValue])

  return (
    <div className="flex flex-row space-x-2 px-2 pr-8">
      <p className="w-28 text-center">Billing Year</p>
      <p>:</p>
      <Input 
      className={cn(
        "h-5.5 w-52",
        !(yearFilterValues) && "text-muted-foreground",
      )}
      value={inputValue}
      onChange={changeHandler}
      placeholder={inputValue ? "" : "Type in a Year Filter"} />
    </div>
  )
}