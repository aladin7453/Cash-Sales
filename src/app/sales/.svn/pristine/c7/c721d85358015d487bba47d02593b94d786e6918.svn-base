"use client";

import React, { useEffect, useState, useRef } from "react";
import { useForm } from "react-hook-form";
import { FaClipboard, FaLayerGroup, FaObjectUngroup } from "react-icons/fa6";

import { z } from "zod";
import { zodResolver } from "@hookform/resolvers/zod";

import { notFound, useRouter, useSearchParams } from "next/navigation";
import { Form } from "@/components/ui/form";
import useSWR from "swr";

import { useToast } from "@/components/ui/use-toast";
import LoadingUI from "@/components/LoadingUI";
import { ScrollArea } from "@/components/ui/scroll-area";
import { TabsNavigator } from "@/components/ui/TabsNavigator";
import { getFileToBase64 } from "@/lib/utils/commonFunction";
import {
  ORIGIN,
  getAuthHeaders,
  getCurrentAcc,
  getCurrentAccount,
  getCurrentCompany,
  getCurrentCompanyUUID,
  removeKeys
} from "@/lib/constants";
import { AutoBillingConfigForm } from "./main-details/general-details/AutoBillingConfigForm";
import TopActionBar from "./TopActionBar";

type PageParams = {
  params: { slug: string };
};

const validRoutes = ["new", "edit", "clone"] as const;

const fetcher = async (url: string) => {
  const headers = getAuthHeaders();

  return fetch(url, { headers }).then((res) => {
    if (!res.ok) {
      throw new Error("Failed to fetch data");
    }
    return res.json();
  });
};

type ValidRoute = (typeof validRoutes)[number];

const autoBillingConfigFormSchema = z.object({
  // accountName: z.union([z.string(), z.literal("")]).optional(),
  // company: z.union([z.string(), z.literal("")]).optional(),
  // companyName: z.union([z.string(), z.literal("")]).optional(),
  // // autoBillingConfigCode: z.string().min(2, {
  // //   message: "Customer Group Code must be at least 2 characters.",
  // // }),
  // autoBillingConfigName: z.string().min(2, {
  //   message: "Customer Group Name is required and must be at least 2 characters.",
  // }),
});

function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

const tabs = [
  {
    id: "mainDetails",
    name: "Main Details",
    icon: FaClipboard,
    shortName: "Main",
  },
  // {
  //   id: "moreDetails",
  //   name: "More Details",
  //   icon: FaLayerGroup,
  //   shortName: "More",
  // },
  // {
  //   id: "authorizedLocation",
  //   name: "Authorized Location",
  //   icon: FaObjectUngroup,
  //   shortName: "Auth",
  // },
];

export default function AutoBillingConfigDetailsPage({ params }: PageParams) {
  const headers = getAuthHeaders();
  const router = useRouter();
  const searchParams = useSearchParams();

  const id = searchParams.get("id");

  const { toast } = useToast();

  const slug = params.slug;

  const [autoBillingConfigData, setAutoBillingConfigData] = useState({});
  
  const [tempRowCustomInfo, setTempRowCustomInfo] = useState([]);
  const [tempRowAuthorizedUser, setTempRowAuthorizedUser] = useState([]);

  const [formResetKey, setFormResetKey] = useState(0);
  const [isSaving, setIsSaving] = useState(false);

  const currentAccountUUID = getCurrentAccount();
  const currentAccountName = getCurrentAcc();
  const currentCompanyUUID = getCurrentCompanyUUID();
  const currentCompanyName = getCurrentCompany();

  const mainDetailsRef = useRef(null);

  const [tempRowQuotationDetailsList, setTempRowQuotationDetailsList] = useState([]);

  const resetForm = () => {
    setFormResetKey((prevKey) => prevKey + 1);
  };

  if (!isValidRoute(slug)) {
    notFound();
  }

  const {
    data: autoBillingConfig,
    error,
    isLoading,
    isValidating,
    mutate: mutateAutoBillingConfig,
  } = useSWR(
    id
      ? `${ORIGIN}/auto_billing_config/api/auto-billing-config/get-update-auto-billing-config-data?id=${id}`
      : null,
    fetcher,
    { revalidateOnFocus: false }
  );


  const isFetching = isLoading || isValidating;


  useEffect(() => {
    if (autoBillingConfig) {
      const autoBillingConfigDataCopy = { ...autoBillingConfig.data };
      const autoBillingConfigSubDataCopy = [...autoBillingConfig.subData];

      // Clear autoBillingConfigCode if it's a clone page
      if (slug === "clone") {
        autoBillingConfigDataCopy.ID = "";
      }
      setAutoBillingConfigData(autoBillingConfigDataCopy);
      setTempRowQuotationDetailsList(autoBillingConfigSubDataCopy)
      setIsSaving(false);
    }
  }, [autoBillingConfig, slug]);

  // const revalidateAuthorizedUserData = () => {
  //   mutateAuthorizedUser();
  // };

  const handleSubmit = async () => {
    try {
      await form.trigger();

      setIsSaving(true);
      await form.handleSubmit(onSubmit)();
    } catch (error) {
      console.error("Form submission error:", error);
    } finally {
      setIsSaving(false);
    }
  };

  const form = useForm<z.infer<typeof autoBillingConfigFormSchema>>({
    resolver: zodResolver(autoBillingConfigFormSchema),
    defaultValues: {
      ID: autoBillingConfig?.ID ?? "",
      description: autoBillingConfig?.description ?? "",
      customer: autoBillingConfig?.customer ?? "",
      valid: autoBillingConfig?.valid ?? "1",
    },
  });

  const onSubmit = async () => {
    var form_data = new FormData();
    var formValues = form.getValues();
    var saveType =
      slug == "clone"
        ? `create-data?c_id=1`
        : id
          ? `update-auto-billing-config-data?id=${id}`
          : `create-data`;

    // if (saveType === "create-data?c_id=1") {
    //   // Empty UUID if present
    //   if (formValues.UUID) {
    //     form_data.set('autoBillingConfig[UUID]', '');
    //   }
    // };

    const autoBillingConfigData = { ...formValues };
    const updatedTempRowQuotationDetailsList = tempRowQuotationDetailsList.map(item => ({
      UUID:item.UUID,
      seq:item.seq,
      quotation: item.quotation
    }));

    
    const combinedData = {
      autoBillingConfig: autoBillingConfigData,
      autoBillingConfigHasDocuments: updatedTempRowQuotationDetailsList,
    };

    form_data.append("data", JSON.stringify(combinedData));

    try {
      const response = await fetch(
        `${ORIGIN}/auto_billing_config/api/auto-billing-config/${saveType}`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      if (response.status === 401) {
        console.error("Session expired. Redirecting to login.");
        toast({
          variant: "destructive",
          title: "Session Expired",
          description: "Your session has expired. Redirecting to login page.",
        });
        router.push("/login");
        throw new Error("Session expired");
      }

      if (!response.ok) {
        const errorData = await response.json();

        setIsSaving(false);

        let errorMessage = errorData.message;

        // Error Handling for "Data too long"
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 2000,
        });

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        const url = `/sales/auto-billing-config/edit?item=${responseData.item}&id=${responseData.data}`;

        router.push(url);

        if (params.slug == "edit") {
          mutateAutoBillingConfig();
          // mutateAuthorizedUser();
        }

        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        router.push(`/sales/auto-billing-config/clone?id=${id}`);

        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error creating new customer group data:", error);
    }
  };

  return (
    <>
      <div className="sticky top-0 z-20">
        <TopActionBar
          autoBillingConfig={autoBillingConfigData}
          form={form}
          action={slug}
          handleSubmit={handleSubmit}
          autoBillingConfigFormSchema={autoBillingConfigFormSchema}
          params={params}
        />
      </div>
      <div className="grid h-full grid-rows-[auto_1fr]">
        <Form {...form}>
          <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
            <ScrollArea className="h-full">
              <div id="mainDetails" className="mt-2" ref={mainDetailsRef}>
                <AutoBillingConfigForm
                  key={formResetKey}
                  tempRowCustomInfo={tempRowCustomInfo}
                  form={form}
                  slug={slug}
                  tempRowQuotationDetailsList={tempRowQuotationDetailsList}
                  setTempRowQuotationDetailsList={setTempRowQuotationDetailsList}
                />
              </div>
            </ScrollArea>

            <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14" />
          </div>

        </Form>
        {isLoading && <LoadingUI />}
        {(isFetching || isSaving) && <LoadingUI />}
      </div>
    </>
  );
}