"use client";

import { zodResolver } from "@hookform/resolvers/zod";
import { notFound, useRouter, useSearchParams } from "next/navigation";
import React, { useEffect, useRef, useState } from "react";
import { useForm } from "react-hook-form";

//Icon
import { FaClipboard, FaLayerGroup, FaListCheck } from "react-icons/fa6";
import { IoLocationSharp } from "react-icons/io5";
import { GiCardPickup } from "react-icons/gi";
import { FaTruck } from "react-icons/fa";

import { z } from "zod";
import LoadingUI from "@/components/LoadingUI";
import { Form } from "@/components/ui/form";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { ScrollArea } from "@/components/ui/scroll-area";
import { TabsNavigator } from "@/components/ui/TabsNavigator";
import { useToast } from "@/components/ui/use-toast";
import { getAuthHeaders, ORIGIN } from "@/lib/constants";
import { useApi } from "@/lib/hooks/useAPI";
import { getFileToBase64 } from "@/lib/utils/commonFunction";
import { Tab, TabList, TabPanel, Tabs } from "react-tabs";
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from "@/components/ui/tooltip";

import { SVGHouseCheck } from "../SVGRepo";
import { assigneeDetailsColumns } from "./job-assignment/assignee-details/columns";
import AssigneeDetailsDataTableOld from "./job-assignment/assignee-details/DataTableOld";
import AssigneeDetailsDataTable from "./job-assignment/assignee-details/DataTable";
import { JobAssignmentDetailsFormOld } from "./job-assignment/job-assignment-details/JobAssignmentDetailsFormOld";
import { DeliveryOrderColumns } from "./main-details/delivery-order-details/columns";
import DeliveryOrderDataTable from "./main-details/delivery-order-details/DataTable";
import CustomerDetailsForm from "./main-details/customer-details/CustomerDetailsForm";
import DeliveryOrderForm from "./main-details/document-details/DeliveryOrderForm"
import DeliveryOrderDataTableOld from "./main-details/delivery-order-details/DataTableOld";
import { DeliveryOrderFormOld } from "./main-details/document-details/DeliveryOrderFormOld";
import MoreDetailsFormOld from "./more-details/MoreDetailsFormOld";

import { itemDetailsColumns } from "./POD/ItemDetails/columns";
import ItemDetailsDataTableOld from "./POD/ItemDetails/DataTableOld";
import ItemDetailsDataTable from "./POD/ItemDetails/DataTable";

import PODTab from "./POD/PODToolbar";

//New UI
import StartingPointForm from "./POD/StartingPointForm";
import PickupPointForm from "./POD/PickupPointForm";
import DeliveryPointForm from "./POD/DeliveryPointForm";

//Old UI
import StartingPointFormOld from "./POD/StartingPointFormOld";
import PickupPointFormOld from "./POD/PickupPointFormOld";
import DeliveryPointFormOld from "./POD/DeliveryPointFormOld";

import TopActionBar from "./TopActionBar";
import { DateRestrictionContext } from "@/components/custom/DateRestrictionContext";
import { CustomFieldHandle, CustomFieldDefinition } from "@/components/DisplayCustomField";

type PageParams = {
  params: { slug: string };
};

const validRoutes = ["new", "edit", "clone", "transfer-to", "transfer-from"] as const;

type ValidRoute = (typeof validRoutes)[number];

const deliveryOrderFormSchema = z.object({
  customerCodeCode: z.string().min(1, {
    message: "Required",
  }),
});

function isValidRoute(route: string): route is ValidRoute {
  return validRoutes.includes(route as ValidRoute);
}

const tabs = [
  {
    id: "mainDetails",
    name: "Main Details",
    icon: FaClipboard,
    shortName: "Main",
  },
  {
    id: "moreDetails",
    name: "More Details",
    icon: FaLayerGroup,
    shortName: "More",
  },
  {
    id: "jobAssignment",
    name: "Job Assignment",
    icon: FaListCheck,
    shortName: "Job",
  },
  {
    id: "POD",
    name: "POD",
    icon: SVGHouseCheck,
    shortName: "POD",
  },
];

export default function DeliveryOrderPage({ params }: PageParams) {

  //State
  const slug = params.slug;

  const { toast } = useToast();
  const [allowPastRecord, setAllowPastRecord] = useState(false);

  const searchParams = useSearchParams();
  const router = useRouter();
  const headers = getAuthHeaders();

  const id = searchParams.get("id");
  const customFieldRef = useRef<CustomFieldHandle>(null);
  const [tempRowDeliveryLink, setTempRowDeliveryLink] = useState([]);
  const [tempRowPickupLink, setTempRowPickupLink] = useState([]);
  const [tempRowStartingLink, setTempRowStartingLink] = useState([]);
  const [actualPickUpAttachment, setActualPickUpAttachment] = useState([]);
  const [actualDeliveryAttachment, setActualDeliveryAttachment] = useState([]);
  const [actualStartingAttachment, setActualStartingAttachment] = useState([]);
  const [tempRowAttachments, setTempRowAttachments] = useState([]);
  const [tempRowDeliveryOrderDetailsList, setTempRowDeliveryOrderDetailsList] = useState([]);
  const [tempRowAssigneeDetail, setTempRowAssigneeDetail] = useState([]);
  const [tempRowItemDetail, setTempRowItemDetail] = useState([]);
  const [selectedPoint, setSelectedPoint] = useState<string | null>("Starting Point");
  const [isExpand, setIsExpand] = useState(false);

  const [formResetKey, setFormResetKey] = useState(0);
  const [isSaving, setIsSaving] = useState(false);
  const [deliveryOrderData, setDeliveryOrderData] = useState({});
  const [approvalStatus, setApprovalStatus] = useState({});
  const [jobAssignmentData, setJobAssignmentData] = useState({});
  const [UOMDetails, setUOMDetails] = useState({});
  const [PODData, setPODData] = useState({});
  const [submitAttempted, setSubmitAttempted] = useState(false);

  if (!isValidRoute(slug)) {
    notFound();
  }

  // ─── Layout State ─────────────────────────────────────────────────────────────
  const [layout, setLayout] = useState<"new" | "old">(() => {
    if (typeof window === "undefined") return "old";
    return (localStorage.getItem("Layout") as "new" | "old") || "old";
  });

  const handleLayoutChange = (newLayout: "new" | "old") => {
    localStorage.setItem("Layout", newLayout);
    setLayout(newLayout);
  };

  const {
    data: deliveryOrder,
    error,
    isLoading,
    isValidating,
    mutate: mutateDeliveryOrder,
  } = useApi(
    id
      ? `${ORIGIN}/delivery_order/api/delivery-order/get-update-delivery-order-data?id=${id}`
      : null,
    { revalidateOnFocus: false },
  );

  const {
    data: deliveryOrderDetails,
    error: deliveryOrderDetailsError,
    mutate: mutateDeliveryOrderDetails,
  } = useApi(
    id
      ? `${ORIGIN}/delivery_order/api/delivery-order/get-delivery-order-has-details?deliveryOrderUUID=${id}`
      : null,
    { revalidateOnFocus: false },
  );

  const {
    data: jobAssignment,
    error: jobAssignmentError,
    mutate: mutateJobAssignment,
  } = useApi(
    id
      ? `${ORIGIN}/delivery_order/api/delivery-order/get-delivery-order-has-assignments?deliveryOrderUUID=${id}`
      : null,
    { revalidateOnFocus: false },
  );

  const {
    data: assigneeDetailData,
    error: AssigneeDetailError,
    mutate: mutateAssigneeDetail,
  } = useApi(
    id
      ? `${ORIGIN}/delivery_order/api/delivery-order/get-job-order-has-assignee?deliveryOrderUUID=${id}`
      : null,
    { revalidateOnFocus: false },
  );

  const {
    data: itemDetailData,
    error: ItemDetailError,
    mutate: mutateItemDetail,
  } = useApi(
    id
      ? `${ORIGIN}/delivery_order/api/delivery-order/get-d-o-a-has-details?deliveryOrderUUID=${id}`
      : null,
    { revalidateOnFocus: false },
  );

  const isFetching = isLoading || isValidating || isSaving;

  // Preference (State)
  const [preferenceData, setPreferenceData] = useState<any>(null);
  const [customFieldDefs, setCustomFieldDefs] = useState<CustomFieldDefinition[]>([]);
  const [customFieldSavedData, setCustomFieldSavedData] = useState<Record<string, unknown>>({});

  const fetchPreferenceData = async () => {
    try {
      const headers = getAuthHeaders();

      const response = await fetch(`${ORIGIN}/universal/get-preference?module=sales`, {
        method: "GET",
        headers,
      });
      if (!response.ok) throw new Error("Failed to fetch preference data");
      const data = await response.json();
      setPreferenceData(data);

      // Fetch custom field definitions
      const prefRes = await fetch(
        `${ORIGIN}/sales_preference/api/sales-preference/get-index-sales-preference`,
        { method: "GET", headers }
      );
      if (!prefRes.ok) throw new Error("Failed to fetch custom field preference");
      const prefData = await prefRes.json();
      const raw = prefData?.data?.customDIYFields ?? prefData?.customDIYFields ?? [];
      const rawFields: CustomFieldDefinition[] = (() => {
        try {
          const parsed = typeof raw === "string" ? JSON.parse(raw) : raw;
          return Array.isArray(parsed) ? parsed : [];
        } catch { return []; }
      })();
      setCustomFieldDefs(rawFields);

    } catch (error) {
      console.error("Error fetching preference data:", error);
    }
  };

  useEffect(() => {
    fetchPreferenceData();
  }, []);

  useEffect(() => {
    if (deliveryOrder && slug !== "transfer-to" && slug !== "transfer-from") {
      const deliveryOrderDataCopy = { ...deliveryOrder.data };

      // Clear docNo if it's a clone page
      if (slug === "clone") {
        deliveryOrderDataCopy.docNo = "";
        deliveryOrderDataCopy.docDate = Math.floor(Date.now() / 1000);
      }
      setDeliveryOrderData(deliveryOrderDataCopy);
      setApprovalStatus(deliveryOrder.approval);
      setAllowPastRecord(deliveryOrder.data.allowPastDates === "1");
      setIsSaving(false);

      const rawSaved = deliveryOrder?.customDIYFieldData;
      if (rawSaved) {
        setCustomFieldSavedData(
          typeof rawSaved === "string" ? JSON.parse(rawSaved) : rawSaved
        );
      } else {
        setCustomFieldSavedData({});
      }
    }
  }, [deliveryOrder, slug, preferenceData]);

  useEffect(() => {
    if (deliveryOrderDetails && slug !== "transfer-to" && slug !== "transfer-from") {
      // Preference (Add Preference Data to Table Details)
      const detailsWithPreferences = deliveryOrderDetails.rows.map((row) => ({
        ...row,
        preferenceData: preferenceData,
      }));

      setTempRowDeliveryOrderDetailsList(detailsWithPreferences);
    }
  }, [deliveryOrderDetails, preferenceData]);

  useEffect(() => {
    if (jobAssignment) {
      const data = jobAssignment.data || {};

      setJobAssignmentData(data);
      setTempRowDeliveryLink(data.actualDeliverySignatureLink || []);
      setTempRowPickupLink(data.actualPickUpSignatureLink || []);
      setTempRowStartingLink(data.actualStartingSignatureLink || []);
      setActualDeliveryAttachment(data.actualDeliveryAttachmentLink || []);
      setActualPickUpAttachment(data.actualPickUpAttachmentLink || []);
      setActualStartingAttachment(data.actualStartingAttachmentLink || []);
    }
  }, [jobAssignment]);

  useEffect(() => {
    if (assigneeDetailData) {
      setTempRowAssigneeDetail(assigneeDetailData.rows);
    }
  }, [assigneeDetailData]);

  const revalidateDeliveryOrderDetails = () => {
    mutateDeliveryOrderDetails();
  };

  const revalidateAssigneeDetail = () => {
    mutateAssigneeDetail();
  };

  const revalidateItemDetail = () => {
    mutateItemDetail();
  };

  const handleSelectPoint = (item: string) => {
    setSelectedPoint(item);
  };

  const handleSubmit = async () => {
    setSubmitAttempted(true);
    const isFormValid = await form.trigger();

    if (!isFormValid) {
      const errors = form.formState.errors;

      if (errors.customerCodeCode) {
        toast({
          title: "Customer Required",
          description: "Please select a customer before saving.",
          variant: "destructive",
          duration: 3000,
        });
      }
      return;
    }

    try {
      await onSubmit();
    } catch (error) {
      console.error("Form submission error:", error);
    }
  };

  const form = useForm<z.infer<typeof deliveryOrderFormSchema>>({
    resolver: zodResolver(deliveryOrderFormSchema),
    defaultValues: {
      docNo: deliveryOrder?.docNo ?? "",
      docDate: deliveryOrder?.docDate ?? "",
      agentName: deliveryOrder?.agentName ?? "",
      term: deliveryOrder?.term ?? "",
      creditTermCode: deliveryOrder?.creditTermCode ?? "",
      closingDate: deliveryOrder?.closingDate ?? "",
      description: deliveryOrder?.description ?? "",
      customerCodeCode: deliveryOrder?.customerCodeCode ?? "",
      customerName: deliveryOrder?.customerName ?? "",
      BRN: deliveryOrder?.BRN ?? "",
      attentionName: deliveryOrder?.attentionName ?? "",
      address: deliveryOrder?.address ?? "",
      TIN: deliveryOrder?.TIN ?? "",
      SSTNo: deliveryOrder?.SSTNo ?? "",
      phoneNo: deliveryOrder?.phoneNo ?? "",
      email: deliveryOrder?.email ?? "",
      valid: deliveryOrder?.valid ?? "1",
      currency: deliveryOrder?.currency ?? "",
      currencyCode: deliveryOrder?.currencyCode ?? "",
      currencyRate: deliveryOrder?.currencyRate ?? "",
    },
  });

  const onSubmit = async () => {
    setIsSaving(true);

    setSubmitAttempted(true);

    const ok = await customFieldRef.current?.save();
    if (ok === false) {
      setIsSaving(false);
      return;
    }

    var form_data = new FormData();
    var formValues = form.getValues();

    const localNetTotal = document.querySelector(".localNetTotal");
    const netTotal = document.querySelector(".netTotal");

    var saveType =
      slug == "clone"
        ? `create-data?c_id=1`
        : id
          ? `update-delivery-order-data?id=${id}`
          : `create-data`;

    var transferType = "";
    var transferData = "";

    if (slug === "transfer-to") {
      transferData = JSON.parse(localStorage.getItem("transfer-to.sales-delivery-order") || "{}");
    } else if (slug === "transfer-from") {
      transferData = JSON.parse(localStorage.getItem("transfer-from.sales-delivery-order") || "{}");
    }

    var transferDocType = transferData?.data?.transferDocType;

    // Preference (Get Decimal Places for Calculations)
    const decimal = preferenceData?.data?.decimal || 2;

    // Ensure all required fields exist and default to 0 if undefined or empty
    let totalAmount = tempRowDeliveryOrderDetailsList.reduce((sum, row) => {
      return sum + (row.amount ? parseFloat(row.amount) : 0);
    }, 0);

    let totalDiscount = tempRowDeliveryOrderDetailsList.reduce((sum, row) => {
      const discount1 = row.discountAmount ? parseFloat(row.discountAmount) : 0;
      const discount2 = row.discountAmount2 ? parseFloat(row.discountAmount2) : 0;
      const discount3 = row.discountAmount3 ? parseFloat(row.discountAmount3) : 0;

      return sum + discount1 + discount2 + discount3;
    }, 0);

    let totalTax = tempRowDeliveryOrderDetailsList.reduce((sum, row) => {
      return sum + (row.taxAmount ? parseFloat(row.taxAmount) : 0);
    }, 0);

    // Fix the calculation of totalSubtotal
    let totalSubtotal = totalAmount - totalDiscount + totalTax;
    let totalSubtotalWithoutTax = totalAmount - totalDiscount;

    let prepaymentAmount = parseFloat(formValues.prepaymentAmount) || 0;
    let totalFeeAmount = parseFloat(formValues.totalFeeAmount) || 0;

    // Calculate subtotal tax (amount after discount + tax)
    let subtotalTax = totalAmount - totalDiscount + totalTax;

    // Calculate Rounding Amount
    let roundedSubtotalTax = Math.round(subtotalTax * 20) / 20;
    let roundingAmount = roundedSubtotalTax - subtotalTax;

    // Correct totalPayable Calculation
    let totalPayable =
      totalAmount - totalDiscount + totalTax - prepaymentAmount + totalFeeAmount + roundingAmount;

    // Round totalPayable to the nearest 5 cents
    totalPayable = Math.round(totalPayable * 20) / 20;

    // Preference (Apply Decimal Formatting to Totals)
    formValues.totalAmount = totalAmount.toFixed(decimal);
    formValues.totalDiscount = totalDiscount.toFixed(decimal);
    formValues.totalTax = totalTax.toFixed(decimal);
    formValues.totalSubtotal = totalSubtotalWithoutTax.toFixed(decimal);
    formValues.roundingAmount = roundingAmount.toFixed(decimal);
    formValues.totalPayable = totalPayable.toFixed(decimal);

    formValues.localNetTotal = localNetTotal?.value;
    formValues.netTotal = netTotal?.value;

    //Create deliveryOrder object excluding attachments
    const deliveryOrderData = { ...formValues };
    delete deliveryOrderData.attachmentLink;
    delete deliveryOrderData.attachment;

    //Combine deliveryOrder and deliveryOrderHasDetails into single data object
    const combinedData = {
      deliveryOrder: deliveryOrderData,
      deliveryOrderHasDetails: tempRowDeliveryOrderDetailsList,
    };

    //Add combined data as JSON string
    form_data.append("data", JSON.stringify(combinedData));

    if (saveType === "create-data") {
      var counter = 0;

      for (const file of tempRowAttachments) {
        if (file instanceof File) {
          const base64 = await getFileToBase64(file);

          form_data.append(`deliveryOrder[attachment][${counter}][Name]`, file.name);

          form_data.append(`deliveryOrder[attachment][${counter}][File]`, base64);
        } else {
          form_data.append(`deliveryOrder[attachment][${counter}][Name]`, file.name || "");

          form_data.append(`deliveryOrder[attachment][${counter}][File]`, "");
        }

        counter++;
      }
    } else {
      var counter = 0;

      for (const attachment of tempRowAttachments) {
        if (attachment.link) {
          form_data.append(`deliveryOrder[attachment][${counter}][Name]`, attachment.name);

          form_data.append(`deliveryOrder[attachment][${counter}][File]`, "");
        } else if (attachment instanceof File) {
          const base64 = await getFileToBase64(attachment);

          form_data.append(`deliveryOrder[attachment][${counter}][Name]`, attachment.name);

          form_data.append(`deliveryOrder[attachment][${counter}][File]`, base64);
        } else {
          form_data.append(`deliveryOrder[attachment][${counter}][Name]`, attachment.name || "");

          form_data.append(`deliveryOrder[attachment][${counter}][File]`, "");
        }
        counter++;
      }
    }

    transferType =
      slug == "transfer-to" || slug == "transfer-from" ? `?transferFrom=${transferDocType}` : "";

    try {
      const response = await fetch(
        `${ORIGIN}/delivery_order/api/delivery-order/${saveType}${transferType}`,
        {
          method: "POST",
          headers,
          body: form_data,
        },
      );

      if (!response.ok) {
        const errorData = await response.json();

        setIsSaving(false);

        let errorMessage = errorData.message;

        // Error Handling for "Data too long"
        if (errorMessage.includes("Data too long")) {
          errorMessage = errorMessage.split("\n")[0];
        }

        toast({
          title: errorData.name,
          description: errorMessage,
          variant: "destructive",
          duration: 2000,
        });

        throw new Error("Failed to fetch data");
      }

      const responseData = await response.json();

      if (responseData && responseData.item) {
        if (slug === "transfer-to") localStorage.removeItem("transfer-to.sales-delivery-order");
        else if (slug === "transfer-from") localStorage.removeItem("transfer-from.sales-delivery-order");

        if (customFieldRef.current) {
          try {
            await customFieldRef.current.save(
              responseData.data,
              responseData.item,
            );
          } catch (err) {
            console.error("Failed to save custom fields:", err);
          }
        }

        const url = `/sales/sales-delivery-order/edit?item=${responseData.item}&id=${responseData.data}`;

        router.push(url);

        if (params.slug == "edit") {
          mutateDeliveryOrder();
          mutateDeliveryOrderDetails();
          mutateAssigneeDetail();
          mutateJobAssignment();
          mutateItemDetail();
        }

        toast({
          title: responseData.message,
          duration: 2000,
        });
      } else if (slug === "clone" && id) {
        router.push(`/sales/sales-delivery-order/clone?id=${id}`);

        toast({
          title: responseData.message,
          duration: 2000,
        });
      }
    } catch (error) {
      console.error("Error creating new delivery order data:", error);

      setIsSaving(false);

      toast({
        title: "Failed",
        description: `${error.message}`,
        variant: "destructive",
        duration: 2000,
      });
    }
  };

  useEffect(() => {
    if (id) {
      loadFiles(id);
    }
  }, [id]);

  const loadFiles = async (id: string | null) => {
    if (id) {
      try {
        const response = await fetch(
          `${ORIGIN}/delivery_order/api/delivery-order/load-files?id=${id}`,
          {
            headers,
          },
        );

        if (!response.ok) {
          throw new Error("Failed to load files");
        }

        const loadedFilesData = await response.json();

        setTempRowAttachments(loadedFilesData);
      } catch (error) {
        console.error("Error loading files:", error);
      }
    }
  };

  useEffect(() => {
    if (typeof window !== "undefined" && (slug === "transfer-to" || slug === "transfer-from")) {
      const transferDataKey =
        slug === "transfer-to"
          ? "transfer-to.sales-delivery-order"
          : "transfer-from.sales-delivery-order";

      const transferData = JSON.parse(localStorage.getItem(transferDataKey) || "{}");

      //Map quotation fields to sales delivery order fields
      const mappedData = {
        ...transferData?.data,
        description: "",
        note: "",
        UUID: "",
        docDate: Math.floor(Date.now() / 1000),
      };

      setDeliveryOrderData(mappedData);

      transferData?.subData?.forEach((detail) => {
        detail["item"] = detail["item"];
        detail["itemGroup"] = detail["itemGroupCode"];
        detail["itemCategory"] = detail["itemCategoryCode"];
      });

      setTempRowAttachments(transferData?.data?.attachmentLink ?? []);
      setTempRowDeliveryOrderDetailsList(transferData?.subData);

      function beforeUnload(e: BeforeUnloadEvent) {
        localStorage.removeItem(transferDataKey);

        e.preventDefault();
      }

      window.addEventListener("beforeunload", beforeUnload);

      return () => {
        window.removeEventListener("beforeunload", beforeUnload);
      };
    }
  }, [slug]);

  //Create refs for each section
  const mainDetailsRef = useRef(null);
  const moreDetailsRef = useRef(null);
  const jobAssignmentRef = useRef(null);
  const PODRef = useRef(null);

  //Shared Props
  const dataTableProps = {
    columns: DeliveryOrderColumns,
    data: id
      ? deliveryOrderDetails
        ? deliveryOrderDetails.rows
        : []
      : tempRowDeliveryOrderDetailsList,
    tempRowDeliveryOrderDetailsList,
    setTempRowDeliveryOrderDetailsList,
    revalidateDeliveryOrderDetails,
    form,
    deliveryOrderData,
    UOMDetails,
    preferenceData,
    slug,
  };

  const deliveryOrderFormProps = {
    form,
    slug,
    isExpand,
    preferenceData,
    deliveryOrderData,
    jobAssignmentData,
    tempRowAttachments,
    setTempRowAttachments,
  };

  const assigneeDetailsTableProps = {
    columns: assigneeDetailsColumns,
    data: id ? (assigneeDetailData ? assigneeDetailData.rows : []) : tempRowAssigneeDetail,
    tempRowAssigneeDetail,
    setTempRowAssigneeDetail,
    revalidateAssigneeDetail,
  };

  const itemDetailsTableProps = {
    columns: itemDetailsColumns,
    data: id ? (itemDetailData ? itemDetailData.rows || [] : []) : tempRowItemDetail,
    tempRowItemDetail,
    setTempRowItemDetail,
    revalidateItemDetail,
  };

  return (
    <DateRestrictionContext.Provider value={{ allowPastRecord, setAllowPastRecord }}>
      <div className="sticky top-0 z-20">
        <TopActionBar
          deliveryOrder={deliveryOrderData}
          approvalStatus={approvalStatus}
          jobAssignment={jobAssignmentData}
          POD={PODData}
          form={form}
          handleSubmit={handleSubmit}
          deliveryOrderFormSchema={deliveryOrderFormSchema}
          slug={slug}
          deliveryOrderData={deliveryOrder}
          // Layout switcher props
          layout={layout}
          onLayoutChange={handleLayoutChange}
        />
      </div>

      {/* New Design */}
      {layout === "new" && (
        <div className="box-border flex w-full h-full items-center justify-between gap-x-2 p-1.5">
          <Form {...form}>
            {/* Left */}
            <div className="flex h-full min-w-[380px] w-[480px] flex-col gap-y-2">
              <CustomerDetailsForm
                form={form}
                setIsExpand={setIsExpand}
                isExpand={isExpand}
                slug={slug}
                id={id}
                docNo={deliveryOrderData?.docNo}
                customFieldRef={customFieldRef}
                preferenceData={preferenceData}
                customFieldDefs={customFieldDefs}
                customFieldSavedData={customFieldSavedData}
                submitAttempted={submitAttempted}
              />

              <DeliveryOrderForm {...deliveryOrderFormProps} />
            </div>

            {/* Right */}
            <div className="w-full flex flex-1 flex-col h-full mt-3.5 md:mt-0">
              <Card className="w-full shadow-sm">
                <CardContent className="px-0 py-1">
                  <Tabs>
                    <TabList className="flex px-1.5">
                      {["Charges", "Assignee", "Items", "POD"].map(
                        (label) => (
                          <Tab
                            key={label}
                            className="cursor-pointer rounded-tl-md rounded-tr-md border-[1px] border-gray-200 bg-transparent px-2 py-1 text-[12px] text-black outline-none transition-all duration-300 ease-in-out"
                            selectedClassName="!bg-blue-300 border-blue-300 text-white"
                          >
                            {label}
                          </Tab>
                        ),
                      )}
                    </TabList>

                    {/* Delivery Order Table */}
                    <TabPanel
                      forceRender
                      className="hidden"
                      selectedClassName="react-tabs__tab-panel--selected"
                    >
                      <DeliveryOrderDataTable {...dataTableProps} />
                    </TabPanel>

                    {/* Assignee Details Table */}
                    <TabPanel
                      forceRender
                      className="hidden"
                      selectedClassName="react-tabs__tab-panel--selected"
                    >
                      <AssigneeDetailsDataTable {...assigneeDetailsTableProps} />
                    </TabPanel>

                    {/* Item Details Table */}
                    <TabPanel
                      forceRender
                      className="hidden"
                      selectedClassName="react-tabs__tab-panel--selected"
                    >
                      <ItemDetailsDataTable {...itemDetailsTableProps} />
                    </TabPanel>

                    {/* POD Table */}
                    <TabPanel
                      forceRender
                      className="hidden"
                      selectedClassName="react-tabs__tab-panel--selected"
                    >
                      <Tabs>
                        <div className="flex px-0.5">
                          {/* Left Container*/}
                          <div className="min-w-0 flex-1">
                            {/* Starting Point */}
                            <TabPanel
                              forceRender
                              className="hidden"
                              selectedClassName="react-tabs__tab-panel--selected"
                            >
                              <StartingPointForm
                                key={formResetKey}
                                form={form}
                                jobAssignmentData={jobAssignmentData}
                                tempRowStartingLink={tempRowStartingLink}
                                actualStartingAttachment={actualStartingAttachment}
                              />
                            </TabPanel>

                            {/* Pick Up Point */}
                            <TabPanel
                              forceRender
                              className="hidden"
                              selectedClassName="react-tabs__tab-panel--selected"
                            >
                              <PickupPointForm
                                key={formResetKey}
                                form={form}
                                jobAssignmentData={jobAssignmentData}
                                tempRowPickupLink={tempRowPickupLink}
                                actualPickUpAttachment={actualPickUpAttachment}
                              />
                            </TabPanel>

                            {/* Starting Point */}
                            <TabPanel
                              forceRender
                              className="hidden"
                              selectedClassName="react-tabs__tab-panel--selected"
                            >
                              <DeliveryPointForm
                                key={formResetKey}
                                form={form}
                                jobAssignmentData={jobAssignmentData}
                                tempRowDeliveryLink={tempRowDeliveryLink}
                                actualDeliveryAttachment={actualDeliveryAttachment}
                              />
                            </TabPanel>
                          </div>

                          {/* Right - Vertical TabList */}
                          <TabList className="ml-1 flex flex-col gap-y-1">
                            {[
                              {
                                icon: <IoLocationSharp className="size-4.5" />,
                                label: "Starting Point",
                              },
                              {
                                icon: <GiCardPickup className="size-4.5" />,
                                label: "Pick Up Point",
                              },
                              {
                                icon: <FaTruck className="size-4.5" />,
                                label: "Delivery Point",
                              },
                            ].map((item, index) => (
                              <Tab
                                key={index}
                                className="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-y-0.5 rounded-md border border-gray-200 bg-white text-[9px] text-gray-600 outline-none transition-all duration-200 ease-in-out"
                                selectedClassName="!bg-blue-300 border-blue-300 text-white"
                              >
                                <TooltipProvider delayDuration={1000}>
                                  <Tooltip>
                                    <TooltipTrigger asChild>
                                      <span className="flex h-full w-full items-center justify-center">
                                        {item.icon}
                                      </span>
                                    </TooltipTrigger>
                                    <TooltipContent side="right" align="start">
                                      {item.label}
                                    </TooltipContent>
                                  </Tooltip>
                                </TooltipProvider>
                              </Tab>
                            ))}
                          </TabList>
                        </div>
                      </Tabs>
                    </TabPanel>

                  </Tabs>
                </CardContent>
              </Card>
            </div>
          </Form>

          {/* Loading */}
          {isFetching && <LoadingUI />}
        </div>
      )}

      {/* Old Deisgn */}
      {layout === "old" && (
        <div className="grid h-full grid-rows-[auto_1fr]">
          <div className="grid h-full grid-cols-[1fr_auto] gap-x-2">
            {/* Preference (Pass preferenceData Prop) */}
            <ScrollArea className="h-full">
              <div id="mainDetails" className="mt-2" ref={mainDetailsRef}>
                <DeliveryOrderFormOld
                  key={formResetKey}
                  form={form}
                  slug={slug}
                  preferenceData={preferenceData}
                />
              </div>

              <div className="mt-2">
                <DeliveryOrderDataTableOld
                  columns={DeliveryOrderColumns}
                  data={
                    id
                      ? deliveryOrderDetails
                        ? deliveryOrderDetails.rows
                        : []
                      : tempRowDeliveryOrderDetailsList
                  }
                  tempRowDeliveryOrderDetailsList={tempRowDeliveryOrderDetailsList}
                  setTempRowDeliveryOrderDetailsList={setTempRowDeliveryOrderDetailsList}
                  revalidateDeliveryOrderDetails={revalidateDeliveryOrderDetails}
                  form={form}
                  deliveryOrderData={deliveryOrderData}
                  UOMDetails={UOMDetails}
                  preferenceData={preferenceData}
                  slug={slug}
                />
              </div>

              <div id="moreDetails" className="mt-2" ref={moreDetailsRef}>
                <MoreDetailsFormOld
                  tempRowAttachments={tempRowAttachments}
                  setTempRowAttachments={setTempRowAttachments}
                  form={form}
                  deliveryOrderData={deliveryOrderData}
                  slug={slug}
                  preferenceData={preferenceData}
                />
              </div>

              <div id="jobAssignment" className="mt-2" ref={jobAssignmentRef}>
                <JobAssignmentDetailsFormOld
                  key={formResetKey}
                  form={form}
                  jobAssignmentData={jobAssignmentData}
                />

                <div className="mt-2">
                  <AssigneeDetailsDataTableOld
                    columns={assigneeDetailsColumns}
                    data={
                      id ? (assigneeDetailData ? assigneeDetailData.rows : []) : tempRowAssigneeDetail
                    }
                    tempRowAssigneeDetail={tempRowAssigneeDetail}
                    setTempRowAssigneeDetail={setTempRowAssigneeDetail}
                    revalidateAssigneeDetail={revalidateAssigneeDetail}
                  />
                </div>
              </div>

              <div id="POD" className="mt-2" ref={PODRef}>
                <Card collapsible defaultCollapsed={false} className="shadow-md">
                  <CardHeader>
                    <CardTitle className="text-lg font-bold">POD (Proof of Delivery)</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <PODTab
                      jobAssignmentData={jobAssignmentData}
                      selectedPoint={selectedPoint}
                      handleSelectPoint={handleSelectPoint}
                    />

                    <div className="mt-4">
                      {selectedPoint === "Starting Point" && (
                        <>
                          <StartingPointFormOld
                            key={formResetKey}
                            form={form}
                            jobAssignmentData={jobAssignmentData}
                            tempRowStartingLink={tempRowStartingLink}
                            actualStartingAttachment={actualStartingAttachment}
                          />
                          <div className="mt-2">
                            <ItemDetailsDataTableOld
                              columns={itemDetailsColumns}
                              data={
                                id
                                  ? itemDetailData
                                    ? itemDetailData.startingJobDetails.rows
                                    : []
                                  : tempRowItemDetail
                              }
                              tempRowItemDetail={tempRowItemDetail}
                              setTempRowItemDetail={setTempRowItemDetail}
                              revalidateItemDetail={revalidateItemDetail}
                            />
                          </div>
                        </>
                      )}
                      {selectedPoint === "Pickup Point" && (
                        <>
                          <PickupPointFormOld
                            key={formResetKey}
                            form={form}
                            jobAssignmentData={jobAssignmentData}
                            tempRowPickupLink={tempRowPickupLink}
                            actualPickUpAttachment={actualPickUpAttachment}
                          />
                          <div className="mt-2">
                            <ItemDetailsDataTableOld
                              columns={itemDetailsColumns}
                              data={
                                id
                                  ? itemDetailData
                                    ? itemDetailData.pickupJobDetails.rows
                                    : []
                                  : tempRowItemDetail
                              }
                              tempRowItemDetail={tempRowItemDetail}
                              setTempRowItemDetail={setTempRowItemDetail}
                              revalidateItemDetail={revalidateItemDetail}
                            />
                          </div>
                        </>
                      )}
                      {selectedPoint === "Delivery Point" && (
                        <>
                          <DeliveryPointFormOld
                            key={formResetKey}
                            form={form}
                            jobAssignmentData={jobAssignmentData}
                            tempRowDeliveryLink={tempRowDeliveryLink}
                            actualDeliveryAttachment={actualDeliveryAttachment}
                          />
                          <div className="mt-2">
                            <ItemDetailsDataTableOld
                              columns={itemDetailsColumns}
                              data={
                                id
                                  ? itemDetailData
                                    ? itemDetailData.deliveryJobDetails.rows
                                    : []
                                  : tempRowItemDetail
                              }
                              tempRowItemDetail={tempRowItemDetail}
                              setTempRowItemDetail={setTempRowItemDetail}
                              revalidateItemDetail={revalidateItemDetail}
                            />
                          </div>
                        </>
                      )}
                    </div>
                  </CardContent>
                </Card>
              </div>
            </ScrollArea>

            <TabsNavigator tabs={tabs} initialActiveTabId="mainDetails" stickyTop="top-14" />
          </div>
          {isFetching && <LoadingUI />}
        </div>
      )}
    </DateRestrictionContext.Provider>
  );
}