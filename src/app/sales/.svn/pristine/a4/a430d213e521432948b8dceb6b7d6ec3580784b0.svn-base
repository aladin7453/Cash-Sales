"use client";

import { PDFDownloadLink, PDFViewer } from "@react-pdf/renderer";
import { CalendarIcon } from "lucide-react";
import moment from "moment";
import React, { useEffect, useRef, useState } from "react";
import { UseFormReturn } from "react-hook-form";
import { FaMagnifyingGlass } from "react-icons/fa6";

import DescriptionCellTooltip from "@/components/data-table/DescriptionCellTooltip";
import DropdownTable from "@/components/data-table/DropdownTable";
import ReportPreviewButton from "@/components/form/ActionButton/ReportPreview";
import SalesReport from "@/components/templates/sales/salesReportTemplate";
import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
  AlertDialogTrigger,
} from "@/components/ui/alert-dialog";
import { Button, buttonVariants } from "@/components/ui/button";
import { Calendar } from "@/components/ui/calendar";
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import {
  Dialog,
  DialogClose,
  DialogContent,
  DialogFooter,
  DialogTitle,
} from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { ScrollArea, ScrollBar } from "@/components/ui/scroll-area";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { DATE_FORMAT, getAuthHeaders, ORIGIN } from "@/lib/constants";
import { cn } from "@/lib/utils/cn";

type DropdownConfig = {
  tableName: string;
  columns: { accessorKey: string; header: string }[];
  valueField: string;
  displayField: string;
  formValueField: string;
  formDisplayField: string;
  additionalMappings?: { sourceField: string; targetFormField: string }[];
};

interface CustomerAnalysisByDocumentFormProps {
  form: UseFormReturn<any>;
  onGenerate: (data: any) => void;
  onPreview?: (data: any, isGenerated?: boolean) => void;
  previewPDF?: any;
  customerAnalysisByDocumentData?: any;
  generatedReport?: any;
  onReset?: () => void;
  filterFields?: string[];
  sorting?: any;
}

const customerAnalysisByDocumentList = [
  { id: "customerAnalysisByDocument", name: "Customer Analysis By Document" },
  {
    id: "customerAnalysisByDocumentLv2CustomerName",
    name: "Cust Analysis By Document - Level 2 (Customer Name)",
  },
];

export default function CustomerAnalysisByDocumentForm({
  form,
  onGenerate,
  onPreview,
  previewPDF,
  customerAnalysisByDocumentData,
  generatedReport,
  customerAnalysisByDocumentColumns,
  onReset,
  filterFields,
  sorting,
}: CustomerAnalysisByDocumentFormProps & { customerAnalysisByDocumentColumns?: any[] }) {
  const headers = getAuthHeaders();
  const systemAccount = JSON.parse(localStorage.getItem("system-account"));
  const formData = form.getValues();
  const [fromDateOpen, setFromDateOpen] = useState(false);
  const [toDateOpen, setToDateOpen] = useState(false);

  const [dropdownState, setDropdownState] = useState({
    currentDropdown: null as string | null,
    data: [] as any[],
    originalData: [] as any[],
    showTable: false,
  });

  const [selectedReportList, setSelectedReportList] = useState<any>(customerAnalysisByDocumentList);

  const dropdownInputRef = useRef(null);
  const dropdownTableRef = useRef(null);
  const [isAlertOpen, setIsAlertOpen] = useState(false);

  const dropdownConfigs: Record<string, DropdownConfig> = {
    customer: {
      tableName: "customer",
      columns: [
        { accessorKey: "customerName", header: "Customer Name" },
        { accessorKey: "customerCode", header: "Customer Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "customerName",
      formValueField: "customer",
      formDisplayField: "customerName",
    },
    agent: {
      tableName: "agent",
      columns: [
        { accessorKey: "agentCode", header: "Agent Code" },
        { accessorKey: "agentName", header: "Agent Name" },
      ],
      valueField: "UUID",
      displayField: "agentName",
      formValueField: "agent",
      formDisplayField: "agentName",
    },
    stockItem: {
      tableName: "stock",
      columns: [
        { accessorKey: "stockCode", header: "Stock Code" },
        { accessorKey: "description", header: "Description" },
      ],
      valueField: "UUID",
      displayField: "stockCode",
      formValueField: "stockItem",
      formDisplayField: "stockCode",
    },
    project: {
      tableName: "project",
      columns: [
        { accessorKey: "projectCode", header: "Project Code" },
        {
          accessorKey: "description",
          header: "Description",
          cell: ({ row }) => <DescriptionCellTooltip row={row} />,
        },
      ],
      valueField: "UUID",
      displayField: "projectCode",
      formValueField: "project",
      formDisplayField: "projectCode",
    },
    // currencyCode: {
    //   tableName: "currency",
    //   columns: [
    //     { accessorKey: "currencyCode", header: "Currency Code" },
    //     { accessorKey: "description", header: "Description", cell: ({ row }) => <DescriptionCellTooltip row={row} /> }
    //   ],
    //   valueField: "UUID",
    //   displayField: "currencyCode",
    //   formValueField: "currency",
    //   formDisplayField: "currencyCode",
    //   // additionalMappings: [
    //   //   { sourceField: "exchangeRateSales", targetFormField: "currencyRate" }
    //   // ]
    // },
  };

  const handleClickOutside = (event) => {
    if (
      dropdownTableRef.current &&
      !dropdownTableRef.current.contains(event.target) &&
      dropdownInputRef.current !== event.target
    ) {
      setDropdownState((prev) => ({ ...prev, showTable: false }));
    }
  };

  useEffect(() => {
    document.body.addEventListener("click", handleClickOutside);

    return () => {
      document.body.removeEventListener("click", handleClickOutside);
    };
  }, []);

  const fetchDropdownData = async (dropdownKey: string) => {
    try {
      const config = dropdownConfigs[dropdownKey];

      if (!config) return;

      var form_data = new FormData();

      form_data.append(`table[0]`, config.tableName);

      const response = await fetch(`${ORIGIN}/universal/get-all-drop-down-table-data`, {
        method: "POST",
        headers,
        body: form_data,
      });

      if (!response.ok) {
        throw new Error(`Failed to fetch ${dropdownKey} data`);
      }

      const data = await response.json();

      setDropdownState({
        currentDropdown: dropdownKey,
        data: data.rows,
        originalData: data.rows,
        showTable: true,
      });
    } catch (error) {
      console.error(`Error fetching ${dropdownKey} data:`, error);

      throw new Error(`Failed to fetch ${dropdownKey} data`);
    }
  };

  const onClickRow = (row: any) => {
    const config = dropdownConfigs[dropdownState.currentDropdown!];

    if (config) {
      form.setValue(config.formValueField, row[config.valueField]);
      form.setValue(config.formDisplayField, row[config.displayField]);

      if (config.additionalMappings) {
        config.additionalMappings.forEach((mapping) => {
          if (row[mapping.sourceField]) {
            form.setValue(mapping.targetFormField, row[mapping.sourceField]);
          }
        });
      }
    }

    setDropdownState((prev) => ({ ...prev, showTable: false }));
  };

  const [showPreviewDialog, setShowPreviewDialog] = useState(false);
  const [showDialog, setShowDialog] = useState(false);
  const [reportType, setReportType] = useState("Customer Analysis By Document"); // Default type

  // Orientation Option (Constant)
  const [orientation, setOrientation] = useState<"portrait" | "landscape">("portrait");

  const [isVariantAvailable, setIsVariantAvailable] = useState(false);
  const [selectedReport, setSelectedReport] = useState<string | null>(null);

  const handlePreview = () => {
    if (generatedReport.length == 0) {
      setIsAlertOpen(true);
      return false;
    }

    if (onPreview) {
      // Ensure fromDate and toDate are included in the preview data
      // onPreview(formData, false);
      onPreview(
        {
          ...formData,
          reportTypeName: selectedReport,
        },
        false,
      );
    }

    setReportType("Customer Analysis By Document");
    setShowPreviewDialog(false);
    setTimeout(() => {
      setShowPreviewDialog(true);
    }, 0);
  };

  const handleReset = () => {
    if (onReset) {
      onReset();
      setDropdownState({
        currentDropdown: null,
        data: [],
        originalData: [],
        showTable: false,
      });
      setShowPreviewDialog(false);
    }
  };

  const handleDropdownSearchChange = (dropdownKey: string, searchTerm: string) => {
    const config = dropdownConfigs[dropdownKey];
    if (!config) return;

    form.setValue(config.formDisplayField, searchTerm);

    if (searchTerm.trim() === "") {
      // Clear related fields: hidden UUID, and additional mappings
      form.setValue(config.formValueField, ""); // clear UUID

      if (config.additionalMappings) {
        config.additionalMappings.forEach((mapping) => {
          form.setValue(mapping.targetFormField, ""); // clear mapped fields
        });
      }

      return; // Exit early — no filtering needed
    }

    if (!dropdownState.originalData || dropdownState.currentDropdown !== dropdownKey) {
      fetchDropdownData(dropdownKey);
      return;
    }

    const filtered = dropdownState.originalData.filter((row: any) =>
      row[config.displayField]?.toString().toLowerCase().includes(searchTerm.toLowerCase()),
    );

    setDropdownState((prev) => ({
      ...prev,
      data: filtered,
      showTable: true,
      currentDropdown: dropdownKey,
    }));
  };

  useEffect(() => {
    setSelectedReportList(customerAnalysisByDocumentList);
  }, []);

  return (
    <div className="mx-auto">
      <Card collapsible defaultCollapsed={false} className="shadow-md">
        <CardHeader></CardHeader>
        <CardContent>
          <Form {...form}>
            <form onSubmit={form.handleSubmit(onGenerate)}>
              {/* Main Filters Section */}
              <div className="mb-4">
                <h3 className="text-md mb-2 font-semibold">Main Filters:</h3>

                <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* From Date */}
                  <FormField
                    control={form.control}
                    name="startDate"
                    render={({ field }) => (
                      <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                        <FormLabel>From Date:</FormLabel>
                        <Popover open={fromDateOpen} onOpenChange={setFromDateOpen}>
                          <PopoverTrigger asChild>
                            <FormControl>
                              <Button
                                className={cn(
                                  "flex h-7.5 w-full",
                                  !field.value && "text-muted-foreground",
                                )}
                                variant="outline"
                                size="sm"
                              >
                                {field.value
                                  ? moment.unix(field.value).format(DATE_FORMAT)
                                  : moment().format(DATE_FORMAT)}
                                <CalendarIcon className="ml-auto h-4 w-4 text-gray-400" />
                              </Button>
                            </FormControl>
                          </PopoverTrigger>
                          <PopoverContent className="w-auto p-0" align="start">
                            <Calendar
                              mode="single"
                              selected={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                              onSelect={(date) => {
                                const unixTimestamp = date
                                  ? Math.floor(date.getTime() / 1000)
                                  : Math.floor(Date.now() / 1000);
                                field.onChange(unixTimestamp.toString());
                                setFromDateOpen(false);
                              }}
                              initialFocus
                              defaultMonth={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                            />
                          </PopoverContent>
                        </Popover>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* To Date */}
                  <FormField
                    control={form.control}
                    name="endDate"
                    render={({ field }) => (
                      <FormItem className="col-span-1 row-span-1 grid h-full grid-rows-[auto_1fr] space-y-1">
                        <FormLabel>To Date:</FormLabel>
                        <Popover open={toDateOpen} onOpenChange={setToDateOpen}>
                          <PopoverTrigger asChild>
                            <FormControl>
                              <Button
                                className={cn(
                                  "flex h-7.5 w-full",
                                  !field.value && "text-muted-foreground",
                                )}
                                variant="outline"
                                size="sm"
                              >
                                {field.value
                                  ? moment.unix(field.value).format(DATE_FORMAT)
                                  : moment().format(DATE_FORMAT)}
                                <CalendarIcon className="ml-auto h-4 w-4 text-gray-400" />
                              </Button>
                            </FormControl>
                          </PopoverTrigger>
                          <PopoverContent className="w-auto p-0" align="start">
                            <Calendar
                              mode="single"
                              selected={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                              onSelect={(date) => {
                                const endOfDay = date ? new Date(date) : new Date();
                                endOfDay.setHours(23, 59, 59, 999);
                                const unixTimestamp = Math.floor(endOfDay.getTime() / 1000);
                                field.onChange(unixTimestamp.toString());
                                setToDateOpen(false);
                              }}
                              initialFocus
                              defaultMonth={
                                field.value ? moment.unix(field.value).toDate() : new Date()
                              }
                            />
                          </PopoverContent>
                        </Popover>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Customer Field - UUID */}
                  <FormField
                    control={form.control}
                    name="customer"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Customer:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Customer Field - Display */}
                  <FormField
                    control={form.control}
                    name="customerName"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Customer: </FormLabel>
                        <FormControl className="relative">
                          <div className="relative">
                            <Input
                              className="h-7.5 pr-8"
                              {...field}
                              // readOnly
                              onChange={(e) =>
                                handleDropdownSearchChange("customer", e.target.value)
                              }
                              onClick={() => fetchDropdownData("customer")}
                              ref={
                                dropdownState.currentDropdown === "customer"
                                  ? dropdownInputRef
                                  : null
                              }
                              autoComplete="off"
                            />
                            <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                              <FaMagnifyingGlass className="text-gray-400" />
                            </div>
                            {dropdownState.showTable &&
                              dropdownState.currentDropdown === "customer" && (
                                <div
                                  ref={dropdownTableRef}
                                  className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownConfigs.customer.columns}
                                      data={dropdownState.data}
                                      onClickRow={onClickRow}
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                          </div>
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Agent - UUID */}
                  <FormField
                    control={form.control}
                    name="agent"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Agent:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Agent - Display */}
                  <FormField
                    control={form.control}
                    name="agentName"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Agent:</FormLabel>
                        <FormControl className="relative">
                          <div className="relative">
                            <Input
                              className="h-7.5 pr-8"
                              {...field}
                              // readOnly
                              onChange={(e) => handleDropdownSearchChange("agent", e.target.value)}
                              onClick={() => fetchDropdownData("agent")}
                              ref={
                                dropdownState.currentDropdown === "agent" ? dropdownInputRef : null
                              }
                              autoComplete="off"
                            />
                            <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                              <FaMagnifyingGlass className="text-gray-400" />
                            </div>
                            {dropdownState.showTable &&
                              dropdownState.currentDropdown === "agent" && (
                                <div
                                  ref={dropdownTableRef}
                                  className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownConfigs.agent.columns}
                                      data={dropdownState.data}
                                      onClickRow={onClickRow}
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                          </div>
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Project - UUID */}
                  <FormField
                    control={form.control}
                    name="project"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>Project UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Project - Display */}
                  <FormField
                    control={form.control}
                    name="projectCode"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Project:</FormLabel>
                        <FormControl className="relative">
                          <div className="relative">
                            <Input
                              className="h-7.5 pr-8"
                              {...field}
                              // readOnly
                              onChange={(e) =>
                                handleDropdownSearchChange("project", e.target.value)
                              }
                              onClick={() => fetchDropdownData("project")}
                              ref={
                                dropdownState.currentDropdown === "project"
                                  ? dropdownInputRef
                                  : null
                              }
                              autoComplete="off"
                            />
                            <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                              <FaMagnifyingGlass className="text-gray-400" />
                            </div>
                            {dropdownState.showTable &&
                              dropdownState.currentDropdown === "project" && (
                                <div
                                  ref={dropdownTableRef}
                                  className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownConfigs.project.columns}
                                      data={dropdownState.data}
                                      onClickRow={onClickRow}
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                          </div>
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>

                <div className="mt-4 grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* Currency - UUID */}
                  <FormField
                    control={form.control}
                    name="currency"
                    render={({ field }) => (
                      <FormItem className="hidden">
                        <FormLabel>UUID:</FormLabel>
                        <FormControl>
                          <Input className="h-7" {...field} readOnly={true} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Currency - Display */}
                  <FormField
                    control={form.control}
                    name="currencyCode"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Currency:</FormLabel>
                        <FormControl className="relative">
                          <div className="relative">
                            <Input
                              className="h-7.5 pr-8"
                              {...field}
                              // readOnly
                              onChange={(e) =>
                                handleDropdownSearchChange("currencyCode", e.target.value)
                              }
                              onClick={() => fetchDropdownData("currencyCode")}
                              ref={
                                dropdownState.currentDropdown === "currencyCode"
                                  ? dropdownInputRef
                                  : null
                              }
                              autoComplete="off"
                            />
                            <div className="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                              <FaMagnifyingGlass className="text-gray-400" />
                            </div>
                            {dropdownState.showTable &&
                              dropdownState.currentDropdown === "currencyCode" && (
                                <div
                                  ref={dropdownTableRef}
                                  className="absolute top-full z-50 h-[200px] rounded border border-gray-200 bg-white shadow-md"
                                >
                                  <ScrollArea className="h-[30cqh] bg-erp-gray-3">
                                    <DropdownTable
                                      columns={dropdownConfigs.currencyCode.columns}
                                      data={dropdownState.data}
                                      onClickRow={onClickRow}
                                    />
                                    <ScrollBar orientation="vertical" />
                                  </ScrollArea>
                                </div>
                              )}
                          </div>
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>
              </div>

              {/* Separator Line */}
              <hr className="my-6 border-gray-300" />

              {/* Column Filters Section */}
              <div className="mb-4">
                <h3 className="text-md mb-2 font-semibold">Column Filters:</h3>

                <div className="grid grid-flow-col-dense grid-cols-1 items-start gap-x-8 gap-y-1 md:grid-cols-5">
                  {/* Customer Name */}
                  <FormField
                    control={form.control}
                    name="customerName"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Customer Name:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Agent */}
                  <FormField
                    control={form.control}
                    name="agentName"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Agent:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Project */}
                  <FormField
                    control={form.control}
                    name="projectCode"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Project:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />

                  {/* Currency */}
                  <FormField
                    control={form.control}
                    name="currencyCode"
                    render={({ field }) => (
                      <FormItem className="flex flex-col space-y-1">
                        <FormLabel>Currency:</FormLabel>
                        <FormControl>
                          <Input className="h-7.5" {...field} />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>
              </div>

              <div className="mr-16 mt-6 flex flex-row justify-center space-x-4">
                <Button
                  type="button"
                  className="erp-blue-12 w-28 text-white hover:bg-blue-800"
                  onClick={form.handleSubmit(onGenerate)}
                >
                  Generate
                </Button>
                <Button
                  type="button"
                  className="erp-blue-12 w-28 text-white hover:bg-blue-800"
                  // onClick={handlePreview}
                  onClick={() => {
                    if (generatedReport.length == 0) {
                      setIsAlertOpen(true);
                      return false;
                    }
                    setIsVariantAvailable(true);
                  }}
                >
                  Preview
                </Button>
                <Button
                  type="button"
                  className="erp-blue-12 w-28 text-white hover:bg-blue-800"
                  onClick={handleReset}
                >
                  Reset
                </Button>
                {systemAccount === "dev" || systemAccount === "infollectivetesting" ? (
                  <>
                    <ReportPreviewButton
                      form={form}
                      formData={formData}
                      previewType={"CUSTOMER ANALYSIS BY DOCUMENT"}
                      docType={"customer"}
                      reportType={"customerAnalysisByDocument"}
                      modelType={"sales"}
                      filterFields={filterFields}
                      sorting={sorting}
                      generatedReport={generatedReport}
                      setIsAlertOpen={setIsAlertOpen}
                      showPreviewDialog={showDialog}
                      setShowPreviewDialog={setShowDialog}
                      sortBy={"createdAt"}
                    />
                  </>
                ) : null}
              </div>
            </form>
          </Form>
        </CardContent>
      </Card>

      <Dialog open={isVariantAvailable} onOpenChange={setIsVariantAvailable}>
        <DialogContent className="max-w-l rounded-md bg-white p-6">
          <Form {...form}>
            <form className="space-y-4" onSubmit={(e) => e.preventDefault()}>
              <h2 className="text-center text-lg font-semibold">Select Report</h2>

              <div className="h-[160px] overflow-auto border border-gray-300 bg-white">
                {selectedReportList?.map((report) => (
                  <div
                    key={report.id}
                    onClick={() => setSelectedReport(report.id)}
                    className={`cursor-pointer px-3 py-1 text-sm
            hover:bg-blue-100
            ${selectedReport === report.id ? "bg-blue-600 text-white" : ""}`}
                  >
                    {report.name}
                  </div>
                ))}
              </div>

              <div className="mt-[10px] flex justify-center gap-4 p-10">
                <Button
                  type="button"
                  variant="ghost"
                  onClick={() => setIsVariantAvailable(false)}
                  className="h-10 w-40 bg-erp-blue-14 text-white hover:bg-erp-blue-13 hover:text-white"
                >
                  Cancel
                </Button>
                <Button
                  type="button"
                  onClick={handlePreview}
                  className="h-10 w-40 border border-erp-blue-14 bg-white text-erp-blue-14"
                >
                  OK
                </Button>
              </div>
            </form>
          </Form>
        </DialogContent>
      </Dialog>

      {/* Preview Dialog */}
      <Dialog open={showPreviewDialog} onOpenChange={setShowPreviewDialog}>
        <DialogContent className="max-w-6xl">
          {/* Orientation Option (Add to Dialog Title) */}
          <DialogTitle className="flex items-center justify-between">
            <span>{reportType} Preview</span>
            <div className="flex items-center gap-2">
              <span className="text-sm text-gray-600">Orientation:</span>
              <Button
                type="button"
                variant={orientation === "portrait" ? "default" : "outline"}
                size="sm"
                onClick={() => setOrientation("portrait")}
                className="h-8 px-3"
              >
                Portrait
              </Button>
              <Button
                type="button"
                variant={orientation === "landscape" ? "default" : "outline"}
                size="sm"
                onClick={() => setOrientation("landscape")}
                className="h-8 px-3"
              >
                Landscape
              </Button>
            </div>
          </DialogTitle>
          <div className="relative h-[550px] w-full">
            {previewPDF ? (
              <PDFViewer width="100%" height="100%" className="absolute inset-0">
                <SalesReport
                  type={reportType}
                  data={previewPDF}
                  salesReportData={customerAnalysisByDocumentData}
                  generatedReport={generatedReport}
                  salesReportColumns={customerAnalysisByDocumentColumns}
                  orientation={orientation}
                />
              </PDFViewer>
            ) : (
              <div className="flex h-full items-center justify-center">
                <p className="animate-pulse text-lg">
                  Loading preview
                  <span className="ml-1 inline-block">
                    <span>. </span>
                    <span className="animation-delay-200">. </span>
                    <span className="animation-delay-400">.</span>
                  </span>
                </p>
              </div>
            )}
          </div>
          <DialogFooter className="flex !justify-center gap-x-2">
            <PDFDownloadLink
              document={
                // Orientation Option (Add Orientation Prop)
                <SalesReport
                  type={reportType}
                  data={previewPDF}
                  salesReportData={customerAnalysisByDocumentData}
                  generatedReport={generatedReport}
                  salesReportColumns={customerAnalysisByDocumentColumns}
                  orientation={orientation}
                />
              }
              fileName={`${previewPDF?.currentCompany?.company || ""} - Customer Analysis By Document.pdf`}
              className={cn(buttonVariants({ variant: "default" }), "mt-2 sm:mt-0")}
            >
              {({ loading }) => (loading ? "Preparing..." : "Download PDF")}
            </PDFDownloadLink>
            <DialogClose
              className={cn(buttonVariants({ variant: "outline" }), "mt-2 sm:mt-0")}
              // onClick={() => setShowPreviewDialog(false)}
              onClick={() => {
                setShowPreviewDialog(false);
                setIsVariantAvailable(false);
              }}
            >
              Close
            </DialogClose>
          </DialogFooter>
        </DialogContent>
      </Dialog>
      <AlertDialog open={isAlertOpen} onOpenChange={setIsAlertOpen}>
        <AlertDialogContent className="max-w-sm">
          <div className="flex flex-col items-center gap-2">
            <p className="text-md text-center text-erp-blue-14">kindly generate first.</p>
          </div>
          <AlertDialogFooter className="mt-2 flex items-center !justify-center justify-center gap-3 [&>*]:m-0">
            <AlertDialogAction className="h-9 w-24" autoFocus onClick={() => setShowDialog(false)}>
              Close
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </div>
  );
}
